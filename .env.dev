# ====================================================================================================
# Development Environment Configuration
# ====================================================================================================
# This configuration is for LOCAL DEVELOPMENT ONLY
# Uses simple passwords and default settings for ease of development

# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# ====================================================================================================
# Database Configuration
# ====================================================================================================
POSTGRES_USER=healthdata_dev
POSTGRES_PASSWORD=dev_password_123
POSTGRES_DB=healthdata_cql

# Quality Measure Service Database
QM_POSTGRES_DB=healthdata_quality_measure
QM_POSTGRES_USER=healthdata_dev
QM_POSTGRES_PASSWORD=dev_password_123

# FHIR Service Database
FHIR_POSTGRES_DB=healthdata_fhir
FHIR_POSTGRES_USER=healthdata_dev
FHIR_POSTGRES_PASSWORD=dev_password_123

# ====================================================================================================
# Redis Configuration
# ====================================================================================================
REDIS_PASSWORD=dev_redis_pass

# ====================================================================================================
# Kafka Configuration
# ====================================================================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ====================================================================================================
# FHIR Service
# ====================================================================================================
FHIR_SERVICE_URL=http://fhir-service-mock:8080/fhir

# ====================================================================================================
# Security Configuration (Development - Simple)
# ====================================================================================================
# SSL/TLS (disabled for easier local development)
SSL_ENABLED=false
SSL_KEY_STORE=/home/webemo-aaron/projects/healthdata-in-motion/ssl/dev/keystore.p12
SSL_KEY_STORE_PASSWORD=changeit

# JWT Configuration (simple for dev)
JWT_SECRET=dev_jwt_secret_key_for_testing_only_not_for_production_use_minimum_256_bits
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# Service API Key (for inter-service communication)
SERVICE_API_KEY=dev_api_key_12345

# CORS (allow all for development)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:4200

# ====================================================================================================
# Rate Limiting (Relaxed for development)
# ====================================================================================================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=1000
RATE_LIMIT_REQUESTS_PER_HOUR=10000

# ====================================================================================================
# Service Versions
# ====================================================================================================
CQL_ENGINE_VERSION=latest
QM_SERVICE_VERSION=latest

# ====================================================================================================
# Logging
# ====================================================================================================
LOG_LEVEL=DEBUG

# ====================================================================================================
# Java Options
# ====================================================================================================
JAVA_OPTS=-Xmx2g -Xms512m

# ====================================================================================================
# Monitoring & Metrics
# ====================================================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_SECRET_KEY=dev_grafana_secret

# ====================================================================================================
# Backup Configuration (Disabled in dev)
# ====================================================================================================
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7

# ====================================================================================================
# SMTP Configuration (Optional for dev)
# ====================================================================================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@healthdata.dev

# ====================================================================================================
# Demo Tenant IDs
# ====================================================================================================
DEMO_TENANT_001=DEMO_TENANT_001
DEMO_TENANT_002=DEMO_TENANT_002
