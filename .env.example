# ============================================================================
# HDIM - HealthData-in-Motion Environment Configuration Template
# ============================================================================
#
# SECURITY WARNING: This is a TEMPLATE file only.
# 1. Copy this file to .env.local (which is gitignored)
# 2. Fill in actual values for your environment
# 3. NEVER commit files with real credentials to version control
#
# For production, use a secrets manager (HashiCorp Vault, AWS Secrets Manager)
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
POSTGRES_DB=healthdata_cql
POSTGRES_USER=healthdata
# ⚠️ CHANGE THIS: Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/healthdata_cql
SPRING_DATASOURCE_USERNAME=healthdata
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
# ⚠️ CHANGE THIS: Generate with: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD

# ============================================================================
# KAFKA CONFIGURATION
# ============================================================================
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ============================================================================
# JWT CONFIGURATION
# ============================================================================
# ⚠️ CHANGE THIS: Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_GENERATE_256_BIT_SECRET
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# ============================================================================
# GATEWAY AUTHENTICATION
# ============================================================================
# ⚠️ CHANGE THIS: Generate with: openssl rand -base64 32
# Used for HMAC signature validation between gateway and backend services
GATEWAY_AUTH_SIGNING_SECRET=CHANGE_ME_GENERATE_256_BIT_SECRET
GATEWAY_AUTH_DEV_MODE=true

# ============================================================================
# SERVICE AUTHENTICATION
# ============================================================================
# For service-to-service auth (leave empty if using JWT/mTLS)
SERVICE_AUTH_USERNAME=
SERVICE_AUTH_PASSWORD=
CQL_ENGINE_AUTH_USERNAME=
CQL_ENGINE_AUTH_PASSWORD=

# ============================================================================
# SERVICE CONFIGURATION
# ============================================================================
CQL_ENGINE_PORT=8081
SPRING_PROFILES_ACTIVE=docker

FHIR_SERVICE_URL=http://fhir-service-mock:8080/fhir
FHIR_SERVICE_TIMEOUT=30000
CQL_ENGINE_SERVICE_URL=http://cql-engine-service:8081/cql-engine

# ============================================================================
# SECURITY SETTINGS
# ============================================================================
SSL_ENABLED=false
WEBSOCKET_REQUIRE_SSL=false
RATE_LIMIT_ENABLED=true

# ============================================================================
# AUDIT CONFIGURATION
# ============================================================================
AUDIT_ENABLED=true
# ⚠️ CHANGE THIS: Generate with: openssl rand -base64 32
AUDIT_ENCRYPTION_KEY=CHANGE_ME_GENERATE_256_BIT_KEY

# ============================================================================
# THREAD POOL CONFIGURATION
# ============================================================================
MEASURE_EVALUATION_CORE_POOL_SIZE=10
MEASURE_EVALUATION_MAX_POOL_SIZE=50
MEASURE_EVALUATION_QUEUE_CAPACITY=500

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_HEALTHDATA_CQL=DEBUG

# ============================================================================
# MONITORING CONFIGURATION (Optional)
# ============================================================================
GRAFANA_ADMIN_USER=admin
# ⚠️ CHANGE THIS in production
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ============================================================================
# JVM CONFIGURATION
# ============================================================================
JAVA_OPTS=-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0

# ============================================================================
# SALES AUTOMATION SERVICE
# ============================================================================
# Email Configuration (Zoho Mail SMTP)
MAIL_HOST=smtp.zoho.com
MAIL_PORT=587
MAIL_USERNAME=your-email@yourdomain.com
MAIL_PASSWORD=CHANGE_ME_ZOHO_APP_PASSWORD
MAIL_FROM=sales@healthdatainmotion.com
MAIL_FROM_NAME=HealthData-in-Motion

# LinkedIn Integration (OAuth credentials from LinkedIn Developer Portal)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_DAILY_CONNECTION_LIMIT=50
LINKEDIN_DAILY_INMAIL_LIMIT=25

# Zoho CRM Integration
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_SYNC_ENABLED=false

# ============================================================================
# DOCKER COMPOSE PROFILES
# ============================================================================
# COMPOSE_PROFILES=monitoring  # Uncomment to enable Prometheus + Grafana
