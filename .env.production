# HealthData in Motion - Production Environment Configuration
# Generated: 2025-11-18
# SECURITY: Replace all passwords and secrets before deploying to production!

# ========================================
# DATABASE CONFIGURATION
# ========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5435
POSTGRES_DB=healthdata_cql
POSTGRES_USER=cql_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE_32_CHARS

# ========================================
# REDIS CONFIGURATION
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE

# HIPAA Compliance: Cache TTL must be ≤ 5 minutes for PHI
REDIS_TTL_SECONDS=300

# ========================================
# KAFKA CONFIGURATION
# ========================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9094
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# For production, use SASL_SSL and set:
# KAFKA_SASL_MECHANISM=SCRAM-SHA-512
# KAFKA_SASL_USERNAME=your_kafka_user
# KAFKA_SASL_PASSWORD=CHANGE_ME_KAFKA_PASSWORD

# ========================================
# BACKEND SERVICES
# ========================================

# CQL Engine Service
CQL_ENGINE_PORT=8081
CQL_ENGINE_USERNAME=cql-service-user
CQL_ENGINE_PASSWORD=CHANGE_ME_CQL_ENGINE_PASSWORD_32_CHARS

# Quality Measure Service
QUALITY_MEASURE_PORT=8087
QUALITY_MEASURE_DB=healthdata_quality

# FHIR Service
FHIR_PORT=8083
FHIR_DB=healthdata_fhir

# Patient Service
PATIENT_PORT=8084

# Care Gap Service
CARE_GAP_PORT=8086

# ========================================
# SECURITY & AUTHENTICATION
# ========================================

# JWT Configuration
JWT_SECRET=CHANGE_ME_GENERATE_256_BIT_SECRET_HERE
JWT_EXPIRATION=3600
JWT_ISSUER=healthdata-in-motion

# Session Configuration
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_32_CHARS
SESSION_TIMEOUT=1800

# CORS Configuration
ALLOWED_ORIGINS=https://your-domain.com,https://portal.your-domain.com
ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH
ALLOWED_HEADERS=Content-Type,Authorization,X-Tenant-ID

# ========================================
# FRONTEND CONFIGURATION
# ========================================

# Angular Clinical Portal
ANGULAR_PORT=4200
API_BASE_URL=https://api.your-domain.com

# React Dashboard
REACT_PORT=3004
WEBSOCKET_URL=wss://api.your-domain.com/ws

# ========================================
# MONITORING & LOGGING
# ========================================

# Log Level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# Prometheus
PROMETHEUS_PORT=9090
PROMETHEUS_ENABLED=true

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ========================================
# HIPAA COMPLIANCE
# ========================================

# Audit Logging
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=2555  # 7 years

# Data Retention
SOFT_DELETE_ENABLED=true
DATA_RETENTION_YEARS=7

# ========================================
# MULTI-TENANCY
# ========================================

# Default Tenant
DEFAULT_TENANT_ID=default

# Tenant Isolation Level: STRICT, RELAXED
TENANT_ISOLATION=STRICT

# ========================================
# PERFORMANCE
# ========================================

# Connection Pool
DB_POOL_SIZE=20
DB_POOL_MAX_WAIT_MS=30000

# Batch Processing
BATCH_SIZE=100
MAX_CONCURRENT_EVALUATIONS=10

# Cache Settings
CACHE_ENABLED=true
CACHE_SIZE_MB=512

# ========================================
# BACKUP & DISASTER RECOVERY
# ========================================

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=90
BACKUP_LOCATION=/var/backups/healthdata

# ========================================
# SSL/TLS CONFIGURATION
# ========================================

# SSL Certificate Paths
SSL_ENABLED=true
SSL_CERT_PATH=/etc/ssl/certs/healthdata.crt
SSL_KEY_PATH=/etc/ssl/private/healthdata.key
SSL_CA_PATH=/etc/ssl/certs/ca-bundle.crt

# ========================================
# FEATURE FLAGS
# ========================================

# Enable/Disable Features
WEBSOCKET_ENABLED=true
VISUALIZATION_ENABLED=true
CUSTOM_MEASURES_ENABLED=true
MEASURE_BUILDER_ENABLED=true
REPORTS_ENABLED=true
EXPORT_ENABLED=true

# ========================================
# RATE LIMITING
# ========================================

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_BURST=20

# ========================================
# HEALTH CHECKS
# ========================================

HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL_SECONDS=30
HEALTH_CHECK_TIMEOUT_SECONDS=5

# ========================================
# NOTIFICATION SETTINGS
# ========================================

# Email Configuration (for alerts)
SMTP_HOST=smtp.your-domain.com
SMTP_PORT=587
SMTP_USERNAME=noreply@your-domain.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=HealthData in Motion <noreply@your-domain.com>

# Alert Recipients
ALERT_EMAIL=ops@your-domain.com
CRITICAL_ALERT_EMAIL=oncall@your-domain.com

# ========================================
# DEPLOYMENT METADATA
# ========================================

ENVIRONMENT=production
VERSION=1.0.0
BUILD_DATE=2025-11-18
DEPLOYMENT_REGION=us-east-1
