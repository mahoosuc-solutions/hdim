# ====================================================================================================
# Production Environment Configuration - HDIM Sales Agent Services
# ====================================================================================================
# WARNING: This file contains production settings. Handle with care.
# All passwords and secrets should be managed via environment variables or secrets management.
# DO NOT commit real passwords to version control.

# ====================================================================================================
# Environment & Deployment
# ====================================================================================================
ENVIRONMENT=production
REGION=us-east-1
DEPLOYMENT_TYPE=docker-swarm
BUILD_VERSION=latest
BUILD_DATE=$(date -u +'%Y-%m-%dT%H:%M:%SZ')

# ====================================================================================================
# Security & TLS Configuration
# ====================================================================================================
SSL_ENABLED=true
SSL_CERTIFICATE_PATH=/secrets/tls/cert.pem
SSL_KEY_PATH=/secrets/tls/key.pem
SSL_CA_PATH=/secrets/tls/ca.pem
SSL_PROTOCOLS=TLSv1.2,TLSv1.3

# ====================================================================================================
# Database Configuration - PostgreSQL HA (Primary + Replica)
# ====================================================================================================
POSTGRES_USER=healthdata
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}

# Primary database
POSTGRES_PRIMARY_HOST=postgres-primary
POSTGRES_PRIMARY_PORT=5432

# Replica for read scaling
POSTGRES_REPLICA_HOST=postgres-replica
POSTGRES_REPLICA_PORT=5432
DB_USE_REPLICA_FOR_READS=true

# Connection pool optimization
DB_CONNECTION_POOL_SIZE=50
DB_MAXIMUM_POOL_SIZE=100
DB_CONNECTION_TIMEOUT_SECONDS=30
DB_VALIDATION_QUERY=SELECT 1

# Backup configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 3 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_DESTINATION=s3://hdim-backups-prod/postgres
BACKUP_ENCRYPTION=true

# ====================================================================================================
# Redis Cache Configuration - HA (Primary + Replica)
# ====================================================================================================
REDIS_PRIMARY_HOST=redis-primary
REDIS_PRIMARY_PORT=6379
REDIS_REPLICA_HOST=redis-replica
REDIS_REPLICA_PORT=6379
REDIS_PASSWORD=${REDIS_PASSWORD}

# Cluster mode for HA
REDIS_CLUSTER_ENABLED=true
REDIS_CLUSTER_NODES=redis-primary:6379,redis-replica:6379

# Memory management
REDIS_MAXMEMORY=2gb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_APPENDONLY=yes
REDIS_APPENDFSYNC=everysec

# ====================================================================================================
# OpenTelemetry Configuration - Production (1% sampling)
# ====================================================================================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_TRACES_EXPORTER=otlp
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_SAMPLER=parentbased_traceidratio
OTEL_SAMPLER_ARG=0.01
OTEL_METRICS_EXPORTER=prometheus
OTEL_PROPAGATORS=tracecontext,baggage

# ============================================ =======================================
# Google Cloud APIs - Production
# ====================================================================================================
GOOGLE_APPLICATION_CREDENTIALS=/secrets/google-meet-service-account.json
GOOGLE_CLOUD_PROJECT=hdim-production
GOOGLE_CLOUD_REGION=us-central1

# APIs: Real (not mocked) for production
MOCK_GOOGLE_MEET=false
MOCK_SPEECH_TO_TEXT=false
MOCK_ANTHROPIC_API=false

# ====================================================================================================
# Anthropic Claude API - Production
# ====================================================================================================
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ====================================================================================================
# Service Communication
# ====================================================================================================
AI_SALES_AGENT_URL=http://ai-sales-agent-1:8090
WEBSOCKET_URL=ws://clinical-workflow-service:8090/ws

# ====================================================================================================
# Application Configuration
# ====================================================================================================
DEBUG=false
LOG_LEVEL=WARN
ENVIRONMENT=production

# Logging
LOG_AGGREGATION_ENABLED=true
LOG_ELASTICSEARCH_ENDPOINT=http://elasticsearch:9200
LOG_RETENTION_DAYS=30

# ====================================================================================================
# Rate Limiting & Security
# ====================================================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=1000
RATE_LIMIT_REQUESTS_PER_HOUR=50000
RATE_LIMIT_PER_IP=true

# ====================================================================================================
# HIPAA Compliance Configuration
# ====================================================================================================
HIPAA_CACHE_TTL_MINUTES=5
HIPAA_AUDIT_ENABLED=true
HIPAA_AUDIT_LOG_RETENTION_DAYS=7
HIPAA_PHI_LOGGING_ENABLED=false
HIPAA_ENCRYPTION_ENABLED=true

# Data retention
DATA_RETENTION_DAYS=30
CUSTOMER_DATA_RETENTION_DAYS=90
TRANSCRIPT_RETENTION_DAYS=90

# ====================================================================================================
# File Storage - Production
# ====================================================================================================
TRANSCRIPT_STORAGE_PATH=/data/transcripts
TRANSCRIPT_STORAGE_TYPE=s3
TRANSCRIPT_STORAGE_S3_BUCKET=hdim-transcripts-prod
TRANSCRIPT_STORAGE_S3_REGION=us-east-1
TRANSCRIPT_STORAGE_ENCRYPTION=AES256

# ====================================================================================================
# Monitoring & Alerting
# ====================================================================================================
PROMETHEUS_ENDPOINT=http://prometheus:9090
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_EVALUATION_INTERVAL=30s
PROMETHEUS_SCRAPE_INTERVAL=30s

# Alert routing (PagerDuty, Slack, Email)
ALERTMANAGER_ENDPOINT=http://alertmanager:9093
PAGERDUTY_INTEGRATION_KEY=${PAGERDUTY_INTEGRATION_KEY}
SLACK_WEBHOOK_URL=${SLACK_WEBHOOK_URL}
EMAIL_ALERTS_TO=devops@example.com
EMAIL_ALERTS_FROM=alerts@example.com

# ====================================================================================================
# Grafana Configuration
# ====================================================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=${GRAFANA_PASSWORD}
GRAFANA_SECRET_KEY=${GRAFANA_SECRET_KEY}
GRAFANA_SECURITY_ALLOW_EMBED_INIT_STATUS_TOKEN=true

# ====================================================================================================
# Health Check Configuration
# ====================================================================================================
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_INITIAL_DELAY=15
HEALTH_CHECK_INTERVAL=30

# Database health check
DB_HEALTH_CHECK_ENABLED=true
DB_HEALTH_CHECK_INTERVAL_SECONDS=30

# Redis health check
REDIS_HEALTH_CHECK_ENABLED=true
REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30

# ====================================================================================================
# Performance Tuning - Production
# ====================================================================================================
# Thread pools
THREAD_POOL_CORE_SIZE=20
THREAD_POOL_MAX_SIZE=50

# Cache settings
CACHE_TTL_MINUTES=10
CACHE_MAX_SIZE=10000

# Connection timeout
CONNECTION_TIMEOUT_SECONDS=30
READ_TIMEOUT_SECONDS=60

# ====================================================================================================
# AWS Configuration (if using AWS)
# ====================================================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}

# S3 for backups and transcripts
S3_BACKUP_BUCKET=hdim-backups-prod
S3_TRANSCRIPT_BUCKET=hdim-transcripts-prod

# ====================================================================================================
# Disaster Recovery
# ====================================================================================================
DISASTER_RECOVERY_ENABLED=true
DISASTER_RECOVERY_TEST_SCHEDULE=0 2 * * 0
BACKUP_VERIFICATION_ENABLED=true

# ====================================================================================================
# SLO Contracts - Observable Commitments
# ====================================================================================================
SLO_AVAILABILITY_TARGET=0.999
SLO_LATENCY_P95_TARGET_MS=200
SLO_LATENCY_P99_TARGET_MS=500
SLO_ERROR_RATE_TARGET=0.001

# ====================================================================================================
# Build & Deployment Info
# ====================================================================================================
BUILD_COMMIT=${GIT_COMMIT}
BUILD_BRANCH=${GIT_BRANCH:-main}
DEPLOYMENT_TIMESTAMP=$(date -u +'%Y-%m-%dT%H:%M:%SZ')

# ====================================================================================================
# Notes
# ====================================================================================================
#
# PRODUCTION SECURITY CHECKLIST:
#
# 1. Database Passwords:
#    [ ] Use strong passwords (20+ chars, mixed case, numbers, symbols)
#    [ ] Store in Kubernetes Secrets or HashiCorp Vault
#    [ ] Rotate monthly
#    [ ] Never commit to version control
#
# 2. API Keys:
#    [ ] Google Cloud service account JSON in /secrets/
#    [ ] Anthropic API key in secrets manager
#    [ ] PagerDuty and Slack webhooks in secrets manager
#    [ ] AWS credentials in IAM roles (not env vars)
#
# 3. SSL/TLS Certificates:
#    [ ] Install valid certificates in /secrets/tls/
#    [ ] Auto-renew with Let's Encrypt
#    [ ] Use TLSv1.2+ only
#    [ ] Verify HSTS headers
#
# 4. Backup & Recovery:
#    [ ] Daily backups to S3 (encrypted)
#    [ ] Monthly backup restoration test
#    [ ] 30-day retention minimum
#    [ ] Document recovery procedures
#
# 5. Monitoring & Alerting:
#    [ ] Prometheus collecting all service metrics
#    [ ] Grafana dashboards created and tested
#    [ ] PagerDuty configured for critical alerts
#    [ ] Slack configured for warnings/info
#    [ ] Alert thresholds calibrated
#
# 6. Security & Compliance:
#    [ ] HIPAA audit logging enabled
#    [ ] All PHI access logged
#    [ ] Network policies enforced
#    [ ] Rate limiting enabled
#    [ ] DDoS protection in place
#
# 7. Team & Runbooks:
#    [ ] Team trained on procedures
#    [ ] Runbooks documented and tested
#    [ ] On-call rotation configured
#    [ ] Incident response procedures ready
#
