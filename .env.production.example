# HealthData-in-Motion Production Environment Configuration
# Copy this file to .env.production and fill in secure values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL Database
POSTGRES_USER=healthdata_prod_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=healthdata_cql
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Quality Measure Database
QM_POSTGRES_USER=healthdata_qm_user
QM_POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
QM_POSTGRES_DB=healthdata_quality_measure

# FHIR Database
FHIR_POSTGRES_USER=healthdata_fhir_user
FHIR_POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
FHIR_POSTGRES_DB=healthdata_fhir

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_HERE
REDIS_HOST=redis
REDIS_PORT=6379

# =============================================================================
# KAFKA CONFIGURATION
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# For production with authentication, change to SASL_SSL and provide credentials
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_USERNAME=kafka_user
# KAFKA_SASL_PASSWORD=CHANGE_ME_KAFKA_PASSWORD

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHAR_HEX_STRING
JWT_EXPIRATION_MS=3600000  # 1 hour
JWT_REFRESH_EXPIRATION_MS=86400000  # 24 hours

# =============================================================================
# SERVICE AUTHENTICATION
# =============================================================================
# CQL Engine Service
CQL_SERVICE_USERNAME=cql_service_user
CQL_SERVICE_PASSWORD=CHANGE_ME_CQL_SERVICE_PASSWORD

# Quality Measure Service
QM_SERVICE_USERNAME=qm_service_user
QM_SERVICE_PASSWORD=CHANGE_ME_QM_SERVICE_PASSWORD

# Inter-service API keys
SERVICE_API_KEY=CHANGE_ME_GENERATE_RANDOM_API_KEY

# =============================================================================
# SSL/TLS CONFIGURATION
# =============================================================================
SSL_ENABLED=true
SSL_KEY_STORE=/etc/ssl/keystore.p12
SSL_KEY_STORE_PASSWORD=CHANGE_ME_KEYSTORE_PASSWORD
SSL_KEY_STORE_TYPE=PKCS12
SSL_KEY_ALIAS=healthdata

# =============================================================================
# FHIR SERVER CONFIGURATION
# =============================================================================
FHIR_SERVER_URL=https://fhir-service:8443/fhir
FHIR_SERVER_USERNAME=fhir_client
FHIR_SERVER_PASSWORD=CHANGE_ME_FHIR_PASSWORD

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_SCRAPE_INTERVAL=15s

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
GRAFANA_SECRET_KEY=CHANGE_ME_GRAFANA_SECRET_KEY

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Spring profiles
SPRING_PROFILES_ACTIVE=production

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/healthdata/application.log

# CORS
CORS_ALLOWED_ORIGINS=https://dashboard.healthdata.example.com,https://app.healthdata.example.com
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# External Kafka (if using)
EXTERNAL_KAFKA_BOOTSTRAP=motel-comedian:9094
EXTERNAL_KAFKA_USERNAME=external_user
EXTERNAL_KAFKA_PASSWORD=CHANGE_ME_EXTERNAL_KAFKA_PASSWORD

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=healthdata-backups
AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET_KEY
AWS_REGION=us-east-1

# =============================================================================
# ALERTING CONFIGURATION
# =============================================================================
# Email alerts
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=alerts@healthdata.example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=alerts@healthdata.example.com
ALERT_EMAIL_TO=ops-team@healthdata.example.com

# Slack alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# PagerDuty
PAGERDUTY_INTEGRATION_KEY=CHANGE_ME_PAGERDUTY_KEY

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================
# JVM Settings
JAVA_OPTS=-Xms2g -Xmx4g -XX:+UseG1GC -XX:MaxGCPauseMillis=200

# Thread Pool
THREAD_POOL_CORE_SIZE=8
THREAD_POOL_MAX_SIZE=32
THREAD_POOL_QUEUE_CAPACITY=1000

# Connection Pool
DB_POOL_SIZE=20
DB_POOL_MIN_IDLE=10
DB_POOL_MAX_LIFETIME=1800000

# Cache
REDIS_MAX_MEMORY=1GB
REDIS_EVICTION_POLICY=allkeys-lru

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_WEBSOCKET_ENABLED=true
FEATURE_BATCH_EVALUATION_ENABLED=true
FEATURE_ANALYTICS_ENABLED=true
FEATURE_EXPORT_ENABLED=true

# =============================================================================
# DATA RETENTION
# =============================================================================
EVALUATION_RETENTION_DAYS=365
LOG_RETENTION_DAYS=90
METRICS_RETENTION_DAYS=180

# =============================================================================
# NOTES
# =============================================================================
# 1. NEVER commit this file with actual passwords to version control
# 2. Use strong passwords (min 16 characters, mixed case, numbers, symbols)
# 3. Rotate passwords every 90 days
# 4. Use Docker secrets or vault for production deployment
# 5. Generate JWT secret with: openssl rand -hex 64
# 6. Generate API keys with: openssl rand -base64 32
# 7. Review and update CORS origins for your actual domains
# 8. Configure firewall rules to restrict port access
# 9. Enable SSL/TLS for all services in production
# 10. Set up monitoring and alerting before go-live
