# ====================================================================================================
# Staging Environment Configuration - Production-like settings
# ====================================================================================================
# This configuration mirrors production with realistic constraints for pre-production testing
# Resource limits, 10% tracing, real external APIs, production-like logging

# Spring Profile
SPRING_PROFILES_ACTIVE=staging

# ====================================================================================================
# Database Configuration (Production-like)
# ====================================================================================================
# PostgreSQL - Staging customer_deployments_db
CUSTOMER_DEPLOYMENTS_DB=customer_deployments_db
CUSTOMER_DEPLOYMENTS_USER=healthdata
CUSTOMER_DEPLOYMENTS_PASSWORD=staging_db_password_secure

# Main HDIM databases (existing Java services)
POSTGRES_USER=healthdata
POSTGRES_PASSWORD=staging_db_password_secure
POSTGRES_DB=healthdata_cql

# Quality Measure Service Database
QM_POSTGRES_DB=healthdata_quality_measure
QM_POSTGRES_USER=healthdata
QM_POSTGRES_PASSWORD=staging_db_password_secure

# FHIR Service Database
FHIR_POSTGRES_DB=healthdata_fhir
FHIR_POSTGRES_USER=healthdata
FHIR_POSTGRES_PASSWORD=staging_db_password_secure

# ====================================================================================================
# Redis Configuration (Production-like)
# ====================================================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=staging_redis_password_secure

# ====================================================================================================
# Kafka Configuration
# ====================================================================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ====================================================================================================
# FHIR Service
# ====================================================================================================
FHIR_SERVICE_URL=http://fhir-service-mock:8080/fhir

# ====================================================================================================
# Security Configuration (Staging - closer to production)
# ====================================================================================================
# SSL/TLS (enabled for staging to test certificate handling)
SSL_ENABLED=true
SSL_KEY_STORE=/secrets/keystore.staging.p12
SSL_KEY_STORE_PASSWORD=changeit_staging

# JWT Configuration (staging tokens valid for longer to support testing)
JWT_SECRET=staging_jwt_secret_key_minimum_256_bits_for_security_testing
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# Service API Key (for inter-service communication)
SERVICE_API_KEY=staging_api_key_12345

# CORS (staging allows specific testing domains)
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://staging.example.com,https://staging.example.com

# ====================================================================================================
# Rate Limiting (Staging - realistic production rates)
# ====================================================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=500
RATE_LIMIT_REQUESTS_PER_HOUR=5000

# ====================================================================================================
# Service Versions
# ====================================================================================================
CQL_ENGINE_VERSION=latest
QM_SERVICE_VERSION=latest

# ====================================================================================================
# Logging (Staging - INFO level like production)
# ====================================================================================================
LOG_LEVEL=INFO

# ====================================================================================================
# Java Options
# ====================================================================================================
JAVA_OPTS=-Xmx2g -Xms1g

# ====================================================================================================
# Monitoring & Metrics (Staging - reduced sampling vs production)
# ====================================================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=staging_admin_password
GRAFANA_SECRET_KEY=staging_grafana_secret

# ====================================================================================================
# Backup Configuration (Staging - daily backups)
# ====================================================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7

# ====================================================================================================
# SMTP Configuration (Staging - test email gateway)
# ====================================================================================================
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@staging.example.com

# ====================================================================================================
# Demo Tenant IDs
# ====================================================================================================
DEMO_TENANT_001=STAGING_TENANT_001
DEMO_TENANT_002=STAGING_TENANT_002

# ====================================================================================================
# Sales Agent Services - Docker Compose Staging
# ====================================================================================================

# Customer Deployments Database (Live Call Sales Agent)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# OpenTelemetry Configuration - 10% sampling (production-like load)
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_TRACES_EXPORTER=otlp
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_SAMPLER=parentbased_traceidratio
OTEL_SAMPLER_ARG=0.1
OTEL_METRICS_EXPORTER=prometheus

# Google Cloud APIs (Real APIs - staging project)
GOOGLE_APPLICATION_CREDENTIALS=/secrets/google-meet-service-account.json
GOOGLE_CLOUD_PROJECT=hdim-staging-project
MOCK_GOOGLE_MEET=false
MOCK_SPEECH_TO_TEXT=false
MOCK_ANTHROPIC_API=false

# Internal Service Communication
AI_SALES_AGENT_URL=http://ai-sales-agent:8090
WEBSOCKET_URL=ws://clinical-workflow-service:8090/ws

# Sales Agent Docker Services
COACHING_UI_PORT=4200
LIVE_CALL_AGENT_PORT=8095
AI_SALES_AGENT_STAGING_PORT=8090

# Feature Flags (All enabled in staging for full testing)
FEATURE_COACHING_UI_ENABLED=true
FEATURE_OBSERVABLE_SLOS_ENABLED=true
FEATURE_AUTO_COACHING=true
FEATURE_LIVE_CALL_AGENT_ENABLED=true

# File Storage (Staging uses local volumes)
TRANSCRIPT_STORAGE_PATH=/data/transcripts
TRANSCRIPT_RETENTION_DAYS=90

# Anthropic Claude API (for AI Sales Agent)
# Get key from: https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ====================================================================================================
# Observability & Monitoring (Staging)
# ====================================================================================================

# Jaeger Configuration
JAEGER_SAMPLER_TYPE=const
JAEGER_SAMPLER_PARAM=0.1
JAEGER_REPORTER_LOG_SPANS=true
JAEGER_REPORTER_MAX_PACKET_SIZE=65000

# Prometheus Configuration
PROMETHEUS_RETENTION_TIME=30d
PROMETHEUS_EVALUATION_INTERVAL=15s
PROMETHEUS_SCRAPE_INTERVAL=15s

# Grafana Configuration
GRAFANA_INSTALL_PLUGINS=grafana-piechart-panel
GRAFANA_SECURITY_ALLOW_EMBED_INIT_STATUS_TOKEN=true

# ====================================================================================================
# Application Performance Monitoring (APM)
# ====================================================================================================

# Application Insights (optional)
# APPINSIGHTS_INSTRUMENTATIONKEY=...

# DataDog (optional)
# DD_AGENT_HOST=datadog-agent
# DD_TRACE_SAMPLE_RATE=0.1
# DD_PROFILING_ENABLED=true

# ====================================================================================================
# Compliance & Security (Staging)
# ====================================================================================================

# HIPAA-specific settings
HIPAA_CACHE_TTL_MINUTES=5
HIPAA_AUDIT_ENABLED=true
HIPAA_PHI_LOGGING_ENABLED=false

# Data retention (staging)
DATA_RETENTION_DAYS=30
CUSTOMER_DATA_RETENTION_DAYS=90

# ====================================================================================================
# Performance Tuning (Staging - production-realistic)
# ====================================================================================================

# Connection Pools
DB_CONNECTION_POOL_SIZE=20
DB_MAXIMUM_POOL_SIZE=30

# Cache Settings
CACHE_TTL_MINUTES=10
CACHE_MAX_SIZE=1000

# Thread Pools
THREAD_POOL_CORE_SIZE=10
THREAD_POOL_MAX_SIZE=20

# ====================================================================================================
# Build & Deployment Info
# ====================================================================================================

BUILD_VERSION=staging-1.0.0
BUILD_DATE=$(date -u +'%Y-%m-%dT%H:%M:%SZ')
BUILD_COMMIT=staging
ENVIRONMENT=staging
REGION=us-east-1

# ====================================================================================================
# Alerting (Staging - PagerDuty for critical, Slack for warnings)
# ====================================================================================================

# PagerDuty Integration (critical alerts)
# PAGERDUTY_CRITICAL_KEY=...
# PAGERDUTY_WARNING_KEY=...

# Slack Integration (warnings and notifications)
# SLACK_ALERTS_WEBHOOK=...
# SLACK_NOTIFICATIONS_WEBHOOK=...

# Email Notifications
# EMAIL_ALERTS_TO=devops@example.com
# EMAIL_ALERTS_FROM=alerts@staging.example.com

# ====================================================================================================
# Health Check Configuration
# ====================================================================================================

# Service health check timeouts (seconds)
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_INITIAL_DELAY=15
HEALTH_CHECK_INTERVAL=30

# Database health check
DB_HEALTH_CHECK_ENABLED=true
DB_HEALTH_CHECK_INTERVAL_SECONDS=30

# Redis health check
REDIS_HEALTH_CHECK_ENABLED=true
REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30

# ====================================================================================================
# Testing & Validation Settings (Staging)
# ====================================================================================================

# Enable detailed request/response logging for debugging
DETAILED_LOGGING_ENABLED=false

# Contract testing validation
CONTRACT_TESTING_ENABLED=true

# Load testing preparation
LOAD_TEST_MODE=false
LOAD_TEST_CONCURRENT_USERS=100

# ====================================================================================================
# Notes for Staging Environment
# ====================================================================================================
#
# 1. Database Passwords:
#    - These should be stored in Kubernetes Secrets or HashiCorp Vault
#    - Never commit real passwords to version control
#    - This file is for template/example purposes
#
# 2. Google Cloud APIs:
#    - staging-project: Separate GCP project for staging
#    - Service account credentials mounted at /secrets/google-meet-service-account.json
#    - Real APIs used (not mocked) to test integration
#
# 3. Tracing:
#    - 10% sampling in staging (vs 100% in dev, 1% in production)
#    - Balances observability with resource usage
#    - Catch real-world patterns without overwhelming storage
#
# 4. Resource Limits:
#    - docker-compose.staging.sales-agents.yml defines CPU/memory limits
#    - Staging should run within production-like constraints
#    - Helps identify resource issues before production
#
# 5. Alerting:
#    - rules-staging.yml defines all monitoring rules
#    - Critical alerts -> PagerDuty (on-call engineer)
#    - Warnings -> Slack #alerts channel
#    - Configure webhook URLs in production setup
#
# 6. Data Retention:
#    - PostgreSQL retention: 30 days (trace old data)
#    - Transcripts retention: 90 days (longer for training data)
#    - Backups: daily with 7-day retention
#
