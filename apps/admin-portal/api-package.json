{
  "name": "investor-api",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone Investor Dashboard API for Vercel deployment",
  "scripts": {
    "dev:api": "vercel dev",
    "build:api": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "npx ts-node --esm prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "lint:api": "eslint api/**/*.ts lib/**/*.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@vercel/postgres": "^0.10.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.11.30",
    "prisma": "^5.22.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
