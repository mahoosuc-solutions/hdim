{
  "name": "clinical-portal",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/clinical-portal/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/apps/clinical-portal",
        "browser": "apps/clinical-portal/src/main.ts",
        "polyfills": [
          "zone.js"
        ],
        "tsConfig": "apps/clinical-portal/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/clinical-portal/public"
          },
          {
            "glob": "**/*",
            "input": "node_modules/monaco-editor",
            "output": "assets/monaco-editor"
          }
        ],
        "styles": [
          "apps/clinical-portal/src/styles.scss"
        ]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "800kb",
              "maximumError": "1.5mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "16kb",
              "maximumError": "24kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "options": {
        "proxyConfig": "apps/clinical-portal/proxy.conf.json"
      },
      "configurations": {
        "production": {
          "buildTarget": "clinical-portal:build:production"
        },
        "development": {
          "buildTarget": "clinical-portal:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "extract-i18n": {
      "executor": "@angular/build:extract-i18n",
      "options": {
        "buildTarget": "clinical-portal:build"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "apps/clinical-portal/jest.config.ts",
        "tsConfig": "apps/clinical-portal/tsconfig.spec.json"
      },
      "configurations": {
        "coverage": {
          "codeCoverage": true
        }
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "clinical-portal:build",
        "port": 4200,
        "staticFilePath": "dist/apps/clinical-portal/browser",
        "spa": true
      }
    },
    "test-contracts": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}/pact"
      ],
      "options": {
        "jestConfig": "apps/clinical-portal/jest.pact.config.js",
        "runInBand": true
      }
    },
    "pact-publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pact-broker publish ./pacts --consumer-app-version=${CONSUMER_VERSION:-0.0.0} --broker-base-url=${PACT_BROKER_URL:-http://localhost:9292}",
        "cwd": "apps/clinical-portal"
      }
    }
  }
}
