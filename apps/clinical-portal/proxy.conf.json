{
  "/fhir": {
    "target": "http://localhost:8081",
    "secure": false,
    "changeOrigin": true,
    "logLevel": "debug",
    "pathRewrite": {
      "^/fhir": "/fhir/fhir"
    },
    "headers": {
      "X-Tenant-ID": "demo-tenant"
    }
  },
  "/quality-measure": {
    "target": "http://localhost:8087",
