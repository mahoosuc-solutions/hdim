      "^/quality-measure": "/quality-measure/quality-measure"
    },
    "headers": {
      "X-Tenant-ID": "demo-tenant"
    }
  },
  "/cql-engine": {
    "target": "http://localhost:8086",
    "secure": false,
    "changeOrigin": true,
    "logLevel": "debug",
