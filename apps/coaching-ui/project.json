{
  "name": "coaching-ui",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/coaching-ui/src",
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/apps/coaching-ui",
        "browser": "apps/coaching-ui/src/main.ts",
        "index": "apps/coaching-ui/src/index.html",
        "polyfills": [
          "zone.js"
        ],
        "tsConfig": "apps/coaching-ui/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [],
        "styles": [
          "apps/coaching-ui/src/styles.scss"
        ]
      },
      "configurations": {
        "production": {
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    }
  }
}
