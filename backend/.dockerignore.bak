# Docker ignore file for backend build optimization
# Excludes unnecessary files from Docker build context

# Build directories (exclude specific subdirs, allow libs/)
**/build/classes/
**/build/generated/
**/build/resources/
**/build/tmp/
**/build/reports/
**/build/test-results/
**/target/
**/dist/
**/out/
**/.gradle/
**/bin/

# IDE directories
**/.idea/
**/.vscode/
**/.eclipse/
**/.settings/
**/*.iml
**/*.iws
**/*.ipr

# Git
.git/
.gitignore
.gitattributes

# Node modules (if any)
**/node_modules/
**/npm-debug.log
**/yarn-error.log

# Test reports
**/test-results/

# Logs
**/*.log
**/logs/

# Temporary files
**/*.tmp
**/*.temp
**/.DS_Store
**/Thumbs.db

# Documentation
README.md
CHANGELOG.md
LICENSE
**/*.md

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
Jenkinsfile

# Docker files
Dockerfile
.dockerignore
docker-compose*.yml

# Environment files
.env
.env.*
!.env.example

# Backups
**/backups/
**/*.sql
**/*.bak

# Coverage reports
**/coverage/
**/.nyc_output/
**/htmlcov/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
**/*.swp
**/*.swo
**/*~
