{
  "name": "modules-apps-migration-cli",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "backend/modules/apps/migration-cli/src",
  "tags": [
    "backend",
    "app"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/backend/modules/apps/migration-cli/build"
      ],
      "options": {
        "command": "./backend/gradlew -p backend :modules:apps:migration-cli:build"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./backend/gradlew -p backend :modules:apps:migration-cli:test"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./backend/gradlew -p backend :modules:apps:migration-cli:clean"
      }
    },
    "coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./backend/gradlew -p backend :modules:apps:migration-cli:test :modules:apps:migration-cli:jacocoTestReport :modules:apps:migration-cli:jacocoTestCoverageVerification"
      }
    }
  }
}
