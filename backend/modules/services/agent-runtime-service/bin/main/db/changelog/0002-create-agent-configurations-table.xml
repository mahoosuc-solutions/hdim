<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="0002-create-agent-configurations-table" author="hdim">
        <comment>Create agent_configurations table for custom agent configurations</comment>

        <createTable tableName="agent_configurations">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="VARCHAR(32)" defaultValue="1.0.0">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(32)" defaultValue="DRAFT">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="persona_name" type="VARCHAR(255)"/>
            <column name="persona_role" type="VARCHAR(255)"/>
            <column name="model_provider" type="VARCHAR(64)"/>
            <column name="model_id" type="VARCHAR(128)"/>
            <column name="system_prompt" type="TEXT"/>
            <column name="prompt_templates" type="JSONB" defaultValue="{}"/>
            <column name="tool_configuration" type="JSONB" defaultValue="[]"/>
            <column name="guardrail_configuration" type="JSONB" defaultValue="{}"/>
            <column name="created_by" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP"/>
            <column name="published_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <addUniqueConstraint tableName="agent_configurations"
                             columnNames="tenant_id, name, version"
                             constraintName="uk_agent_config_tenant_name_version"/>

        <sql>
            ALTER TABLE agent_configurations
                ADD CONSTRAINT chk_agent_status
                CHECK (status IN ('DRAFT', 'TESTING', 'ACTIVE', 'DEPRECATED'));
        </sql>

        <createIndex tableName="agent_configurations" indexName="idx_agent_config_tenant">
            <column name="tenant_id"/>
        </createIndex>

        <sql>
            CREATE INDEX IF NOT EXISTS idx_agent_config_status
                ON agent_configurations(status) WHERE status = 'ACTIVE';
        </sql>

        <rollback>
            <dropTable tableName="agent_configurations"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
