<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0002-create-analytics-reports-table" author="healthdata-system">
        <comment>Create analytics reports table for generated reports and dashboards</comment>

        <createTable tableName="analytics_reports">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>

            <!-- Report Details -->
            <column name="report_name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="report_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text">
                <constraints nullable="true"/>
            </column>

            <!-- Report Period -->
            <column name="period_start" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="period_end" type="date">
                <constraints nullable="false"/>
            </column>

            <!-- Report Data -->
            <column name="report_data" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="summary_statistics" type="text">
                <constraints nullable="true"/>
            </column>

            <!-- Generation Info -->
            <column name="generated_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="generated_by" type="varchar(128)">
                <constraints nullable="true"/>
            </column>
            <column name="status" type="varchar(20)" defaultValue="COMPLETED">
                <constraints nullable="false"/>
            </column>

            <!-- File Storage -->
            <column name="file_url" type="varchar(512)">
                <constraints nullable="true"/>
            </column>
            <column name="file_format" type="varchar(20)">
                <constraints nullable="true"/>
            </column>

            <!-- Audit -->
            <column name="expires_at" type="timestamp with time zone">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <createIndex indexName="idx_reports_tenant" tableName="analytics_reports">
            <column name="tenant_id"/>
            <column name="generated_at" descending="true"/>
        </createIndex>

        <createIndex indexName="idx_reports_type" tableName="analytics_reports">
            <column name="report_type"/>
        </createIndex>

        <createIndex indexName="idx_reports_period" tableName="analytics_reports">
            <column name="period_start"/>
            <column name="period_end"/>
        </createIndex>

        <rollback>
            <dropTable tableName="analytics_reports"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
