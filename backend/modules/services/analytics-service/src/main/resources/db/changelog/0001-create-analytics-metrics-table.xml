<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0001-create-analytics-metrics-table" author="healthdata-system">
        <comment>Create analytics metrics table for time-series performance data</comment>

        <createTable tableName="analytics_metrics">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>

            <!-- Metric Details -->
            <column name="metric_name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="metric_category" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="metric_value" type="decimal(18,6)">
                <constraints nullable="false"/>
            </column>
            <column name="metric_unit" type="varchar(50)">
                <constraints nullable="true"/>
            </column>

            <!-- Dimensions -->
            <column name="dimension_1" type="varchar(128)">
                <constraints nullable="true"/>
            </column>
            <column name="dimension_2" type="varchar(128)">
                <constraints nullable="true"/>
            </column>
            <column name="dimension_3" type="varchar(128)">
                <constraints nullable="true"/>
            </column>

            <!-- Temporal -->
            <column name="measurement_date" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="measurement_period" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="recorded_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <!-- Context -->
            <column name="metadata" type="text">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <createIndex indexName="idx_analytics_tenant_date" tableName="analytics_metrics">
            <column name="tenant_id"/>
            <column name="measurement_date" descending="true"/>
        </createIndex>

        <createIndex indexName="idx_analytics_metric" tableName="analytics_metrics">
            <column name="metric_name"/>
            <column name="measurement_date" descending="true"/>
        </createIndex>

        <createIndex indexName="idx_analytics_category" tableName="analytics_metrics">
            <column name="metric_category"/>
        </createIndex>

        <rollback>
            <dropTable tableName="analytics_metrics"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
