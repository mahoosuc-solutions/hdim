<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0001-create-care-gap-projections-table" author="care-gap-event-service">
        <comment>
            Create care_gap_projections read model table for handler projections.
            This schema aligns with com.healthdata.caregap.projection.CareGapProjection.
        </comment>

        <createTable tableName="care_gap_projections">
            <column name="id" type="VARCHAR(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="patient_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="gap_code" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="gap_description" type="TEXT"/>
            <column name="severity" type="VARCHAR(50)"/>
            <column name="status" type="VARCHAR(50)"/>
            <column name="qualified" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="recommended_intervention" type="TEXT"/>
            <column name="detection_date" type="DATE"/>
            <column name="closure_date" type="DATE"/>
            <column name="version" type="BIGINT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="last_updated" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <createIndex indexName="idx_caregap_tenant_status" tableName="care_gap_projections">
            <column name="tenant_id"/>
            <column name="status"/>
        </createIndex>

        <createIndex indexName="idx_caregap_patient_tenant" tableName="care_gap_projections">
            <column name="patient_id"/>
            <column name="tenant_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="care_gap_projections"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
