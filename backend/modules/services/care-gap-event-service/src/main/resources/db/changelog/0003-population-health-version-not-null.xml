<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0003-population-health-version-not-null" author="care-gap-event-service">
        <comment>
            Enforce non-null version column to align with PopulationHealthProjection entity.
        </comment>

        <addNotNullConstraint
            tableName="population_health_projections"
            columnName="version"
            columnDataType="BIGINT"/>

        <rollback>
            <dropNotNullConstraint
                tableName="population_health_projections"
                columnName="version"
                columnDataType="BIGINT"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
