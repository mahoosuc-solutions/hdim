<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0004-create-star-rating-projections" author="codex">
        <createTable tableName="star_rating_projections">
            <column name="tenant_id" type="VARCHAR(100)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="overall_rating" type="DECIMAL(4,2)">
                <constraints nullable="false"/>
            </column>
            <column name="rounded_rating" type="DECIMAL(3,1)">
                <constraints nullable="false"/>
            </column>
            <column name="measure_count" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="open_gap_count" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="closed_gap_count" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="quality_bonus_eligible" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="last_trigger_event" type="VARCHAR(255)"/>
            <column name="last_calculated_at" type="TIMESTAMP"/>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
