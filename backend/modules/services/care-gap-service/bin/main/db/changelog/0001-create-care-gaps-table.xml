<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0001-create-care-gaps-table" author="healthdata-system">
        <comment>Create care gaps table for tracking quality measure deficiencies</comment>

        <createTable tableName="care_gaps">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>

            <!-- Gap Details -->
            <column name="measure_id" type="varchar(128)">
                <constraints nullable="false"/>
            </column>
            <column name="measure_name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="gap_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="gap_category" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text">
                <constraints nullable="false"/>
            </column>

            <!-- Priority and Impact -->
            <column name="priority" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="severity" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="star_impact" type="decimal(3,2)">
                <constraints nullable="true"/>
            </column>

            <!-- Status -->
            <column name="status" type="varchar(20)" defaultValue="OPEN">
                <constraints nullable="false"/>
            </column>
            <column name="identified_date" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="due_date" type="date">
                <constraints nullable="true"/>
            </column>
            <column name="closed_date" type="timestamp with time zone">
                <constraints nullable="true"/>
            </column>

            <!-- Assignment -->
            <column name="assigned_to_provider_id" type="varchar(64)">
                <constraints nullable="true"/>
            </column>
            <column name="assigned_to_care_team_id" type="varchar(64)">
                <constraints nullable="true"/>
            </column>

            <!-- Additional Context -->
            <column name="clinical_data" type="text">
                <constraints nullable="true"/>
            </column>
            <column name="notes" type="text">
                <constraints nullable="true"/>
            </column>

            <!-- Audit -->
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_care_gaps_patient" tableName="care_gaps">
            <column name="tenant_id"/>
            <column name="patient_id"/>
        </createIndex>

        <createIndex indexName="idx_care_gaps_measure" tableName="care_gaps">
            <column name="measure_id"/>
        </createIndex>

        <createIndex indexName="idx_care_gaps_status" tableName="care_gaps">
            <column name="status"/>
            <column name="priority"/>
        </createIndex>

        <createIndex indexName="idx_care_gaps_assigned" tableName="care_gaps">
            <column name="assigned_to_provider_id"/>
        </createIndex>

        <createIndex indexName="idx_care_gaps_due_date" tableName="care_gaps">
            <column name="due_date"/>
        </createIndex>

        <rollback>
            <dropTable tableName="care_gaps"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
