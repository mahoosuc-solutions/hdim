<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0003-create-care-gap-closures-table" author="healthdata-system">
        <comment>Create care gap closures table for tracking gap resolution</comment>

        <createTable tableName="care_gap_closures">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="care_gap_id" type="uuid">
                <constraints nullable="false"
                            foreignKeyName="fk_closure_care_gap"
                            references="care_gaps(id)"/>
            </column>
            <column name="tenant_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>

            <!-- Closure Details -->
            <column name="closure_method" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="closure_date" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
            <column name="closed_by_provider_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="closed_by_provider_name" type="varchar(255)">
                <constraints nullable="true"/>
            </column>

            <!-- Evidence -->
            <column name="supporting_evidence_type" type="varchar(50)">
                <constraints nullable="true"/>
            </column>
            <column name="supporting_evidence_id" type="varchar(128)">
                <constraints nullable="true"/>
            </column>
            <column name="service_date" type="date">
                <constraints nullable="true"/>
            </column>

            <!-- Documentation -->
            <column name="notes" type="text">
                <constraints nullable="true"/>
            </column>
            <column name="documentation_url" type="varchar(512)">
                <constraints nullable="true"/>
            </column>

            <!-- Verification -->
            <column name="verified" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="verified_at" type="timestamp with time zone">
                <constraints nullable="true"/>
            </column>
            <column name="verified_by" type="varchar(128)">
                <constraints nullable="true"/>
            </column>

            <!-- Audit -->
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_closures_gap" tableName="care_gap_closures">
            <column name="care_gap_id"/>
        </createIndex>

        <createIndex indexName="idx_closures_provider" tableName="care_gap_closures">
            <column name="closed_by_provider_id"/>
        </createIndex>

        <createIndex indexName="idx_closures_date" tableName="care_gap_closures">
            <column name="closure_date" descending="true"/>
        </createIndex>

        <rollback>
            <dropTable tableName="care_gap_closures"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
