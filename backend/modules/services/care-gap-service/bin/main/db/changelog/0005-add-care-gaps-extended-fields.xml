<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0005-add-care-gaps-extended-fields" author="healthdata-system">
        <preConditions onFail="MARK_RAN" onError="MARK_RAN">
            <not>
                <columnExists tableName="care_gaps" columnName="measure_year"/>
            </not>
        </preConditions>

        <comment>Add extended care gap fields for CQL evaluation and recommendations</comment>

        <addColumn tableName="care_gaps">
            <column name="measure_year" type="integer"/>
            <column name="risk_score" type="double precision"/>
            <column name="gap_reason" type="text"/>
            <column name="recommendation" type="text"/>
            <column name="recommendation_type" type="varchar(100)"/>
            <column name="recommended_action" type="text"/>
            <column name="cql_library" type="varchar(200)"/>
            <column name="cql_expression" type="varchar(200)"/>
            <column name="cql_result" type="text"/>
            <column name="related_encounter_id" type="varchar(128)"/>
            <column name="related_condition_id" type="varchar(128)"/>
            <column name="related_procedure_id" type="varchar(128)"/>
            <column name="closed_by" type="varchar(255)"/>
            <column name="closure_reason" type="text"/>
            <column name="closure_action" type="text"/>
        </addColumn>

        <rollback>
            <dropColumn tableName="care_gaps" columnName="measure_year"/>
            <dropColumn tableName="care_gaps" columnName="risk_score"/>
            <dropColumn tableName="care_gaps" columnName="gap_reason"/>
            <dropColumn tableName="care_gaps" columnName="recommendation"/>
            <dropColumn tableName="care_gaps" columnName="recommendation_type"/>
            <dropColumn tableName="care_gaps" columnName="recommended_action"/>
            <dropColumn tableName="care_gaps" columnName="cql_library"/>
            <dropColumn tableName="care_gaps" columnName="cql_expression"/>
            <dropColumn tableName="care_gaps" columnName="cql_result"/>
            <dropColumn tableName="care_gaps" columnName="related_encounter_id"/>
            <dropColumn tableName="care_gaps" columnName="related_condition_id"/>
            <dropColumn tableName="care_gaps" columnName="related_procedure_id"/>
            <dropColumn tableName="care_gaps" columnName="closed_by"/>
            <dropColumn tableName="care_gaps" columnName="closure_reason"/>
            <dropColumn tableName="care_gaps" columnName="closure_action"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
