<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0002-create-care-gap-recommendations-table" author="healthdata-system">
        <comment>Create care gap recommendations table for suggested interventions</comment>

        <createTable tableName="care_gap_recommendations">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="care_gap_id" type="uuid">
                <constraints nullable="false"
                            foreignKeyName="fk_recommendation_care_gap"
                            references="care_gaps(id)"/>
            </column>
            <column name="tenant_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>

            <!-- Recommendation Details -->
            <column name="recommendation_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="action_required" type="text">
                <constraints nullable="false"/>
            </column>

            <!-- Priority -->
            <column name="priority" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <!-- Evidence -->
            <column name="evidence_level" type="varchar(20)">
                <constraints nullable="true"/>
            </column>
            <column name="guideline_reference" type="text">
                <constraints nullable="true"/>
            </column>

            <!-- Status -->
            <column name="status" type="varchar(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="accepted_at" type="timestamp with time zone">
                <constraints nullable="true"/>
            </column>
            <column name="rejected_at" type="timestamp with time zone">
                <constraints nullable="true"/>
            </column>
            <column name="rejection_reason" type="text">
                <constraints nullable="true"/>
            </column>

            <!-- Audit -->
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_recommendations_gap" tableName="care_gap_recommendations">
            <column name="care_gap_id"/>
        </createIndex>

        <createIndex indexName="idx_recommendations_status" tableName="care_gap_recommendations">
            <column name="status"/>
        </createIndex>

        <rollback>
            <dropTable tableName="care_gap_recommendations"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
