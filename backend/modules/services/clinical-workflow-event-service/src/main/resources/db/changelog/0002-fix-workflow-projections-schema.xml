<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0002-fix-workflow-projections-schema" author="hdim-platform-team">
        <comment>Fix workflow_projections table to match WorkflowProjection entity</comment>

        <!-- Drop existing table with incompatible schema -->
        <dropTable tableName="workflow_projections" cascadeConstraints="true"/>

        <!-- Recreate with correct schema matching WorkflowProjection entity -->
        <createTable tableName="workflow_projections">
            <!-- Primary Key - String composite key -->
            <column name="id" type="VARCHAR(255)">
                <constraints primaryKey="true" primaryKeyName="pk_workflow_projections"/>
            </column>

            <!-- Tenant Isolation (CRITICAL) -->
            <column name="tenant_id" type="VARCHAR(100)" remarks="Multi-tenant isolation key">
                <constraints nullable="false"/>
            </column>

            <!-- Workflow Identity -->
            <column name="patient_id" type="VARCHAR(100)" remarks="Patient ID">
                <constraints nullable="false"/>
            </column>

            <column name="workflow_type" type="VARCHAR(100)" remarks="Type of workflow">
                <constraints nullable="false"/>
            </column>

            <!-- Workflow Status -->
            <column name="status" type="VARCHAR(50)" remarks="INITIATED, IN_PROGRESS, COMPLETED, CANCELLED">
                <constraints nullable="true"/>
            </column>

            <column name="current_step" type="VARCHAR(100)" remarks="Current workflow step">
                <constraints nullable="true"/>
            </column>

            <column name="assigned_to" type="VARCHAR(100)" remarks="User ID assigned to workflow">
                <constraints nullable="true"/>
            </column>

            <column name="last_step_successful" type="BOOLEAN" defaultValue="false">
                <constraints nullable="false"/>
            </column>

            <column name="approval_status" type="VARCHAR(50)" remarks="APPROVED, DENIED, PENDING_REVIEW">
                <constraints nullable="true"/>
            </column>

            <!-- Timeline -->
            <column name="initiated_date" type="DATE" remarks="Date workflow was initiated">
                <constraints nullable="true"/>
            </column>

            <column name="completed_date" type="DATE" remarks="Date workflow was completed">
                <constraints nullable="true"/>
            </column>

            <!-- Event Versioning -->
            <column name="version" type="BIGINT" defaultValue="1">
                <constraints nullable="false"/>
            </column>

            <column name="last_updated" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- TENANT ISOLATION INDEX (CRITICAL) -->
        <createIndex indexName="idx_workflow_tenant_status" tableName="workflow_projections">
            <column name="tenant_id"/>
            <column name="status"/>
        </createIndex>

        <createIndex indexName="idx_workflow_patient_tenant" tableName="workflow_projections">
            <column name="patient_id"/>
            <column name="tenant_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="workflow_projections" cascadeConstraints="true"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
