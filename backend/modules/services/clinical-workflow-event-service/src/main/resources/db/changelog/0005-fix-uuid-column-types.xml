<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0005-fix-uuid-column-types" author="hdim-platform-team">
        <comment>Fix UUID column types - workflow_id, patient_id, and related_care_gap_id should be UUID not VARCHAR</comment>

        <!-- Convert workflow_id from VARCHAR to UUID -->
        <modifyDataType tableName="workflow_projections"
                        columnName="workflow_id"
                        newDataType="UUID"/>

        <!-- Convert patient_id from VARCHAR to UUID -->
        <modifyDataType tableName="workflow_projections"
                        columnName="patient_id"
                        newDataType="UUID"/>

        <rollback>
            <modifyDataType tableName="workflow_projections"
                            columnName="workflow_id"
                            newDataType="VARCHAR(100)"/>
            <modifyDataType tableName="workflow_projections"
                            columnName="patient_id"
                            newDataType="VARCHAR(100)"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
