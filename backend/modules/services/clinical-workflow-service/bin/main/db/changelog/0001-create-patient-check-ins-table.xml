<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0001-create-patient-check-ins-table" author="hdim-platform-team">
        <comment>Create patient_check_ins table for MA check-in workflow tracking</comment>

        <createTable tableName="patient_check_ins">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_patient_check_ins"/>
            </column>
            <column name="tenant_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="appointment_id" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="encounter_id" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="check_in_time" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="checked_in_by" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)" defaultValue="checked-in">
                <constraints nullable="false"/>
            </column>
            <column name="insurance_verified" type="BOOLEAN" defaultValue="false">
                <constraints nullable="false"/>
            </column>
            <column name="demographics_updated" type="BOOLEAN" defaultValue="false">
                <constraints nullable="false"/>
            </column>
            <column name="consent_obtained" type="BOOLEAN" defaultValue="false">
                <constraints nullable="false"/>
            </column>
            <column name="waiting_time_minutes" type="INTEGER">
                <constraints nullable="true"/>
            </column>
            <column name="notes" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_patient_check_ins_tenant_id" tableName="patient_check_ins">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_patient_check_ins_patient_id" tableName="patient_check_ins">
            <column name="tenant_id"/>
            <column name="patient_id"/>
        </createIndex>

        <createIndex indexName="idx_patient_check_ins_check_in_time" tableName="patient_check_ins">
            <column name="tenant_id"/>
            <column name="check_in_time"/>
        </createIndex>

        <rollback>
            <dropTable tableName="patient_check_ins"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
