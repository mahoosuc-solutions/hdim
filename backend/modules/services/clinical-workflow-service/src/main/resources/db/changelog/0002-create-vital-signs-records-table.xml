<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0002-create-vital-signs-records-table" author="hdim-platform-team">
        <comment>Create vital_signs_records table for MA vitals recording with alert thresholds</comment>

        <createTable tableName="vital_signs_records">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_vital_signs_records"/>
            </column>
            <column name="tenant_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="encounter_id" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="observation_id" type="VARCHAR(255)" remarks="FHIR Observation resource ID">
                <constraints nullable="true"/>
            </column>
            <column name="recorded_by" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <!-- Vital Signs -->
            <column name="systolic_bp" type="NUMERIC(5,1)" remarks="Systolic Blood Pressure in mmHg">
                <constraints nullable="true"/>
            </column>
            <column name="diastolic_bp" type="NUMERIC(5,1)" remarks="Diastolic Blood Pressure in mmHg">
                <constraints nullable="true"/>
            </column>
            <column name="heart_rate" type="NUMERIC(5,1)" remarks="Heart Rate in beats per minute">
                <constraints nullable="true"/>
            </column>
            <column name="temperature_f" type="NUMERIC(5,2)" remarks="Temperature in Fahrenheit">
                <constraints nullable="true"/>
            </column>
            <column name="respiration_rate" type="NUMERIC(5,1)" remarks="Respiration Rate in breaths per minute">
                <constraints nullable="true"/>
            </column>
            <column name="oxygen_saturation" type="NUMERIC(5,1)" remarks="O2 Saturation in percentage">
                <constraints nullable="true"/>
            </column>
            <column name="weight_kg" type="NUMERIC(7,2)" remarks="Weight in kilograms">
                <constraints nullable="true"/>
            </column>
            <column name="height_cm" type="NUMERIC(5,1)" remarks="Height in centimeters">
                <constraints nullable="true"/>
            </column>
            <column name="bmi" type="NUMERIC(5,2)" remarks="Body Mass Index">
                <constraints nullable="true"/>
            </column>
            <!-- Alert Status -->
            <column name="alert_status" type="VARCHAR(50)" defaultValue="normal" remarks="normal, warning, critical">
                <constraints nullable="false"/>
            </column>
            <column name="alert_message" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <!-- Workflow -->
            <column name="recorded_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_vital_signs_tenant_id" tableName="vital_signs_records">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_vital_signs_patient_id" tableName="vital_signs_records">
            <column name="tenant_id"/>
            <column name="patient_id"/>
        </createIndex>

        <createIndex indexName="idx_vital_signs_recorded_at" tableName="vital_signs_records">
            <column name="tenant_id"/>
            <column name="patient_id"/>
            <column name="recorded_at"/>
        </createIndex>

        <createIndex indexName="idx_vital_signs_alert_status" tableName="vital_signs_records">
            <column name="tenant_id"/>
            <column name="alert_status"/>
        </createIndex>

        <rollback>
            <dropTable tableName="vital_signs_records"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
