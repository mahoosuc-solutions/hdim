<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0009-create-audit-events-table" author="healthdata-system">
        <comment>Create audit_events table for audit logging</comment>

        <createTable tableName="audit_events">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_audit_events"/>
            </column>

            <column name="timestamp" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>

            <column name="tenant_id" type="VARCHAR(100)"/>
            <column name="user_id" type="VARCHAR(100)"/>
            <column name="username" type="VARCHAR(255)"/>
            <column name="role" type="VARCHAR(100)"/>
            <column name="ip_address" type="VARCHAR(45)"/>
            <column name="user_agent" type="VARCHAR(500)"/>

            <column name="action" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="resource_type" type="VARCHAR(100)"/>
            <column name="resource_id" type="VARCHAR(255)"/>
            <column name="outcome" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <column name="service_name" type="VARCHAR(100)"/>
            <column name="method_name" type="VARCHAR(100)"/>
            <column name="request_path" type="VARCHAR(500)"/>
            <column name="purpose_of_use" type="VARCHAR(100)"/>

            <column name="request_payload" type="JSONB"/>
            <column name="response_payload" type="JSONB"/>
            <column name="error_message" type="TEXT"/>
            <column name="duration_ms" type="BIGINT"/>

            <column name="fhir_audit_event_id" type="VARCHAR(255)"/>

            <column name="encrypted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_audit_tenant_timestamp" tableName="audit_events">
            <column name="tenant_id"/>
            <column name="timestamp"/>
        </createIndex>

        <createIndex indexName="idx_audit_user_timestamp" tableName="audit_events">
            <column name="user_id"/>
            <column name="timestamp"/>
        </createIndex>

        <createIndex indexName="idx_audit_resource" tableName="audit_events">
            <column name="resource_type"/>
            <column name="resource_id"/>
            <column name="timestamp"/>
        </createIndex>

        <createIndex indexName="idx_audit_timestamp" tableName="audit_events">
            <column name="timestamp"/>
        </createIndex>

        <rollback>
            <dropTable tableName="audit_events"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
