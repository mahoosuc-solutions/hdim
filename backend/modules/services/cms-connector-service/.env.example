# CMS Connector Service - Environment Variables
# Copy this file to .env and fill in with actual values for production deployment

# ========== Database Configuration ==========
DB_URL=jdbc:postgresql://postgres:5432/cms_production
DB_USER=cms_service
DB_PASSWORD=your_secure_database_password_here
DB_NAME=cms_production

# ========== Redis Configuration ==========
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# ========== BCDA API Configuration ==========
BCDA_URL=https://api.bcda.cms.gov
BCDA_TOKEN_URL=https://api.bcda.cms.gov/auth/token
BCDA_CLIENT_ID=your_bcda_client_id_here
BCDA_CLIENT_SECRET=your_bcda_client_secret_here

# ========== DPC API Configuration ==========
DPC_URL=https://api.dpc.cms.gov
DPC_TOKEN_URL=https://api.dpc.cms.gov/auth/token
DPC_CLIENT_ID=your_dpc_client_id_here
DPC_CLIENT_SECRET=your_dpc_client_secret_here

# ========== AB2D API Configuration ==========
AB2D_URL=https://api.ab2d.cms.gov
AB2D_TOKEN_URL=https://api.ab2d.cms.gov/auth/token
AB2D_CLIENT_ID=your_ab2d_client_id_here
AB2D_CLIENT_SECRET=your_ab2d_client_secret_here

# ========== JWT Security ==========
JWT_ISSUER_URI=https://auth.cms.gov
JWT_JWK_SET_URI=https://auth.cms.gov/.well-known/jwks.json

# ========== Docker Image Configuration ==========
DOCKER_REGISTRY=docker.io
DOCKER_NAMESPACE=webemo
APP_NAME=cms-connector-service
APP_VERSION=1.0.0

# ========== Application Settings ==========
SPRING_PROFILES_ACTIVE=prod

# ========== Monitoring & Logging ==========
LOGGING_LEVEL_ROOT=WARN
LOGGING_LEVEL_COM_HEALTHDATA_CMS=INFO

# ========== JVM Configuration ==========
JAVA_OPTS=-Xms512m -Xmx2g -XX:+UseG1GC -XX:MaxGCPauseMillis=200

# ========== Server Configuration ==========
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api/v1

# ========== Notes ==========
# 1. Replace all 'your_*_here' values with actual credentials
# 2. For production, use a secrets management system (Vault, AWS Secrets Manager, K8s Secrets)
# 3. Never commit the actual .env file to version control
# 4. Use strong passwords (minimum 32 characters for database)
# 5. Rotate credentials regularly (quarterly recommended)
# 6. Keep backups of this file in secure location
