package com.healthdata.cms.client;

import com.healthdata.cms.auth.OAuth2Manager;
import com.healthdata.cms.exception.CmsApiException;
import com.healthdata.cms.model.CmsApiProvider;
import io.github.resilience4j.circuitbreaker.annotation.CircuitBreaker;
import io.github.resilience4j.retry.annotation.Retry;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Qualifier;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.http.HttpEntity;
import org.springframework.http.HttpHeaders;
import org.springframework.http.MediaType;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Component;
import org.springframework.web.client.HttpClientErrorException;
import org.springframework.web.client.RestTemplate;

import java.util.Arrays;
import java.util.List;

/**
 * BCDA (Beneficiary Claims Data API) Client
 *
 * Handles integration with CMS BCDA API for bulk Medicare claims exports.
 *
 * Features:
 * - Weekly bulk export of Part A, B, D claims
 * - NDJSON format (newline-delimited JSON)
 * - OAuth2 authentication with bearer tokens
 * - Batch polling for export status
 * - Resilience patterns: circuit breaker + retry
 *
 * API Reference: https://bcda.cms.gov/api/v2
 */
@Slf4j
@Component
public class BcdaClient {

    private final OAuth2Manager oauth2Manager;
    private final RestTemplate restTemplate;
    private final String baseUrl;
    private final boolean isSandbox;

    public BcdaClient(OAuth2Manager oauth2Manager,
                      @Qualifier("cmsRestTemplate") RestTemplate restTemplate,
                      @Value("${cms.bcda.base-url:https://sandbox.bcda.cms.gov}") String baseUrl,
                      @Value("${cms.sandbox-mode:true}") boolean isSandbox) {
        this.oauth2Manager = oauth2Manager;
        this.restTemplate = restTemplate;
        this.baseUrl = baseUrl;
        this.isSandbox = isSandbox;

        log.info("Initialized BCDA client for {} environment. Base URL: {}",
            isSandbox ? "SANDBOX" : "PRODUCTION", baseUrl);
    }

    /**
     * Get the authorization header with OAuth2 bearer token
     */
    private String getAuthorizationHeader() {
        String token = oauth2Manager.getAccessToken(CmsApiProvider.BCDA);
        return "Bearer " + token;
    }

    /**
     * Get HTTP headers for BCDA API requests
     */
    private HttpHeaders getHeaders() {
        HttpHeaders headers = new HttpHeaders();
        headers.setContentType(MediaType.APPLICATION_JSON);
        headers.set("Authorization", getAuthorizationHeader());
        headers.set("Accept", "application/fhir+json");
        return headers;
    }

    /**
     * List available bulk data exports
     * GET /api/v2/bulkdata
     */
    @CircuitBreaker(name = "bcda", fallbackMethod = "listBulkDataExportsFallback")
    @Retry(name = "bcda-retry")
    public List<BulkDataExport> listBulkDataExports() {
        log.info("Fetching list of BCDA bulk data exports");

        try {
            String url = baseUrl + "/api/v2/bulkdata";
            HttpEntity<String> entity = new HttpEntity<>(getHeaders());

            ResponseEntity<BulkDataExport[]> response = restTemplate.getForEntity(url, BulkDataExport[].class);

            if (response.getBody() == null) {
                log.warn("Empty response from BCDA listBulkDataExports");
                return List.of();
            }

            List<BulkDataExport> exports = Arrays.asList(response.getBody());
            log.info("Retrieved {} bulk data exports from BCDA", exports.size());
            return exports;

        } catch (HttpClientErrorException e) {
            log.error("HTTP error listing bulk data exports: {} - {}",
                e.getStatusCode(), e.getStatusText());
            throw new CmsApiException(
                "Failed to list bulk data exports from BCDA",
                CmsApiProvider.BCDA,
                "list_exports_failed",
                e.getStatusCode().value(),
                e
            );
        } catch (Exception e) {
            log.error("Error listing bulk data exports", e);
            throw new CmsApiException(
                "Error listing bulk data exports: " + e.getMessage(),
                CmsApiProvider.BCDA,
                "list_exports_error",
                -1,
                e
            );
        }
    }

    /**
     * Fallback method for listBulkDataExports
     */
    public List<BulkDataExport> listBulkDataExportsFallback(Exception e) {
        log.warn("Using fallback for listBulkDataExports due to: {}", e.getMessage());
        return List.of();
    }

    /**
     * Request a new bulk data export
     * POST /api/v2/bulkdata
     */
    @CircuitBreaker(name = "bcda", fallbackMethod = "requestBulkDataExportFallback")
    @Retry(name = "bcda-retry")
    public BulkDataExportResponse requestBulkDataExport(BulkDataExportRequest request) {
        log.info("Requesting BCDA bulk data export with output format: {}", request.getOutputFormat());

        try {
            String url = baseUrl + "/api/v2/bulkdata";
            HttpEntity<BulkDataExportRequest> entity = new HttpEntity<>(request, getHeaders());

            ResponseEntity<BulkDataExportResponse> response = restTemplate.postForEntity(
                url, entity, BulkDataExportResponse.class
            );

            BulkDataExportResponse exportResponse = response.getBody();
            if (exportResponse == null) {
                throw new CmsApiException(
                    "Null response from BCDA export request",
                    CmsApiProvider.BCDA,
                    "null_response",
                    response.getStatusCodeValue()
                );
            }

            log.info("BCDA export request successful. Export ID: {}. Status: {}",
                exportResponse.getExportId(), exportResponse.getStatus());

            return exportResponse;

        } catch (HttpClientErrorException e) {
            log.error("HTTP error requesting bulk export: {} - {}",
                e.getStatusCode(), e.getStatusText());
            throw new CmsApiException(
                "Failed to request bulk export from BCDA",
                CmsApiProvider.BCDA,
                "request_export_failed",
                e.getStatusCode().value(),
                e
            );
        } catch (Exception e) {
            log.error("Error requesting bulk export", e);
            throw new CmsApiException(
                "Error requesting bulk export: " + e.getMessage(),
                CmsApiProvider.BCDA,
                "request_export_error",
                -1,
                e
            );
        }
    }

    /**
     * Fallback method for requestBulkDataExport
     */
    public BulkDataExportResponse requestBulkDataExportFallback(BulkDataExportRequest request, Exception e) {
        log.warn("Using fallback for requestBulkDataExport due to: {}", e.getMessage());
        return new BulkDataExportResponse("pending", "fallback-export-id");
    }

    /**
     * Get status of a bulk data export
     * GET /api/v2/bulkdata/{exportId}
     */
    @CircuitBreaker(name = "bcda", fallbackMethod = "getExportStatusFallback")
    @Retry(name = "bcda-retry")
    public BulkDataExportStatus getExportStatus(String exportId) {
        log.debug("Fetching status for BCDA export: {}", exportId);

        try {
            String url = baseUrl + "/api/v2/bulkdata/" + exportId;
            HttpEntity<String> entity = new HttpEntity<>(getHeaders());

            ResponseEntity<BulkDataExportStatus> response = restTemplate.getForEntity(
                url, BulkDataExportStatus.class
            );

            BulkDataExportStatus status = response.getBody();
            if (status == null) {
                throw new CmsApiException(
                    "Null response from BCDA export status",
                    CmsApiProvider.BCDA,
                    "null_response",
                    response.getStatusCodeValue()
                );
            }

            log.debug("Export {} status: {}. Progress: {}%",
                exportId, status.getStatus(), status.getPercentComplete());

            return status;

        } catch (HttpClientErrorException e) {
            log.error("HTTP error getting export status: {} - {}",
                e.getStatusCode(), e.getStatusText());
            throw new CmsApiException(
                "Failed to get export status from BCDA",
                CmsApiProvider.BCDA,
                "status_error",
                e.getStatusCode().value(),
                e
            );
        }
    }

    /**
     * Fallback method for getExportStatus
     */
    public BulkDataExportStatus getExportStatusFallback(String exportId, Exception e) {
        log.warn("Using fallback for getExportStatus due to: {}", e.getMessage());
        return new BulkDataExportStatus("pending", 0);
    }

    /**
     * Get download URLs for completed export files
     * GET /api/v2/bulkdata/{exportId}/file_paths
     */
    public List<String> getExportFilePaths(String exportId) {
        log.info("Fetching file paths for BCDA export: {}", exportId);

        try {
            String url = baseUrl + "/api/v2/bulkdata/" + exportId + "/file_paths";
            HttpEntity<String> entity = new HttpEntity<>(getHeaders());

            ResponseEntity<String[]> response = restTemplate.getForEntity(url, String[].class);

            if (response.getBody() == null) {
                log.warn("Empty response from BCDA getExportFilePaths");
                return List.of();
            }

            List<String> filePaths = Arrays.asList(response.getBody());
            log.info("Retrieved {} file paths for export {}", filePaths.size(), exportId);
            return filePaths;

        } catch (HttpClientErrorException e) {
            log.error("HTTP error getting file paths: {} - {}",
                e.getStatusCode(), e.getStatusText());
            throw new CmsApiException(
                "Failed to get file paths from BCDA",
                CmsApiProvider.BCDA,
                "file_paths_error",
                e.getStatusCode().value(),
                e
            );
        }
    }

    /**
     * Download bulk data export file
     * GET /api/v2/File/{fileName}
     */
    public String downloadFile(String fileName) {
        log.info("Downloading BCDA file: {}", fileName);

        try {
            String url = baseUrl + "/api/v2/File/" + fileName;
            ResponseEntity<String> response = restTemplate.getForEntity(url, String.class);

            String fileContent = response.getBody();
            if (fileContent == null) {
                log.warn("Empty content from BCDA file download: {}", fileName);
                return "";
            }

            log.info("Successfully downloaded BCDA file: {}. Size: {} bytes",
                fileName, fileContent.length());
            return fileContent;

        } catch (HttpClientErrorException e) {
            log.error("HTTP error downloading file: {} - {}",
                e.getStatusCode(), e.getStatusText());
            throw new CmsApiException(
                "Failed to download file from BCDA",
                CmsApiProvider.BCDA,
                "download_error",
                e.getStatusCode().value(),
                e
            );
        }
    }

    /**
     * Get BCDA metadata
     * GET /api/v2
     */
    public BcdaMetadata getMetadata() {
        log.info("Fetching BCDA API metadata");

        try {
            String url = baseUrl + "/api/v2";
            HttpEntity<String> entity = new HttpEntity<>(getHeaders());

            ResponseEntity<BcdaMetadata> response = restTemplate.getForEntity(url, BcdaMetadata.class);

            BcdaMetadata metadata = response.getBody();
            if (metadata == null) {
                log.warn("Empty metadata response from BCDA");
                return new BcdaMetadata();
            }

            log.info("BCDA API version: {}. Supported resource types: {}",
                metadata.getApiVersion(), metadata.getSupportedResourceTypes());

            return metadata;

        } catch (HttpClientErrorException e) {
            log.error("HTTP error getting metadata: {} - {}",
                e.getStatusCode(), e.getStatusText());
            throw new CmsApiException(
                "Failed to get metadata from BCDA",
                CmsApiProvider.BCDA,
                "metadata_error",
                e.getStatusCode().value(),
                e
            );
        }
    }

    // ============ DTOs ============

    public static class BulkDataExport {
        private String id;
        private String status;
        private String createdAt;
        private List<String> filePaths;

        public BulkDataExport() {}

        public String getId() { return id; }
        public void setId(String id) { this.id = id; }
        public String getStatus() { return status; }
        public void setStatus(String status) { this.status = status; }
        public String getCreatedAt() { return createdAt; }
        public void setCreatedAt(String createdAt) { this.createdAt = createdAt; }
        public List<String> getFilePaths() { return filePaths; }
        public void setFilePaths(List<String> filePaths) { this.filePaths = filePaths; }
    }

    public static class BulkDataExportRequest {
        private String outputFormat; // "ndjson"
        private List<String> resourceTypes; // ["ExplanationOfBenefit", "Patient", "Coverage"]

        public BulkDataExportRequest() {}

        public String getOutputFormat() { return outputFormat; }
        public void setOutputFormat(String outputFormat) { this.outputFormat = outputFormat; }
        public List<String> getResourceTypes() { return resourceTypes; }
        public void setResourceTypes(List<String> resourceTypes) { this.resourceTypes = resourceTypes; }
    }

    public static class BulkDataExportResponse {
        private String status;
        private String exportId;

        public BulkDataExportResponse() {}

        public BulkDataExportResponse(String status, String exportId) {
            this.status = status;
            this.exportId = exportId;
        }

        public String getStatus() { return status; }
        public void setStatus(String status) { this.status = status; }
        public String getExportId() { return exportId; }
        public void setExportId(String exportId) { this.exportId = exportId; }
    }

    public static class BulkDataExportStatus {
        private String status;
        private int percentComplete;

        public BulkDataExportStatus() {}

        public BulkDataExportStatus(String status, int percentComplete) {
            this.status = status;
            this.percentComplete = percentComplete;
        }

        public String getStatus() { return status; }
        public void setStatus(String status) { this.status = status; }
        public int getPercentComplete() { return percentComplete; }
        public void setPercentComplete(int percentComplete) { this.percentComplete = percentComplete; }
    }

    public static class BcdaMetadata {
        private String apiVersion;
        private List<String> supportedResourceTypes;
        private String dataLag; // "5-10 days"

        public BcdaMetadata() {}

        public String getApiVersion() { return apiVersion; }
        public void setApiVersion(String apiVersion) { this.apiVersion = apiVersion; }
        public List<String> getSupportedResourceTypes() { return supportedResourceTypes; }
        public void setSupportedResourceTypes(List<String> supportedResourceTypes) { this.supportedResourceTypes = supportedResourceTypes; }
        public String getDataLag() { return dataLag; }
        public void setDataLag(String dataLag) { this.dataLag = dataLag; }
    }
}
