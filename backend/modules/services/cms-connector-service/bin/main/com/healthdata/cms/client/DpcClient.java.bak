            );
        }
    }

    /**
     * Fallback method for getMedicationRequests
     */
    public String getMedicationRequestsFallback(String patientId, Exception e) {
        log.warn("Using fallback for getMedicationRequests({}) due to: {}", patientId, e.getMessage());
        return "";
    }

    /**
     * Get FHIR Observation resources for a patient
     * GET /api/v1/Observation?patient={patientId}
     *
     * Returns all lab results and observations
     */
    @CircuitBreaker(name = "dpc", fallbackMethod = "getObservationsFallback")
    @Retry(name = "dpc-retry")
    public String getObservations(String patientId) {
        log.debug("Fetching Observation resources from DPC for patient: {}", patientId);

        try {
            String url = baseUrl + "/api/v1/Observation?patient=" + patientId;
            HttpEntity<String> entity = new HttpEntity<>(getHeaders());

            ResponseEntity<String> response = restTemplate.getForEntity(url, String.class);
            String obsData = response.getBody();

            if (obsData == null || obsData.isEmpty()) {
                log.debug("No Observation records found for patient: {}", patientId);
