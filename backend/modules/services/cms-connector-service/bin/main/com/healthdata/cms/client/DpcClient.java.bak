            return medData;

        } catch (HttpClientErrorException e) {
            log.error("HTTP error fetching medications: {} - {}",
                e.getStatusCode(), e.getStatusText());
            throw new CmsApiException(
                "Failed to fetch MedicationRequest from DPC",
                CmsApiProvider.DPC,
