    @Retry(name = "dpc-retry")
    public String getConditions(String patientId) {
        log.debug("Fetching Condition resources from DPC for patient: {}", patientId);

        try {
            String url = baseUrl + "/api/v1/Condition?patient=" + patientId;
            HttpEntity<String> entity = new HttpEntity<>(getHeaders());

            ResponseEntity<String> response = restTemplate.getForEntity(url, String.class);
            String conditionData = response.getBody();

            if (conditionData == null || conditionData.isEmpty()) {
                log.debug("No Condition records found for patient: {}", patientId);
                return "";
            }

            return conditionData;

        } catch (HttpClientErrorException e) {
            log.error("HTTP error fetching conditions: {} - {}",
                e.getStatusCode(), e.getStatusText());
            throw new CmsApiException(
                "Failed to fetch Condition from DPC",
                CmsApiProvider.DPC,
                "condition_error",
                e.getStatusCode().value(),
                e
            );
        }
    }

    /**
     * Fallback method for getConditions
     */
    public String getConditionsFallback(String patientId, Exception e) {
        log.warn("Using fallback for getConditions({}) due to: {}", patientId, e.getMessage());
        return "";
    }

    /**
     * Get FHIR Procedure resources for a patient
     * GET /api/v1/Procedure?patient={patientId}
