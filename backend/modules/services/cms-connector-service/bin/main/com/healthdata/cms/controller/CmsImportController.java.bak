package com.healthdata.cms.controller;

import com.healthdata.cms.model.CmsClaim;
import com.healthdata.cms.scheduler.CmsDataSyncScheduler;
import com.healthdata.cms.service.CmsDataImportService;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.security.access.prepost.PreAuthorize;
import org.springframework.web.bind.annotation.*;
import org.springframework.web.multipart.MultipartFile;

import java.io.IOException;
import java.util.*;

/**
 * CMS Import Controller
 * REST API for manual claim imports and sync management
 *
 * Endpoints:
 * - POST /api/v1/imports/manual - Manual NDJSON import
 * - POST /api/v1/imports/sync/bcda - Trigger BCDA sync
 * - POST /api/v1/imports/sync/ab2d - Trigger AB2D sync
 * - POST /api/v1/imports/dpc/:patientId - Point-of-care query
 * - GET /api/v1/imports/:importId - Get import status
 */
@Slf4j
@RestController
@RequestMapping("/api/v1/imports")
public class CmsImportController {

    @Autowired
    private CmsDataImportService importService;

    @Autowired
    private CmsDataSyncScheduler syncScheduler;

    /**
     * Manual NDJSON File Import
     * POST /api/v1/imports/manual
     *
     * Accepts: multipart/form-data with:
     * - file: NDJSON file
     * - source: BCDA|DPC|AB2D
     * - tenantId: UUID
     */
    @PostMapping("/manual")
    @PreAuthorize("hasRole('CLAIMS_ADMIN')")
    public ResponseEntity<Map<String, Object>> importNdjson(
            @RequestParam("file") MultipartFile file,
            @RequestParam("source") String source,
            @RequestParam("tenantId") UUID tenantId) {

        log.info("Manual import request: source={}, tenantId={}, filename={}",
            source, tenantId, file.getOriginalFilename());

        try {
            // Validate source
            CmsClaim.ClaimSource claimSource = CmsClaim.ClaimSource.valueOf(source.toUpperCase());

            // Import claims
            CmsDataImportService.ImportResult result = importService.importFromNdjson(
                file.getInputStream(), tenantId, claimSource
            );

            // Build response
            Map<String, Object> response = new LinkedHashMap<>();
            response.put("status", result.isSuccess() ? "SUCCESS" : "PARTIAL_FAILURE");
            response.put("parsed", result.getParsedCount());
            response.put("valid", result.getValidCount());
            response.put("invalid", result.getInvalidCount());
            response.put("duplicates", result.getDuplicateCount());
            response.put("saved", result.getSuccessCount());
            response.put("failed", result.getFailureCount());
            response.put("duration_seconds", result.getDurationSeconds());
            response.put("success_rate", String.format("%.1f%%", result.getSuccessRate()));

            if (!result.isSuccess()) {
                response.put("errors", result.getErrors());
            }

            log.info("Import complete: {}", response);

            return ResponseEntity.ok(response);

        } catch (IllegalArgumentException e) {
            log.error("Invalid source: {}", source);
            return ResponseEntity.badRequest()
                    .body(Map.of("error", "Invalid source: " + source));

        } catch (IOException e) {
            log.error("File read error", e);
            return ResponseEntity.badRequest()
                    .body(Map.of("error", "File read error: " + e.getMessage()));

        } catch (Exception e) {
            log.error("Import failed", e);
            return ResponseEntity.internalServerError()
                    .body(Map.of("error", "Import failed: " + e.getMessage()));
        }
    }

    /**
     * Trigger BCDA Manual Sync
     * POST /api/v1/imports/sync/bcda
     */
    @PostMapping("/sync/bcda")
    @PreAuthorize("hasRole('SYNC_ADMIN')")
    public ResponseEntity<Map<String, Object>> triggerBcdaSync() {
        log.info("Manual BCDA sync triggered");

        try {
            long startTime = System.currentTimeMillis();

            // Run sync (normally scheduled, but callable on-demand)
            syncScheduler.syncBcdaClaimsDaily();

            long duration = System.currentTimeMillis() - startTime;

            Map<String, Object> response = new LinkedHashMap<>();
            response.put("status", "INITIATED");
            response.put("source", "BCDA");
            response.put("duration_ms", duration);
            response.put("message", "BCDA sync initiated successfully");

            return ResponseEntity.accepted().body(response);

        } catch (Exception e) {
            log.error("BCDA sync failed", e);
            return ResponseEntity.internalServerError()
                    .body(Map.of("error", "BCDA sync failed: " + e.getMessage()));
        }
    }

    /**
     * Trigger AB2D Manual Sync
     * POST /api/v1/imports/sync/ab2d
     */
    @PostMapping("/sync/ab2d")
    @PreAuthorize("hasRole('SYNC_ADMIN')")
    public ResponseEntity<Map<String, Object>> triggerAb2dSync() {
        log.info("Manual AB2D sync triggered");

        try {
            long startTime = System.currentTimeMillis();

            syncScheduler.syncAb2dClaimsDaily();

            long duration = System.currentTimeMillis() - startTime;

            Map<String, Object> response = new LinkedHashMap<>();
            response.put("status", "INITIATED");
            response.put("source", "AB2D");
            response.put("duration_ms", duration);
            response.put("message", "AB2D sync initiated successfully");

            return ResponseEntity.accepted().body(response);

        } catch (Exception e) {
            log.error("AB2D sync failed", e);
            return ResponseEntity.internalServerError()
                    .body(Map.of("error", "AB2D sync failed: " + e.getMessage()));
        }
    }

    /**
     * DPC Point-of-Care Query for Patient
     * POST /api/v1/imports/dpc/{patientId}
     *
     * Real-time query for single patient's claims
     */
    @PostMapping("/dpc/{patientId}")
    @PreAuthorize("hasRole('CLINICIAN')")
    public ResponseEntity<Map<String, Object>> queryDpcForPatient(
            @PathVariable String patientId,
            @RequestParam("tenantId") UUID tenantId) {

        log.info("DPC point-of-care query: patientId={}, tenantId={}", patientId, tenantId);

        try {
            CmsDataImportService.ImportResult result = syncScheduler.syncDpcForPatient(patientId, tenantId);

            Map<String, Object> response = new LinkedHashMap<>();
            response.put("patient_id", patientId);
            response.put("claims_found", result.getSuccessCount());
            response.put("duration_seconds", result.getDurationSeconds());

            if (result.getSuccessCount() > 0) {
                response.put("status", "SUCCESS");
            } else {
                response.put("status", "NO_CLAIMS_FOUND");
            }

            return ResponseEntity.ok(response);

        } catch (Exception e) {
            log.error("DPC query failed for patient {}", patientId, e);
            return ResponseEntity.internalServerError()
                    .body(Map.of("error", "DPC query failed: " + e.getMessage()));
        }
    }

    /**
     * Get Import Status
     * GET /api/v1/imports/{importId}
     */
    @GetMapping("/{importId}")
    @PreAuthorize("hasRole('CLAIMS_VIEWER')")
    public ResponseEntity<Map<String, Object>> getImportStatus(
            @PathVariable String importId) {

        log.debug("Getting import status: {}", importId);

        // In production, would query audit/status table
        Map<String, Object> response = new LinkedHashMap<>();
        response.put("import_id", importId);
        response.put("status", "COMPLETED");
        response.put("message", "Not yet implemented - see audit logs for status");

        return ResponseEntity.ok(response);
    }

    /**
     * Health Check for Import Service
     * GET /api/v1/imports/health
     */
    @GetMapping("/health")
    public ResponseEntity<Map<String, String>> health() {
        return ResponseEntity.ok(Map.of(
            "service", "cms-import",
            "status", "UP"
        ));
    }
}
