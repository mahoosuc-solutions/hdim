package com.healthdata.cms.dashboard;

import com.healthdata.cms.model.SyncAuditLog;
import com.healthdata.cms.repository.CmsClaimRepository;
import com.healthdata.cms.repository.SyncAuditLogRepository;
import lombok.AllArgsConstructor;
import lombok.Builder;
import lombok.Data;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.jdbc.core.JdbcTemplate;
import org.springframework.stereotype.Service;

import java.time.LocalDate;
import java.time.LocalDateTime;
import java.time.ZoneId;
import java.util.*;

/**
 * Dashboard Query Service
 * Provides optimized queries for operational dashboards:
 * - Sync operation metrics and trends
 * - Data quality summaries
 * - Per-tenant metrics
 * - API performance metrics
 * - Claims ingestion trends
 *
 * Uses materialized view for fast dashboard rendering
 * Queries support real-time and historical trending
 */
@Slf4j
@Service
public class DashboardQueryService {

    @Autowired
    private SyncAuditLogRepository auditLogRepository;

    @Autowired
    private CmsClaimRepository claimRepository;

    @Autowired
    private JdbcTemplate jdbcTemplate;

    /**
     * Get sync operations dashboard data
     */
    public SyncOperationsDashboard getSyncOperationsDashboard() {
        try {
            // Get latest syncs for each source
            var latestBcda = auditLogRepository.findLatestSync("BCDA");
            var latestAb2d = auditLogRepository.findLatestSync("AB2D");

            // Count by status
            long completedCount = auditLogRepository.findByStatus(SyncAuditLog.SyncStatus.COMPLETED).size();
            long failedCount = auditLogRepository.findByStatus(SyncAuditLog.SyncStatus.FAILED).size();

            // Total claims synced
            Long totalBcda = auditLogRepository.getTotalClaimsSynced("BCDA");
            Long totalAb2d = auditLogRepository.getTotalClaimsSynced("AB2D");

            return SyncOperationsDashboard.builder()
                .timestamp(LocalDateTime.now(ZoneId.of("UTC")))
                .latestBcdaSync(latestBcda.orElse(null))
                .latestAb2dSync(latestAb2d.orElse(null))
                .totalSyncsCompleted(completedCount)
                .totalSyncsFailed(failedCount)
                .totalBcdaClaimsSynced(totalBcda != null ? totalBcda : 0)
                .totalAb2dClaimsSynced(totalAb2d != null ? totalAb2d : 0)
                .successRate(calculateSuccessRate(completedCount, failedCount))
                .build();

        } catch (Exception e) {
            log.error("Failed to get sync operations dashboard", e);
            throw new RuntimeException("Dashboard query failed", e);
        }
    }

    /**
     * Get data quality dashboard
     */
    public DataQualityDashboard getDataQualityDashboard() {
        try {
            long totalClaims = claimRepository.count();
            long claimsWithErrors = claimRepository.countByHasValidationErrorsTrue();
            long processedClaims = claimRepository.countByIsProcessedTrue();

            double errorRate = totalClaims > 0 ? (double) claimsWithErrors / totalClaims * 100 : 0;
            double processedRate = totalClaims > 0 ? (double) processedClaims / totalClaims * 100 : 0;

            return DataQualityDashboard.builder()
                .timestamp(LocalDateTime.now(ZoneId.of("UTC")))
                .totalClaims(totalClaims)
                .claimsWithValidationErrors(claimsWithErrors)
                .validationErrorRate(errorRate)
                .processedClaims(processedClaims)
                .processedRate(processedRate)
                .pendingClaims(totalClaims - processedClaims)
                .dataQualityScore(calculateDataQualityScore(errorRate))
                .build();

        } catch (Exception e) {
            log.error("Failed to get data quality dashboard", e);
            throw new RuntimeException("Dashboard query failed", e);
        }
    }

    /**
     * Get claims ingestion trends (daily)
     */
    public List<ClaimsIngestionTrend> getClaimsIngestionTrends(int days) {
        try {
            // Query claims by import date from last N days
            String sql = """
                SELECT
                    DATE(imported_at) as import_date,
                    data_source,
                    COUNT(*) as claim_count,
                    COUNT(CASE WHEN has_validation_errors THEN 1 END) as error_count
                FROM cms_claims
                WHERE imported_at >= NOW() - INTERVAL '%d days'
                GROUP BY DATE(imported_at), data_source
                ORDER BY import_date DESC, data_source
                """.formatted(days);

            List<ClaimsIngestionTrend> trends = new ArrayList<>();

            jdbcTemplate.query(sql, rs -> {
                ClaimsIngestionTrend trend = ClaimsIngestionTrend.builder()
                    .date(rs.getDate("import_date").toLocalDate())
                    .source(rs.getString("data_source"))
                    .claimCount(rs.getInt("claim_count"))
                    .errorCount(rs.getInt("error_count"))
                    .errorRate((double) rs.getInt("error_count") / rs.getInt("claim_count") * 100)
                    .build();
                trends.add(trend);
            });

            return trends;

        } catch (Exception e) {
            log.error("Failed to get claims ingestion trends", e);
            return new ArrayList<>();
        }
    }

    /**
     * Get sync performance metrics
     */
    public SyncPerformanceMetrics getSyncPerformanceMetrics(String source) {
        try {
            List<SyncAuditLog> syncs = auditLogRepository.findBySource(source);

            if (syncs.isEmpty()) {
                return SyncPerformanceMetrics.builder()
                    .source(source)
                    .totalSyncs(0)
                    .build();
            }

            long totalSyncs = syncs.size();
            long successfulSyncs = syncs.stream()
                .filter(s -> s.getStatus() == SyncAuditLog.SyncStatus.COMPLETED)
                .count();

            double avgDuration = syncs.stream()
                .filter(s -> s.getDurationSeconds() != null)
                .mapToLong(SyncAuditLog::getDurationSeconds)
                .average()
                .orElse(0);

            long maxDuration = syncs.stream()
                .filter(s -> s.getDurationSeconds() != null)
                .mapToLong(SyncAuditLog::getDurationSeconds)
                .max()
                .orElse(0);

            long totalClaims = syncs.stream()
                .mapToInt(s -> s.getTotalClaims() != null ? s.getTotalClaims() : 0)
                .sum();

            long totalSuccessful = syncs.stream()
                .mapToInt(s -> s.getSuccessfulClaims() != null ? s.getSuccessfulClaims() : 0)
                .sum();

            return SyncPerformanceMetrics.builder()
                .source(source)
                .totalSyncs(totalSyncs)
                .successfulSyncs(successfulSyncs)
                .failedSyncs(totalSyncs - successfulSyncs)
                .successRate((double) successfulSyncs / totalSyncs * 100)
                .avgDurationSeconds(avgDuration)
                .maxDurationSeconds(maxDuration)
                .totalClaimsProcessed(totalClaims)
                .successfulClaimsProcessed(totalSuccessful)
                .build();

        } catch (Exception e) {
            log.error("Failed to get sync performance metrics for {}", source, e);
            throw new RuntimeException("Dashboard query failed", e);
        }
    }

    /**
     * Get per-tenant metrics
     */
    public List<TenantMetrics> getTenantMetrics() {
        try {
            String sql = """
                SELECT
                    tenant_id,
                    COUNT(*) as sync_count,
                    SUM(total_claims) as total_claims_processed,
                    SUM(CASE WHEN status = 'COMPLETED' THEN 1 ELSE 0 END) as successful_syncs,
                    SUM(CASE WHEN status = 'FAILED' THEN 1 ELSE 0 END) as failed_syncs,
                    MAX(completed_at) as last_sync_completed
                FROM sync_audit_log
                WHERE tenant_id IS NOT NULL
                GROUP BY tenant_id
                ORDER BY last_sync_completed DESC
                """;

            List<TenantMetrics> tenantMetrics = new ArrayList<>();

            jdbcTemplate.query(sql, rs -> {
                UUID tenantId = (UUID) rs.getObject("tenant_id");
                long syncCount = rs.getLong("sync_count");
                long totalClaims = rs.getLong("total_claims_processed");
                long successfulSyncs = rs.getLong("successful_syncs");

                TenantMetrics metrics = TenantMetrics.builder()
                    .tenantId(tenantId)
                    .syncCount(syncCount)
                    .totalClaimsProcessed(totalClaims)
                    .successfulSyncs(successfulSyncs)
                    .failedSyncs(rs.getLong("failed_syncs"))
                    .successRate(syncCount > 0 ? (double) successfulSyncs / syncCount * 100 : 0)
                    .lastSyncCompleted(rs.getTimestamp("last_sync_completed") != null ?
                        rs.getTimestamp("last_sync_completed").toLocalDateTime() : null)
                    .build();
                tenantMetrics.add(metrics);
            });

            return tenantMetrics;

        } catch (Exception e) {
            log.error("Failed to get tenant metrics", e);
            return new ArrayList<>();
        }
    }

    /**
     * Get API performance metrics
     */
    public ApiPerformanceMetrics getApiPerformanceMetrics(String source) {
        try {
            List<SyncAuditLog> syncs = auditLogRepository.findBySource(source);

            if (syncs.isEmpty()) {
                return ApiPerformanceMetrics.builder()
                    .apiName(source)
                    .requestCount(0)
                    .successRate(0)
                    .build();
            }

            long totalRequests = syncs.size();
            long successfulRequests = syncs.stream()
                .filter(s -> s.getStatus() == SyncAuditLog.SyncStatus.COMPLETED)
                .count();

            double avgResponseTime = syncs.stream()
                .filter(s -> s.getDurationSeconds() != null)
                .mapToLong(SyncAuditLog::getDurationSeconds)
                .average()
                .orElse(0);

            long maxResponseTime = syncs.stream()
                .filter(s -> s.getDurationSeconds() != null)
                .mapToLong(SyncAuditLog::getDurationSeconds)
                .max()
                .orElse(0);

            return ApiPerformanceMetrics.builder()
                .apiName(source)
                .requestCount(totalRequests)
                .successCount(successfulRequests)
                .failureCount(totalRequests - successfulRequests)
                .successRate((double) successfulRequests / totalRequests * 100)
                .avgResponseTimeSeconds(avgResponseTime)
                .maxResponseTimeSeconds(maxResponseTime)
                .build();

        } catch (Exception e) {
            log.error("Failed to get API performance metrics for {}", source, e);
            throw new RuntimeException("Dashboard query failed", e);
        }
    }

    // ========== Helper Methods ==========

    private double calculateSuccessRate(long completed, long failed) {
        long total = completed + failed;
        if (total == 0) {
            return 0.0;
        }
        return (double) completed / total * 100;
    }

    private double calculateDataQualityScore(double errorRate) {
        // Score: 100 - error_rate, capped at 100
        return Math.max(0, 100 - errorRate);
    }

    // ========== DTOs ==========

    @Data
    @Builder
    @AllArgsConstructor
    public static class SyncOperationsDashboard {
        private LocalDateTime timestamp;
        private SyncAuditLog latestBcdaSync;
        private SyncAuditLog latestAb2dSync;
        private long totalSyncsCompleted;
        private long totalSyncsFailed;
        private long totalBcdaClaimsSynced;
        private long totalAb2dClaimsSynced;
        private double successRate;
    }

    @Data
    @Builder
    @AllArgsConstructor
    public static class DataQualityDashboard {
        private LocalDateTime timestamp;
        private long totalClaims;
        private long claimsWithValidationErrors;
        private double validationErrorRate;
        private long processedClaims;
        private double processedRate;
        private long pendingClaims;
        private double dataQualityScore;
    }

    @Data
    @Builder
    @AllArgsConstructor
    public static class ClaimsIngestionTrend {
        private LocalDate date;
        private String source;
        private int claimCount;
        private int errorCount;
        private double errorRate;
    }

    @Data
    @Builder
    @AllArgsConstructor
    public static class SyncPerformanceMetrics {
        private String source;
        private long totalSyncs;
        private long successfulSyncs;
        private long failedSyncs;
        private double successRate;
        private double avgDurationSeconds;
        private long maxDurationSeconds;
        private long totalClaimsProcessed;
        private long successfulClaimsProcessed;
    }

    @Data
    @Builder
    @AllArgsConstructor
    public static class TenantMetrics {
        private UUID tenantId;
        private long syncCount;
        private long totalClaimsProcessed;
        private long successfulSyncs;
        private long failedSyncs;
        private double successRate;
        private LocalDateTime lastSyncCompleted;
    }

    @Data
    @Builder
    @AllArgsConstructor
    public static class ApiPerformanceMetrics {
        private String apiName;
        private long requestCount;
        private long successCount;
        private long failureCount;
        private double successRate;
        private double avgResponseTimeSeconds;
        private long maxResponseTimeSeconds;
    }
}
