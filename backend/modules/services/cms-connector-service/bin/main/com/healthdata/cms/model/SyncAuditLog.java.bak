package com.healthdata.cms.model;

import lombok.AllArgsConstructor;
import lombok.Data;
import lombok.NoArgsConstructor;

import jakarta.persistence.*;
import java.time.LocalDateTime;
import java.time.ZoneId;
import java.util.UUID;

/**
 * Sync Audit Log Entity
 * Tracks all CMS data sync operations for compliance and monitoring
 *
 * Maps to sync_audit_log table created in Flyway V1 migration
 */
@Entity
@Table(name = "sync_audit_log")
@Data
@NoArgsConstructor
@AllArgsConstructor
public class SyncAuditLog {

    @Id
    @Column(columnDefinition = "UUID")
    private UUID id = UUID.randomUUID();

    @Column(name = "sync_source", nullable = false)
    private String source;  // BCDA, DPC, AB2D

    @Column(name = "sync_type", nullable = false)
    private String type;  // BULK_EXPORT, POINT_OF_CARE, MANUAL

    @Column(name = "sync_status", nullable = false)
    @Enumerated(EnumType.STRING)
    private SyncStatus status;

    @Column(name = "tenant_id")
    private UUID tenantId;

    @Column(name = "total_claims")
    private Integer totalClaims = 0;

    @Column(name = "successful_claims")
    private Integer successfulClaims = 0;

    @Column(name = "failed_claims")
    private Integer failedClaims = 0;

    @Column(name = "duplicate_claims")
    private Integer duplicateClaims = 0;

    @Column(name = "error_message", columnDefinition = "TEXT")
    private String errorMessage;

    @Column(name = "started_at", nullable = false)
    private LocalDateTime startedAt;

    @Column(name = "completed_at")
    private LocalDateTime completedAt;

    @Column(name = "duration_seconds")
    private Long durationSeconds;

    @Column(name = "export_id")
    private String exportId;  // BCDA/AB2D export ID for tracking

    @Column(name = "created_by")
    private String createdBy;

    @Column(name = "created_at")
    private LocalDateTime createdAt = LocalDateTime.now(ZoneId.of("UTC"));

    public enum SyncStatus {
        INITIATED, IN_PROGRESS, COMPLETED, FAILED
    }

    public enum SyncType {
        BULK_EXPORT, POINT_OF_CARE, MANUAL
    }

    public enum SyncSource {
        BCDA, DPC, AB2D
    }
}
