package com.healthdata.cms.scheduler;

import com.healthdata.cms.client.BcdaClient;
import com.healthdata.cms.client.DpcClient;
import com.healthdata.cms.model.CmsClaim;
import com.healthdata.cms.service.CmsDataImportService;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.scheduling.annotation.Scheduled;
import org.springframework.stereotype.Service;

import java.io.ByteArrayInputStream;
import java.io.InputStream;
import java.nio.charset.StandardCharsets;
import java.time.LocalDateTime;
import java.time.ZoneId;
import java.util.*;
import java.util.concurrent.CompletableFuture;

/**
 * CMS Data Sync Scheduler
 * Orchestrates scheduled data imports from CMS APIs:
 * - BCDA: Daily bulk Medicare claims export
 * - DPC: Point-of-care (on-demand only)
 * - AB2D: Daily Part D (Prescription) claims export
 *
 * Features:
 * - Scheduled execution via @Scheduled
 * - Tenant-aware multi-tenant imports
 * - Audit logging of all imports
 * - Error handling and retry logic
 * - Progress tracking and reporting
 */
@Slf4j
@Service
public class CmsDataSyncScheduler {

    @Autowired
    private BcdaClient bcdaClient;

    @Autowired
    private DpcClient dpcClient;

    @Autowired
    private CmsDataImportService importService;

    @Autowired
    private SyncAuditService auditService;

    @Value("${scheduling.bcda-sync.enabled:false}")
    private boolean bcdaSyncEnabled;

    @Value("${scheduling.bcda-sync.batch-size:1000}")
    private int bcdaBatchSize;

    @Value("${scheduling.ab2d-sync.enabled:false}")
    private boolean ab2dSyncEnabled;

    @Value("${scheduling.ab2d-sync.batch-size:500}")
    private int ab2dBatchSize;

    /**
     * BCDA Daily Sync: Scheduled daily at configured time
     * Downloads bulk Medicare claims export from BCDA
     * Default: 2 AM UTC
     */
    @Scheduled(cron = "${scheduling.bcda-sync.cron:0 0 2 * * ?}")
    public void syncBcdaClaimsDaily() {
        if (!bcdaSyncEnabled) {
            log.debug("BCDA sync disabled, skipping");
            return;
        }

        log.info("Starting BCDA daily sync");
        LocalDateTime syncStart = LocalDateTime.now(ZoneId.of("UTC"));

        try {
            // Request new bulk export from BCDA
            log.info("Requesting bulk export from BCDA");
            var exportRequest = new BcdaClient.BulkDataExportRequest();
            exportRequest.setOutputFormat("ndjson");

            var exportResponse = bcdaClient.requestBulkDataExport(exportRequest);
            String exportId = exportResponse.getExportId();
            log.info("BCDA export requested: {}", exportId);

            // Poll for export completion
            boolean exportReady = waitForExportCompletion(exportId, 120); // 2 hour timeout
            if (!exportReady) {
                log.error("BCDA export {} did not complete in time", exportId);
                auditService.recordFailure("BCDA", "Export timeout after 120 minutes", syncStart);
                return;
            }

            // Download and import all claims from export
            log.info("Export {} ready, downloading claims", exportId);
            List<String> filePaths = bcdaClient.getExportFilePaths(exportId);
            log.info("Export contains {} files", filePaths.size());

            int totalClaims = 0;
            int successfulClaims = 0;

            for (String filePath : filePaths) {
                try {
                    // Download file from BCDA
                    String fileContent = bcdaClient.downloadFile(filePath);
                    InputStream inputStream = new ByteArrayInputStream(
                        fileContent.getBytes(StandardCharsets.UTF_8)
                    );

                    // Import to database
                    UUID systemTenantId = getOrCreateSystemTenant("BCDA");
                    CmsDataImportService.ImportResult result = importService.importFromNdjson(
                        inputStream, systemTenantId, CmsClaim.ClaimSource.BCDA
                    );

                    totalClaims += result.getParsedCount();
                    successfulClaims += result.getSuccessCount();

                    log.info("File {} imported: {} claims, {} successful",
                        filePath, result.getParsedCount(), result.getSuccessCount());

                } catch (Exception e) {
                    log.error("Error processing BCDA file {}", filePath, e);
                }
            }

            // Record audit log
            log.info("BCDA sync complete: {} total claims, {} successful",
                totalClaims, successfulClaims);
            auditService.recordSuccess("BCDA", totalClaims, successfulClaims, syncStart);

        } catch (Exception e) {
            log.error("BCDA daily sync failed", e);
            auditService.recordFailure("BCDA", e.getMessage(), syncStart);
        }
    }

    /**
     * AB2D Daily Sync: Scheduled daily for Part D claims
     * Default: 3 AM UTC
     */
    @Scheduled(cron = "${scheduling.ab2d-sync.cron:0 0 3 * * ?}")
    public void syncAb2dClaimsDaily() {
        if (!ab2dSyncEnabled) {
            log.debug("AB2D sync disabled, skipping");
            return;
        }

        log.info("Starting AB2D daily sync");
        LocalDateTime syncStart = LocalDateTime.now(ZoneId.of("UTC"));

        try {
            UUID systemTenantId = getOrCreateSystemTenant("AB2D");

            // AB2D export request (similar to BCDA)
            log.info("Requesting bulk export from AB2D");
            var exportRequest = new BcdaClient.BulkDataExportRequest();
            exportRequest.setOutputFormat("ndjson");

            // Note: This uses BcdaClient as placeholder; in production would use AB2DClient
            var exportResponse = bcdaClient.requestBulkDataExport(exportRequest);
            String exportId = exportResponse.getExportId();

            boolean exportReady = waitForExportCompletion(exportId, 90);
            if (!exportReady) {
                log.error("AB2D export {} did not complete", exportId);
                auditService.recordFailure("AB2D", "Export timeout", syncStart);
                return;
            }

            // Download and import
            List<String> filePaths = bcdaClient.getExportFilePaths(exportId);
            int totalClaims = 0;
            int successfulClaims = 0;

            for (String filePath : filePaths) {
                try {
                    String fileContent = bcdaClient.downloadFile(filePath);
                    InputStream inputStream = new ByteArrayInputStream(
                        fileContent.getBytes(StandardCharsets.UTF_8)
                    );

                    // AB2D claims are Part D, but imported as regular claims with type marker
                    CmsDataImportService.ImportResult result = importService.importFromNdjson(
                        inputStream, systemTenantId, CmsClaim.ClaimSource.AB2D
                    );

                    totalClaims += result.getParsedCount();
                    successfulClaims += result.getSuccessCount();

                } catch (Exception e) {
                    log.error("Error processing AB2D file {}", filePath, e);
                }
            }

            log.info("AB2D sync complete: {} total claims, {} successful",
                totalClaims, successfulClaims);
            auditService.recordSuccess("AB2D", totalClaims, successfulClaims, syncStart);

        } catch (Exception e) {
            log.error("AB2D daily sync failed", e);
            auditService.recordFailure("AB2D", e.getMessage(), syncStart);
        }
    }

    /**
     * On-Demand DPC Point-of-Care Query
     * Called by controllers for real-time patient data lookup
     */
    public CmsDataImportService.ImportResult syncDpcForPatient(String patientId, UUID tenantId) {
        log.info("Starting DPC sync for patient: {}", patientId);

        try {
            // Query DPC for patient's claims
            String eobData = dpcClient.getExplanationOfBenefits(patientId);

            if (eobData == null || eobData.isEmpty()) {
                log.warn("No EOB data found for patient {}", patientId);
                return new CmsDataImportService.ImportResult();
            }

            // Import directly (single patient, likely small dataset)
            InputStream inputStream = new ByteArrayInputStream(
                eobData.getBytes(StandardCharsets.UTF_8)
            );

            return importService.importFromNdjson(
                inputStream, tenantId, CmsClaim.ClaimSource.DPC
            );

        } catch (Exception e) {
            log.error("DPC sync failed for patient {}", patientId, e);
            return new CmsDataImportService.ImportResult();
        }
    }

    /**
     * Wait for bulk export to complete
     * Polls export status until ready or timeout
     */
    private boolean waitForExportCompletion(String exportId, int timeoutMinutes) {
        LocalDateTime deadline = LocalDateTime.now(ZoneId.of("UTC")).plusMinutes(timeoutMinutes);

        while (LocalDateTime.now(ZoneId.of("UTC")).isBefore(deadline)) {
            try {
                var status = bcdaClient.getExportStatus(exportId);
                log.debug("Export {} status: {}", exportId, status);

                if ("completed".equalsIgnoreCase(status.toString())) {
                    return true;
                }

                if ("failed".equalsIgnoreCase(status.toString())) {
                    log.error("Export {} failed", exportId);
                    return false;
                }

                // Wait 30 seconds before next poll
                Thread.sleep(30000);

            } catch (Exception e) {
                log.warn("Error checking export status", e);
                // Continue polling
            }
        }

        return false;
    }

    /**
     * Get or create system tenant for CMS imports
     * Each CMS API has a dedicated tenant for system-wide imports
     */
    private UUID getOrCreateSystemTenant(String source) {
        // In production, this would:
        // 1. Check if system tenant exists for source
        // 2. Create if not
        // 3. Return tenant ID
        // For now, return a static UUID per source
        return UUID.nameUUIDFromBytes(("system-" + source).getBytes());
    }
}

/**
 * Audit service for tracking sync operations
 */
@Service
@Slf4j
class SyncAuditService {

    public void recordSuccess(String source, int totalClaims, int successfulClaims, LocalDateTime startTime) {
        long duration = java.time.temporal.ChronoUnit.SECONDS.between(
            startTime, LocalDateTime.now(ZoneId.of("UTC"))
        );

        log.info("SYNC_AUDIT: source={}, total={}, success={}, duration_seconds={}",
            source, totalClaims, successfulClaims, duration);

        // In production, persist to audit table
    }

    public void recordFailure(String source, String error, LocalDateTime startTime) {
        long duration = java.time.temporal.ChronoUnit.SECONDS.between(
            startTime, LocalDateTime.now(ZoneId.of("UTC"))
        );

        log.error("SYNC_AUDIT: source={}, error={}, duration_seconds={}",
            source, error, duration);

        // In production, persist to audit table
    }
}
