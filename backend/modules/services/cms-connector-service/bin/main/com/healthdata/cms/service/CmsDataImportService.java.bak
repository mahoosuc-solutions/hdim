package com.healthdata.cms.service;

import com.healthdata.cms.dedup.DeduplicationService;
import com.healthdata.cms.model.CmsClaim;
import com.healthdata.cms.parser.FhirBundleParser;
import com.healthdata.cms.repository.CmsClaimRepository;
import com.healthdata.cms.validation.ClaimValidator;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.io.InputStream;
import java.time.LocalDateTime;
import java.time.ZoneId;
import java.util.*;
import java.util.stream.Collectors;

/**
 * CMS Data Import Service
 *
 * Orchestrates the complete import pipeline:
 * 1. Parse NDJSON from CMS API
 * 2. Validate claims (20+ rules)
 * 3. Deduplicate (3 strategies)
 * 4. Persist to PostgreSQL
 * 5. Report results
 *
 * Features:
 * - Transactional processing
 * - Batch import with rollback support
 * - Comprehensive reporting (success, failures, warnings)
 * - Idempotent operations (safe re-runs)
 * - Real-time progress tracking
 */
@Slf4j
@Service
public class CmsDataImportService {

    private final FhirBundleParser fhirBundleParser;
    private final ClaimValidator claimValidator;
    private final DeduplicationService deduplicationService;
    private final CmsClaimRepository claimRepository;

    public CmsDataImportService(
            FhirBundleParser fhirBundleParser,
            ClaimValidator claimValidator,
            DeduplicationService deduplicationService,
            CmsClaimRepository claimRepository) {
        this.fhirBundleParser = fhirBundleParser;
        this.claimValidator = claimValidator;
        this.deduplicationService = deduplicationService;
        this.claimRepository = claimRepository;
    }

    /**
     * Import claims from NDJSON file (BCDA bulk export)
     *
     * @param inputStream NDJSON file stream
     * @param tenantId    Tenant for multi-tenancy
     * @param dataSource  Source of claims (BCDA, DPC, AB2D)
     * @return ImportResult with detailed statistics
     */
    @Transactional
    public ImportResult importFromNdjson(InputStream inputStream, UUID tenantId, CmsClaim.ClaimSource dataSource) {
        log.info("Starting NDJSON import for tenant: {}. Source: {}", tenantId, dataSource.getDisplayName());

        ImportResult result = new ImportResult();
        result.setStartTime(LocalDateTime.now(ZoneId.of("UTC")));
        result.setTenantId(tenantId);
        result.setDataSource(dataSource);

        try {
            // STEP 1: Parse NDJSON file
            log.info("STEP 1: Parsing NDJSON file...");
            List<CmsClaim> parsedClaims = fhirBundleParser.parseNdjsonStream(inputStream, tenantId, dataSource);
            result.setParsedCount(parsedClaims.size());
            log.info("Parsed {} claims from NDJSON", parsedClaims.size());

            if (parsedClaims.isEmpty()) {
                log.warn("No claims found in NDJSON file");
                result.setEndTime(LocalDateTime.now(ZoneId.of("UTC")));
                return result;
            }

            // STEP 2: Validate claims
            log.info("STEP 2: Validating {} claims...", parsedClaims.size());
            Map<String, ClaimValidator.ValidationResult> validationResults = claimValidator.validateBatch(parsedClaims);

            int validCount = (int) validationResults.values().stream()
                    .filter(v -> !v.hasErrors())
                    .count();
            result.setValidCount(validCount);
            result.setInvalidCount(parsedClaims.size() - validCount);

            log.info("Validation complete. Valid: {}. Invalid: {}", validCount, result.getInvalidCount());

            // STEP 3: Deduplicate
            log.info("STEP 3: Checking for duplicates...");
            List<CmsClaim> uniqueClaims = new ArrayList<>();
            int duplicateCount = 0;

            for (CmsClaim claim : parsedClaims) {
                DeduplicationService.DuplicateCheckResult dupResult =
                        deduplicationService.checkForDuplicates(claim, uniqueClaims, tenantId);

                if (dupResult.isDuplicate()) {
                    duplicateCount++;
                    result.addDuplicate(claim.getClaimId(), dupResult.getHighestConfidenceDuplicate());
                    log.debug("Claim {} is duplicate: {}", claim.getClaimId(), dupResult.getSummary());
                } else {
                    uniqueClaims.add(claim);
                }
            }

            result.setDuplicateCount(duplicateCount);
            log.info("Deduplication complete. Unique: {}. Duplicates: {}", uniqueClaims.size(), duplicateCount);

            // STEP 4: Persist to database
            log.info("STEP 4: Persisting {} claims to database...", uniqueClaims.size());
            int successCount = 0;
            int failureCount = 0;

            for (CmsClaim claim : uniqueClaims) {
                try {
                    CmsClaim saved = claimRepository.save(claim);
                    successCount++;
                    deduplicationService.markProcessed(saved);
                } catch (Exception e) {
                    failureCount++;
                    result.addError(claim.getClaimId(), "Database save failed: " + e.getMessage());
                    log.error("Failed to save claim {}", claim.getClaimId(), e);
                }
            }

            result.setSuccessCount(successCount);
            result.setFailureCount(failureCount);
            log.info("Database persistence complete. Success: {}. Failures: {}", successCount, failureCount);

            // STEP 5: Generate final report
            result.setEndTime(LocalDateTime.now(ZoneId.of("UTC")));
            logImportSummary(result);

            return result;

        } catch (Exception e) {
            log.error("Critical error during import", e);
            result.setError(e.getMessage());
            result.setEndTime(LocalDateTime.now(ZoneId.of("UTC")));
            return result;
        }
    }

    /**
     * Log import summary
     */
    private void logImportSummary(ImportResult result) {
        log.info("========== IMPORT SUMMARY ==========");
        log.info("Tenant: {}", result.getTenantId());
        log.info("Data Source: {}", result.getDataSource().getDisplayName());
        log.info("Duration: {} seconds", result.getDurationSeconds());
        log.info("");
        log.info("PARSING:");
        log.info("  Parsed: {}", result.getParsedCount());
        log.info("");
        log.info("VALIDATION:");
        log.info("  Valid: {}", result.getValidCount());
        log.info("  Invalid: {}", result.getInvalidCount());
        log.info("");
        log.info("DEDUPLICATION:");
        log.info("  Unique: {}", result.getSuccessCount() + result.getFailureCount());
        log.info("  Duplicates: {}", result.getDuplicateCount());
        log.info("");
        log.info("PERSISTENCE:");
        log.info("  Saved: {}", result.getSuccessCount());
        log.info("  Failed: {}", result.getFailureCount());
        log.info("");
        log.info("OVERALL: {} claims successfully imported", result.getSuccessCount());
        log.info("====================================");
    }

    /**
     * Import result summary
     */
    public static class ImportResult {
        private UUID tenantId;
        private CmsClaim.ClaimSource dataSource;
        private LocalDateTime startTime;
        private LocalDateTime endTime;

        private int parsedCount;
        private int validCount;
        private int invalidCount;
        private int duplicateCount;
        private int successCount;
        private int failureCount;

        private final Map<String, String> errors = new HashMap<>();
        private final Map<String, DeduplicationService.DuplicateMatch> duplicates = new HashMap<>();
        private String error;

        // Getters
        public UUID getTenantId() { return tenantId; }
        public CmsClaim.ClaimSource getDataSource() { return dataSource; }
        public LocalDateTime getStartTime() { return startTime; }
        public LocalDateTime getEndTime() { return endTime; }
        public int getParsedCount() { return parsedCount; }
        public int getValidCount() { return validCount; }
        public int getInvalidCount() { return invalidCount; }
        public int getDuplicateCount() { return duplicateCount; }
        public int getSuccessCount() { return successCount; }
        public int getFailureCount() { return failureCount; }
        public Map<String, String> getErrors() { return errors; }
        public Map<String, DeduplicationService.DuplicateMatch> getDuplicates() { return duplicates; }
        public String getError() { return error; }

        // Setters
        public void setTenantId(UUID tenantId) { this.tenantId = tenantId; }
        public void setDataSource(CmsClaim.ClaimSource dataSource) { this.dataSource = dataSource; }
        public void setStartTime(LocalDateTime startTime) { this.startTime = startTime; }
        public void setEndTime(LocalDateTime endTime) { this.endTime = endTime; }
        public void setParsedCount(int parsedCount) { this.parsedCount = parsedCount; }
        public void setValidCount(int validCount) { this.validCount = validCount; }
        public void setInvalidCount(int invalidCount) { this.invalidCount = invalidCount; }
        public void setDuplicateCount(int duplicateCount) { this.duplicateCount = duplicateCount; }
        public void setSuccessCount(int successCount) { this.successCount = successCount; }
        public void setFailureCount(int failureCount) { this.failureCount = failureCount; }
        public void setError(String error) { this.error = error; }

        public void addError(String claimId, String errorMessage) {
            errors.put(claimId, errorMessage);
        }

        public void addDuplicate(String claimId, DeduplicationService.DuplicateMatch match) {
            duplicates.put(claimId, match);
        }

        /**
         * Get duration in seconds
         */
        public long getDurationSeconds() {
            if (startTime != null && endTime != null) {
                return java.time.temporal.ChronoUnit.SECONDS.between(startTime, endTime);
            }
            return 0;
        }

        /**
         * Was import successful?
         */
        public boolean isSuccess() {
            return error == null && failureCount == 0;
        }

        /**
         * Get success rate percentage
         */
        public double getSuccessRate() {
            int total = validCount + invalidCount;
            if (total == 0) return 0.0;
            return (double) successCount / total * 100;
        }

        /**
         * Get detailed summary
         */
        public String getSummary() {
            StringBuilder sb = new StringBuilder();
            sb.append("Import Result Summary\n");
            sb.append("=====================\n");
            sb.append(String.format("Tenant: %s\n", tenantId));
            sb.append(String.format("Source: %s\n", dataSource.getDisplayName()));
            sb.append(String.format("Duration: %d seconds\n\n", getDurationSeconds()));

            sb.append("Statistics:\n");
            sb.append(String.format("  Parsed:    %d\n", parsedCount));
            sb.append(String.format("  Valid:     %d\n", validCount));
            sb.append(String.format("  Invalid:   %d\n", invalidCount));
            sb.append(String.format("  Unique:    %d\n", duplicateCount == 0 ? parsedCount : parsedCount - duplicateCount));
            sb.append(String.format("  Duplicates: %d\n", duplicateCount));
            sb.append(String.format("  Saved:     %d\n", successCount));
            sb.append(String.format("  Failed:    %d\n", failureCount));
            sb.append(String.format("  Success Rate: %.1f%%\n", getSuccessRate()));

            if (error != null) {
                sb.append(String.format("\nError: %s\n", error));
            }

            return sb.toString();
        }
    }
}
