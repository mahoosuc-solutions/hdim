package com.healthdata.cms.dedup;

import com.fasterxml.jackson.databind.JsonNode;
import com.healthdata.cms.model.CmsClaim;
import com.healthdata.cms.repository.CmsClaimRepository;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Service;

import java.nio.charset.StandardCharsets;
import java.security.MessageDigest;
import java.security.NoSuchAlgorithmException;
import java.util.*;
import java.util.stream.Collectors;

/**
 * Deduplication Service for CMS Claims
 *
 * Detects duplicate claims using multiple strategies:
 * - Content hash (SHA-256 of FHIR resource)
 * - Claim ID matching (exact, within same data source)
 * - Beneficiary + Service Date matching
 *
 * Features:
 * - Fast hash-based detection
 * - Database lookup for existing duplicates
 * - Detailed duplicate reporting
 * - Configurable sensitivity levels
 */
@Slf4j
@Service
public class DeduplicationService {

    private final CmsClaimRepository claimRepository;
    private final MessageDigest messageDigest;

    public DeduplicationService(CmsClaimRepository claimRepository) throws NoSuchAlgorithmException {
        this.claimRepository = claimRepository;
        this.messageDigest = MessageDigest.getInstance("SHA-256");
    }

    /**
     * Generate content hash for a claim's FHIR resource
     * Used for exact duplicate detection
     *
     * @param claim Claim with FHIR resource
     * @return SHA-256 hash as hex string
     */
    public String generateContentHash(CmsClaim claim) {
        if (claim.getFhirResource() == null) {
            return null;
        }

        try {
            String jsonString = claim.getFhirResource().toString();
            byte[] hash = messageDigest.digest(jsonString.getBytes(StandardCharsets.UTF_8));
            return bytesToHex(hash);
        } catch (Exception e) {
            log.warn("Error generating content hash for claim {}", claim.getClaimId(), e);
            return null;
        }
    }

    /**
     * Check if claim is duplicate (various strategies)
     *
     * @param claim Claim to check
     * @param existingClaims Previously imported claims in this batch
     * @param tenantId Tenant context
     * @return DuplicateCheckResult with findings
     */
    public DuplicateCheckResult checkForDuplicates(CmsClaim claim, List<CmsClaim> existingClaims, UUID tenantId) {
        DuplicateCheckResult result = new DuplicateCheckResult(claim.getClaimId());

        log.debug("Checking for duplicates: {}", claim.getClaimId());

        // STRATEGY 1: Exact claim ID match (within same source)
        checkClaimIdDuplicates(claim, existingClaims, result);

        // STRATEGY 2: Content hash match (exact duplicate)
        checkContentHashDuplicates(claim, tenantId, result);

        // STRATEGY 3: Beneficiary + Service Date match (possible duplicate)
        checkBeneficiaryDateDuplicates(claim, existingClaims, result);

        if (!result.getDuplicates().isEmpty()) {
            log.warn("Claim {} identified as potential duplicate. Count: {}",
                    claim.getClaimId(), result.getDuplicates().size());
        }

        return result;
    }

    /**
     * STRATEGY 1: Check for exact claim ID duplicates
     * Same claim ID from same source = definite duplicate
     */
    private void checkClaimIdDuplicates(CmsClaim claim, List<CmsClaim> batchClaims, DuplicateCheckResult result) {
        // Check within batch
        batchClaims.stream()
                .filter(c -> !c.getId().equals(claim.getId())) // Don't compare to itself
                .filter(c -> claim.getClaimId().equals(c.getClaimId()))
                .filter(c -> claim.getDataSource() == c.getDataSource()) // Same source
                .forEach(c -> {
                    result.addDuplicate(
                            new DuplicateMatch(
                                    c.getClaimId(),
                                    DuplicateStrategy.EXACT_CLAIM_ID,
                                    "Exact claim ID match within batch",
                                    1.0 // 100% confidence
                            )
                    );
                });

        // Check against database (same tenant, same source, same claim ID)
        try {
            List<CmsClaim> dbMatches = claimRepository.findByTenantIdAndDataSource(
                    claim.getTenantId(), claim.getDataSource()
            ).stream()
                    .filter(c -> claim.getClaimId().equals(c.getClaimId()))
                    .collect(Collectors.toList());

            dbMatches.forEach(c -> {
                result.addDuplicate(
                        new DuplicateMatch(
                                c.getClaimId(),
                                DuplicateStrategy.EXACT_CLAIM_ID,
                                "Exact claim ID already in database (imported at: " + c.getImportedAt() + ")",
                                1.0
                        )
                );
            });
        } catch (Exception e) {
            log.warn("Error checking database for claim ID duplicates", e);
        }
    }

    /**
     * STRATEGY 2: Check for content hash duplicates
     * Same FHIR resource content = exact duplicate
     */
    private void checkContentHashDuplicates(CmsClaim claim, UUID tenantId, DuplicateCheckResult result) {
        String hash = generateContentHash(claim);
        if (hash == null) {
            return;
        }

        claim.setContentHash(hash);

        try {
            List<CmsClaim> hashMatches = claimRepository.findByTenantIdAndContentHash(tenantId, hash);

            hashMatches.forEach(c -> {
                if (!c.getId().equals(claim.getId())) { // Don't compare to itself
                    result.addDuplicate(
                            new DuplicateMatch(
                                    c.getClaimId(),
                                    DuplicateStrategy.CONTENT_HASH,
                                    "Identical FHIR resource content (SHA-256 match)",
                                    1.0
                            )
                    );
                }
            });
        } catch (Exception e) {
            log.warn("Error checking database for content hash duplicates", e);
        }
    }

    /**
     * STRATEGY 3: Check for beneficiary + service date duplicates
     * Same beneficiary + same service period = likely duplicate (lower confidence)
     */
    private void checkBeneficiaryDateDuplicates(CmsClaim claim, List<CmsClaim> batchClaims, DuplicateCheckResult result) {
        if (claim.getBeneficiaryId() == null || claim.getServiceStartDate() == null) {
            return;
        }

        // Check within batch
        batchClaims.stream()
                .filter(c -> !c.getId().equals(claim.getId()))
                .filter(c -> claim.getBeneficiaryId().equals(c.getBeneficiaryId()))
                .filter(c -> claim.getServiceStartDate().equals(c.getServiceStartDate()))
                .filter(c -> !claim.getClaimId().equals(c.getClaimId())) // Different claim IDs
                .forEach(c -> {
                    result.addDuplicate(
                            new DuplicateMatch(
                                    c.getClaimId(),
                                    DuplicateStrategy.BENEFICIARY_DATE,
                                    "Same beneficiary and service date (possible re-submission)",
                                    0.7 // 70% confidence
                            )
                    );
                });
    }

    /**
     * Mark claim as processed/deduplicated
     */
    public void markProcessed(CmsClaim claim) {
        claim.setIsProcessed(true);
    }

    /**
     * Convert byte array to hex string
     */
    private String bytesToHex(byte[] bytes) {
        StringBuilder sb = new StringBuilder();
        for (byte b : bytes) {
            sb.append(String.format("%02x", b));
        }
        return sb.toString();
    }

    /**
     * Deduplication result for a single claim
     */
    public static class DuplicateCheckResult {
        private final String claimId;
        private final List<DuplicateMatch> duplicates = new ArrayList<>();

        public DuplicateCheckResult(String claimId) {
            this.claimId = claimId;
        }

        public void addDuplicate(DuplicateMatch match) {
            duplicates.add(match);
        }

        public String getClaimId() { return claimId; }
        public List<DuplicateMatch> getDuplicates() { return duplicates; }
        public boolean isDuplicate() { return !duplicates.isEmpty(); }

        /**
         * Get highest confidence duplicate
         */
        public DuplicateMatch getHighestConfidenceDuplicate() {
            return duplicates.stream()
                    .max(Comparator.comparingDouble(DuplicateMatch::getConfidence))
                    .orElse(null);
        }

        /**
         * Get all high-confidence duplicates (>80%)
         */
        public List<DuplicateMatch> getHighConfidenceDuplicates() {
            return duplicates.stream()
                    .filter(d -> d.getConfidence() >= 0.8)
                    .collect(Collectors.toList());
        }

        public String getSummary() {
            if (duplicates.isEmpty()) {
                return "No duplicates found";
            }

            return String.format("Found %d potential duplicate(s):\n%s",
                    duplicates.size(),
                    duplicates.stream()
                            .map(d -> String.format("  - %s (confidence: %.0f%%)", d.getReason(), d.getConfidence() * 100))
                            .collect(Collectors.joining("\n"))
            );
        }
    }

    /**
     * Individual duplicate match
     */
    public static class DuplicateMatch {
        private final String matchingClaimId;
        private final DuplicateStrategy strategy;
        private final String reason;
        private final double confidence; // 0.0 to 1.0

        public DuplicateMatch(String matchingClaimId, DuplicateStrategy strategy, String reason, double confidence) {
            this.matchingClaimId = matchingClaimId;
            this.strategy = strategy;
            this.reason = reason;
            this.confidence = Math.min(1.0, Math.max(0.0, confidence));
        }

        public String getMatchingClaimId() { return matchingClaimId; }
        public DuplicateStrategy getStrategy() { return strategy; }
        public String getReason() { return reason; }
        public double getConfidence() { return confidence; }
    }

    /**
     * Deduplication strategies
     */
    public enum DuplicateStrategy {
        EXACT_CLAIM_ID("Exact claim ID", "Same claim ID from same source"),
        CONTENT_HASH("Content hash", "Identical FHIR resource (SHA-256)"),
        BENEFICIARY_DATE("Beneficiary + Date", "Same beneficiary and service date"),
        UNKNOWN("Unknown", "Unknown deduplication strategy");

        private final String name;
        private final String description;

        DuplicateStrategy(String name, String description) {
            this.name = name;
            this.description = description;
        }

        public String getName() { return name; }
        public String getDescription() { return description; }
    }
}
