package com.healthdata.cms.metrics;

import io.micrometer.core.instrument.*;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import java.time.Duration;
import java.time.LocalDateTime;
import java.time.ZoneId;
import java.util.concurrent.atomic.AtomicInteger;

/**
 * CMS Sync Metrics Service
 * Provides Prometheus metrics for CMS sync operations:
 * - Sync operation counts (total, successful, failed)
 * - Claim import metrics (total, success rate, duration)
 * - API response times (BCDA, DPC, AB2D)
 * - Data quality metrics (validation errors, deduplication)
 *
 * Metrics exported via /actuator/prometheus
 * Used for dashboards, alerts, and SLA monitoring
 */
@Slf4j
@Service
public class CmsSyncMetricsService {

    private final MeterRegistry meterRegistry;

    // Counters
    private final AtomicInteger totalSyncsInitiated = new AtomicInteger(0);
    private final AtomicInteger totalSyncsCompleted = new AtomicInteger(0);
    private final AtomicInteger totalSyncsFailed = new AtomicInteger(0);
    private final AtomicInteger totalClaimsImported = new AtomicInteger(0);
    private final AtomicInteger totalClaimsValidationErrors = new AtomicInteger(0);
    private final AtomicInteger totalDuplicatesDetected = new AtomicInteger(0);

    // Timers
    private Timer bcdaSyncDurationTimer;
    private Timer ab2dSyncDurationTimer;
    private Timer dpcQueryDurationTimer;
    private Timer claimValidationDurationTimer;

    // Gauges
    private AtomicInteger activesyncsCount;

    @Autowired
    public CmsSyncMetricsService(MeterRegistry meterRegistry) {
        this.meterRegistry = meterRegistry;
        initializeMetrics();
    }

    /**
     * Initialize all metrics
     */
    private void initializeMetrics() {
        // Counters
        meterRegistry.counter("cms.sync.initiated.total", "source", "all")
            .increment(0);
        meterRegistry.counter("cms.sync.completed.total", "source", "all")
            .increment(0);
        meterRegistry.counter("cms.sync.failed.total", "source", "all")
            .increment(0);

        // Claim metrics
        meterRegistry.counter("cms.claims.imported.total")
            .increment(0);
        meterRegistry.counter("cms.claims.validation.errors.total")
            .increment(0);
        meterRegistry.counter("cms.claims.duplicates.detected.total")
            .increment(0);

        // Timers
        bcdaSyncDurationTimer = Timer.builder("cms.sync.duration")
            .description("BCDA sync operation duration")
            .tag("source", "BCDA")
            .publishPercentiles(0.5, 0.95, 0.99)
            .register(meterRegistry);

        ab2dSyncDurationTimer = Timer.builder("cms.sync.duration")
            .description("AB2D sync operation duration")
            .tag("source", "AB2D")
            .publishPercentiles(0.5, 0.95, 0.99)
            .register(meterRegistry);

        dpcQueryDurationTimer = Timer.builder("cms.sync.duration")
            .description("DPC point-of-care query duration")
            .tag("source", "DPC")
            .publishPercentiles(0.5, 0.95, 0.99)
            .register(meterRegistry);

        claimValidationDurationTimer = Timer.builder("cms.claim.validation.duration")
            .description("Claim validation operation duration")
            .publishPercentiles(0.5, 0.95, 0.99)
            .register(meterRegistry);

        // Gauges
        activesyncsCount = meterRegistry.gauge("cms.sync.active.count",
            new AtomicInteger(0));

        log.info("CMS metrics initialized");
    }

    /**
     * Record BCDA sync initiation
     */
    public void recordBcdaSyncInitiated() {
        meterRegistry.counter("cms.sync.initiated.total", "source", "BCDA").increment();
        totalSyncsInitiated.incrementAndGet();
        activesyncsCount.incrementAndGet();
        log.debug("BCDA sync initiated - active: {}", activesyncsCount.get());
    }

    /**
     * Record BCDA sync completion with claims count and duration
     */
    public void recordBcdaSyncCompleted(int claimsImported, int claimsWithErrors, long durationMs) {
        meterRegistry.counter("cms.sync.completed.total", "source", "BCDA").increment();
        meterRegistry.counter("cms.claims.imported.total").increment(claimsImported);
        if (claimsWithErrors > 0) {
            meterRegistry.counter("cms.claims.validation.errors.total").increment(claimsWithErrors);
        }

        bcdaSyncDurationTimer.record(Duration.ofMillis(durationMs));

        totalSyncsCompleted.incrementAndGet();
        totalClaimsImported.addAndGet(claimsImported);
        totalClaimsValidationErrors.addAndGet(claimsWithErrors);
        activesyncsCount.decrementAndGet();

        log.info("BCDA sync completed: {} claims in {} ms", claimsImported, durationMs);
    }

    /**
     * Record BCDA sync failure
     */
    public void recordBcdaSyncFailed(String errorMessage, long durationMs) {
        meterRegistry.counter("cms.sync.failed.total", "source", "BCDA").increment();
        bcdaSyncDurationTimer.record(Duration.ofMillis(durationMs));

        totalSyncsFailed.incrementAndGet();
        activesyncsCount.decrementAndGet();

        log.warn("BCDA sync failed after {} ms: {}", durationMs, errorMessage);
    }

    /**
     * Record AB2D sync initiation
     */
    public void recordAb2dSyncInitiated() {
        meterRegistry.counter("cms.sync.initiated.total", "source", "AB2D").increment();
        totalSyncsInitiated.incrementAndGet();
        activesyncsCount.incrementAndGet();
    }

    /**
     * Record AB2D sync completion
     */
    public void recordAb2dSyncCompleted(int claimsImported, int claimsWithErrors, long durationMs) {
        meterRegistry.counter("cms.sync.completed.total", "source", "AB2D").increment();
        meterRegistry.counter("cms.claims.imported.total").increment(claimsImported);
        if (claimsWithErrors > 0) {
            meterRegistry.counter("cms.claims.validation.errors.total").increment(claimsWithErrors);
        }

        ab2dSyncDurationTimer.record(Duration.ofMillis(durationMs));

        totalSyncsCompleted.incrementAndGet();
        totalClaimsImported.addAndGet(claimsImported);
        totalClaimsValidationErrors.addAndGet(claimsWithErrors);
        activesyncsCount.decrementAndGet();

        log.info("AB2D sync completed: {} claims in {} ms", claimsImported, durationMs);
    }

    /**
     * Record AB2D sync failure
     */
    public void recordAb2dSyncFailed(String errorMessage, long durationMs) {
        meterRegistry.counter("cms.sync.failed.total", "source", "AB2D").increment();
        ab2dSyncDurationTimer.record(Duration.ofMillis(durationMs));

        totalSyncsFailed.incrementAndGet();
        activesyncsCount.decrementAndGet();

        log.warn("AB2D sync failed after {} ms: {}", durationMs, errorMessage);
    }

    /**
     * Record DPC point-of-care query
     */
    public void recordDpcQuery(int claimsRetrieved, long durationMs) {
        meterRegistry.counter("cms.sync.initiated.total", "source", "DPC").increment();
        meterRegistry.counter("cms.sync.completed.total", "source", "DPC").increment();
        meterRegistry.counter("cms.claims.imported.total").increment(claimsRetrieved);

        dpcQueryDurationTimer.record(Duration.ofMillis(durationMs));

        totalClaimsImported.addAndGet(claimsRetrieved);

        log.debug("DPC query completed: {} claims in {} ms", claimsRetrieved, durationMs);
    }

    /**
     * Record DPC query failure
     */
    public void recordDpcQueryFailed(String errorMessage, long durationMs) {
        meterRegistry.counter("cms.sync.failed.total", "source", "DPC").increment();
        dpcQueryDurationTimer.record(Duration.ofMillis(durationMs));

        totalSyncsFailed.incrementAndGet();

        log.warn("DPC query failed after {} ms: {}", durationMs, errorMessage);
    }

    /**
     * Record claim validation
     */
    public void recordClaimValidation(int totalClaims, int errorCount, long durationMs) {
        claimValidationDurationTimer.record(Duration.ofMillis(durationMs));

        if (errorCount > 0) {
            meterRegistry.counter("cms.claims.validation.errors.total").increment(errorCount);
            totalClaimsValidationErrors.addAndGet(errorCount);
        }

        log.debug("Validated {} claims in {} ms: {} errors", totalClaims, durationMs, errorCount);
    }

    /**
     * Record deduplication detection
     */
    public void recordDuplicateDetected(int count) {
        meterRegistry.counter("cms.claims.duplicates.detected.total").increment(count);
        totalDuplicatesDetected.addAndGet(count);

        log.debug("Detected {} duplicate claims", count);
    }

    /**
     * Get current metrics snapshot
     */
    public MetricsSnapshot getCurrentSnapshot() {
        return MetricsSnapshot.builder()
            .timestamp(LocalDateTime.now(ZoneId.of("UTC")))
            .totalSyncsInitiated(totalSyncsInitiated.get())
            .totalSyncsCompleted(totalSyncsCompleted.get())
            .totalSyncsFailed(totalSyncsFailed.get())
            .activeSyncs(activesyncsCount.get())
            .totalClaimsImported(totalClaimsImported.get())
            .totalClaimsValidationErrors(totalClaimsValidationErrors.get())
            .totalDuplicatesDetected(totalDuplicatesDetected.get())
            .successRate(calculateSuccessRate())
            .build();
    }

    /**
     * Calculate success rate
     */
    private double calculateSuccessRate() {
        int total = totalSyncsInitiated.get();
        if (total == 0) {
            return 0.0;
        }
        return (double) totalSyncsCompleted.get() / total * 100;
    }

    /**
     * Metrics snapshot DTO
     */
    @lombok.Data
    @lombok.Builder
    public static class MetricsSnapshot {
        private LocalDateTime timestamp;
        private int totalSyncsInitiated;
        private int totalSyncsCompleted;
        private int totalSyncsFailed;
        private int activeSyncs;
        private int totalClaimsImported;
        private int totalClaimsValidationErrors;
        private int totalDuplicatesDetected;
        private double successRate;
    }
}
