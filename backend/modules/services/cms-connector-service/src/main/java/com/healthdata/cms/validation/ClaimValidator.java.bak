package com.healthdata.cms.validation;

import com.fasterxml.jackson.databind.JsonNode;
import com.healthdata.cms.model.CmsClaim;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Component;

import java.time.LocalDateTime;
import java.time.ZoneId;
import java.util.*;
import java.util.regex.Pattern;
import java.util.stream.Collectors;

/**
 * Claim Data Quality Validator
 *
 * Validates CMS Medicare claims for data quality issues:
 * - Required field presence
 * - Data type correctness
 * - Value range validation
 * - Logical consistency
 * - FHIR compliance
 *
 * Features:
 * - 20+ validation rules
 * - Non-blocking validation (collects all errors)
 * - Severity levels (ERROR, WARNING, INFO)
 * - Detailed error messages with field paths
 */
@Slf4j
@Component
public class ClaimValidator {

    private static final Pattern VALID_UUID = Pattern.compile(
            "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$", Pattern.CASE_INSENSITIVE);
    private static final Pattern VALID_BENEFICIARY_ID = Pattern.compile("^[A-Z0-9]{5,20}$");

    /**
     * Validate a single claim
     *
     * @param claim Claim to validate
     * @return ValidationResult with all errors found
     */
    public ValidationResult validate(CmsClaim claim) {
        ValidationResult result = new ValidationResult();

        log.debug("Validating claim: {}", claim.getClaimId());

        // Required field validations
        validateRequiredFields(claim, result);

        // Data type validations
        validateDataTypes(claim, result);

        // Value range validations
        validateValueRanges(claim, result);

        // Logical consistency validations
        validateLogicalConsistency(claim, result);

        // FHIR compliance validations
        validateFhirCompliance(claim, result);

        // Update claim with validation results
        if (!result.getErrors().isEmpty()) {
            claim.setHasValidationErrors(true);
            claim.setValidationErrors(result.getErrorsSummary());
            log.warn("Claim {} has {} validation errors", claim.getClaimId(), result.getErrors().size());
        } else {
            claim.setHasValidationErrors(false);
            log.debug("Claim {} passed all validations", claim.getClaimId());
        }

        return result;
    }

    /**
     * Validate batch of claims
     */
    public Map<String, ValidationResult> validateBatch(List<CmsClaim> claims) {
        log.info("Validating {} claims", claims.size());

        Map<String, ValidationResult> results = new HashMap<>();
        int errorCount = 0;

        for (CmsClaim claim : claims) {
            ValidationResult result = validate(claim);
            results.put(claim.getClaimId(), result);
            if (!result.getErrors().isEmpty()) {
                errorCount++;
            }
        }

        log.info("Batch validation complete. {} claims with errors", errorCount);
        return results;
    }

    /**
     * RULE 1-5: Required field validations
     */
    private void validateRequiredFields(CmsClaim claim, ValidationResult result) {
        // RULE 1: Claim ID must exist
        if (claim.getClaimId() == null || claim.getClaimId().trim().isEmpty()) {
            result.addError("claimId", "Claim ID is required", Severity.ERROR);
        }

        // RULE 2: Beneficiary ID must exist
        if (claim.getBeneficiaryId() == null || claim.getBeneficiaryId().trim().isEmpty()) {
            result.addError("beneficiaryId", "Beneficiary ID is required", Severity.ERROR);
        }

        // RULE 3: Tenant ID must exist
        if (claim.getTenantId() == null) {
            result.addError("tenantId", "Tenant ID is required", Severity.ERROR);
        }

        // RULE 4: FHIR resource must exist
        if (claim.getFhirResource() == null) {
            result.addError("fhirResource", "FHIR resource is required", Severity.ERROR);
        }

        // RULE 5: Data source must exist
        if (claim.getDataSource() == null) {
            result.addError("dataSource", "Data source is required", Severity.ERROR);
        }
    }

    /**
     * RULE 6-10: Data type validations
     */
    private void validateDataTypes(CmsClaim claim, ValidationResult result) {
        // RULE 6: Claim ID format
        if (claim.getClaimId() != null && claim.getClaimId().length() > 100) {
            result.addError("claimId", "Claim ID exceeds maximum length (100 chars)", Severity.WARNING);
        }

        // RULE 7: Beneficiary ID format
        if (claim.getBeneficiaryId() != null && !VALID_BENEFICIARY_ID.matcher(claim.getBeneficiaryId()).matches()) {
            result.addWarning("beneficiaryId", "Beneficiary ID format suspicious: " + claim.getBeneficiaryId());
        }

        // RULE 8: Tenant ID UUID format
        if (claim.getTenantId() != null && !VALID_UUID.matcher(claim.getTenantId().toString()).matches()) {
            result.addError("tenantId", "Invalid tenant ID format (not UUID)", Severity.ERROR);
        }

        // RULE 9: Amount fields must be non-negative
        if (claim.getClaimAmount() != null && claim.getClaimAmount() < 0) {
            result.addError("claimAmount", "Claim amount cannot be negative: " + claim.getClaimAmount(), Severity.ERROR);
        }

        if (claim.getPaidAmount() != null && claim.getPaidAmount() < 0) {
            result.addError("paidAmount", "Paid amount cannot be negative: " + claim.getPaidAmount(), Severity.ERROR);
        }

        // RULE 10: Allowed amount must be non-negative
        if (claim.getAllowedAmount() != null && claim.getAllowedAmount() < 0) {
            result.addError("allowedAmount", "Allowed amount cannot be negative", Severity.ERROR);
        }
    }

    /**
     * RULE 11-15: Value range validations
     */
    private void validateValueRanges(CmsClaim claim, ValidationResult result) {
        // RULE 11: Claim amount reasonable range (0 to $1M)
        if (claim.getClaimAmount() != null && claim.getClaimAmount() > 1_000_000) {
            result.addWarning("claimAmount", "Unusually high claim amount: $" + claim.getClaimAmount());
        }

        // RULE 12: Paid amount <= allowed amount
        if (claim.getPaidAmount() != null && claim.getAllowedAmount() != null
                && claim.getPaidAmount() > claim.getAllowedAmount()) {
            result.addWarning("amounts",
                "Paid amount (" + claim.getPaidAmount() + ") exceeds allowed amount (" + claim.getAllowedAmount() + ")");
        }

        // RULE 13: Allowed amount <= claim amount
        if (claim.getClaimAmount() != null && claim.getAllowedAmount() != null
                && claim.getAllowedAmount() > claim.getClaimAmount()) {
            result.addWarning("amounts",
                "Allowed amount (" + claim.getAllowedAmount() + ") exceeds claim amount (" + claim.getClaimAmount() + ")");
        }

        // RULE 14: Service dates not in future
        LocalDateTime now = LocalDateTime.now(ZoneId.of("UTC"));
        if (claim.getServiceStartDate() != null && claim.getServiceStartDate().isAfter(now)) {
            result.addWarning("serviceStartDate", "Service start date is in the future");
        }

        // RULE 15: Service end date >= start date
        if (claim.getServiceStartDate() != null && claim.getServiceEndDate() != null
                && claim.getServiceEndDate().isBefore(claim.getServiceStartDate())) {
            result.addError("serviceEndDate",
                "Service end date before start date", Severity.ERROR);
        }
    }

    /**
     * RULE 16-18: Logical consistency validations
     */
    private void validateLogicalConsistency(CmsClaim claim, ValidationResult result) {
        // RULE 16: Imported date not in future
        if (claim.getImportedAt() != null) {
            LocalDateTime now = LocalDateTime.now(ZoneId.of("UTC"));
            if (claim.getImportedAt().isAfter(now)) {
                result.addError("importedAt", "Import date is in the future", Severity.ERROR);
            }
        }

        // RULE 17: At least one amount field present
        if ((claim.getClaimAmount() == null || claim.getClaimAmount() == 0)
                && (claim.getPaidAmount() == null || claim.getPaidAmount() == 0)
                && (claim.getAllowedAmount() == null || claim.getAllowedAmount() == 0)) {
            result.addWarning("amounts", "No claim amounts found (all zero or null)");
        }

        // RULE 18: Claim date consistency
        if (claim.getClaimDate() != null && claim.getServiceStartDate() != null
                && claim.getClaimDate().isBefore(claim.getServiceStartDate())) {
            result.addWarning("dates", "Claim date before service start date");
        }
    }

    /**
     * RULE 19-20: FHIR compliance validations
     */
    private void validateFhirCompliance(CmsClaim claim, ValidationResult result) {
        if (claim.getFhirResource() == null) {
            return;
        }

        JsonNode eob = claim.getFhirResource();

        // RULE 19: Valid FHIR resourceType
        String resourceType = eob.path("resourceType").asText();
        if (!resourceType.equals("ExplanationOfBenefit")) {
            result.addError("fhirResource.resourceType",
                "Invalid FHIR resource type: " + resourceType + " (expected ExplanationOfBenefit)", Severity.ERROR);
        }

        // RULE 20: Required FHIR fields
        if (!eob.has("id") || eob.path("id").asText().isEmpty()) {
            result.addWarning("fhirResource.id", "FHIR resource missing id field");
        }

        if (!eob.has("patient")) {
            result.addError("fhirResource.patient", "FHIR ExplanationOfBenefit missing patient reference", Severity.ERROR);
        }

        if (!eob.has("status") || eob.path("status").asText().isEmpty()) {
            result.addWarning("fhirResource.status", "FHIR resource missing status field");
        }
    }

    /**
     * Validation result class
     */
    public static class ValidationResult {
        private final List<ValidationError> errors = new ArrayList<>();

        public void addError(String field, String message, Severity severity) {
            errors.add(new ValidationError(field, message, severity));
        }

        public void addWarning(String field, String message) {
            errors.add(new ValidationError(field, message, Severity.WARNING));
        }

        public List<ValidationError> getErrors() {
            return errors;
        }

        public List<ValidationError> getErrorsByField(String field) {
            return errors.stream()
                    .filter(e -> e.getField().equals(field))
                    .collect(Collectors.toList());
        }

        public boolean hasErrors() {
            return !errors.isEmpty();
        }

        public int getErrorCount() {
            return (int) errors.stream()
                    .filter(e -> e.getSeverity() == Severity.ERROR)
                    .count();
        }

        public int getWarningCount() {
            return (int) errors.stream()
                    .filter(e -> e.getSeverity() == Severity.WARNING)
                    .count();
        }

        public String getErrorsSummary() {
            return errors.stream()
                    .map(e -> e.getField() + ": " + e.getMessage())
                    .collect(Collectors.joining("; "));
        }

        public String getDetailedSummary() {
            return errors.stream()
                    .map(e -> String.format("[%s] %s: %s", e.getSeverity(), e.getField(), e.getMessage()))
                    .collect(Collectors.joining("\n"));
        }
    }

    /**
     * Individual validation error
     */
    public static class ValidationError {
        private final String field;
        private final String message;
        private final Severity severity;

        public ValidationError(String field, String message, Severity severity) {
            this.field = field;
            this.message = message;
            this.severity = severity;
        }

        public String getField() { return field; }
        public String getMessage() { return message; }
        public Severity getSeverity() { return severity; }
    }

    /**
     * Error severity levels
     */
    public enum Severity {
        ERROR("Error - blocks import"),
        WARNING("Warning - flags for review"),
        INFO("Info - for logging");

        private final String description;

        Severity(String description) {
            this.description = description;
        }

        public String getDescription() { return description; }
    }
}
