<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="0001-create-synthetic-id-mappings" author="hdim-platform">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="synthetic_id_mappings"/></not>
        </preConditions>

        <createTable tableName="synthetic_id_mappings">
            <column name="id" type="UUID">
                <constraints primaryKey="true"/>
            </column>
            <column name="tenant_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="real_entity_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="synthetic_entity_id" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="entity_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="synthetic_id_mappings" indexName="idx_synthetic_mappings_real">
            <column name="tenant_id"/>
            <column name="real_entity_id"/>
        </createIndex>

        <createIndex tableName="synthetic_id_mappings" indexName="idx_synthetic_mappings_synthetic">
            <column name="synthetic_entity_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="synthetic_id_mappings"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
