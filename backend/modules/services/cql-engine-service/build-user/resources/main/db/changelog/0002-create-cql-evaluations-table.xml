<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0002-create-cql-evaluations-table" author="healthdata-system">
        <comment>Create table for storing CQL evaluation results and history</comment>

        <createTable tableName="cql_evaluations">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="library_id" type="uuid">
                <constraints nullable="false"
                            foreignKeyName="fk_cql_evaluation_library"
                            references="cql_libraries(id)"/>
            </column>
            <column name="patient_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="measure_name" type="varchar(255)">
                <constraints nullable="true"/>
            </column>
            <column name="evaluation_date" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="result" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="duration_ms" type="bigint">
                <constraints nullable="true"/>
            </column>
            <column name="error_message" type="text">
                <constraints nullable="true"/>
            </column>
            <column name="context_data" type="text">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <createIndex indexName="idx_cql_eval_tenant_patient" tableName="cql_evaluations">
            <column name="tenant_id"/>
            <column name="patient_id"/>
        </createIndex>

        <createIndex indexName="idx_cql_eval_library" tableName="cql_evaluations">
            <column name="library_id"/>
        </createIndex>

        <createIndex indexName="idx_cql_eval_date" tableName="cql_evaluations">
            <column name="evaluation_date" descending="true"/>
        </createIndex>

        <createIndex indexName="idx_cql_eval_measure" tableName="cql_evaluations">
            <column name="measure_name"/>
        </createIndex>

        <rollback>
            <dropTable tableName="cql_evaluations"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
