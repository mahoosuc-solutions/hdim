<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0006-fix-cql-libraries-schema-alignment" author="healthdata-system">
        <comment>Fix CqlLibrary entity-schema misalignments identified in Phase 17 audit</comment>

        <!-- Issue 1: Add missing library_name column -->
        <addColumn tableName="cql_libraries">
            <column name="library_name" type="varchar(255)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <!-- Copy existing name values to library_name for existing records -->
        <sql>
            UPDATE cql_libraries SET library_name = name WHERE library_name IS NULL;
        </sql>

        <!-- Now make it NOT NULL -->
        <addNotNullConstraint tableName="cql_libraries" columnName="library_name" columnDataType="varchar(255)"/>

        <!-- Issue 2: Rename compiled_elm to elm_json -->
        <renameColumn tableName="cql_libraries"
                      oldColumnName="compiled_elm"
                      newColumnName="elm_json"
                      columnDataType="text"/>

        <!-- Issue 3: Add elm_xml column -->
        <addColumn tableName="cql_libraries">
            <column name="elm_xml" type="text">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <!-- Issue 4: Add fhir_library_id column -->
        <addColumn tableName="cql_libraries">
            <column name="fhir_library_id" type="uuid">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <!-- Issue 5: Add active column -->
        <addColumn tableName="cql_libraries">
            <column name="active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <!-- Issue 6: Update version column length from 50 to 32 -->
        <modifyDataType tableName="cql_libraries"
                        columnName="version"
                        newDataType="varchar(32)"/>

        <!-- Issue 7: Update created_by column length from 128 to 64 -->
        <modifyDataType tableName="cql_libraries"
                        columnName="created_by"
                        newDataType="varchar(64)"/>

        <!-- Issue 8: Add missing composite index on library_name, version -->
        <createIndex indexName="idx_library_name_version" tableName="cql_libraries">
            <column name="library_name"/>
            <column name="version"/>
        </createIndex>

        <!-- Add index on active for filtering -->
        <createIndex indexName="idx_cql_libraries_active" tableName="cql_libraries">
            <column name="active"/>
        </createIndex>

        <rollback>
            <dropIndex indexName="idx_cql_libraries_active" tableName="cql_libraries"/>
            <dropIndex indexName="idx_library_name_version" tableName="cql_libraries"/>
            <modifyDataType tableName="cql_libraries" columnName="created_by" newDataType="varchar(128)"/>
            <modifyDataType tableName="cql_libraries" columnName="version" newDataType="varchar(50)"/>
            <dropColumn tableName="cql_libraries" columnName="active"/>
            <dropColumn tableName="cql_libraries" columnName="fhir_library_id"/>
            <dropColumn tableName="cql_libraries" columnName="elm_xml"/>
            <renameColumn tableName="cql_libraries" oldColumnName="elm_json" newColumnName="compiled_elm" columnDataType="text"/>
            <dropColumn tableName="cql_libraries" columnName="library_name"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
