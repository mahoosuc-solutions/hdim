            <column name="tenant_id" value="acme-health"/>
            <column name="oid" value="2.16.840.1.113883.3.464.1003.108.12.1018"/>
            <column name="name" value="Mammography Procedures"/>
            <column name="version" value="2024"/>
            <column name="code_system" value="LOINC"/>
            <column name="codes" value='["24606-6", "24604-1", "37768-7", "37551-7", "42174-9"]'/>
            <column name="description" value="LOINC codes for mammography studies used in breast cancer screening"/>
            <column name="publisher" value="NCQA"/>
