<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="0002-create-demo-sessions-table" author="demo-seeding-service">
        <comment>Create demo_sessions table for tracking demo sessions</comment>

        <createTable tableName="demo_sessions">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="scenario_id" type="UUID">
                <constraints foreignKeyName="fk_demo_sessions_scenario"
                             references="demo_scenarios(id)"/>
            </column>
            <column name="session_name" type="VARCHAR(255)"/>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="started_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="last_reset_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="ended_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="session_state" type="JSONB"/>
            <column name="performance_metrics" type="JSONB"/>
            <column name="snapshot_id" type="UUID"/>
            <column name="created_by" type="VARCHAR(255)"/>
        </createTable>

        <createIndex tableName="demo_sessions" indexName="idx_demo_sessions_scenario">
            <column name="scenario_id"/>
        </createIndex>

        <createIndex tableName="demo_sessions" indexName="idx_demo_sessions_status">
            <column name="status"/>
        </createIndex>

        <createIndex tableName="demo_sessions" indexName="idx_demo_sessions_started">
            <column name="started_at" descending="true"/>
        </createIndex>

        <rollback>
            <dropTable tableName="demo_sessions"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
