<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0001-create-document-metadata-table" author="agent-5">
        <comment>Create document metadata table for documentation portal system</comment>

        <createTable tableName="document_metadata">
            <!-- Core Identifiers -->
            <column name="id" type="VARCHAR(100)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="portal_type" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="path" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>

            <!-- Organization -->
            <column name="category" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="subcategory" type="VARCHAR(50)">
                <constraints nullable="true"/>
            </column>
            <column name="tags" type="TEXT[]">
                <constraints nullable="false"/>
            </column>
            <column name="related_documents" type="TEXT[]" defaultValueComputed="ARRAY[]::text[]">
                <constraints nullable="false"/>
            </column>

            <!-- Content Description -->
            <column name="summary" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="estimated_read_time" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="difficulty" type="VARCHAR(20)">
                <constraints nullable="true"/>
            </column>
            <column name="last_updated" type="DATE">
                <constraints nullable="false"/>
            </column>

            <!-- Access & Governance -->
            <column name="target_audience" type="TEXT[]">
                <constraints nullable="false"/>
            </column>
            <column name="access_level" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="owner" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="review_cycle" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="next_review_date" type="DATE">
                <constraints nullable="false"/>
            </column>

            <!-- Status & Versioning -->
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="last_reviewed" type="DATE">
                <constraints nullable="false"/>
            </column>

            <!-- SEO & Discovery -->
            <column name="seo_keywords" type="TEXT[]">
                <constraints nullable="true"/>
            </column>
            <column name="external_links" type="JSONB">
                <constraints nullable="true"/>
            </column>
            <column name="has_video" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="video_url" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>

            <!-- Content Metrics -->
            <column name="word_count" type="INTEGER">
                <constraints nullable="true"/>
            </column>
            <column name="created_date" type="DATE">
                <constraints nullable="true"/>
            </column>
            <column name="view_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="avg_rating" type="DECIMAL(2,1)">
                <constraints nullable="true"/>
            </column>
            <column name="feedback_count" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <!-- Multi-tenancy -->
            <column name="tenant_id" type="VARCHAR(100)" defaultValue="default">
                <constraints nullable="false"/>
            </column>

            <!-- Audit fields -->
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Check constraints -->
        <sql>
            ALTER TABLE document_metadata
            ADD CONSTRAINT check_portal_type CHECK (portal_type IN ('product', 'user', 'sales'));

            ALTER TABLE document_metadata
            ADD CONSTRAINT check_difficulty CHECK (difficulty IS NULL OR difficulty IN ('beginner', 'intermediate', 'advanced'));

            ALTER TABLE document_metadata
            ADD CONSTRAINT check_access_level CHECK (access_level IN ('public', 'internal', 'restricted'));

            ALTER TABLE document_metadata
            ADD CONSTRAINT check_review_cycle CHECK (review_cycle IN ('monthly', 'quarterly', 'semi-annual', 'annual'));

            ALTER TABLE document_metadata
            ADD CONSTRAINT check_status CHECK (status IN ('draft', 'published', 'archived'));

            ALTER TABLE document_metadata
            ADD CONSTRAINT check_dates CHECK (last_updated &lt;= CURRENT_DATE AND next_review_date &gt; CURRENT_DATE);

            ALTER TABLE document_metadata
            ADD CONSTRAINT check_video_url CHECK (NOT has_video OR video_url IS NOT NULL);

            ALTER TABLE document_metadata
            ADD CONSTRAINT check_tags_count CHECK (array_length(tags, 1) &gt;= 3 AND array_length(tags, 1) &lt;= 10);

            ALTER TABLE document_metadata
            ADD CONSTRAINT check_audience_count CHECK (array_length(target_audience, 1) &gt;= 1 AND array_length(target_audience, 1) &lt;= 5);

            ALTER TABLE document_metadata
            ADD CONSTRAINT check_avg_rating CHECK (avg_rating IS NULL OR (avg_rating &gt;= 1.0 AND avg_rating &lt;= 5.0));

            ALTER TABLE document_metadata
            ADD CONSTRAINT check_estimated_read_time CHECK (estimated_read_time &gt; 0);
        </sql>

        <!-- Indexes for performance -->
        <createIndex indexName="idx_document_portal_type" tableName="document_metadata">
            <column name="portal_type"/>
        </createIndex>

        <createIndex indexName="idx_document_category" tableName="document_metadata">
            <column name="category"/>
        </createIndex>

        <createIndex indexName="idx_document_status" tableName="document_metadata">
            <column name="status"/>
        </createIndex>

        <createIndex indexName="idx_document_tenant" tableName="document_metadata">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_document_next_review_date" tableName="document_metadata">
            <column name="next_review_date"/>
        </createIndex>

        <createIndex indexName="idx_document_view_count" tableName="document_metadata">
            <column name="view_count"/>
        </createIndex>

        <createIndex indexName="idx_document_avg_rating" tableName="document_metadata">
            <column name="avg_rating"/>
        </createIndex>

        <!-- GIN indexes for array fields -->
        <sql>
            CREATE INDEX idx_document_tags ON document_metadata USING GIN(tags);
            CREATE INDEX idx_document_target_audience ON document_metadata USING GIN(target_audience);
        </sql>

        <!-- Full-text search index -->
        <sql>
            CREATE INDEX idx_document_fulltext ON document_metadata USING GIN(
                to_tsvector('english', title || ' ' || summary)
            );
        </sql>

        <rollback>
            <dropTable tableName="document_metadata"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
