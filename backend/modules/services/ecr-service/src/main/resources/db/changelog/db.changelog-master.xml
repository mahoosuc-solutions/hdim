<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-ecr-schema" author="hdim">
        <preConditions onFail="MARK_RAN">
            <not>
                <schemaExists schemaName="ecr"/>
            </not>
        </preConditions>
        <sql>CREATE SCHEMA IF NOT EXISTS ecr;</sql>
    </changeSet>

    <!-- Electronic Case Reports Table -->
    <changeSet id="002-create-electronic-case-reports" author="hdim">
        <createTable tableName="electronic_case_reports" schemaName="ecr">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="encounter_id" type="UUID"/>

            <!-- Trigger Information -->
            <column name="trigger_code" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="trigger_code_system" type="VARCHAR(64)"/>
            <column name="trigger_display" type="VARCHAR(500)"/>
            <column name="trigger_category" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="condition_name" type="VARCHAR(255)"/>

            <!-- Status and Urgency -->
            <column name="status" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="urgency" type="VARCHAR(32)"/>

            <!-- eICR Data -->
            <column name="eicr_bundle_json" type="JSONB"/>

            <!-- Reportability Response -->
            <column name="rr_status" type="VARCHAR(64)"/>
            <column name="rr_response_json" type="JSONB"/>

            <!-- AIMS Integration -->
            <column name="aims_tracking_id" type="VARCHAR(255)"/>
            <column name="jurisdiction" type="VARCHAR(128)"/>

            <!-- Error Handling -->
            <column name="error_message" type="TEXT"/>
            <column name="retry_count" type="INTEGER"/>
            <column name="next_retry_at" type="TIMESTAMP"/>

            <!-- Timestamps -->
            <column name="trigger_detected_at" type="TIMESTAMP"/>
            <column name="eicr_generated_at" type="TIMESTAMP"/>
            <column name="submitted_at" type="TIMESTAMP"/>
            <column name="rr_received_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Indexes for Electronic Case Reports -->
        <createIndex tableName="electronic_case_reports" schemaName="ecr"
            indexName="idx_ecr_tenant_patient">
            <column name="tenant_id"/>
            <column name="patient_id"/>
        </createIndex>

        <createIndex tableName="electronic_case_reports" schemaName="ecr"
            indexName="idx_ecr_tenant_status">
            <column name="tenant_id"/>
            <column name="status"/>
        </createIndex>

        <createIndex tableName="electronic_case_reports" schemaName="ecr"
            indexName="idx_ecr_aims_tracking">
            <column name="aims_tracking_id"/>
        </createIndex>

        <createIndex tableName="electronic_case_reports" schemaName="ecr"
            indexName="idx_ecr_urgency_status">
            <column name="urgency"/>
            <column name="status"/>
        </createIndex>
    </changeSet>

    <!-- RCTC Trigger Codes Table -->
    <changeSet id="003-create-rctc-trigger-codes" author="hdim">
        <createTable tableName="rctc_trigger_codes" schemaName="ecr">
            <column name="code" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="code_system" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="display" type="VARCHAR(500)"/>
            <column name="trigger_type" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="condition_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="value_set_oid" type="VARCHAR(128)"/>
            <column name="value_set_name" type="VARCHAR(255)"/>
            <column name="urgency" type="VARCHAR(32)"/>
            <column name="is_active" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="rctc_version" type="VARCHAR(32)"/>
            <column name="effective_date" type="DATE"/>
            <column name="retirement_date" type="DATE"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Composite primary key -->
        <addPrimaryKey tableName="rctc_trigger_codes" schemaName="ecr"
            columnNames="code, code_system"
            constraintName="pk_rctc_trigger_codes"/>

        <!-- Indexes for RCTC Trigger Codes -->
        <createIndex tableName="rctc_trigger_codes" schemaName="ecr"
            indexName="idx_rctc_code_system">
            <column name="code_system"/>
        </createIndex>

        <createIndex tableName="rctc_trigger_codes" schemaName="ecr"
            indexName="idx_rctc_condition">
            <column name="condition_name"/>
        </createIndex>

        <createIndex tableName="rctc_trigger_codes" schemaName="ecr"
            indexName="idx_rctc_active">
            <column name="is_active"/>
        </createIndex>
    </changeSet>

    <!-- Table Comments -->
    <changeSet id="004-add-table-comments" author="hdim">
        <sql>
            COMMENT ON TABLE ecr.electronic_case_reports IS
                'Electronic Case Reports (eCR) for public health surveillance';
            COMMENT ON TABLE ecr.rctc_trigger_codes IS
                'CDC RCTC (Reportable Condition Trigger Codes) value sets for eCR detection';
        </sql>
    </changeSet>

