<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0003-create-dead-letter-queue-table" author="healthdata-system">
        <comment>Create dead letter queue table for failed event processing</comment>

        <createTable tableName="dead_letter_queue">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="event_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="subscription_id" type="uuid">
                <constraints nullable="true"/>
            </column>
            <column name="topic" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="event_type" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="varchar(100)">
                <constraints nullable="true"/>
            </column>
            <column name="event_payload" type="jsonb">
                <constraints nullable="true"/>
            </column>
            <column name="error_message" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="stack_trace" type="text">
                <constraints nullable="true"/>
            </column>
            <column name="retry_count" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="max_retry_count" type="integer" defaultValueNumeric="3">
                <constraints nullable="false"/>
            </column>
            <column name="first_failure_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_retry_at" type="timestamp with time zone">
                <constraints nullable="true"/>
            </column>
            <column name="next_retry_at" type="timestamp with time zone">
                <constraints nullable="true"/>
            </column>
            <column name="status" type="varchar(20)" defaultValue="FAILED">
                <constraints nullable="false"/>
            </column>
            <column name="resolved_at" type="timestamp with time zone">
                <constraints nullable="true"/>
            </column>
            <column name="resolved_by" type="varchar(128)">
                <constraints nullable="true"/>
            </column>
            <column name="resolution_notes" type="text">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <createIndex indexName="idx_dlq_event" tableName="dead_letter_queue">
            <column name="event_id"/>
        </createIndex>

        <createIndex indexName="idx_dlq_status" tableName="dead_letter_queue">
            <column name="status"/>
            <column name="first_failure_at" descending="true"/>
        </createIndex>

        <createIndex indexName="idx_dlq_tenant" tableName="dead_letter_queue">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_dlq_patient" tableName="dead_letter_queue">
            <column name="patient_id"/>
        </createIndex>

        <createIndex indexName="idx_dlq_retry_eligible" tableName="dead_letter_queue">
            <column name="status"/>
            <column name="next_retry_at"/>
        </createIndex>

        <createIndex indexName="idx_dlq_topic" tableName="dead_letter_queue">
            <column name="topic"/>
            <column name="event_type"/>
        </createIndex>

        <rollback>
            <dropTable tableName="dead_letter_queue"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
