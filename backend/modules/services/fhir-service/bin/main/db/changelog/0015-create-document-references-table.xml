<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0015-create-document-references-table" author="hdim">
        <comment>Create document_references table for FHIR DocumentReference resources</comment>

        <createTable tableName="document_references">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="resource_json" type="JSONB">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="encounter_id" type="UUID">
                <constraints nullable="true"/>
            </column>
            <column name="status" type="VARCHAR(32)">
                <constraints nullable="true"/>
            </column>
            <column name="doc_status" type="VARCHAR(32)">
                <constraints nullable="true"/>
            </column>
            <column name="type_code" type="VARCHAR(64)">
                <constraints nullable="true"/>
            </column>
            <column name="type_system" type="VARCHAR(128)">
                <constraints nullable="true"/>
            </column>
            <column name="type_display" type="VARCHAR(256)">
                <constraints nullable="true"/>
            </column>
            <column name="category_code" type="VARCHAR(64)">
                <constraints nullable="true"/>
            </column>
            <column name="category_display" type="VARCHAR(256)">
                <constraints nullable="true"/>
            </column>
            <column name="created_date" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="true"/>
            </column>
            <column name="indexed_date" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="true"/>
            </column>
            <column name="description" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="security_labels" type="VARCHAR(256)">
                <constraints nullable="true"/>
            </column>
            <column name="content_type" type="VARCHAR(64)">
                <constraints nullable="true"/>
            </column>
            <column name="content_url" type="VARCHAR(512)">
                <constraints nullable="true"/>
            </column>
            <column name="content_size" type="BIGINT">
                <constraints nullable="true"/>
            </column>
            <column name="content_hash" type="VARCHAR(128)">
                <constraints nullable="true"/>
            </column>
            <column name="author_reference" type="VARCHAR(128)">
                <constraints nullable="true"/>
            </column>
            <column name="custodian_reference" type="VARCHAR(128)">
                <constraints nullable="true"/>
            </column>
            <column name="relates_to_code" type="VARCHAR(32)">
                <constraints nullable="true"/>
            </column>
            <column name="relates_to_target" type="VARCHAR(128)">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(128)">
                <constraints nullable="true"/>
            </column>
            <column name="last_modified_by" type="VARCHAR(128)">
                <constraints nullable="true"/>
            </column>
            <column name="version" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="true"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <!-- Indexes for common queries -->
        <createIndex indexName="idx_docref_tenant_patient" tableName="document_references">
            <column name="tenant_id"/>
            <column name="patient_id"/>
        </createIndex>

        <createIndex indexName="idx_docref_tenant_encounter" tableName="document_references">
            <column name="tenant_id"/>
            <column name="encounter_id"/>
        </createIndex>

        <createIndex indexName="idx_docref_tenant_status" tableName="document_references">
            <column name="tenant_id"/>
            <column name="status"/>
        </createIndex>

        <createIndex indexName="idx_docref_tenant_type" tableName="document_references">
            <column name="tenant_id"/>
            <column name="type_code"/>
        </createIndex>

        <createIndex indexName="idx_docref_tenant_category" tableName="document_references">
            <column name="tenant_id"/>
            <column name="category_code"/>
        </createIndex>

        <createIndex indexName="idx_docref_created_date" tableName="document_references">
            <column name="tenant_id"/>
            <column name="created_date"/>
        </createIndex>

        <createIndex indexName="idx_docref_indexed_date" tableName="document_references">
            <column name="indexed_date"/>
        </createIndex>

        <createIndex indexName="idx_docref_content_type" tableName="document_references">
            <column name="tenant_id"/>
            <column name="content_type"/>
        </createIndex>

        <createIndex indexName="idx_docref_deleted" tableName="document_references">
            <column name="deleted_at"/>
        </createIndex>

        <!-- GIN index for JSONB full-text search -->
        <sql>
            CREATE INDEX idx_docref_resource_gin ON document_references USING GIN (resource_json jsonb_path_ops);
        </sql>

        <!-- Full-text search index on description -->
        <sql>
            CREATE INDEX idx_docref_description_trgm ON document_references USING GIN (description gin_trgm_ops);
        </sql>

        <rollback>
            <dropTable tableName="document_references"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
