<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0006-create-procedures-table" author="codex">
        <createTable tableName="procedures">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="resource_type" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="resource_json" type="jsonb">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="procedure_code" type="varchar(128)"/>
            <column name="procedure_system" type="varchar(128)"/>
            <column name="procedure_display" type="varchar(512)"/>
            <column name="status" type="varchar(32)"/>
            <column name="category_code" type="varchar(128)"/>
            <column name="category_display" type="varchar(256)"/>
            <column name="performed_date" type="date"/>
            <column name="performed_start" type="timestamp"/>
            <column name="performed_end" type="timestamp"/>
            <column name="performer_id" type="varchar(255)"/>
            <column name="performer_display" type="varchar(512)"/>
            <column name="performer_function" type="varchar(128)"/>
            <column name="location_id" type="varchar(255)"/>
            <column name="location_display" type="varchar(512)"/>
            <column name="reason_code" type="varchar(128)"/>
            <column name="reason_system" type="varchar(128)"/>
            <column name="reason_display" type="varchar(512)"/>
            <column name="reason_reference" type="varchar(255)"/>
            <column name="body_site_code" type="varchar(128)"/>
            <column name="body_site_system" type="varchar(128)"/>
            <column name="body_site_display" type="varchar(512)"/>
            <column name="outcome_code" type="varchar(128)"/>
            <column name="outcome_display" type="varchar(256)"/>
            <column name="complication_code" type="varchar(128)"/>
            <column name="complication_display" type="varchar(256)"/>
            <column name="encounter_id" type="uuid"/>
            <column name="based_on_reference" type="varchar(255)"/>
            <column name="part_of_reference" type="varchar(255)"/>
            <column name="recorded_date" type="date"/>
            <column name="has_notes" type="boolean"/>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_by" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Index for tenant + patient lookups with performed_date for sorting -->
        <createIndex indexName="idx_procedure_tenant_patient" tableName="procedures">
            <column name="tenant_id"/>
            <column name="patient_id"/>
            <column name="performed_date" descending="true"/>
        </createIndex>

        <!-- Index for tenant + patient + procedure code -->
        <createIndex indexName="idx_procedure_code" tableName="procedures">
            <column name="tenant_id"/>
            <column name="patient_id"/>
            <column name="procedure_code"/>
            <column name="performed_date" descending="true"/>
        </createIndex>

        <!-- Index for tenant + patient + status -->
        <createIndex indexName="idx_procedure_status" tableName="procedures">
            <column name="tenant_id"/>
            <column name="patient_id"/>
            <column name="status"/>
            <column name="performed_date" descending="true"/>
        </createIndex>

        <!-- Index for date range queries -->
        <createIndex indexName="idx_procedure_date_range" tableName="procedures">
            <column name="tenant_id"/>
            <column name="patient_id"/>
            <column name="performed_date"/>
        </createIndex>

        <!-- Index for surgical procedures -->
        <createIndex indexName="idx_procedure_surgical" tableName="procedures">
            <column name="tenant_id"/>
            <column name="patient_id"/>
            <column name="category_code"/>
            <column name="status"/>
            <column name="performed_date" descending="true"/>
        </createIndex>

        <!-- Index for performer queries -->
        <createIndex indexName="idx_procedure_performer" tableName="procedures">
            <column name="tenant_id"/>
            <column name="performer_id"/>
            <column name="performed_date" descending="true"/>
        </createIndex>

        <!-- Index for location queries -->
        <createIndex indexName="idx_procedure_location" tableName="procedures">
            <column name="tenant_id"/>
            <column name="location_id"/>
            <column name="performed_date" descending="true"/>
        </createIndex>

        <!-- Index for encounter queries -->
        <createIndex indexName="idx_procedure_encounter" tableName="procedures">
            <column name="tenant_id"/>
            <column name="encounter_id"/>
        </createIndex>

        <!-- Index for reason code queries -->
        <createIndex indexName="idx_procedure_reason" tableName="procedures">
            <column name="tenant_id"/>
            <column name="patient_id"/>
            <column name="reason_code"/>
        </createIndex>

        <!-- Index for body site queries -->
        <createIndex indexName="idx_procedure_body_site" tableName="procedures">
            <column name="tenant_id"/>
            <column name="patient_id"/>
            <column name="body_site_code"/>
        </createIndex>

        <!-- Index for complications tracking -->
        <createIndex indexName="idx_procedure_complications" tableName="procedures">
            <column name="tenant_id"/>
            <column name="patient_id"/>
            <column name="complication_code"/>
            <column name="performed_date" descending="true"/>
        </createIndex>

        <!-- Index for outcome tracking -->
        <createIndex indexName="idx_procedure_outcome" tableName="procedures">
            <column name="tenant_id"/>
            <column name="patient_id"/>
            <column name="outcome_code"/>
        </createIndex>

        <!-- Foreign key to patients table -->
        <addForeignKeyConstraint
            baseTableName="procedures"
            baseColumnNames="patient_id"
            constraintName="fk_procedure_patient"
            referencedTableName="patients"
            referencedColumnNames="id"
            onDelete="CASCADE"/>

        <!-- Foreign key to encounters table (optional) -->
        <addForeignKeyConstraint
            baseTableName="procedures"
            baseColumnNames="encounter_id"
            constraintName="fk_procedure_encounter"
            referencedTableName="encounters"
            referencedColumnNames="id"
            onDelete="SET NULL"/>

        <!-- PostgreSQL-specific: Use JSONB for better performance -->

        <rollback>
            <dropTable tableName="procedures"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
