<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0011-create-bulk-export-jobs-table" author="codex">
        <createTable tableName="bulk_export_jobs">
            <column name="job_id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="export_level" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="resource_id" type="varchar(64)"/>
            <column name="resource_types" type="jsonb"/>
            <column name="output_format" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="since_param" type="timestamp with time zone"/>
            <column name="type_filters" type="jsonb"/>
            <column name="request_url" type="varchar(512)"/>
            <column name="requested_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
            <column name="started_at" type="timestamp with time zone"/>
            <column name="completed_at" type="timestamp with time zone"/>
            <column name="transaction_time" type="timestamp with time zone"/>
            <column name="requested_by" type="varchar(100)"/>
            <column name="output_files" type="jsonb"/>
            <column name="error_files" type="jsonb"/>
            <column name="error_message" type="varchar(1000)"/>
            <column name="total_resources" type="bigint"/>
            <column name="exported_resources" type="bigint"/>
        </createTable>

        <createIndex indexName="idx_bulk_export_tenant_status" tableName="bulk_export_jobs">
            <column name="tenant_id"/>
            <column name="status"/>
        </createIndex>

        <createIndex indexName="idx_bulk_export_requested_at" tableName="bulk_export_jobs">
            <column name="requested_at"/>
        </createIndex>

        <createIndex indexName="idx_bulk_export_status" tableName="bulk_export_jobs">
            <column name="status"/>
        </createIndex>

        <createIndex indexName="idx_bulk_export_completed_at" tableName="bulk_export_jobs">
            <column name="completed_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
