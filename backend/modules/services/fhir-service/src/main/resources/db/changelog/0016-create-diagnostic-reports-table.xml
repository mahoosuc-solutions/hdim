<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0016-create-diagnostic-reports-table" author="hdim">
        <comment>Create diagnostic_reports table for FHIR DiagnosticReport resources</comment>

        <createTable tableName="diagnostic_reports">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="resource_json" type="JSONB">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="encounter_id" type="UUID">
                <constraints nullable="true"/>
            </column>
            <column name="status" type="VARCHAR(32)">
                <constraints nullable="true"/>
            </column>
            <column name="code" type="VARCHAR(64)">
                <constraints nullable="true"/>
            </column>
            <column name="code_system" type="VARCHAR(128)">
                <constraints nullable="true"/>
            </column>
            <column name="code_display" type="VARCHAR(256)">
                <constraints nullable="true"/>
            </column>
            <column name="category_code" type="VARCHAR(64)">
                <constraints nullable="true"/>
            </column>
            <column name="category_display" type="VARCHAR(256)">
                <constraints nullable="true"/>
            </column>
            <column name="effective_datetime" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="true"/>
            </column>
            <column name="issued_datetime" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="true"/>
            </column>
            <column name="performer_reference" type="VARCHAR(128)">
                <constraints nullable="true"/>
            </column>
            <column name="conclusion" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="conclusion_codes" type="VARCHAR(512)">
                <constraints nullable="true"/>
            </column>
            <column name="result_count" type="INTEGER">
                <constraints nullable="true"/>
            </column>
            <column name="based_on_reference" type="VARCHAR(128)">
                <constraints nullable="true"/>
            </column>
            <column name="specimen_references" type="VARCHAR(512)">
                <constraints nullable="true"/>
            </column>
            <column name="presented_form_url" type="VARCHAR(512)">
                <constraints nullable="true"/>
            </column>
            <column name="presented_form_content_type" type="VARCHAR(64)">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(128)">
                <constraints nullable="true"/>
            </column>
            <column name="last_modified_by" type="VARCHAR(128)">
                <constraints nullable="true"/>
            </column>
            <column name="version" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="true"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <!-- Indexes for common queries -->
        <createIndex indexName="idx_diagrpt_tenant_patient" tableName="diagnostic_reports">
            <column name="tenant_id"/>
            <column name="patient_id"/>
        </createIndex>

        <createIndex indexName="idx_diagrpt_tenant_encounter" tableName="diagnostic_reports">
            <column name="tenant_id"/>
            <column name="encounter_id"/>
        </createIndex>

        <createIndex indexName="idx_diagrpt_tenant_status" tableName="diagnostic_reports">
            <column name="tenant_id"/>
            <column name="status"/>
        </createIndex>

        <createIndex indexName="idx_diagrpt_tenant_code" tableName="diagnostic_reports">
            <column name="tenant_id"/>
            <column name="code"/>
        </createIndex>

        <createIndex indexName="idx_diagrpt_tenant_category" tableName="diagnostic_reports">
            <column name="tenant_id"/>
            <column name="category_code"/>
        </createIndex>

        <createIndex indexName="idx_diagrpt_effective_date" tableName="diagnostic_reports">
            <column name="tenant_id"/>
            <column name="effective_datetime"/>
        </createIndex>

        <createIndex indexName="idx_diagrpt_issued_date" tableName="diagnostic_reports">
            <column name="tenant_id"/>
            <column name="issued_datetime"/>
        </createIndex>

        <createIndex indexName="idx_diagrpt_deleted" tableName="diagnostic_reports">
            <column name="deleted_at"/>
        </createIndex>

        <!-- GIN index for JSONB full-text search -->
        <sql>
            CREATE INDEX idx_diagrpt_resource_gin ON diagnostic_reports USING GIN (resource_json jsonb_path_ops);
        </sql>

        <rollback>
            <dropTable tableName="diagnostic_reports"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
