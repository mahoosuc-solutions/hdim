<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0017-create-care-plans-table" author="hdim">
        <comment>Create care_plans table for FHIR CarePlan resources</comment>

        <createTable tableName="care_plans">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="resource_json" type="JSONB">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="encounter_id" type="UUID">
                <constraints nullable="true"/>
            </column>
            <column name="status" type="VARCHAR(32)">
                <constraints nullable="true"/>
            </column>
            <column name="intent" type="VARCHAR(32)">
                <constraints nullable="true"/>
            </column>
            <column name="title" type="VARCHAR(256)">
                <constraints nullable="true"/>
            </column>
            <column name="description" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="category_code" type="VARCHAR(64)">
                <constraints nullable="true"/>
            </column>
            <column name="category_display" type="VARCHAR(256)">
                <constraints nullable="true"/>
            </column>
            <column name="period_start" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="true"/>
            </column>
            <column name="period_end" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="true"/>
            </column>
            <column name="created_date" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="true"/>
            </column>
            <column name="author_reference" type="VARCHAR(128)">
                <constraints nullable="true"/>
            </column>
            <column name="care_team_references" type="VARCHAR(512)">
                <constraints nullable="true"/>
            </column>
            <column name="activity_count" type="INTEGER">
                <constraints nullable="true"/>
            </column>
            <column name="goal_references" type="VARCHAR(512)">
                <constraints nullable="true"/>
            </column>
            <column name="addresses_references" type="VARCHAR(512)">
                <constraints nullable="true"/>
            </column>
            <column name="supporting_info_references" type="VARCHAR(512)">
                <constraints nullable="true"/>
            </column>
            <column name="replaces_reference" type="VARCHAR(128)">
                <constraints nullable="true"/>
            </column>
            <column name="part_of_reference" type="VARCHAR(128)">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="last_modified_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(128)">
                <constraints nullable="true"/>
            </column>
            <column name="last_modified_by" type="VARCHAR(128)">
                <constraints nullable="true"/>
            </column>
            <column name="version" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="true"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <!-- Indexes for common queries -->
        <createIndex indexName="idx_careplan_tenant_patient" tableName="care_plans">
            <column name="tenant_id"/>
            <column name="patient_id"/>
        </createIndex>

        <createIndex indexName="idx_careplan_tenant_encounter" tableName="care_plans">
            <column name="tenant_id"/>
            <column name="encounter_id"/>
        </createIndex>

        <createIndex indexName="idx_careplan_tenant_status" tableName="care_plans">
            <column name="tenant_id"/>
            <column name="status"/>
        </createIndex>

        <createIndex indexName="idx_careplan_tenant_intent" tableName="care_plans">
            <column name="tenant_id"/>
            <column name="intent"/>
        </createIndex>

        <createIndex indexName="idx_careplan_tenant_category" tableName="care_plans">
            <column name="tenant_id"/>
            <column name="category_code"/>
        </createIndex>

        <createIndex indexName="idx_careplan_period" tableName="care_plans">
            <column name="tenant_id"/>
            <column name="period_start"/>
            <column name="period_end"/>
        </createIndex>

        <createIndex indexName="idx_careplan_part_of" tableName="care_plans">
            <column name="part_of_reference"/>
        </createIndex>

        <createIndex indexName="idx_careplan_deleted" tableName="care_plans">
            <column name="deleted_at"/>
        </createIndex>

        <!-- GIN index for JSONB full-text search -->
        <sql>
            CREATE INDEX idx_careplan_resource_gin ON care_plans USING GIN (resource_json jsonb_path_ops);
        </sql>

        <!-- Full-text search indexes -->
        <sql>
            CREATE INDEX idx_careplan_title_trgm ON care_plans USING GIN (title gin_trgm_ops);
            CREATE INDEX idx_careplan_desc_trgm ON care_plans USING GIN (description gin_trgm_ops);
        </sql>

        <rollback>
            <dropTable tableName="care_plans"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
