<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0002-create-api-keys-tables" author="claude-code">
        <comment>Create API key tables for third-party API authentication</comment>

        <!-- Main API keys table -->
        <createTable tableName="api_keys">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_api_keys"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(500)"/>
            <column name="key_hash" type="VARCHAR(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="key_prefix" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="last_used_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="last_used_ip" type="VARCHAR(45)"/>
            <column name="usage_count" type="BIGINT" defaultValueNumeric="0"/>
            <column name="rate_limit_per_minute" type="INTEGER"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="revoked_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="revoked_by" type="UUID"/>
            <column name="revocation_reason" type="VARCHAR(500)"/>
        </createTable>

        <!-- Indexes on api_keys table -->
        <createIndex indexName="idx_api_keys_key_hash" tableName="api_keys" unique="true">
            <column name="key_hash"/>
        </createIndex>

        <createIndex indexName="idx_api_keys_tenant_id" tableName="api_keys">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_api_keys_active" tableName="api_keys">
            <column name="active"/>
        </createIndex>

        <createIndex indexName="idx_api_keys_prefix" tableName="api_keys">
            <column name="key_prefix"/>
        </createIndex>

        <!-- API key scopes collection table -->
        <createTable tableName="api_key_scopes">
            <column name="api_key_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_api_key_scopes_api_key"
                             references="api_keys(id)"
                             deleteCascade="true"/>
            </column>
            <column name="scope" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_api_key_scopes_api_key_id" tableName="api_key_scopes">
            <column name="api_key_id"/>
        </createIndex>

        <!-- API key allowed IPs collection table -->
        <createTable tableName="api_key_allowed_ips">
            <column name="api_key_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_api_key_allowed_ips_api_key"
                             references="api_keys(id)"
                             deleteCascade="true"/>
            </column>
            <column name="ip_cidr" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_api_key_allowed_ips_api_key_id" tableName="api_key_allowed_ips">
            <column name="api_key_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="api_key_allowed_ips"/>
            <dropTable tableName="api_key_scopes"/>
            <dropTable tableName="api_keys"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
