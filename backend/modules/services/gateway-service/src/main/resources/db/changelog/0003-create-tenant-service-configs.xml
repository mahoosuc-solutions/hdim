<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0003-create-tenant-service-configs" author="gateway-service">
        <comment>Tenant service configuration versioning and audit tables</comment>

        <createTable tableName="tenant_service_config_versions">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="service_name" type="VARCHAR(120)">
                <constraints nullable="false"/>
            </column>
            <column name="version_number" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="config_json" type="JSONB">
                <constraints nullable="false"/>
            </column>
            <column name="config_hash" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="change_summary" type="TEXT"/>
            <column name="source_version_id" type="UUID"/>
            <column name="created_by" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint
            tableName="tenant_service_config_versions"
            columnNames="tenant_id,service_name,version_number"
            constraintName="uq_tenant_service_config_versions"/>

        <createIndex tableName="tenant_service_config_versions" indexName="idx_config_versions_tenant_service">
            <column name="tenant_id"/>
            <column name="service_name"/>
        </createIndex>

        <createTable tableName="tenant_service_config_current">
            <column name="tenant_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="service_name" type="VARCHAR(120)">
                <constraints nullable="false"/>
            </column>
            <column name="active_version_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="updated_by" type="VARCHAR(255)"/>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <addPrimaryKey
            tableName="tenant_service_config_current"
            columnNames="tenant_id,service_name"
            constraintName="pk_tenant_service_config_current"/>

        <addForeignKeyConstraint
            baseTableName="tenant_service_config_current"
            baseColumnNames="active_version_id"
            referencedTableName="tenant_service_config_versions"
            referencedColumnNames="id"
            constraintName="fk_config_current_version"/>

        <createTable tableName="tenant_service_config_audit">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="service_name" type="VARCHAR(120)">
                <constraints nullable="false"/>
            </column>
            <column name="version_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="action" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="actor" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="details" type="JSONB"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="tenant_service_config_audit" indexName="idx_config_audit_tenant_service">
            <column name="tenant_id"/>
            <column name="service_name"/>
        </createIndex>

        <createIndex tableName="tenant_service_config_audit" indexName="idx_config_audit_version">
            <column name="version_id"/>
        </createIndex>

        <createTable tableName="tenant_service_config_approvals">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="service_name" type="VARCHAR(120)">
                <constraints nullable="false"/>
            </column>
            <column name="version_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="action" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="actor" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="comment" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="tenant_service_config_approvals"
            baseColumnNames="version_id"
            referencedTableName="tenant_service_config_versions"
            referencedColumnNames="id"
            constraintName="fk_config_approval_version"/>

        <createIndex tableName="tenant_service_config_approvals" indexName="idx_config_approvals_tenant_service">
            <column name="tenant_id"/>
            <column name="service_name"/>
        </createIndex>

        <createIndex tableName="tenant_service_config_approvals" indexName="idx_config_approvals_version">
            <column name="version_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
