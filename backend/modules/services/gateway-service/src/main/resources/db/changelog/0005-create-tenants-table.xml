<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0005-create-tenants-table" author="tenant-registration">
        <comment>Create tenants table with metadata for multi-tenant organizations</comment>

        <createTable tableName="tenants">
            <column name="id" type="varchar(255)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(20)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Index for status lookups (find all active/inactive tenants) -->
        <createIndex tableName="tenants" indexName="idx_tenants_status">
            <column name="status"/>
        </createIndex>

        <!-- Index for name searches -->
        <createIndex tableName="tenants" indexName="idx_tenants_name">
            <column name="name"/>
        </createIndex>

        <!-- Add foreign key constraint: user_tenants.tenant_id -> tenants.id -->
        <addForeignKeyConstraint
            baseTableName="user_tenants"
            baseColumnNames="tenant_id"
            referencedTableName="tenants"
            referencedColumnNames="id"
            constraintName="fk_user_tenants_tenant"
            onDelete="RESTRICT"/>

        <rollback>
            <dropForeignKeyConstraint baseTableName="user_tenants" constraintName="fk_user_tenants_tenant"/>
            <dropIndex tableName="tenants" indexName="idx_tenants_name"/>
            <dropIndex tableName="tenants" indexName="idx_tenants_status"/>
            <dropTable tableName="tenants"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
