<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0006-seed-demo-tenant" author="tenant-registration">
        <comment>Seed acme-health demo tenant for backward compatibility</comment>

        <insert tableName="tenants">
            <column name="id" value="acme-health"/>
            <column name="name" value="Acme Health Systems (Demo)"/>
            <column name="status" value="ACTIVE"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>

        <rollback>
            <delete tableName="tenants">
                <where>id = 'acme-health'</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
