<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0008-add-audit-log-columns" author="development">
        <comment>Add missing columns to audit_logs table to match AuditLog entity</comment>

        <!-- HTTP metadata -->
        <addColumn tableName="audit_logs">
            <column name="http_method" type="VARCHAR(10)" defaultValue="GET">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="audit_logs">
            <column name="request_path" type="VARCHAR(2048)" defaultValue="/unknown">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="audit_logs">
            <column name="query_parameters" type="TEXT"/>
        </addColumn>

        <!-- User context (username was missing) -->
        <addColumn tableName="audit_logs">
            <column name="username" type="VARCHAR(255)"/>
        </addColumn>

        <!-- tenant_id was missing -->
        <addColumn tableName="audit_logs">
            <column name="tenant_id" type="VARCHAR(255)" defaultValue="unknown">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <!-- roles was missing -->
        <addColumn tableName="audit_logs">
            <column name="roles" type="VARCHAR(255)"/>
        </addColumn>

        <!-- Network info (client_ip, user_agent already exist as ip_address and user_agent) -->
        <!-- Rename ip_address to client_ip for consistency -->
        <renameColumn tableName="audit_logs"
                      oldColumnName="ip_address"
                      newColumnName="client_ip"
                      columnDataType="VARCHAR(45)"/>

        <!-- Response information -->
        <addColumn tableName="audit_logs">
            <column name="http_status_code" type="INTEGER"/>
        </addColumn>

        <addColumn tableName="audit_logs">
            <column name="response_time_ms" type="INTEGER"/>
        </addColumn>

        <addColumn tableName="audit_logs">
            <column name="success" type="BOOLEAN"/>
        </addColumn>

        <!-- Authorization information -->
        <addColumn tableName="audit_logs">
            <column name="authorization_allowed" type="BOOLEAN"/>
        </addColumn>

        <addColumn tableName="audit_logs">
            <column name="required_role" type="VARCHAR(255)"/>
        </addColumn>

        <!-- Error information -->
        <addColumn tableName="audit_logs">
            <column name="error_message" type="TEXT"/>
        </addColumn>

        <!-- Tracing information -->
        <addColumn tableName="audit_logs">
            <column name="trace_id" type="VARCHAR(255)"/>
        </addColumn>

        <addColumn tableName="audit_logs">
            <column name="span_id" type="VARCHAR(255)"/>
        </addColumn>

        <!-- created_at column -->
        <addColumn tableName="audit_logs">
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <!-- Drop old columns that were replaced/renamed -->
        <dropColumn tableName="audit_logs" columnName="action"/>
        <dropColumn tableName="audit_logs" columnName="entity_type"/>
        <dropColumn tableName="audit_logs" columnName="entity_id"/>
        <dropColumn tableName="audit_logs" columnName="details"/>

        <!-- Add new indexes -->
        <createIndex tableName="audit_logs" indexName="idx_audit_logs_tenant_id">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex tableName="audit_logs" indexName="idx_audit_logs_http_status">
            <column name="http_status_code"/>
        </createIndex>

        <createIndex tableName="audit_logs" indexName="idx_audit_logs_trace_id">
            <column name="trace_id"/>
        </createIndex>

        <createIndex tableName="audit_logs" indexName="idx_audit_logs_request_path">
            <column name="request_path"/>
        </createIndex>

        <rollback>
            <!-- Rollback: reverse all changes -->
            <dropIndex tableName="audit_logs" indexName="idx_audit_logs_request_path"/>
            <dropIndex tableName="audit_logs" indexName="idx_audit_logs_trace_id"/>
            <dropIndex tableName="audit_logs" indexName="idx_audit_logs_http_status"/>
            <dropIndex tableName="audit_logs" indexName="idx_audit_logs_tenant_id"/>

            <addColumn tableName="audit_logs">
                <column name="action" type="VARCHAR(100)">
                    <constraints nullable="false"/>
                </column>
            </addColumn>
            <addColumn tableName="audit_logs">
                <column name="entity_type" type="VARCHAR(100)"/>
            </addColumn>
            <addColumn tableName="audit_logs">
                <column name="entity_id" type="UUID"/>
            </addColumn>
            <addColumn tableName="audit_logs">
                <column name="details" type="JSONB"/>
            </addColumn>

            <dropColumn tableName="audit_logs" columnName="created_at"/>
            <dropColumn tableName="audit_logs" columnName="span_id"/>
            <dropColumn tableName="audit_logs" columnName="trace_id"/>
            <dropColumn tableName="audit_logs" columnName="error_message"/>
            <dropColumn tableName="audit_logs" columnName="required_role"/>
            <dropColumn tableName="audit_logs" columnName="authorization_allowed"/>
            <dropColumn tableName="audit_logs" columnName="success"/>
            <dropColumn tableName="audit_logs" columnName="response_time_ms"/>
            <dropColumn tableName="audit_logs" columnName="http_status_code"/>
            <renameColumn tableName="audit_logs"
                          oldColumnName="client_ip"
                          newColumnName="ip_address"
                          columnDataType="VARCHAR(45)"/>
            <dropColumn tableName="audit_logs" columnName="roles"/>
            <dropColumn tableName="audit_logs" columnName="tenant_id"/>
            <dropColumn tableName="audit_logs" columnName="username"/>
            <dropColumn tableName="audit_logs" columnName="query_parameters"/>
            <dropColumn tableName="audit_logs" columnName="request_path"/>
            <dropColumn tableName="audit_logs" columnName="http_method"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
