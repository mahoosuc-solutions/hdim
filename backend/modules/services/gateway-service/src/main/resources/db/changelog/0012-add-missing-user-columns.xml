<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0012-add-missing-user-columns" author="development">
        <comment>Add MFA and OAuth columns to users table to match User entity</comment>

        <!-- MFA columns -->
        <addColumn tableName="users">
            <column name="mfa_enabled_at" type="TIMESTAMP WITH TIME ZONE"/>
        </addColumn>

        <addColumn tableName="users">
            <column name="mfa_secret" type="VARCHAR(255)"/>
        </addColumn>

        <addColumn tableName="users">
            <column name="mfa_recovery_codes" type="TEXT"/>
        </addColumn>

        <!-- OAuth columns -->
        <addColumn tableName="users">
            <column name="oauth_provider" type="VARCHAR(50)"/>
        </addColumn>

        <addColumn tableName="users">
            <column name="oauth_provider_id" type="VARCHAR(255)"/>
        </addColumn>

        <!-- Notes column -->
        <addColumn tableName="users">
            <column name="notes" type="TEXT"/>
        </addColumn>

        <rollback>
            <dropColumn tableName="users" columnName="notes"/>
            <dropColumn tableName="users" columnName="oauth_provider_id"/>
            <dropColumn tableName="users" columnName="oauth_provider"/>
            <dropColumn tableName="users" columnName="mfa_recovery_codes"/>
            <dropColumn tableName="users" columnName="mfa_secret"/>
            <dropColumn tableName="users" columnName="mfa_enabled_at"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
