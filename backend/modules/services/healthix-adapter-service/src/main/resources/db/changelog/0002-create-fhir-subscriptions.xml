<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="0002-create-fhir-subscriptions" author="hdim-platform">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="fhir_subscriptions"/></not>
        </preConditions>

        <createTable tableName="fhir_subscriptions">
            <column name="id" type="UUID">
                <constraints primaryKey="true"/>
            </column>
            <column name="tenant_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="resource_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="subscription_id" type="VARCHAR(255)"/>
            <column name="callback_url" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="REQUESTED">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_notification_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <rollback>
            <dropTable tableName="fhir_subscriptions"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
