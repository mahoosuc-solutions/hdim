<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="0001-create-measure-sync-log" author="hdim-platform">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="measure_sync_log"/></not>
        </preConditions>

        <createTable tableName="measure_sync_log">
            <column name="id" type="UUID">
                <constraints primaryKey="true"/>
            </column>
            <column name="sync_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="measure_count" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="hedis_count" type="INTEGER" defaultValueNumeric="0"/>
            <column name="mips_count" type="INTEGER" defaultValueNumeric="0"/>
            <column name="star_count" type="INTEGER" defaultValueNumeric="0"/>
            <column name="status" type="VARCHAR(20)" defaultValue="SUCCESS">
                <constraints nullable="false"/>
            </column>
            <column name="error_message" type="TEXT"/>
            <column name="synced_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="measure_sync_log" indexName="idx_measure_sync_time">
            <column name="synced_at"/>
        </createIndex>

        <rollback>
            <dropTable tableName="measure_sync_log"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
