<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="0002-create-investor-tasks-table" author="hdim">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="investor_tasks"/>
            </not>
        </preConditions>

        <createTable tableName="investor_tasks">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="subject" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="status" type="VARCHAR(50)" defaultValue="pending">
                <constraints nullable="false"/>
            </column>
            <column name="category" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="week" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="deliverable" type="TEXT"/>
            <column name="owner" type="VARCHAR(100)"/>
            <column name="due_date" type="DATE"/>
            <column name="completed_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="notes" type="TEXT"/>
            <column name="sort_order" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="investor_tasks" indexName="idx_investor_tasks_status">
            <column name="status"/>
        </createIndex>

        <createIndex tableName="investor_tasks" indexName="idx_investor_tasks_category">
            <column name="category"/>
        </createIndex>

        <createIndex tableName="investor_tasks" indexName="idx_investor_tasks_week">
            <column name="week"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="investor_tasks" indexName="idx_investor_tasks_week"/>
            <dropIndex tableName="investor_tasks" indexName="idx_investor_tasks_category"/>
            <dropIndex tableName="investor_tasks" indexName="idx_investor_tasks_status"/>
            <dropTable tableName="investor_tasks"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
