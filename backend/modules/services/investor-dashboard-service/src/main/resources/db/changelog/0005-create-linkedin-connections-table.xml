<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="0005-create-linkedin-connections-table" author="hdim">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="linkedin_connections"/>
            </not>
        </preConditions>

        <createTable tableName="linkedin_connections">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="linkedin_member_id" type="VARCHAR(100)"/>
            <column name="linkedin_profile_url" type="VARCHAR(500)"/>
            <column name="access_token" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="refresh_token" type="TEXT"/>
            <column name="token_expires_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="scope" type="VARCHAR(255)"/>
            <column name="connected" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="last_sync" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="sync_error" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="linkedin_connections"
            baseColumnNames="user_id"
            constraintName="fk_linkedin_connections_user"
            referencedTableName="investor_users"
            referencedColumnNames="id"
            onDelete="CASCADE"/>

        <createIndex tableName="linkedin_connections" indexName="idx_linkedin_connections_user">
            <column name="user_id"/>
        </createIndex>

        <createIndex tableName="linkedin_connections" indexName="idx_linkedin_connections_member">
            <column name="linkedin_member_id"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="linkedin_connections" indexName="idx_linkedin_connections_member"/>
            <dropIndex tableName="linkedin_connections" indexName="idx_linkedin_connections_user"/>
            <dropForeignKeyConstraint baseTableName="linkedin_connections" constraintName="fk_linkedin_connections_user"/>
            <dropTable tableName="linkedin_connections"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
