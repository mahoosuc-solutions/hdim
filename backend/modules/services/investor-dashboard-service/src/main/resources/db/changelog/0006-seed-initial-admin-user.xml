<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="0006-seed-initial-admin-user" author="hdim" context="!test">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM investor_users WHERE email = 'admin@hdim.ai'
            </sqlCheck>
        </preConditions>

        <comment>
            Seed initial admin user for investor dashboard.
            Default credentials: admin@hdim.ai / admin123
            Password hash is BCrypt with cost factor 12.
            IMPORTANT: Change this password immediately in production!
        </comment>

        <insert tableName="investor_users">
            <column name="id" valueComputed="gen_random_uuid()"/>
            <column name="email" value="admin@hdim.ai"/>
            <!-- BCrypt hash of 'admin123' with cost factor 12 -->
            <column name="password_hash" value="$2a$12$LQv3c1yqBWVHxkd0LHAkCOYz6TtxMQJqhN8/X4bVzGzKELFqLqMGa"/>
            <column name="first_name" value="Admin"/>
            <column name="last_name" value="User"/>
            <column name="role" value="ADMIN"/>
            <column name="active" valueBoolean="true"/>
            <column name="failed_login_attempts" valueNumeric="0"/>
            <column name="created_at" valueComputed="CURRENT_TIMESTAMP"/>
            <column name="updated_at" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>

        <rollback>
            <delete tableName="investor_users">
                <where>email = 'admin@hdim.ai'</where>
            </delete>
        </rollback>
    </changeSet>

</databaseChangeLog>
