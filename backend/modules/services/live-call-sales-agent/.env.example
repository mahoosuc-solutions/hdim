# Live Call Sales Agent - Environment Configuration

# Service Config
SERVICE_NAME=live-call-sales-agent
SERVICE_PORT=8095
DEBUG=false

# Google Cloud Config
GOOGLE_APPLICATION_CREDENTIALS=/secrets/google-meet-service-account.json
GOOGLE_MEET_API_ENABLED=true
GOOGLE_SPEECH_API_ENABLED=true

# AI Sales Agent Integration
AI_SALES_AGENT_URL=http://ai-sales-agent:8090

# WebSocket Config (HDIM Pattern)
WEBSOCKET_HOST=localhost
WEBSOCKET_PORT=8080
WEBSOCKET_PATH=/ws

# Database Config (customer_deployments_db)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=customer_deployments_db
POSTGRES_USER=healthdata
POSTGRES_PASSWORD=healthdata

# Redis Config
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# File Storage Config
TRANSCRIPT_BASE_PATH=/data/transcripts

# Pause Detection Config
PAUSE_THRESHOLD_MS=2000
MAX_PENDING_SUGGESTIONS=10

# Bot Config
BOT_HEADLESS=true
BOT_SANDBOX_DISABLED=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable

# Mock Mode (for testing without real Google APIs)
MOCK_GOOGLE_MEET=false
MOCK_GOOGLE_SPEECH=false
