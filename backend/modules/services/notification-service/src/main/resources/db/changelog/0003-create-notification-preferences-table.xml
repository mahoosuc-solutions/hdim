<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0003-create-notification-preferences-table" author="hdim">
        <createTable tableName="notification_preferences">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="channel" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="quiet_hours_start" type="TIME"/>
            <column name="quiet_hours_end" type="TIME"/>
            <column name="timezone" type="VARCHAR(50)" defaultValue="UTC"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <addUniqueConstraint
            constraintName="uk_preference_tenant_user_channel"
            tableName="notification_preferences"
            columnNames="tenant_id, user_id, channel"/>

        <createIndex indexName="idx_preferences_tenant_id" tableName="notification_preferences">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_preferences_user_id" tableName="notification_preferences">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
