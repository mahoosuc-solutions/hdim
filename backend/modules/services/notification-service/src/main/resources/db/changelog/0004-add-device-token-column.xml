<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0004-add-device-token-column" author="hdim">
        <comment>Add device_token column for push notifications (FCM/APNs)</comment>

        <addColumn tableName="notifications">
            <column name="device_token" type="VARCHAR(500)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <createIndex tableName="notifications" indexName="idx_notifications_device_token">
            <column name="device_token"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
