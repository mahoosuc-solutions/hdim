<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0009-create-appointment-reminders-sent-table" author="claude">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="appointment_reminders_sent"/>
            </not>
        </preConditions>

        <createTable tableName="appointment_reminders_sent">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="appointment_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="phone_number" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="reminder_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="days_before" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="sent_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="channel" type="VARCHAR(20)" defaultValue="SMS">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)" defaultValue="SENT">
                <constraints nullable="false"/>
            </column>
            <column name="message_sid" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>
            <column name="error_message" type="TEXT">
                <constraints nullable="true"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint
            tableName="appointment_reminders_sent"
            columnNames="tenant_id, appointment_id, reminder_type, days_before"
            constraintName="uk_appointment_reminders_sent_unique"/>

        <createIndex indexName="idx_appointment_reminders_tenant_id"
                     tableName="appointment_reminders_sent">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_appointment_reminders_appointment_id"
                     tableName="appointment_reminders_sent">
            <column name="appointment_id"/>
        </createIndex>

        <createIndex indexName="idx_appointment_reminders_sent_at"
                     tableName="appointment_reminders_sent">
            <column name="sent_at"/>
        </createIndex>

        <createIndex indexName="idx_appointment_reminders_status"
                     tableName="appointment_reminders_sent">
            <column name="status"/>
        </createIndex>

        <rollback>
            <dropTable tableName="appointment_reminders_sent"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
