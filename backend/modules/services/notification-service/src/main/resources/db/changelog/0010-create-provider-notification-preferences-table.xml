<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0010-create-provider-notification-preferences-table" author="claude-code">
        <comment>Create provider notification preferences table for Issue #148: Smart Notification Preferences</comment>

        <createTable tableName="provider_notification_preferences">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_provider_notification_preferences"/>
            </column>
            <column name="provider_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="notification_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="enabled" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="delivery_method" type="VARCHAR(50)" defaultValue="IN_APP">
                <constraints nullable="false"/>
            </column>
            <column name="additional_delivery_methods" type="VARCHAR(200)"/>
            <column name="min_urgency" type="VARCHAR(20)" defaultValue="LOW"/>
            <column name="digest_enabled" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="digest_frequency" type="VARCHAR(20)" defaultValue="DAILY"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <addUniqueConstraint
            tableName="provider_notification_preferences"
            columnNames="provider_id, notification_type"
            constraintName="uk_prov_pref_provider_type"/>

        <createIndex indexName="idx_prov_pref_tenant_provider" tableName="provider_notification_preferences">
            <column name="tenant_id"/>
            <column name="provider_id"/>
        </createIndex>

        <createIndex indexName="idx_prov_pref_type" tableName="provider_notification_preferences">
            <column name="notification_type"/>
        </createIndex>

        <rollback>
            <dropTable tableName="provider_notification_preferences"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
