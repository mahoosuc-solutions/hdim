<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0003-create-patient-education-logs-table" author="hdim-nurse-workflow-team">
        <comment>Create patient_education_logs table for patient education tracking</comment>

        <createTable tableName="patient_education_logs">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_patient_education_logs"/>
            </column>
            <column name="tenant_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="educator_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="material_id" type="VARCHAR(128)"/>
            <column name="material_type" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="delivery_method" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="topics_covered" type="TEXT"/>
            <column name="teach_back_performed" type="BOOLEAN"/>
            <column name="patient_understanding" type="VARCHAR(20)"/>
            <column name="barriers_to_learning" type="TEXT"/>
            <column name="interpreter_used" type="BOOLEAN"/>
            <column name="interpreter_language" type="VARCHAR(50)"/>
            <column name="caregiver_involved" type="BOOLEAN"/>
            <column name="duration_minutes" type="INT"/>
            <column name="clinical_reason" type="TEXT"/>
            <column name="notes" type="TEXT"/>
            <column name="document_reference_id" type="VARCHAR(128)"/>
            <column name="delivered_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Create indexes for query performance -->
        <createIndex indexName="idx_edu_tenant_patient" tableName="patient_education_logs">
            <column name="tenant_id"/>
            <column name="patient_id"/>
        </createIndex>

        <createIndex indexName="idx_edu_educator" tableName="patient_education_logs">
            <column name="educator_id"/>
        </createIndex>

        <createIndex indexName="idx_edu_delivered_at" tableName="patient_education_logs">
            <column name="delivered_at"/>
        </createIndex>

        <createIndex indexName="idx_edu_material_type" tableName="patient_education_logs">
            <column name="material_type"/>
        </createIndex>

        <!-- Rollback -->
        <rollback>
            <dropTable tableName="patient_education_logs"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
