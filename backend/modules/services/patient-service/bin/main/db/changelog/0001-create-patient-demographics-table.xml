<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0001-create-patient-demographics-table" author="healthdata-system">
        <comment>Create patient demographics table for enhanced patient information</comment>

        <createTable tableName="patient_demographics">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="fhir_patient_id" type="varchar(64)">
                <constraints nullable="false" unique="true"/>
            </column>

            <!-- Demographics -->
            <column name="mrn" type="varchar(50)">
                <constraints nullable="true"/>
            </column>
            <column name="ssn_encrypted" type="varchar(256)">
                <constraints nullable="true"/>
            </column>
            <column name="first_name" type="varchar(128)">
                <constraints nullable="false"/>
            </column>
            <column name="middle_name" type="varchar(128)">
                <constraints nullable="true"/>
            </column>
            <column name="last_name" type="varchar(128)">
                <constraints nullable="false"/>
            </column>
            <column name="date_of_birth" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="gender" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="race" type="varchar(50)">
                <constraints nullable="true"/>
            </column>
            <column name="ethnicity" type="varchar(50)">
                <constraints nullable="true"/>
            </column>
            <column name="preferred_language" type="varchar(50)">
                <constraints nullable="true"/>
            </column>

            <!-- Contact -->
            <column name="email" type="varchar(255)">
                <constraints nullable="true"/>
            </column>
            <column name="phone" type="varchar(20)">
                <constraints nullable="true"/>
            </column>
            <column name="address_line1" type="varchar(255)">
                <constraints nullable="true"/>
            </column>
            <column name="address_line2" type="varchar(255)">
                <constraints nullable="true"/>
            </column>
            <column name="city" type="varchar(100)">
                <constraints nullable="true"/>
            </column>
            <column name="state" type="varchar(50)">
                <constraints nullable="true"/>
            </column>
            <column name="zip_code" type="varchar(20)">
                <constraints nullable="true"/>
            </column>
            <column name="country" type="varchar(50)">
                <constraints nullable="true"/>
            </column>

            <!-- Status -->
            <column name="active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="deceased" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deceased_date" type="date">
                <constraints nullable="true"/>
            </column>

            <!-- Primary Care Provider -->
            <column name="pcp_id" type="varchar(64)">
                <constraints nullable="true"/>
            </column>
            <column name="pcp_name" type="varchar(255)">
                <constraints nullable="true"/>
            </column>

            <!-- Audit -->
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_patient_demo_tenant" tableName="patient_demographics">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_patient_demo_name" tableName="patient_demographics">
            <column name="last_name"/>
            <column name="first_name"/>
        </createIndex>

        <createIndex indexName="idx_patient_demo_dob" tableName="patient_demographics">
            <column name="date_of_birth"/>
        </createIndex>

        <createIndex indexName="idx_patient_demo_mrn" tableName="patient_demographics">
            <column name="mrn"/>
        </createIndex>

        <rollback>
            <dropTable tableName="patient_demographics"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
