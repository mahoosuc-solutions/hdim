<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0003-create-patient-risk-scores-table" author="healthdata-system">
        <comment>Create patient risk scores table for care management and stratification</comment>

        <createTable tableName="patient_risk_scores">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="uuid">
                <constraints nullable="false"
                            foreignKeyName="fk_risk_score_patient"
                            references="patient_demographics(id)"/>
            </column>

            <!-- Risk Assessment -->
            <column name="score_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="score_value" type="decimal(10,4)">
                <constraints nullable="false"/>
            </column>
            <column name="risk_category" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="calculation_date" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
            <column name="valid_until" type="timestamp with time zone">
                <constraints nullable="true"/>
            </column>

            <!-- Details -->
            <column name="factors" type="text">
                <constraints nullable="true"/>
            </column>
            <column name="comorbidities" type="text">
                <constraints nullable="true"/>
            </column>
            <column name="model_version" type="varchar(50)">
                <constraints nullable="true"/>
            </column>

            <!-- Audit -->
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_patient_risk_patient" tableName="patient_risk_scores">
            <column name="patient_id"/>
            <column name="calculation_date" descending="true"/>
        </createIndex>

        <createIndex indexName="idx_patient_risk_category" tableName="patient_risk_scores">
            <column name="risk_category"/>
        </createIndex>

        <createIndex indexName="idx_patient_risk_type" tableName="patient_risk_scores">
            <column name="score_type"/>
        </createIndex>

        <rollback>
            <dropTable tableName="patient_risk_scores"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
