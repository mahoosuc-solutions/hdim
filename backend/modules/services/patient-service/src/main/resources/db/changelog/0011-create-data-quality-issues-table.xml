<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0006-create-data-quality-issues-table" author="healthdata-system">
        <comment>Data Quality Issues table for tracking data quality problems</comment>

        <createTable tableName="data_quality_issues">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="issue_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="severity" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="varchar(2000)"/>
            <column name="affected_field" type="varchar(100)"/>
            <column name="current_value" type="varchar(500)"/>
            <column name="suggested_value" type="varchar(500)"/>
            <column name="recommendation" type="varchar(2000)"/>
            <column name="detected_at" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="resolved_at" type="timestamp"/>
            <column name="resolved_by" type="varchar(100)"/>
            <column name="resolution_notes" type="varchar(2000)"/>
            <column name="created_at" type="timestamp"/>
            <column name="updated_at" type="timestamp"/>
        </createTable>

        <createIndex indexName="idx_dqi_tenant_status" tableName="data_quality_issues">
            <column name="tenant_id"/>
            <column name="status"/>
        </createIndex>
        <createIndex indexName="idx_dqi_patient_id" tableName="data_quality_issues">
            <column name="patient_id"/>
        </createIndex>
        <createIndex indexName="idx_dqi_severity" tableName="data_quality_issues">
            <column name="severity"/>
        </createIndex>
        <createIndex indexName="idx_dqi_detected_at" tableName="data_quality_issues">
            <column name="detected_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
