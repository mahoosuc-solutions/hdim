<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0008-create-mpi-merges-table" author="healthdata-system">
        <comment>MPI Merges table for tracking patient merge operations</comment>

        <createTable tableName="mpi_merges">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="source_patient_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="target_patient_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="merge_type" type="varchar(50)"/>
            <column name="confidence_score" type="double precision"/>
            <column name="merge_status" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="validation_status" type="varchar(20)"/>
            <column name="merge_timestamp" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="performed_by" type="varchar(100)"/>
            <column name="source_patient_snapshot" type="jsonb"/>
            <column name="target_patient_snapshot" type="jsonb"/>
            <column name="merged_patient_snapshot" type="jsonb"/>
            <column name="matching_details" type="jsonb"/>
            <column name="validated_by" type="varchar(100)"/>
            <column name="validated_at" type="timestamp"/>
            <column name="validation_notes" type="varchar(2000)"/>
            <column name="has_merge_errors" type="boolean"/>
            <column name="has_data_quality_issues" type="boolean"/>
            <column name="data_quality_assessment" type="varchar(50)"/>
            <column name="rollback_reason" type="varchar(2000)"/>
            <column name="rolled_back_at" type="timestamp"/>
            <column name="rolled_back_by" type="varchar(100)"/>
            <column name="created_at" type="timestamp"/>
            <column name="updated_at" type="timestamp"/>
        </createTable>

        <createIndex indexName="idx_mpi_tenant_status" tableName="mpi_merges">
            <column name="tenant_id"/>
            <column name="merge_status"/>
        </createIndex>
        <createIndex indexName="idx_mpi_merge_timestamp" tableName="mpi_merges">
            <column name="merge_timestamp"/>
        </createIndex>
        <createIndex indexName="idx_mpi_validation_status" tableName="mpi_merges">
            <column name="validation_status"/>
        </createIndex>
        <createIndex indexName="idx_mpi_source_target" tableName="mpi_merges">
            <column name="source_patient_id"/>
            <column name="target_patient_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
