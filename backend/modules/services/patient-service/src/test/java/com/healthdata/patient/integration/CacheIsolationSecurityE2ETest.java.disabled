package com.healthdata.patient.integration;

// TODO: Re-enable when Patient domain model is implemented
// import com.healthdata.patient.domain.model.Patient;
import com.healthdata.patient.entity.PatientDemographicsEntity;
import com.healthdata.patient.repository.PatientDemographicsRepository;
import com.healthdata.testfixtures.security.GatewayTrustTestHeaders;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Disabled;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Nested;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.autoconfigure.web.servlet.AutoConfigureMockMvc;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.cache.CacheManager;
import org.springframework.data.redis.core.RedisTemplate;
import org.springframework.test.context.ActiveProfiles;
import org.springframework.test.context.DynamicPropertyRegistry;
import org.springframework.test.context.DynamicPropertySource;
import org.springframework.test.web.servlet.MockMvc;
import org.springframework.transaction.annotation.Transactional;
import java.time.Duration;
import java.time.LocalDate;
import java.util.Objects;
import java.util.Set;
import java.util.UUID;

import static org.assertj.core.api.Assertions.assertThat;
import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.get;
import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.*;

/**
 * End-to-End Security Tests for Cache Isolation and HIPAA Compliance.
 *
 * These tests validate that the patient service properly implements HIPAA-compliant
 * caching for Protected Health Information (PHI), including:
 * - Maximum 5-minute TTL for PHI cache entries
 * - Multi-tenant cache isolation
 * - Cache-Control headers preventing client-side caching
 * - No PHI leakage between tenants via cache
 *
 * SECURITY TEST COVERAGE:
 * - HIPAA Security Rule: Access Control (§164.312(a)(1))
 * - HIPAA Cache Compliance (see: backend/HIPAA-CACHE-COMPLIANCE.md)
 * - Multi-tenant cache isolation
 * - PHI cache TTL enforcement
 * - Client-side cache prevention
 *
 * CRITICAL: All PHI must have cache TTL <= 5 minutes per HIPAA compliance requirements.
 *
 * NOTE: This test uses the running Docker Redis container (localhost:6380) instead of
 * Testcontainers to align with the Testcontainers fix strategy for improved test reliability.
 */
@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
@AutoConfigureMockMvc
@ActiveProfiles("test")
@Transactional
@Disabled("Tests require Patient domain model with SSN field that is not yet implemented")
@DisplayName("HIPAA-Compliant Cache Isolation E2E Security Tests")
class CacheIsolationSecurityE2ETest {

    @DynamicPropertySource
    static void redisProperties(DynamicPropertyRegistry registry) {
        registry.add("spring.data.redis.host", () -> "localhost");
        registry.add("spring.data.redis.port", () -> 6380);
    }

    @Autowired
    private MockMvc mockMvc;

    @Autowired
    private PatientDemographicsRepository patientRepository;

    @Autowired
    private CacheManager cacheManager;

    @Autowired
    private RedisTemplate<String, Object> redisTemplate;

    private UUID tenant1PatientId;
    private UUID tenant2PatientId;

    @BeforeEach
    void setUp() {
        // Clear all caches before each test
        Objects.requireNonNull(cacheManager.getCache("patientData")).clear();
        Objects.requireNonNull(cacheManager.getCache("patientSearch")).clear();

        // Clear database
        patientRepository.deleteAll();

        // Create test patients
        Patient tenant1Patient = Patient.builder()
            .tenantId("tenant-1")
            .firstName("John")
            .lastName("Doe")
            .dateOfBirth(LocalDate.of(1980, 1, 1))
            .ssn("123-45-6789")  // PHI
            .build();
        tenant1PatientId = patientRepository.save(tenant1Patient).getId();

        Patient tenant2Patient = Patient.builder()
            .tenantId("tenant-2")
            .firstName("Jane")
            .lastName("Smith")
            .dateOfBirth(LocalDate.of(1985, 5, 15))
            .ssn("987-65-4321")  // PHI
            .build();
        tenant2PatientId = patientRepository.save(tenant2Patient).getId();
    }

    @Nested
    @DisplayName("HIPAA Cache TTL Compliance")
    class HipaaCacheTtlCompliance {

        @Test
        @DisplayName("should set cache TTL to maximum 5 minutes for PHI")
        void shouldEnforceMaximumFiveMinuteTtl() throws Exception {
            var headers = GatewayTrustTestHeaders.adminHeaders("tenant-1");

            // First request: populates cache
            mockMvc.perform(get("/api/v1/patients/" + tenant1PatientId)
                    .headers(headers))
                .andExpect(status().isOk());

            // Verify cache entry exists and has correct TTL
            String cacheKey = "patientData::" + tenant1PatientId + "::tenant-1";
            Long ttl = redisTemplate.getExpire(cacheKey);

            assertThat(ttl).isNotNull();
            assertThat(ttl).isLessThanOrEqualTo(300L);  // 5 minutes = 300 seconds
            assertThat(ttl).isGreaterThan(0L);  // Not expired
        }

        @Test
        @DisplayName("should expire PHI cache after TTL")
        void shouldExpirePhiCacheAfterTtl() throws Exception {
            var headers = GatewayTrustTestHeaders.adminHeaders("tenant-1");

            // First request: populates cache with 1-second TTL (for testing)
            mockMvc.perform(get("/api/v1/patients/" + tenant1PatientId)
                    .headers(headers))
                .andExpect(status().isOk());

            String cacheKey = "patientData::" + tenant1PatientId + "::tenant-1";

            // Verify cache hit
            assertThat(redisTemplate.hasKey(cacheKey)).isTrue();

            // Wait for cache to expire (testing uses shorter TTL)
            Thread.sleep(300);

            // Verify cache expired
            assertThat(redisTemplate.hasKey(cacheKey)).isFalse();
        }

        @Test
        @DisplayName("should not cache PHI indefinitely")
        void shouldNotCachePhiIndefinitely() throws Exception {
            var headers = GatewayTrustTestHeaders.adminHeaders("tenant-1");

            mockMvc.perform(get("/api/v1/patients/" + tenant1PatientId)
                    .headers(headers))
                .andExpect(status().isOk());

            String cacheKey = "patientData::" + tenant1PatientId + "::tenant-1";
            Long ttl = redisTemplate.getExpire(cacheKey);

            // TTL should NOT be -1 (which means no expiration)
            assertThat(ttl).isNotEqualTo(-1L);
        }
    }

    @Nested
    @DisplayName("Multi-Tenant Cache Isolation")
    class MultiTenantCacheIsolation {

        @Test
        @DisplayName("should isolate cache entries by tenant ID")
        void shouldIsolateCacheByTenant() throws Exception {
            // Tenant 1 requests their patient
            var tenant1Headers = GatewayTrustTestHeaders.adminHeaders("tenant-1");
            mockMvc.perform(get("/api/v1/patients/" + tenant1PatientId)
                    .headers(tenant1Headers))
                .andExpect(status().isOk())
                .andExpect(jsonPath("$.firstName").value("John"));

            // Tenant 2 requests their patient
            var tenant2Headers = GatewayTrustTestHeaders.adminHeaders("tenant-2");
            mockMvc.perform(get("/api/v1/patients/" + tenant2PatientId)
                    .headers(tenant2Headers))
                .andExpect(status().isOk())
                .andExpect(jsonPath("$.firstName").value("Jane"));

            // Verify separate cache entries exist
            String tenant1CacheKey = "patientData::" + tenant1PatientId + "::tenant-1";
            String tenant2CacheKey = "patientData::" + tenant2PatientId + "::tenant-2";

            assertThat(redisTemplate.hasKey(tenant1CacheKey)).isTrue();
            assertThat(redisTemplate.hasKey(tenant2CacheKey)).isTrue();
        }

        @Test
        @DisplayName("should prevent cache poisoning via tenant header manipulation")
        void shouldPreventCachePoisoning() throws Exception {
            // Tenant 1 caches their patient
            var tenant1Headers = GatewayTrustTestHeaders.adminHeaders("tenant-1");
            mockMvc.perform(get("/api/v1/patients/" + tenant1PatientId)
                    .headers(tenant1Headers))
                .andExpect(status().isOk());

            // Attacker tries to access cached data using different tenant header
            var attackHeaders = GatewayTrustTestHeaders.builder()
                .tenantId("tenant-2")  // Wrong tenant
                .roles("ADMIN")
                .build();

            // Should NOT get cached tenant-1 data
            mockMvc.perform(get("/api/v1/patients/" + tenant1PatientId)
                    .headers(attackHeaders))
                .andExpect(status().isNotFound());  // Patient doesn't exist in tenant-2
        }

        @Test
        @DisplayName("should clear cache only for specific tenant")
        void shouldClearCacheByTenant() throws Exception {
            // Cache patients for both tenants
            var tenant1Headers = GatewayTrustTestHeaders.adminHeaders("tenant-1");
            mockMvc.perform(get("/api/v1/patients/" + tenant1PatientId)
                    .headers(tenant1Headers))
                .andExpect(status().isOk());

            var tenant2Headers = GatewayTrustTestHeaders.adminHeaders("tenant-2");
            mockMvc.perform(get("/api/v1/patients/" + tenant2PatientId)
                    .headers(tenant2Headers))
                .andExpect(status().isOk());

            // Clear cache for tenant-1
            mockMvc.perform(get("/api/v1/admin/cache/evict/tenant-1")
                    .headers(tenant1Headers))
                .andExpect(status().isOk());

            // Tenant-1 cache should be cleared
            String tenant1CacheKey = "patientData::" + tenant1PatientId + "::tenant-1";
            assertThat(redisTemplate.hasKey(tenant1CacheKey)).isFalse();

            // Tenant-2 cache should still exist
            String tenant2CacheKey = "patientData::" + tenant2PatientId + "::tenant-2";
            assertThat(redisTemplate.hasKey(tenant2CacheKey)).isTrue();
        }
    }

    @Nested
    @DisplayName("Client-Side Cache Prevention")
    class ClientSideCachePrevention {

        @Test
        @DisplayName("should include Cache-Control: no-store header for PHI")
        void shouldIncludeCacheControlNoStore() throws Exception {
            var headers = GatewayTrustTestHeaders.adminHeaders("tenant-1");

            mockMvc.perform(get("/api/v1/patients/" + tenant1PatientId)
                    .headers(headers))
                .andExpect(status().isOk())
                .andExpect(header().string("Cache-Control", "no-store, no-cache, must-revalidate"))
                .andExpect(header().string("Pragma", "no-cache"))
                .andExpect(header().string("Expires", "0"));
        }

        @Test
        @DisplayName("should prevent browser caching of patient lists")
        void shouldPreventBrowserCachingOfLists() throws Exception {
            var headers = GatewayTrustTestHeaders.adminHeaders("tenant-1");

            mockMvc.perform(get("/api/v1/patients")
                    .headers(headers))
                .andExpect(status().isOk())
                .andExpect(header().string("Cache-Control", "no-store, no-cache, must-revalidate"))
                .andExpect(header().string("Pragma", "no-cache"));
        }

        @Test
        @DisplayName("should prevent browser caching of patient search results")
        void shouldPreventBrowserCachingOfSearchResults() throws Exception {
            var headers = GatewayTrustTestHeaders.adminHeaders("tenant-1");

            mockMvc.perform(get("/api/v1/patients/search")
                    .param("firstName", "John")
                    .headers(headers))
                .andExpect(status().isOk())
                .andExpect(header().string("Cache-Control", "no-store, no-cache, must-revalidate"));
        }
    }

    @Nested
    @DisplayName("Cache Key Security")
    class CacheKeySecurity {

        @Test
        @DisplayName("should include tenant ID in cache key to prevent collisions")
        void shouldIncludeTenantInCacheKey() throws Exception {
            var headers = GatewayTrustTestHeaders.adminHeaders("tenant-1");

            mockMvc.perform(get("/api/v1/patients/" + tenant1PatientId)
                    .headers(headers))
                .andExpect(status().isOk());

            // Verify cache key includes tenant ID
            Set<String> keys = redisTemplate.keys("patientData::*");
            assertThat(keys).isNotNull();
            assertThat(keys).isNotEmpty();
            assertThat(keys).anyMatch(key -> key.contains("tenant-1"));
        }

        @Test
        @DisplayName("should prevent cache key enumeration attacks")
        void shouldPreventCacheKeyEnumeration() throws Exception {
            // Attacker tries to enumerate cache keys
            var headers = GatewayTrustTestHeaders.adminHeaders("tenant-1");

            mockMvc.perform(get("/api/v1/admin/cache/keys")
                    .headers(headers))
                .andExpect(status().isForbidden())  // Only SUPER_ADMIN should access
                .andExpect(jsonPath("$.message").value("Insufficient permissions"));
        }
    }

    @Nested
    @DisplayName("Cache Eviction Security")
    class CacheEvictionSecurity {

        @Test
        @DisplayName("should evict cache when patient data is updated")
        void shouldEvictCacheOnUpdate() throws Exception {
            var headers = GatewayTrustTestHeaders.adminHeaders("tenant-1");

            // Cache patient data
            mockMvc.perform(get("/api/v1/patients/" + tenant1PatientId)
                    .headers(headers))
                .andExpect(status().isOk())
                .andExpect(jsonPath("$.firstName").value("John"));

            String cacheKey = "patientData::" + tenant1PatientId + "::tenant-1";
            assertThat(redisTemplate.hasKey(cacheKey)).isTrue();

            // Update patient
            mockMvc.perform(get("/api/v1/patients/" + tenant1PatientId + "/update")
                    .param("firstName", "Johnny")
                    .headers(headers))
                .andExpect(status().isOk());

            // Cache should be evicted
            assertThat(redisTemplate.hasKey(cacheKey)).isFalse();

            // Next request should get fresh data
            mockMvc.perform(get("/api/v1/patients/" + tenant1PatientId)
                    .headers(headers))
                .andExpect(status().isOk())
                .andExpect(jsonPath("$.firstName").value("Johnny"));
        }

        @Test
        @DisplayName("should evict cache when patient is deleted")
        void shouldEvictCacheOnDelete() throws Exception {
            var headers = GatewayTrustTestHeaders.adminHeaders("tenant-1");

            // Cache patient data
            mockMvc.perform(get("/api/v1/patients/" + tenant1PatientId)
                    .headers(headers))
                .andExpect(status().isOk());

            String cacheKey = "patientData::" + tenant1PatientId + "::tenant-1";
            assertThat(redisTemplate.hasKey(cacheKey)).isTrue();

            // Delete patient
            mockMvc.perform(get("/api/v1/patients/" + tenant1PatientId + "/delete")
                    .headers(headers))
                .andExpect(status().isOk());

            // Cache should be evicted
            assertThat(redisTemplate.hasKey(cacheKey)).isFalse();
        }

        @Test
        @DisplayName("should allow tenant admin to clear their tenant cache")
        void shouldAllowTenantAdminToClearCache() throws Exception {
            var headers = GatewayTrustTestHeaders.adminHeaders("tenant-1");

            // Cache data
            mockMvc.perform(get("/api/v1/patients/" + tenant1PatientId)
                    .headers(headers))
                .andExpect(status().isOk());

            // Clear tenant cache
            mockMvc.perform(get("/api/v1/admin/cache/clear")
                    .headers(headers))
                .andExpect(status().isOk());

            // Verify cache cleared
            Set<String> keys = redisTemplate.keys("patientData::*tenant-1");
            assertThat(keys).isEmpty();
        }

        @Test
        @DisplayName("should prevent tenant admin from clearing other tenant caches")
        void shouldPreventCrossTenantCacheEviction() throws Exception {
            var tenant1Headers = GatewayTrustTestHeaders.adminHeaders("tenant-1");
            var tenant2Headers = GatewayTrustTestHeaders.adminHeaders("tenant-2");

            // Cache data for both tenants
            mockMvc.perform(get("/api/v1/patients/" + tenant1PatientId)
                    .headers(tenant1Headers))
                .andExpect(status().isOk());

            mockMvc.perform(get("/api/v1/patients/" + tenant2PatientId)
                    .headers(tenant2Headers))
                .andExpect(status().isOk());

            // Tenant 1 tries to clear tenant 2 cache
            mockMvc.perform(get("/api/v1/admin/cache/evict/tenant-2")
                    .headers(tenant1Headers))
                .andExpect(status().isForbidden())
                .andExpect(jsonPath("$.message").value("Cannot evict cache for other tenants"));

            // Verify tenant-2 cache still exists
            Set<String> tenant2Keys = redisTemplate.keys("patientData::*tenant-2");
            assertThat(tenant2Keys).isNotEmpty();
        }
    }

    @Nested
    @DisplayName("Cache Performance vs Security Balance")
    class CachePerformanceVsSecurity {

        @Test
        @DisplayName("should use cache to improve performance for repeated reads")
        void shouldUseCacheForPerformance() throws Exception {
            var headers = GatewayTrustTestHeaders.adminHeaders("tenant-1");

            // First request: miss, populate cache
            long startTime1 = System.currentTimeMillis();
            mockMvc.perform(get("/api/v1/patients/" + tenant1PatientId)
                    .headers(headers))
                .andExpect(status().isOk());
            long duration1 = System.currentTimeMillis() - startTime1;

            // Second request: hit, from cache (should be faster)
            long startTime2 = System.currentTimeMillis();
            mockMvc.perform(get("/api/v1/patients/" + tenant1PatientId)
                    .headers(headers))
                .andExpect(status().isOk());
            long duration2 = System.currentTimeMillis() - startTime2;

            // Cache hit should be faster (this is a rough check)
            // In real scenarios with actual DB, difference is more pronounced
            assertThat(duration2).isLessThanOrEqualTo(duration1 * 2);  // Allow variance
        }

        @Test
        @DisplayName("should balance cache performance with HIPAA security requirements")
        void shouldBalancePerformanceAndSecurity() throws Exception {
            // Test validates that cache is used for performance
            // BUT respects HIPAA requirements:
            // 1. TTL <= 5 minutes
            // 2. Tenant isolation
            // 3. No client-side caching
            // 4. Proper eviction on updates

            var headers = GatewayTrustTestHeaders.adminHeaders("tenant-1");

            mockMvc.perform(get("/api/v1/patients/" + tenant1PatientId)
                    .headers(headers))
                .andExpect(status().isOk())
                // Performance: Cache used (subsequent reads faster)
                // Security: Cache-Control headers prevent client caching
                .andExpect(header().string("Cache-Control", "no-store, no-cache, must-revalidate"));

            String cacheKey = "patientData::" + tenant1PatientId + "::tenant-1";
            Long ttl = redisTemplate.getExpire(cacheKey);

            // Security: TTL <= 5 minutes
            assertThat(ttl).isLessThanOrEqualTo(300L);

            // Performance: Cache entry exists
            assertThat(redisTemplate.hasKey(cacheKey)).isTrue();
        }
    }
}
