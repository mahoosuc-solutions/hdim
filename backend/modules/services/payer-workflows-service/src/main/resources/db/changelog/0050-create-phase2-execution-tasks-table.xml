<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="0050-create-phase2-execution-tasks-table" author="hdim">
        <createTable tableName="phase2_execution_tasks">
            <!-- Primary Key -->
            <column name="id" type="VARCHAR(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <!-- Multi-Tenant -->
            <column name="tenant_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <!-- Task Identification -->
            <column name="task_name" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>

            <column name="task_category" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <!-- Timeline -->
            <column name="target_due_date" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="completed_date" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="blocked_until" type="TIMESTAMP WITH TIME ZONE"/>

            <!-- Status & Progress -->
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="priority" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="progress_percentage" type="INTEGER" defaultValue="0"/>

            <!-- Ownership -->
            <column name="owner_name" type="VARCHAR(255)"/>
            <column name="owner_role" type="VARCHAR(100)"/>

            <!-- Dependencies -->
            <column name="blocks_tasks" type="TEXT"/>
            <column name="blocked_by_tasks" type="TEXT"/>

            <!-- Success Metrics -->
            <column name="success_metrics" type="TEXT"/>
            <column name="actual_outcomes" type="TEXT"/>

            <!-- Phase 2 Context -->
            <column name="phase2_week" type="INTEGER"/>
            <column name="sprint_cycle" type="VARCHAR(255)"/>

            <!-- Audit -->
            <column name="notes" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Indexes for query performance -->
        <createIndex indexName="idx_phase2_tenant_status" tableName="phase2_execution_tasks">
            <column name="tenant_id"/>
            <column name="status"/>
        </createIndex>

        <createIndex indexName="idx_phase2_category" tableName="phase2_execution_tasks">
            <column name="task_category"/>
        </createIndex>

        <createIndex indexName="idx_phase2_due_date" tableName="phase2_execution_tasks">
            <column name="target_due_date"/>
        </createIndex>

        <createIndex indexName="idx_phase2_owner" tableName="phase2_execution_tasks">
            <column name="owner_name"/>
        </createIndex>

        <createIndex indexName="idx_phase2_week" tableName="phase2_execution_tasks">
            <column name="phase2_week"/>
        </createIndex>

        <!-- Rollback instructions for this changeset -->
        <rollback>
            <dropTable tableName="phase2_execution_tasks"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
