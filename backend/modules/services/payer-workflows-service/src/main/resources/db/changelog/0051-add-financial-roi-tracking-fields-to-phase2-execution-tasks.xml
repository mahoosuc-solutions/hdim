<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="0051-add-financial-roi-tracking-fields-to-phase2-execution-tasks" author="hdim">
        <!-- Financial ROI Tracking Fields -->

        <!-- HEDIS Measure Code -->
        <addColumn tableName="phase2_execution_tasks">
            <column name="hedise_measure" type="VARCHAR(10)"/>
        </addColumn>

        <!-- Baseline Performance Percentage (5,2 precision) -->
        <addColumn tableName="phase2_execution_tasks">
            <column name="baseline_performance_percentage" type="NUMERIC(5,2)"/>
        </addColumn>

        <!-- Current Performance Percentage (5,2 precision) -->
        <addColumn tableName="phase2_execution_tasks">
            <column name="current_performance_percentage" type="NUMERIC(5,2)"/>
        </addColumn>

        <!-- Quality Bonus At Risk (12,2 precision) -->
        <addColumn tableName="phase2_execution_tasks">
            <column name="quality_bonus_at_risk" type="NUMERIC(12,2)"/>
        </addColumn>

        <!-- Quality Bonus Captured (12,2 precision) -->
        <addColumn tableName="phase2_execution_tasks">
            <column name="quality_bonus_captured" type="NUMERIC(12,2)"/>
        </addColumn>

        <!-- Intervention Type -->
        <addColumn tableName="phase2_execution_tasks">
            <column name="intervention_type" type="VARCHAR(50)"/>
        </addColumn>

        <!-- Gaps Closed -->
        <addColumn tableName="phase2_execution_tasks">
            <column name="gaps_closed" type="INTEGER"/>
        </addColumn>

        <!-- Cost Per Gap (10,2 precision) -->
        <addColumn tableName="phase2_execution_tasks">
            <column name="cost_per_gap" type="NUMERIC(10,2)"/>
        </addColumn>

        <!-- ROI Percentage (8,2 precision) -->
        <addColumn tableName="phase2_execution_tasks">
            <column name="roi_percentage" type="NUMERIC(8,2)"/>
        </addColumn>

        <!-- Customer Quote (Text) -->
        <addColumn tableName="phase2_execution_tasks">
            <column name="customer_quote" type="TEXT"/>
        </addColumn>

        <!-- Case Study Published Flag (Boolean) -->
        <addColumn tableName="phase2_execution_tasks">
            <column name="case_study_published" type="BOOLEAN"/>
        </addColumn>

        <!-- Create indexes for financial data queries -->
        <createIndex indexName="idx_phase2_hedise_measure" tableName="phase2_execution_tasks">
            <column name="hedise_measure"/>
        </createIndex>

        <createIndex indexName="idx_phase2_roi_percentage" tableName="phase2_execution_tasks">
            <column name="roi_percentage"/>
        </createIndex>

        <createIndex indexName="idx_phase2_gaps_closed" tableName="phase2_execution_tasks">
            <column name="gaps_closed"/>
        </createIndex>

        <createIndex indexName="idx_phase2_case_study_published" tableName="phase2_execution_tasks">
            <column name="case_study_published"/>
        </createIndex>

        <!-- Rollback instructions for this changeset -->
        <rollback>
            <!-- Drop indexes first -->
            <dropIndex indexName="idx_phase2_case_study_published" tableName="phase2_execution_tasks"/>
            <dropIndex indexName="idx_phase2_gaps_closed" tableName="phase2_execution_tasks"/>
            <dropIndex indexName="idx_phase2_roi_percentage" tableName="phase2_execution_tasks"/>
            <dropIndex indexName="idx_phase2_hedise_measure" tableName="phase2_execution_tasks"/>
            <!-- Drop columns -->
            <dropColumn tableName="phase2_execution_tasks" columnName="hedise_measure"/>
            <dropColumn tableName="phase2_execution_tasks" columnName="baseline_performance_percentage"/>
            <dropColumn tableName="phase2_execution_tasks" columnName="current_performance_percentage"/>
            <dropColumn tableName="phase2_execution_tasks" columnName="quality_bonus_at_risk"/>
            <dropColumn tableName="phase2_execution_tasks" columnName="quality_bonus_captured"/>
            <dropColumn tableName="phase2_execution_tasks" columnName="intervention_type"/>
            <dropColumn tableName="phase2_execution_tasks" columnName="gaps_closed"/>
            <dropColumn tableName="phase2_execution_tasks" columnName="cost_per_gap"/>
            <dropColumn tableName="phase2_execution_tasks" columnName="roi_percentage"/>
            <dropColumn tableName="phase2_execution_tasks" columnName="customer_quote"/>
            <dropColumn tableName="phase2_execution_tasks" columnName="case_study_published"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
