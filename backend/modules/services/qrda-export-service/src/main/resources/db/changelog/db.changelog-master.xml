<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <changeSet id="001-create-quality-schema" author="hdim">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM information_schema.schemata WHERE schema_name = 'quality'
            </sqlCheck>
        </preConditions>
        <sql>CREATE SCHEMA IF NOT EXISTS quality;</sql>

        <rollback>
            <sql>DROP SCHEMA IF EXISTS quality CASCADE;</sql>
        </rollback>
    </changeSet>

    <changeSet id="002-create-qrda-export-jobs-table" author="hdim">
        <createTable tableName="qrda_export_jobs" schemaName="quality">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="job_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="measure_ids" type="JSONB"/>
            <column name="patient_ids" type="JSONB"/>
            <column name="period_start" type="DATE"/>
            <column name="period_end" type="DATE"/>
            <column name="document_location" type="VARCHAR(500)"/>
            <column name="document_count" type="INTEGER"/>
            <column name="patient_count" type="INTEGER"/>
            <column name="error_message" type="TEXT"/>
            <column name="validation_errors" type="JSONB"/>
            <column name="requested_by" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="started_at" type="TIMESTAMP"/>
            <column name="completed_at" type="TIMESTAMP"/>
        </createTable>

        <createIndex tableName="qrda_export_jobs" schemaName="quality" indexName="idx_qrda_jobs_tenant">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex tableName="qrda_export_jobs" schemaName="quality" indexName="idx_qrda_jobs_status">
            <column name="tenant_id"/>
            <column name="status"/>
        </createIndex>

        <createIndex tableName="qrda_export_jobs" schemaName="quality" indexName="idx_qrda_jobs_created">
            <column name="tenant_id"/>
            <column name="created_at"/>
        </createIndex>

        <rollback>
            <dropTable tableName="qrda_export_jobs" schemaName="quality"/>
        </rollback>
    </changeSet>

    <changeSet id="003-create-cms-submissions-table" author="hdim">
        <createTable tableName="cms_submissions" schemaName="quality">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="submission_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="program_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="submission_year" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="performance_period_start" type="TIMESTAMP"/>
            <column name="performance_period_end" type="TIMESTAMP"/>
            <column name="qrda_job_id" type="UUID">
                <constraints foreignKeyName="fk_cms_submissions_qrda_job"
                    references="quality.qrda_export_jobs(id)"/>
            </column>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="submission_reference" type="VARCHAR(255)"/>
            <column name="cms_tracking_number" type="VARCHAR(100)"/>
            <column name="submission_metadata" type="JSONB"/>
            <column name="measure_results" type="JSONB"/>
            <column name="submitted_by" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="submitted_at" type="TIMESTAMP"/>
            <column name="acknowledged_at" type="TIMESTAMP"/>
        </createTable>

        <createIndex tableName="cms_submissions" schemaName="quality" indexName="idx_cms_submissions_tenant">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex tableName="cms_submissions" schemaName="quality" indexName="idx_cms_submissions_year">
            <column name="tenant_id"/>
            <column name="submission_year"/>
        </createIndex>

        <createIndex tableName="cms_submissions" schemaName="quality" indexName="idx_cms_submissions_tracking">
            <column name="cms_tracking_number"/>
        </createIndex>

        <rollback>
            <dropTable tableName="cms_submissions" schemaName="quality"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
