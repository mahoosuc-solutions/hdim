# ============================================================================
# Optimized Multi-Stage Dockerfile for Quality Measure Service
# ============================================================================
# Expected size reduction: 753MB → ~380MB (49% reduction)
# Optimizations:
# - Multi-stage build (JDK for build, JRE for runtime)
# - BuildKit cache mounts for dependency caching
# - Excludes test jars from final image
# - Container-optimized JVM settings
# ============================================================================

# ============================================================================
# BUILD STAGE
# ============================================================================
FROM eclipse-temurin:21-jdk-alpine AS builder

WORKDIR /workspace/app

# Copy Gradle wrapper and build files
COPY gradlew .
COPY gradle gradle
COPY build.gradle.kts .
COPY settings.gradle.kts .

# Copy shared modules (required dependencies)
COPY modules/shared modules/shared
COPY platform platform

# Copy the quality-measure service module
COPY modules/services/quality-measure-service modules/services/quality-measure-service

# Build the application with BuildKit cache mount for Gradle dependencies
# This significantly speeds up rebuilds by caching downloaded dependencies
RUN --mount=type=cache,target=/root/.gradle \
    chmod +x gradlew && \
    ./gradlew :modules:services:quality-measure-service:bootJar -x test --no-daemon

# ============================================================================
# RUNTIME STAGE
# ============================================================================
FROM eclipse-temurin:21-jre-alpine

LABEL maintainer="HDIM Platform Team"
LABEL service="quality-measure-service"
LABEL description="Quality Measure Service for HEDIS Evaluation"

# Install wget for health checks
RUN apk add --no-cache wget

WORKDIR /app

# Create non-root user for security (HIPAA compliance)
RUN addgroup -g 1001 -S healthdata && \
    adduser -u 1001 -S healthdata -G healthdata -h /app

# Copy ONLY the runtime JAR from builder (not test jars)
# This is the key size optimization
COPY --from=builder /workspace/app/modules/services/quality-measure-service/build/libs/quality-measure-service.jar app.jar

# Set ownership to non-root user
RUN chown -R healthdata:healthdata /app

# Switch to non-root user
USER healthdata

# JVM optimization for containers (standardized across all services)
ENV JAVA_OPTS="-XX:+UseContainerSupport \
    -XX:MaxRAMPercentage=75.0 \
    -XX:+UseG1GC \
    -XX:+UseStringDeduplication \
    -XX:+OptimizeStringConcat \
    -Djava.security.egd=file:/dev/./urandom"

EXPOSE 8087

HEALTHCHECK --interval=30s --timeout=10s --retries=3 --start-period=60s \
    CMD wget --no-verbose --tries=1 --spider http://localhost:8087/quality-measure/actuator/health || exit 1

ENTRYPOINT ["sh", "-c", "java $JAVA_OPTS -jar app.jar"]

# ============================================================================
# BUILD INSTRUCTIONS
# ============================================================================
# To build with BuildKit cache support (recommended):
#   cd /mnt/wd-black/dev/projects/hdim-master/backend
#   DOCKER_BUILDKIT=1 docker build -t hdim-quality-measure-service:latest -f modules/services/quality-measure-service/Dockerfile.optimized .
#
# To build without cache:
#   docker build --no-cache -t hdim-quality-measure-service:latest -f modules/services/quality-measure-service/Dockerfile.optimized .
# ============================================================================
