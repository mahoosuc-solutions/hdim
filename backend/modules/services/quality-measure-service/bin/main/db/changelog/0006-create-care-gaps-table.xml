<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0006-create-care-gaps-table" author="healthdata-team">
        <comment>Create care gaps table for tracking identified care gaps requiring clinical attention</comment>

        <createTable tableName="care_gaps">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="tenant_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>

            <column name="patient_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>

            <column name="category" type="varchar(50)">
                <constraints nullable="false"/>
            </column>

            <column name="gap_type" type="varchar(100)">
                <constraints nullable="false"/>
            </column>

            <column name="title" type="varchar(255)">
                <constraints nullable="false"/>
            </column>

            <column name="description" type="text"/>

            <column name="priority" type="varchar(20)">
                <constraints nullable="false"/>
            </column>

            <column name="status" type="varchar(20)">
                <constraints nullable="false"/>
            </column>

            <column name="quality_measure" type="varchar(50)"/>

            <column name="recommendation" type="text"/>

            <column name="evidence" type="text"/>

            <column name="due_date" type="timestamp with time zone"/>

            <column name="identified_date" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>

            <column name="addressed_date" type="timestamp with time zone"/>

            <column name="addressed_by" type="varchar(255)"/>

            <column name="addressed_notes" type="text"/>

            <column name="created_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Index for patient + status queries -->
        <createIndex indexName="idx_cg_patient_status" tableName="care_gaps">
            <column name="patient_id"/>
            <column name="status"/>
        </createIndex>

        <!-- Index for patient + priority queries -->
        <createIndex indexName="idx_cg_patient_priority" tableName="care_gaps">
            <column name="patient_id"/>
            <column name="priority"/>
        </createIndex>

        <!-- Index for due date queries -->
        <createIndex indexName="idx_cg_due_date" tableName="care_gaps">
            <column name="due_date"/>
        </createIndex>

        <!-- Index for quality measure tracking -->
        <createIndex indexName="idx_cg_quality_measure" tableName="care_gaps">
            <column name="quality_measure"/>
        </createIndex>

        <!-- Index for tenant isolation -->
        <createIndex indexName="idx_cg_tenant" tableName="care_gaps">
            <column name="tenant_id"/>
        </createIndex>

        <!-- Composite index for tenant + patient queries -->
        <createIndex indexName="idx_cg_tenant_patient" tableName="care_gaps">
            <column name="tenant_id"/>
            <column name="patient_id"/>
        </createIndex>

        <!-- Composite index for category queries -->
        <createIndex indexName="idx_cg_patient_category" tableName="care_gaps">
            <column name="patient_id"/>
            <column name="category"/>
        </createIndex>

        <rollback>
            <dropTable tableName="care_gaps"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
