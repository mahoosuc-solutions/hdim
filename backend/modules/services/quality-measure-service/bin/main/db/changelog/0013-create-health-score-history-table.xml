<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0009-create-health-score-history-table" author="health-score-service">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="health_score_history"/>
            </not>
        </preConditions>
        <comment>
            Create health_score_history table for trend analysis.
            Stores historical snapshots of health scores for tracking patient progress over time.
        </comment>

        <createTable tableName="health_score_history">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="patient_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>

            <column name="tenant_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>

            <!-- Scores (0-100) -->
            <column name="overall_score" type="decimal(5,2)">
                <constraints nullable="false"/>
            </column>

            <column name="physical_health_score" type="decimal(5,2)">
                <constraints nullable="false"/>
            </column>

            <column name="mental_health_score" type="decimal(5,2)">
                <constraints nullable="false"/>
            </column>

            <column name="social_determinants_score" type="decimal(5,2)">
                <constraints nullable="false"/>
            </column>

            <column name="preventive_care_score" type="decimal(5,2)">
                <constraints nullable="false"/>
            </column>

            <column name="chronic_disease_score" type="decimal(5,2)">
                <constraints nullable="false"/>
            </column>

            <!-- Comparison data -->
            <column name="calculated_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>

            <column name="previous_score" type="decimal(5,2)">
                <constraints nullable="true"/>
            </column>

            <column name="score_delta" type="decimal(6,2)">
                <constraints nullable="true"/>
            </column>

            <column name="change_reason" type="text">
                <constraints nullable="true"/>
            </column>

            <!-- Audit -->
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Indexes for trend queries -->
        <createIndex indexName="idx_hsh_patient_date" tableName="health_score_history">
            <column name="patient_id"/>
            <column name="calculated_at" descending="true"/>
        </createIndex>

        <createIndex indexName="idx_hsh_tenant" tableName="health_score_history">
            <column name="tenant_id"/>
            <column name="calculated_at" descending="true"/>
        </createIndex>

        <createIndex indexName="idx_hsh_tenant_patient" tableName="health_score_history">
            <column name="tenant_id"/>
            <column name="patient_id"/>
            <column name="calculated_at" descending="true"/>
        </createIndex>

        <rollback>
            <dropTable tableName="health_score_history"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
