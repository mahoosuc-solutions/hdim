<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0012-create-ml-predictions-table" author="healthdata-team">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="ml_predictions"/>
            </not>
        </preConditions>
        <comment>Create ML predictions table for predictive analytics</comment>

        <createTable tableName="ml_predictions">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <!-- Tenant isolation -->
            <column name="tenant_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>

            <!-- Patient identification -->
            <column name="patient_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>

            <!-- Model information -->
            <column name="model_name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>

            <column name="model_version" type="varchar(20)">
                <constraints nullable="false"/>
            </column>

            <!-- Prediction details -->
            <column name="prediction_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>

            <column name="prediction_value" type="double precision">
                <constraints nullable="false"/>
            </column>

            <column name="confidence_score" type="double precision">
                <constraints nullable="false"/>
            </column>

            <!-- Features used for prediction (JSONB) -->
            <column name="features_used" type="jsonb">
                <constraints nullable="false"/>
            </column>

            <!-- Timestamps and outcomes -->
            <column name="predicted_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>

            <column name="outcome_date" type="timestamp with time zone">
                <constraints nullable="true"/>
            </column>

            <column name="actual_outcome" type="boolean">
                <constraints nullable="true"/>
            </column>

            <!-- Audit fields -->
            <column name="created_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Index for patient prediction history -->
        <createIndex indexName="idx_mlp_patient" tableName="ml_predictions">
            <column name="tenant_id"/>
            <column name="patient_id"/>
            <column name="predicted_at" descending="true"/>
        </createIndex>

        <!-- Index for prediction type queries -->
        <createIndex indexName="idx_mlp_type" tableName="ml_predictions">
            <column name="tenant_id"/>
            <column name="prediction_type"/>
            <column name="predicted_at" descending="true"/>
        </createIndex>

        <!-- Index for model performance queries -->
        <createIndex indexName="idx_mlp_model_performance" tableName="ml_predictions">
            <column name="tenant_id"/>
            <column name="model_name"/>
            <column name="model_version"/>
            <column name="actual_outcome"/>
        </createIndex>

        <!-- Index for high-risk predictions -->
        <createIndex indexName="idx_mlp_high_risk" tableName="ml_predictions">
            <column name="tenant_id"/>
            <column name="prediction_type"/>
            <column name="prediction_value"/>
        </createIndex>

        <!-- Index for outcome validation -->
        <createIndex indexName="idx_mlp_outcomes" tableName="ml_predictions">
            <column name="tenant_id"/>
            <column name="outcome_date"/>
            <column name="actual_outcome"/>
        </createIndex>

        <!-- Index for tenant isolation -->
        <createIndex indexName="idx_mlp_tenant" tableName="ml_predictions">
            <column name="tenant_id"/>
        </createIndex>

        <!-- GIN index on features_used for fast querying -->
        <sql>
            CREATE INDEX idx_mlp_features_gin ON ml_predictions USING GIN (features_used);
        </sql>

        <rollback>
            <dropTable tableName="ml_predictions"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
