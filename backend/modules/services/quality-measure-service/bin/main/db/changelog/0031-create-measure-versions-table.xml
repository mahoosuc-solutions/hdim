<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!--
        Issue #152: Measure Versioning and Audit Trail

        Creates measure_versions table to store immutable version history
        for custom quality measures. Supports HIPAA compliance with:
        - Immutable version records (no DELETE/UPDATE on CQL content)
        - Full audit trail with author and timestamp
        - Change summary documentation
    -->
    <changeSet id="0031-create-measure-versions-table" author="claude-code">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="measure_versions"/>
            </not>
        </preConditions>
        <createTable tableName="measure_versions" remarks="Immutable version history for custom measures - HIPAA audit trail">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)" remarks="Tenant isolation">
                <constraints nullable="false"/>
            </column>
            <column name="measure_id" type="UUID" remarks="Reference to custom_measures table">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="VARCHAR(20)" remarks="Semantic version (major.minor.patch)">
                <constraints nullable="false"/>
            </column>
            <column name="version_type" type="VARCHAR(20)" remarks="MAJOR, MINOR, PATCH">
                <constraints nullable="false"/>
            </column>
            <column name="cql_text" type="TEXT" remarks="CQL code at this version - immutable">
                <constraints nullable="false"/>
            </column>
            <column name="value_sets" type="JSONB" remarks="Value sets at this version"/>
            <column name="metadata" type="JSONB" remarks="Additional version metadata"/>
            <column name="change_summary" type="TEXT" remarks="Description of changes in this version"/>
            <column name="created_by" type="UUID" remarks="User who created this version">
                <constraints nullable="false"/>
            </column>
            <column name="created_by_name" type="VARCHAR(255)" remarks="Username for display"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="NOW()" remarks="When version was created">
                <constraints nullable="false"/>
            </column>
            <column name="is_current" type="BOOLEAN" defaultValueBoolean="false" remarks="Whether this is the active version">
                <constraints nullable="false"/>
            </column>
            <column name="is_published" type="BOOLEAN" defaultValueBoolean="false" remarks="Whether this version was published to production">
                <constraints nullable="false"/>
            </column>
            <column name="published_at" type="TIMESTAMP WITH TIME ZONE" remarks="When version was published"/>
            <column name="published_by" type="UUID" remarks="User who published"/>
        </createTable>

        <!-- Unique constraint: one version number per measure -->
        <addUniqueConstraint
            constraintName="uk_measure_versions_measure_version"
            tableName="measure_versions"
            columnNames="measure_id, version"/>

        <!-- Foreign key to custom_measures -->
        <addForeignKeyConstraint
            constraintName="fk_measure_versions_measure"
            baseTableName="measure_versions"
            baseColumnNames="measure_id"
            referencedTableName="custom_measures"
            referencedColumnNames="id"
            onDelete="CASCADE"/>

        <!-- Index for efficient lookups by measure -->
        <createIndex indexName="idx_measure_versions_measure_id" tableName="measure_versions">
            <column name="measure_id"/>
        </createIndex>

        <!-- Index for tenant isolation -->
        <createIndex indexName="idx_measure_versions_tenant_id" tableName="measure_versions">
            <column name="tenant_id"/>
        </createIndex>

        <!-- Index for current version lookup -->
        <createIndex indexName="idx_measure_versions_current" tableName="measure_versions">
            <column name="measure_id"/>
            <column name="is_current"/>
        </createIndex>

        <!-- Index for version history queries -->
        <createIndex indexName="idx_measure_versions_created_at" tableName="measure_versions">
            <column name="measure_id"/>
            <column name="created_at" descending="true"/>
        </createIndex>

        <rollback>
            <dropTable tableName="measure_versions"/>
        </rollback>
    </changeSet>

    <!-- Add comment explaining HIPAA immutability requirement -->
    <changeSet id="0031-add-measure-versions-comments" author="claude-code">
        <sql>
            COMMENT ON TABLE measure_versions IS 'HIPAA COMPLIANCE: Records in this table are immutable after creation. The cql_text and value_sets columns must never be modified - only new versions should be created.';
        </sql>

        <rollback>
            <sql>
                COMMENT ON TABLE measure_versions IS NULL;
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
