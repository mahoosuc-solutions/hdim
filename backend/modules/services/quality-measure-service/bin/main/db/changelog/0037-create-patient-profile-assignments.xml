<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!--
        Phase 4: Patient Profile Assignments

        Creates patient_profile_assignments table to track which configuration
        profiles are assigned to which patients.

        Features:
        - Manual and automatic assignment support
        - Date-based activation
        - Multi-profile support per patient
        - Full audit trail
    -->
    <changeSet id="0037-create-patient-profile-assignments" author="claude-code">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="patient_profile_assignments"/>
            </not>
        </preConditions>

        <comment>Create patient profile assignments to link patients with configuration profiles</comment>

        <createTable tableName="patient_profile_assignments">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_patient_profile_assignments"/>
            </column>

            <!-- Tenant Isolation -->
            <column name="tenant_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <!-- Core References -->
            <column name="patient_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="profile_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_ppa_profile"
                             references="measure_config_profiles(id)"
                             deleteCascade="true"/>
            </column>

            <!-- Assignment Details -->
            <column name="assigned_by" type="UUID"/>
            <column name="assigned_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="auto_assigned" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="assignment_reason" type="TEXT"/>

            <!-- Status -->
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="effective_from" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="effective_until" type="DATE"/>

            <!-- Audit -->
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Unique constraint: one active assignment per patient-profile -->
        <addUniqueConstraint
            constraintName="uk_ppa_patient_profile_active"
            tableName="patient_profile_assignments"
            columnNames="patient_id, profile_id, active"/>

        <!-- Indexes for performance -->
        <createIndex indexName="idx_ppa_patient_active" tableName="patient_profile_assignments">
            <column name="patient_id"/>
            <column name="active"/>
        </createIndex>

        <createIndex indexName="idx_ppa_profile" tableName="patient_profile_assignments">
            <column name="profile_id"/>
        </createIndex>

        <createIndex indexName="idx_ppa_tenant" tableName="patient_profile_assignments">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_ppa_effective_period" tableName="patient_profile_assignments">
            <column name="effective_from"/>
            <column name="effective_until"/>
        </createIndex>

        <createIndex indexName="idx_ppa_auto_assigned" tableName="patient_profile_assignments">
            <column name="auto_assigned"/>
            <column name="active"/>
        </createIndex>

        <!-- Comments for documentation -->
        <sql>
            COMMENT ON TABLE patient_profile_assignments IS 'Links patients to measure configuration profiles';
            COMMENT ON COLUMN patient_profile_assignments.auto_assigned IS 'True if system automatically assigned based on profile population_criteria';
        </sql>

        <rollback>
            <dropTable tableName="patient_profile_assignments"/>
        </rollback>
    </changeSet>

    <!-- Add CHECK constraints -->
    <changeSet id="0037-add-ppa-check-constraints" author="claude-code">
        <sql>
            ALTER TABLE patient_profile_assignments
                ADD CONSTRAINT chk_ppa_effective_dates
                    CHECK (effective_until IS NULL OR effective_until >= effective_from);
        </sql>

        <rollback>
            <sql>
                ALTER TABLE patient_profile_assignments DROP CONSTRAINT IF EXISTS chk_ppa_effective_dates;
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
