<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!--
        Phase 5: Measure Modification Audit

        Creates measure_modification_audit table to track all changes to measure
        definitions, overrides, and configurations for compliance and debugging.

        Features:
        - Complete change tracking (CREATE, UPDATE, DELETE)
        - Before/after values
        - Approval workflow integration
        - Impact assessment
        - Rollback capability
        - HIPAA compliance audit trail
    -->
    <changeSet id="0039-create-measure-modification-audit" author="claude-code">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="measure_modification_audit"/>
            </not>
        </preConditions>

        <comment>Create measure modification audit for tracking all changes to measures</comment>

        <createTable tableName="measure_modification_audit">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_measure_modification_audit"/>
            </column>

            <!-- Tenant Isolation -->
            <column name="tenant_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <!-- What Changed -->
            <column name="entity_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="entity_name" type="VARCHAR(255)"/>

            <!-- Change Details -->
            <column name="operation" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="field_name" type="VARCHAR(100)"/>
            <column name="old_value" type="TEXT"/>
            <column name="new_value" type="TEXT"/>
            <column name="change_summary" type="TEXT">
                <constraints nullable="false"/>
            </column>

            <!-- Context -->
            <column name="reason" type="TEXT"/>
            <column name="impact_assessment" type="TEXT"/>
            <column name="rollback_available" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="rollback_data" type="JSONB"/>

            <!-- Approval Workflow -->
            <column name="requires_approval" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="approval_status" type="VARCHAR(50)"/>
            <column name="approved_by" type="UUID"/>
            <column name="approved_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="approval_notes" type="TEXT"/>

            <!-- Who/When/Where -->
            <column name="modified_by" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="modified_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="ip_address" type="VARCHAR(45)"/>
            <column name="user_agent" type="TEXT"/>

            <!-- Audit -->
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Indexes for performance -->
        <createIndex indexName="idx_mma_entity" tableName="measure_modification_audit">
            <column name="entity_type"/>
            <column name="entity_id"/>
            <column name="modified_at" descending="true"/>
        </createIndex>

        <createIndex indexName="idx_mma_modified_by" tableName="measure_modification_audit">
            <column name="modified_by"/>
            <column name="modified_at" descending="true"/>
        </createIndex>

        <createIndex indexName="idx_mma_tenant" tableName="measure_modification_audit">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_mma_operation" tableName="measure_modification_audit">
            <column name="operation"/>
            <column name="modified_at" descending="true"/>
        </createIndex>

        <createIndex indexName="idx_mma_approval_status" tableName="measure_modification_audit">
            <column name="approval_status"/>
        </createIndex>

        <!-- GIN index for JSONB rollback_data -->
        <sql>
            CREATE INDEX idx_mma_rollback_data ON measure_modification_audit USING GIN (rollback_data);
        </sql>

        <!-- Comments for documentation -->
        <sql>
            COMMENT ON TABLE measure_modification_audit IS 'HIPAA COMPLIANCE: Immutable audit trail of all measure definition changes';
            COMMENT ON COLUMN measure_modification_audit.entity_type IS 'QUALITY_MEASURE, CUSTOM_MEASURE, PATIENT_OVERRIDE, CONFIG_PROFILE';
            COMMENT ON COLUMN measure_modification_audit.operation IS 'CREATE, UPDATE, DELETE, ACTIVATE, DEACTIVATE, PUBLISH, APPROVE, REJECT';
            COMMENT ON COLUMN measure_modification_audit.approval_status IS 'PENDING, APPROVED, REJECTED, NOT_REQUIRED';
            COMMENT ON COLUMN measure_modification_audit.rollback_data IS 'JSONB containing data needed to rollback this change';
        </sql>

        <rollback>
            <dropTable tableName="measure_modification_audit"/>
        </rollback>
    </changeSet>

    <!-- Add CHECK constraints -->
    <changeSet id="0039-add-mma-check-constraints" author="claude-code">
        <sql>
            ALTER TABLE measure_modification_audit
                ADD CONSTRAINT chk_mma_entity_type
                    CHECK (entity_type IN (
                        'QUALITY_MEASURE',
                        'CUSTOM_MEASURE',
                        'PATIENT_OVERRIDE',
                        'CONFIG_PROFILE',
                        'MEASURE_VERSION',
                        'PATIENT_ASSIGNMENT',
                        'PROFILE_ASSIGNMENT'
                    ));

            ALTER TABLE measure_modification_audit
                ADD CONSTRAINT chk_mma_operation
                    CHECK (operation IN (
                        'CREATE',
                        'UPDATE',
                        'DELETE',
                        'ACTIVATE',
                        'DEACTIVATE',
                        'PUBLISH',
                        'APPROVE',
                        'REJECT',
                        'ARCHIVE'
                    ));

            ALTER TABLE measure_modification_audit
                ADD CONSTRAINT chk_mma_approval_status
                    CHECK (approval_status IN ('PENDING', 'APPROVED', 'REJECTED', 'NOT_REQUIRED'));

            ALTER TABLE measure_modification_audit
                ADD CONSTRAINT chk_mma_approval
                    CHECK (
                        (requires_approval = false AND approval_status = 'NOT_REQUIRED') OR
                        (requires_approval = true AND approval_status IS NOT NULL)
                    );
        </sql>

        <rollback>
            <sql>
                ALTER TABLE measure_modification_audit DROP CONSTRAINT IF EXISTS chk_mma_entity_type;
                ALTER TABLE measure_modification_audit DROP CONSTRAINT IF EXISTS chk_mma_operation;
                ALTER TABLE measure_modification_audit DROP CONSTRAINT IF EXISTS chk_mma_approval_status;
                ALTER TABLE measure_modification_audit DROP CONSTRAINT IF EXISTS chk_mma_approval;
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
