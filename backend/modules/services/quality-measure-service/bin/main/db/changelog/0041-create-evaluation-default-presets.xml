<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!--
        Evaluation Default Presets

        Stores a single default evaluation preset per tenant and user scope.
        Used by the Evaluations page to auto-apply a default measure + patient.
    -->
    <changeSet id="0041-create-evaluation-default-presets" author="codex">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="evaluation_default_presets"/>
            </not>
        </preConditions>

        <comment>Create evaluation_default_presets table for shared evaluation defaults</comment>

        <createTable tableName="evaluation_default_presets">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_evaluation_default_presets"/>
            </column>

            <column name="tenant_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="user_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="measure_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="patient_id" type="UUID">
                <constraints nullable="false"/>
            </column>

            <column name="use_cql_engine" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <addUniqueConstraint
            tableName="evaluation_default_presets"
            columnNames="tenant_id,user_id"
            constraintName="uk_eval_default_preset_tenant_user"/>

        <createIndex indexName="idx_eval_default_preset_tenant" tableName="evaluation_default_presets">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_eval_default_preset_user" tableName="evaluation_default_presets">
            <column name="user_id"/>
        </createIndex>

        <createIndex indexName="idx_eval_default_preset_measure" tableName="evaluation_default_presets">
            <column name="measure_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="evaluation_default_presets"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
