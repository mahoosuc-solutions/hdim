package com.healthdata.quality.integration;

import static org.assertj.core.api.Assertions.assertThat;
import static org.awaitility.Awaitility.await;

import java.math.BigDecimal;
import java.time.Duration;
import java.time.Instant;
import java.util.List;
import java.util.UUID;
import java.util.concurrent.TimeUnit;
import java.util.concurrent.atomic.AtomicReference;

import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.boot.test.web.client.TestRestTemplate;
import org.springframework.http.HttpEntity;
import org.springframework.http.HttpHeaders;
import org.springframework.http.HttpMethod;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.kafka.core.KafkaTemplate;
import org.springframework.test.context.ActiveProfiles;
import org.springframework.test.context.DynamicPropertyRegistry;
import org.springframework.test.context.DynamicPropertySource;
import org.testcontainers.containers.KafkaContainer;
import org.testcontainers.containers.PostgreSQLContainer;
import org.testcontainers.junit.jupiter.Container;
import org.testcontainers.junit.jupiter.Testcontainers;
import org.testcontainers.utility.DockerImageName;

import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.healthdata.quality.dto.CareGapDTO;
import com.healthdata.quality.dto.ClinicalAlertDTO;
import com.healthdata.quality.dto.HealthScoreDTO;
import com.healthdata.quality.dto.RiskAssessmentDTO;
import com.healthdata.quality.persistence.CareGapEntity;
import com.healthdata.quality.persistence.CareGapRepository;
import com.healthdata.quality.persistence.ClinicalAlertRepository;
import com.healthdata.quality.persistence.HealthScoreRepository;
import com.healthdata.quality.persistence.RiskAssessmentRepository;

/**
 * End-to-End Integration Test Suite
 *
 * Tests the complete event-driven patient health assessment workflow:
 * 1. Patient visits doctor
 * 2. FHIR Observation created (HbA1c = 9.5%)
 * 3. Triggers: Risk reassessment (HIGH)
 * 4. Triggers: Chronic disease deterioration alert
 * 5. Triggers: Care gap creation (diabetes control)
 * 6. Triggers: Health score recalculation (decline)
 * 7. Triggers: Clinical alert (MEDIUM severity)
 * 8. Triggers: Multi-channel notifications
 * 9. Updates: Patient health summary (read model)
 * 10. Stores: Event in event store
 *
 * Target: Complete workflow within 5 seconds
 */
@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
@ActiveProfiles("test")
@Testcontainers
@DisplayName("End-to-End Integration Tests")
public class EndToEndIntegrationTest {

    @Container
    static PostgreSQLContainer<?> postgres = new PostgreSQLContainer<>("postgres:14-alpine")
            .withDatabaseName("healthdata_test")
            .withUsername("test")
            .withPassword("test");

    @Container
    static KafkaContainer kafka = new KafkaContainer(DockerImageName.parse("confluentinc/cp-kafka:7.4.0"));

    @DynamicPropertySource
    static void configureProperties(DynamicPropertyRegistry registry) {
        registry.add("spring.datasource.url", postgres::getJdbcUrl);
        registry.add("spring.datasource.username", postgres::getUsername);
        registry.add("spring.datasource.password", postgres::getPassword);
        registry.add("spring.kafka.bootstrap-servers", kafka::getBootstrapServers);
    }

    @Autowired
    private TestRestTemplate restTemplate;

    @Autowired
    private KafkaTemplate<String, Object> kafkaTemplate;

    @Autowired
    private CareGapRepository careGapRepository;

    @Autowired
    private HealthScoreRepository healthScoreRepository;

    @Autowired
    private RiskAssessmentRepository riskAssessmentRepository;

    @Autowired
    private ClinicalAlertRepository clinicalAlertRepository;

    @Autowired
    private ObjectMapper objectMapper;

    private static final String TENANT_ID = "tenant-integration-test";
    private static final String PATIENT_ID = "patient-" + UUID.randomUUID();

    @BeforeEach
    void setUp() {
        // Clean up test data
        careGapRepository.deleteAll();
        healthScoreRepository.deleteAll();
        riskAssessmentRepository.deleteAll();
        clinicalAlertRepository.deleteAll();
    }

    @Test
    @DisplayName("Complete Patient Health Workflow - HbA1c Deterioration")
    void testCompletePatientHealthWorkflow() throws Exception {
        Instant startTime = Instant.now();

        // STEP 1: Create baseline patient data
        createPatientBaseline();

        // STEP 2: Create FHIR Observation (HbA1c = 9.5% - deteriorating)
        String observationId = createHbA1cObservation(9.5);

        // STEP 3: Wait for event-driven cascade to complete
        await("Risk assessment updated")
                .atMost(5, TimeUnit.SECONDS)
                .pollInterval(100, TimeUnit.MILLISECONDS)
                .untilAsserted(() -> {
                    var riskAssessment = riskAssessmentRepository
                            .findLatestByTenantIdAndPatientId(TENANT_ID, PATIENT_ID);
                    assertThat(riskAssessment).isPresent();
                    assertThat(riskAssessment.get().getRiskLevel()).isIn("HIGH", "VERY_HIGH");
                });

        // STEP 4: Verify care gap created
        await("Care gap created")
                .atMost(5, TimeUnit.SECONDS)
                .pollInterval(100, TimeUnit.MILLISECONDS)
                .untilAsserted(() -> {
                    List<CareGapEntity> careGaps = careGapRepository
                            .findByTenantIdAndPatientIdAndStatus(TENANT_ID, PATIENT_ID, CareGapEntity.CareGapStatus.OPEN);
                    assertThat(careGaps).isNotEmpty();
                    assertThat(careGaps).anyMatch(gap ->
                            gap.getCategory() == CareGapEntity.CareGapCategory.CHRONIC_DISEASE &&
                            gap.getPriority() == CareGapEntity.CareGapPriority.URGENT
                    );
                });

        // STEP 5: Verify health score recalculated (should decline)
        AtomicReference<Double> healthScore = new AtomicReference<>();
        await("Health score updated")
                .atMost(5, TimeUnit.SECONDS)
                .pollInterval(100, TimeUnit.MILLISECONDS)
                .untilAsserted(() -> {
                    var score = healthScoreRepository
                            .findLatestByTenantIdAndPatientId(TENANT_ID, PATIENT_ID);
                    assertThat(score).isPresent();
                    healthScore.set(score.get().getOverallScore());
                    // Score should be less than 70 due to poor HbA1c control
                    assertThat(score.get().getOverallScore()).isLessThan(70.0);
                });

        // STEP 6: Verify clinical alert triggered
        await("Clinical alert created")
                .atMost(5, TimeUnit.SECONDS)
                .pollInterval(100, TimeUnit.MILLISECONDS)
                .untilAsserted(() -> {
                    var alerts = clinicalAlertRepository
                            .findByTenantIdAndPatientIdAndStatus(
                                    TENANT_ID, PATIENT_ID, "ACTIVE");
                    assertThat(alerts).isNotEmpty();
                    assertThat(alerts).anyMatch(alert ->
                            alert.getAlertType().contains("CHRONIC_DETERIORATION") ||
                            alert.getAlertType().contains("HEALTH_DECLINE")
                    );
                });

        // STEP 7: Verify total workflow time
        Duration totalDuration = Duration.between(startTime, Instant.now());
        assertThat(totalDuration).isLessThan(Duration.ofSeconds(5));

        // STEP 8: Verify data consistency across all systems
        verifyDataConsistency(observationId, healthScore.get());
    }

    @Test
    @DisplayName("Care Gap Auto-Closure Workflow")
    void testCareGapAutoClosureWorkflow() throws Exception {
        // STEP 1: Create open care gap for colonoscopy
        CareGapEntity careGap = createColonoscopyCaregap();

        // STEP 2: Patient receives colonoscopy
        String procedureId = createColonoscopyProcedure();

        // STEP 3: Wait for auto-closure
        await("Care gap auto-closed")
                .atMost(5, TimeUnit.SECONDS)
                .pollInterval(100, TimeUnit.MILLISECONDS)
                .untilAsserted(() -> {
                    var updated = careGapRepository.findById(careGap.getId());
                    assertThat(updated).isPresent();
                    assertThat(updated.get().getStatus()).isEqualTo(CareGapEntity.CareGapStatus.CLOSED);
                    assertThat(updated.get().getAutoClosed()).isTrue();
                    assertThat(updated.get().getEvidenceResourceId()).isEqualTo(procedureId);
                    assertThat(updated.get().getEvidenceResourceType()).isEqualTo("Procedure");
                });

        // STEP 4: Verify health score improved
        await("Health score improved")
                .atMost(5, TimeUnit.SECONDS)
                .pollInterval(100, TimeUnit.MILLISECONDS)
                .untilAsserted(() -> {
                    var score = healthScoreRepository
                            .findLatestByTenantIdAndPatientId(TENANT_ID, PATIENT_ID);
                    assertThat(score).isPresent();
                    // Preventive care score should improve
                    assertThat(score.get().getPreventiveCareScore()).isGreaterThan(70.0);
                });
    }

    @Test
    @DisplayName("Mental Health Crisis Detection Workflow")
    void testMentalHealthCrisisDetectionWorkflow() throws Exception {
        // STEP 1: Submit PHQ-9 assessment with score 22 (severe depression)
        String assessmentId = submitPhq9Assessment(22);

        // STEP 2: Verify CRITICAL alert triggered
        await("Critical mental health alert created")
                .atMost(3, TimeUnit.SECONDS)
                .pollInterval(100, TimeUnit.MILLISECONDS)
                .untilAsserted(() -> {
                    var alerts = clinicalAlertRepository
                            .findByTenantIdAndPatientIdAndStatus(TENANT_ID, PATIENT_ID, "ACTIVE");
                    assertThat(alerts).isNotEmpty();
                    assertThat(alerts).anyMatch(alert ->
                            alert.getSeverity().equals("CRITICAL") &&
                            alert.getAlertType().contains("MENTAL_HEALTH_CRISIS")
                    );
                });

        // STEP 3: Verify health score reflects mental health deterioration
        await("Health score updated with mental health component")
                .atMost(5, TimeUnit.SECONDS)
                .pollInterval(100, TimeUnit.MILLISECONDS)
                .untilAsserted(() -> {
                    var score = healthScoreRepository
                            .findLatestByTenantIdAndPatientId(TENANT_ID, PATIENT_ID);
                    assertThat(score).isPresent();
                    // Mental health score should be low
                    assertThat(score.get().getMentalHealthScore()).isLessThan(50.0);
                });

        // STEP 4: Verify notification sent (check WebSocket or email mock)
        // This would require WebSocket client or email mock verification
    }

    @Test
    @DisplayName("Population Calculation Performance Test")
    void testPopulationCalculationPerformance() throws Exception {
        // STEP 1: Create 100 test patients
        for (int i = 0; i < 100; i++) {
            String patientId = "patient-perf-test-" + i;
            createPatient(patientId);
            createHbA1cObservationForPatient(patientId, 7.0 + (i % 5));  // Vary HbA1c
        }

        // STEP 2: Trigger population calculation
        Instant startTime = Instant.now();

        HttpHeaders headers = createHeaders();
        ResponseEntity<JsonNode> response = restTemplate.exchange(
                "/quality-measure/api/v1/population/calculate",
                HttpMethod.POST,
                new HttpEntity<>(createPopulationCalculationRequest(), headers),
                JsonNode.class
        );

        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.ACCEPTED);
        String jobId = response.getBody().get("jobId").asText();

        // STEP 3: Wait for completion
        await("Population calculation complete")
                .atMost(60, TimeUnit.SECONDS)
                .pollInterval(1, TimeUnit.SECONDS)
                .untilAsserted(() -> {
                    ResponseEntity<JsonNode> status = restTemplate.exchange(
                            "/quality-measure/api/v1/population/job/" + jobId + "/status",
                            HttpMethod.GET,
                            new HttpEntity<>(headers),
                            JsonNode.class
                    );
                    assertThat(status.getBody().get("status").asText()).isEqualTo("COMPLETED");
                });

        // STEP 4: Verify throughput
        Duration totalDuration = Duration.between(startTime, Instant.now());
        double patientsPerMinute = 100.0 / (totalDuration.toSeconds() / 60.0);
        assertThat(patientsPerMinute).isGreaterThan(1000);  // Target: >1000 patients/min
    }

    // =========================================================================
    // Helper Methods
    // =========================================================================

    private void createPatientBaseline() throws Exception {
        // Create patient with some baseline data
        createPatient(PATIENT_ID);
        Thread.sleep(100);
    }

    private String createHbA1cObservation(double value) throws Exception {
        String observationId = UUID.randomUUID().toString();

        // Publish FHIR observation event
        var observationEvent = new FhirObservationEvent(
                observationId,
                TENANT_ID,
                PATIENT_ID,
                "4548-4",  // LOINC code for HbA1c
                value,
                "%",
                Instant.now()
        );

        kafkaTemplate.send("fhir.observations.created", observationId, observationEvent);

        return observationId;
    }

    private String createHbA1cObservationForPatient(String patientId, double value) throws Exception {
        String observationId = UUID.randomUUID().toString();

        var observationEvent = new FhirObservationEvent(
                observationId,
                TENANT_ID,
                patientId,
                "4548-4",
                value,
                "%",
                Instant.now()
        );

        kafkaTemplate.send("fhir.observations.created", observationId, observationEvent);

        return observationId;
    }

    private CareGapEntity createColonoscopyCaregap() {
        CareGapEntity careGap = CareGapEntity.builder()
                .id(UUID.randomUUID())
                .tenantId(TENANT_ID)
                .patientId(PATIENT_ID)
                .category(CareGapEntity.CareGapCategory.SCREENING)
                .priority(CareGapEntity.CareGapPriority.MEDIUM)
                .status(CareGapEntity.CareGapStatus.OPEN)
                .title("Colorectal Cancer Screening")
                .matchingCodes("45378,45380,45385")  // CPT codes for colonoscopy
                .dueDate(Instant.now().plus(Duration.ofDays(30)))
                .createdAt(Instant.now())
                .updatedAt(Instant.now())
                .build();

        return careGapRepository.save(careGap);
    }

    private String createColonoscopyProcedure() throws Exception {
        String procedureId = UUID.randomUUID().toString();

        var procedureEvent = new FhirProcedureEvent(
                procedureId,
                TENANT_ID,
                PATIENT_ID,
                "45378",  // CPT code for colonoscopy
                "Colonoscopy",
                Instant.now()
        );

        kafkaTemplate.send("fhir.procedures.created", procedureId, procedureEvent);

        return procedureId;
    }

    private String submitPhq9Assessment(int score) throws Exception {
        String assessmentId = UUID.randomUUID().toString();

        var assessmentEvent = new MentalHealthAssessmentEvent(
                assessmentId,
                TENANT_ID,
                PATIENT_ID,
                "PHQ-9",
                score,
                27,  // max score
                Instant.now()
        );

        kafkaTemplate.send("mental-health-assessment.submitted", assessmentId, assessmentEvent);

        return assessmentId;
    }

    private void createPatient(String patientId) throws Exception {
        var patientEvent = new FhirPatientEvent(
                patientId,
                TENANT_ID,
                "Test Patient",
                "1980-01-01",
                Instant.now()
        );

        kafkaTemplate.send("fhir.patients.created", patientId, patientEvent);
    }

    private JsonNode createPopulationCalculationRequest() throws Exception {
        return objectMapper.readTree("""
                {
                    "tenantId": "%s",
                    "fhirServerUrl": "http://localhost:8085/fhir",
                    "measureIds": ["CMS125", "CMS134"],
                    "batchSize": 50
                }
                """.formatted(TENANT_ID));
    }

    private HttpHeaders createHeaders() {
        HttpHeaders headers = new HttpHeaders();
        headers.set("X-Tenant-ID", TENANT_ID);
        headers.set("Content-Type", "application/json");
        return headers;
    }

    private void verifyDataConsistency(String observationId, Double healthScore) {
        // Verify all data is consistent across systems
        assertThat(healthScore).isNotNull();

        var careGaps = careGapRepository.findByTenantIdAndPatientIdAndStatus(
                TENANT_ID, PATIENT_ID, CareGapEntity.CareGapStatus.OPEN);
        assertThat(careGaps).isNotEmpty();

        var riskAssessment = riskAssessmentRepository
                .findLatestByTenantIdAndPatientId(TENANT_ID, PATIENT_ID);
        assertThat(riskAssessment).isPresent();

        var alerts = clinicalAlertRepository
                .findByTenantIdAndPatientIdAndStatus(TENANT_ID, PATIENT_ID, "ACTIVE");
        assertThat(alerts).isNotEmpty();
    }

    // Event DTOs (would typically be in shared module)
    private record FhirObservationEvent(
            String id, String tenantId, String patientId,
            String code, double value, String unit, Instant timestamp) {
    }

    private record FhirProcedureEvent(
            String id, String tenantId, String patientId,
            String code, String display, Instant timestamp) {
    }

    private record FhirPatientEvent(
            String id, String tenantId, String name,
            String birthDate, Instant timestamp) {
    }

    private record MentalHealthAssessmentEvent(
            String id, String tenantId, String patientId,
            String type, int score, int maxScore, Instant timestamp) {
    }
}
