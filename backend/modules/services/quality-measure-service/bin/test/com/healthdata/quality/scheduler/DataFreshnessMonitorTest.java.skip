package com.healthdata.quality.scheduler;

import com.healthdata.quality.dto.CareGapDTO;
import com.healthdata.quality.persistence.CareGapEntity;
import com.healthdata.quality.service.CareGapService;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.ArgumentCaptor;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import java.time.Instant;
import java.time.temporal.ChronoUnit;
import java.util.Arrays;
import java.util.List;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.ArgumentMatchers.*;
import static org.mockito.Mockito.*;

/**
 * Test-Driven Development for Data Freshness Monitor
 *
 * Hourly: Check for stale data
 * Identify patients with:
 * - No evaluation in 30 days
 * - No vitals in 90 days
 * - No labs in 6 months
 * - No mental health screening in 1 year
 * Create care gaps for missing data
 */
@ExtendWith(MockitoExtension.class)
class DataFreshnessMonitorTest {

    @Mock
    private CareGapService careGapService;

    @InjectMocks
    private DataFreshnessMonitor monitor;

    private String tenantId;
    private Instant now;

    @BeforeEach
    void setUp() {
        tenantId = "test-tenant";
        now = Instant.now();
    }

    /**
     * TEST 1: Detect Stale Evaluations (>30 days)
     * Should identify patients without evaluations in 30 days
     */
    @Test
    void testDetectStaleEvaluations() {
        // Arrange
        List<StaleDataResult> stalePatients = Arrays.asList(
            new StaleDataResult("Patient/123", now.minus(35, ChronoUnit.DAYS)),
            new StaleDataResult("Patient/456", now.minus(45, ChronoUnit.DAYS))
        );

        when(monitor.findPatientsWithoutRecentEvaluations(tenantId, 30))
            .thenReturn(stalePatients);

        // Act
        monitor.checkStaleEvaluations(tenantId);

        // Assert
        verify(careGapService, times(2)).createCareGap(
            eq(tenantId),
            anyString(),
            argThat(gap -> gap.getCategory() == CareGapEntity.GapCategory.DATA_QUALITY &&
                          gap.getGapType().equals("STALE_EVALUATION"))
        );
    }

    /**
     * TEST 2: Detect Stale Vitals (>90 days)
     * Should identify patients without vitals in 90 days
     */
    @Test
    void testDetectStaleVitals() {
        // Arrange
        String patientId = "Patient/123";
        List<StaleDataResult> stalePatients = Arrays.asList(
            new StaleDataResult(patientId, now.minus(100, ChronoUnit.DAYS))
        );

        when(monitor.findPatientsWithoutRecentVitals(tenantId, 90))
            .thenReturn(stalePatients);

        // Act
        monitor.checkStaleVitals(tenantId);

        // Assert
        ArgumentCaptor<CareGapDTO> captor = ArgumentCaptor.forClass(CareGapDTO.class);
        verify(careGapService).createCareGap(eq(tenantId), eq(patientId), captor.capture());

        CareGapDTO gap = captor.getValue();
        assertEquals(CareGapEntity.GapCategory.DATA_QUALITY, gap.getCategory());
        assertEquals("STALE_VITALS", gap.getGapType());
        assertEquals("Missing Vital Signs", gap.getTitle());
        assertTrue(gap.getDescription().contains("90 days"));
    }

    /**
     * TEST 3: Detect Stale Labs (>6 months)
     * Should identify patients without labs in 6 months
     */
    @Test
    void testDetectStaleLabs() {
        // Arrange
        String patientId = "Patient/123";
        List<StaleDataResult> stalePatients = Arrays.asList(
            new StaleDataResult(patientId, now.minus(200, ChronoUnit.DAYS))
        );

        when(monitor.findPatientsWithoutRecentLabs(tenantId, 180))
            .thenReturn(stalePatients);

        // Act
        monitor.checkStaleLabs(tenantId);

        // Assert
        ArgumentCaptor<CareGapDTO> captor = ArgumentCaptor.forClass(CareGapDTO.class);
        verify(careGapService).createCareGap(eq(tenantId), eq(patientId), captor.capture());

        CareGapDTO gap = captor.getValue();
        assertEquals("STALE_LABS", gap.getGapType());
        assertTrue(gap.getDescription().contains("6 months"));
    }

    /**
     * TEST 4: Detect Missing Mental Health Screening (>1 year)
     * Should identify patients without mental health screening in 1 year
     */
    @Test
    void testDetectMissingMentalHealthScreening() {
        // Arrange
        String patientId = "Patient/123";
        List<StaleDataResult> stalePatients = Arrays.asList(
            new StaleDataResult(patientId, now.minus(400, ChronoUnit.DAYS))
        );

        when(monitor.findPatientsWithoutRecentMentalHealthScreening(tenantId, 365))
            .thenReturn(stalePatients);

        // Act
        monitor.checkMissingMentalHealthScreening(tenantId);

        // Assert
        ArgumentCaptor<CareGapDTO> captor = ArgumentCaptor.forClass(CareGapDTO.class);
        verify(careGapService).createCareGap(eq(tenantId), eq(patientId), captor.capture());

        CareGapDTO gap = captor.getValue();
        assertEquals(CareGapEntity.GapCategory.MENTAL_HEALTH, gap.getGapType());
        assertEquals("MISSING_MH_SCREENING", gap.getGapType());
        assertTrue(gap.getDescription().contains("1 year"));
    }

    /**
     * TEST 5: Priority Assignment Based on Patient Risk
     * Should assign higher priority to high-risk patients
     */
    @Test
    void testPriorityAssignment_HighRiskPatient() {
        // Arrange
        String patientId = "Patient/123";
        List<StaleDataResult> stalePatients = Arrays.asList(
            new StaleDataResult(patientId, now.minus(100, ChronoUnit.DAYS), "VERY_HIGH")
        );

        when(monitor.findPatientsWithoutRecentVitals(tenantId, 90))
            .thenReturn(stalePatients);

        // Act
        monitor.checkStaleVitals(tenantId);

        // Assert
        ArgumentCaptor<CareGapDTO> captor = ArgumentCaptor.forClass(CareGapDTO.class);
        verify(careGapService).createCareGap(eq(tenantId), eq(patientId), captor.capture());

        CareGapDTO gap = captor.getValue();
        assertEquals(CareGapEntity.Priority.URGENT, gap.getPriority());
    }

    @Test
    void testPriorityAssignment_LowRiskPatient() {
        // Arrange
        String patientId = "Patient/123";
        List<StaleDataResult> stalePatients = Arrays.asList(
            new StaleDataResult(patientId, now.minus(100, ChronoUnit.DAYS), "LOW")
        );

        when(monitor.findPatientsWithoutRecentVitals(tenantId, 90))
            .thenReturn(stalePatients);

        // Act
        monitor.checkStaleVitals(tenantId);

        // Assert
        ArgumentCaptor<CareGapDTO> captor = ArgumentCaptor.forClass(CareGapDTO.class);
        verify(careGapService).createCareGap(eq(tenantId), eq(patientId), captor.capture());

        CareGapDTO gap = captor.getValue();
        assertEquals(CareGapEntity.Priority.LOW, gap.getPriority());
    }

    /**
     * TEST 6: Avoid Duplicate Care Gaps
     * Should not create duplicate care gaps for same stale data
     */
    @Test
    void testAvoidDuplicateCareGaps() {
        // Arrange
        String patientId = "Patient/123";
        List<StaleDataResult> stalePatients = Arrays.asList(
            new StaleDataResult(patientId, now.minus(100, ChronoUnit.DAYS))
        );

        when(monitor.findPatientsWithoutRecentVitals(tenantId, 90))
            .thenReturn(stalePatients);

        // Existing care gap already exists
        when(careGapService.hasOpenCareGap(tenantId, patientId, "STALE_VITALS"))
            .thenReturn(true);

        // Act
        monitor.checkStaleVitals(tenantId);

        // Assert: No new care gap created
        verify(careGapService, never()).createCareGap(anyString(), anyString(), any());
    }

    /**
     * TEST 7: Comprehensive Freshness Check
     * Should check all data types in one run
     */
    @Test
    void testComprehensiveFreshnessCheck() {
        // Act
        monitor.performComprehensiveFreshnessCheck(tenantId);

        // Assert: All checks executed
        verify(monitor).checkStaleEvaluations(tenantId);
        verify(monitor).checkStaleVitals(tenantId);
        verify(monitor).checkStaleLabs(tenantId);
        verify(monitor).checkMissingMentalHealthScreening(tenantId);
    }

    /**
     * TEST 8: Hourly Scheduling Configuration
     * Should run hourly
     */
    @Test
    void testSchedulingConfiguration() {
        // The actual annotation should be:
        // @Scheduled(cron = "0 0 * * * ?") // Every hour
        // or
        // @Scheduled(fixedRate = 3600000) // 1 hour in milliseconds

        assertNotNull(monitor);
    }

    /**
     * TEST 9: Metrics Tracking
     * Should track number of stale data items found
     */
    @Test
    void testMetricsTracking() {
        // Arrange
        when(monitor.findPatientsWithoutRecentEvaluations(tenantId, 30))
            .thenReturn(Arrays.asList(
                new StaleDataResult("Patient/123", now.minus(35, ChronoUnit.DAYS)),
                new StaleDataResult("Patient/456", now.minus(45, ChronoUnit.DAYS))
            ));
        when(monitor.findPatientsWithoutRecentVitals(tenantId, 90))
            .thenReturn(Arrays.asList(
                new StaleDataResult("Patient/789", now.minus(100, ChronoUnit.DAYS))
            ));

        // Act
        var result = monitor.performComprehensiveFreshnessCheck(tenantId);

        // Assert
        assertNotNull(result);
        assertEquals(2, result.staleEvaluationsCount());
        assertEquals(1, result.staleVitalsCount());
        assertTrue(result.totalIssues() >= 3);
    }

    /**
     * TEST 10: Multi-Tenant Processing
     * Should process all tenants
     */
    @Test
    void testMultiTenantProcessing() {
        // Arrange
        List<String> tenants = Arrays.asList("tenant-1", "tenant-2", "tenant-3");

        when(monitor.findAllActiveTenants()).thenReturn(tenants);

        // Act
        monitor.performComprehensiveFreshnessCheckAllTenants();

        // Assert
        for (String tenant : tenants) {
            verify(monitor).performComprehensiveFreshnessCheck(tenant);
        }
    }

    /**
     * Inner class for test data
     */
    public static class StaleDataResult {
        private final String patientId;
        private final Instant lastDataDate;
        private final String riskLevel;

        public StaleDataResult(String patientId, Instant lastDataDate) {
            this(patientId, lastDataDate, "MODERATE");
        }

        public StaleDataResult(String patientId, Instant lastDataDate, String riskLevel) {
            this.patientId = patientId;
            this.lastDataDate = lastDataDate;
            this.riskLevel = riskLevel;
        }

        public String getPatientId() { return patientId; }
        public Instant getLastDataDate() { return lastDataDate; }
        public String getRiskLevel() { return riskLevel; }
    }
}
