package com.healthdata.quality.scheduler;

import com.healthdata.quality.persistence.RiskAssessmentEntity;
import com.healthdata.quality.persistence.RiskAssessmentRepository;
import com.healthdata.quality.service.RiskStratificationService;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.ArgumentCaptor;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;
import org.springframework.kafka.core.KafkaTemplate;

import java.time.Instant;
import java.time.temporal.ChronoUnit;
import java.util.Arrays;
import java.util.List;
import java.util.UUID;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.ArgumentMatchers.*;
import static org.mockito.Mockito.*;

/**
 * Test-Driven Development for Risk Reassessment Scheduler
 *
 * Daily at 2 AM: Re-assess high-risk patients
 * Alert on risk level changes
 */
@ExtendWith(MockitoExtension.class)
class RiskReassessmentSchedulerTest {

    @Mock
    private RiskAssessmentRepository riskAssessmentRepository;

    @Mock
    private RiskStratificationService riskStratificationService;

    @Mock
    private KafkaTemplate<String, Object> kafkaTemplate;

    @InjectMocks
    private RiskReassessmentScheduler scheduler;

    private String tenantId;
    private Instant now;

    @BeforeEach
    void setUp() {
        tenantId = "test-tenant";
        now = Instant.now();
    }

    /**
     * TEST 1: Daily Reassessment of High-Risk Patients
     * Should identify and reassess all VERY_HIGH and HIGH risk patients
     */
    @Test
    void testDailyReassessment_HighRiskPatients() {
        // Arrange: Multiple high-risk patients
        List<RiskAssessmentEntity> highRiskPatients = Arrays.asList(
            createRiskAssessment("Patient/123", RiskAssessmentEntity.RiskLevel.VERY_HIGH, 85),
            createRiskAssessment("Patient/456", RiskAssessmentEntity.RiskLevel.HIGH, 65),
            createRiskAssessment("Patient/789", RiskAssessmentEntity.RiskLevel.VERY_HIGH, 90)
        );

        when(riskAssessmentRepository.findHighRiskPatientsForReassessment(
            eq(tenantId),
            any(Instant.class)
        )).thenReturn(highRiskPatients);

        // Act
        scheduler.performDailyRiskReassessment(tenantId);

        // Assert
        // Verify all high-risk patients were reassessed
        verify(riskStratificationService, times(3)).calculateRiskAssessment(eq(tenantId), anyString());
        verify(riskStratificationService).calculateRiskAssessment(tenantId, "Patient/123");
        verify(riskStratificationService).calculateRiskAssessment(tenantId, "Patient/456");
        verify(riskStratificationService).calculateRiskAssessment(tenantId, "Patient/789");
    }

    /**
     * TEST 2: Skip Reassessment if Already Assessed Today
     * Should not reassess patients already assessed within last 24 hours
     */
    @Test
    void testDailyReassessment_SkipRecentAssessments() {
        // Arrange: Recent assessment within 24 hours
        Instant recentTime = now.minus(12, ChronoUnit.HOURS);
        List<RiskAssessmentEntity> patients = Arrays.asList(
            createRiskAssessmentWithDate("Patient/123", RiskAssessmentEntity.RiskLevel.VERY_HIGH, 85, recentTime)
        );

        when(riskAssessmentRepository.findHighRiskPatientsForReassessment(
            eq(tenantId),
            any(Instant.class)
        )).thenReturn(Arrays.asList()); // Empty because recent assessments are filtered

        // Act
        scheduler.performDailyRiskReassessment(tenantId);

        // Assert
        verify(riskStratificationService, never()).calculateRiskAssessment(anyString(), anyString());
    }

    /**
     * TEST 3: Risk Level Change Detection
     * Should detect and alert when risk level changes
     */
    @Test
    void testRiskLevelChangeDetection_HighToVeryHigh() {
        // Arrange: Patient risk increased
        String patientId = "Patient/123";
        RiskAssessmentEntity oldAssessment = createRiskAssessment(patientId, RiskAssessmentEntity.RiskLevel.HIGH, 65);
        RiskAssessmentEntity newAssessment = createRiskAssessment(patientId, RiskAssessmentEntity.RiskLevel.VERY_HIGH, 85);

        // Act
        boolean changed = scheduler.detectRiskLevelChange(oldAssessment, newAssessment);

        // Assert
        assertTrue(changed);
    }

    @Test
    void testRiskLevelChangeDetection_NoChange() {
        // Arrange: Same risk level
        String patientId = "Patient/123";
        RiskAssessmentEntity oldAssessment = createRiskAssessment(patientId, RiskAssessmentEntity.RiskLevel.HIGH, 65);
        RiskAssessmentEntity newAssessment = createRiskAssessment(patientId, RiskAssessmentEntity.RiskLevel.HIGH, 68);

        // Act
        boolean changed = scheduler.detectRiskLevelChange(oldAssessment, newAssessment);

        // Assert
        assertFalse(changed);
    }

    /**
     * TEST 4: Alert on Risk Level Escalation
     * Should publish Kafka event when risk escalates
     */
    @Test
    void testAlertOnRiskEscalation() {
        // Arrange
        String patientId = "Patient/123";
        RiskAssessmentEntity oldAssessment = createRiskAssessment(patientId, RiskAssessmentEntity.RiskLevel.MODERATE, 45);
        RiskAssessmentEntity newAssessment = createRiskAssessment(patientId, RiskAssessmentEntity.RiskLevel.HIGH, 65);

        // Act
        scheduler.alertOnRiskChange(tenantId, patientId, oldAssessment, newAssessment);

        // Assert
        verify(kafkaTemplate).send(
            eq("risk.level-changed"),
            eq(patientId),
            argThat(event -> {
                @SuppressWarnings("unchecked")
                var eventMap = (java.util.Map<String, Object>) event;
                return eventMap.get("patientId").equals(patientId) &&
                       eventMap.get("previousLevel").equals("MODERATE") &&
                       eventMap.get("newLevel").equals("HIGH") &&
                       eventMap.get("changeType").equals("ESCALATION");
            })
        );
    }

    @Test
    void testAlertOnRiskDeescalation() {
        // Arrange
        String patientId = "Patient/123";
        RiskAssessmentEntity oldAssessment = createRiskAssessment(patientId, RiskAssessmentEntity.RiskLevel.VERY_HIGH, 85);
        RiskAssessmentEntity newAssessment = createRiskAssessment(patientId, RiskAssessmentEntity.RiskLevel.HIGH, 65);

        // Act
        scheduler.alertOnRiskChange(tenantId, patientId, oldAssessment, newAssessment);

        // Assert
        verify(kafkaTemplate).send(
            eq("risk.level-changed"),
            eq(patientId),
            argThat(event -> {
                @SuppressWarnings("unchecked")
                var eventMap = (java.util.Map<String, Object>) event;
                return eventMap.get("changeType").equals("IMPROVEMENT");
            })
        );
    }

    /**
     * TEST 5: Error Handling for Individual Patient Failures
     * Should continue processing other patients if one fails
     */
    @Test
    void testErrorHandling_ContinueOnIndividualFailure() {
        // Arrange: Multiple patients, one will fail
        List<RiskAssessmentEntity> patients = Arrays.asList(
            createRiskAssessment("Patient/123", RiskAssessmentEntity.RiskLevel.HIGH, 65),
            createRiskAssessment("Patient/456", RiskAssessmentEntity.RiskLevel.VERY_HIGH, 85),
            createRiskAssessment("Patient/789", RiskAssessmentEntity.RiskLevel.HIGH, 70)
        );

        when(riskAssessmentRepository.findHighRiskPatientsForReassessment(eq(tenantId), any(Instant.class)))
            .thenReturn(patients);

        // Patient 456 will fail
        when(riskStratificationService.calculateRiskAssessment(tenantId, "Patient/123"))
            .thenReturn(null); // Success
        when(riskStratificationService.calculateRiskAssessment(tenantId, "Patient/456"))
            .thenThrow(new RuntimeException("Calculation failed"));
        when(riskStratificationService.calculateRiskAssessment(tenantId, "Patient/789"))
            .thenReturn(null); // Success

        // Act
        scheduler.performDailyRiskReassessment(tenantId);

        // Assert: All patients attempted, failure logged
        verify(riskStratificationService).calculateRiskAssessment(tenantId, "Patient/123");
        verify(riskStratificationService).calculateRiskAssessment(tenantId, "Patient/456");
        verify(riskStratificationService).calculateRiskAssessment(tenantId, "Patient/789");
    }

    /**
     * TEST 6: Multi-Tenant Processing
     * Should process all tenants independently
     */
    @Test
    void testMultiTenantProcessing() {
        // Arrange: Multiple tenants
        List<String> tenants = Arrays.asList("tenant-1", "tenant-2", "tenant-3");

        when(riskAssessmentRepository.findAllActiveTenants()).thenReturn(tenants);

        for (String tenant : tenants) {
            when(riskAssessmentRepository.findHighRiskPatientsForReassessment(eq(tenant), any(Instant.class)))
                .thenReturn(Arrays.asList(createRiskAssessment("Patient/123", RiskAssessmentEntity.RiskLevel.HIGH, 65)));
        }

        // Act
        scheduler.performDailyRiskReassessmentAllTenants();

        // Assert: All tenants processed
        for (String tenant : tenants) {
            verify(riskAssessmentRepository).findHighRiskPatientsForReassessment(eq(tenant), any(Instant.class));
            verify(riskStratificationService).calculateRiskAssessment(eq(tenant), eq("Patient/123"));
        }
    }

    /**
     * TEST 7: Scheduling Configuration
     * Should be configured to run daily at 2 AM
     */
    @Test
    void testSchedulingConfiguration() {
        // This test validates the @Scheduled annotation configuration
        // In integration tests, verify the cron expression is correct

        // The actual annotation should be:
        // @Scheduled(cron = "0 0 2 * * ?") // Daily at 2 AM
        // or
        // @Scheduled(cron = "${scheduler.risk-reassessment.cron:0 0 2 * * ?}")

        assertNotNull(scheduler);
    }

    /**
     * Helper Methods
     */

    private RiskAssessmentEntity createRiskAssessment(String patientId, RiskAssessmentEntity.RiskLevel level, int score) {
        return createRiskAssessmentWithDate(patientId, level, score, now.minus(2, ChronoUnit.DAYS));
    }

    private RiskAssessmentEntity createRiskAssessmentWithDate(
        String patientId,
        RiskAssessmentEntity.RiskLevel level,
        int score,
        Instant assessmentDate
    ) {
        return RiskAssessmentEntity.builder()
            .id(UUID.randomUUID())
            .tenantId(tenantId)
            .patientId(patientId)
            .riskLevel(level)
            .riskScore(score)
            .riskFactors(Arrays.asList())
            .predictedOutcomes(Arrays.asList())
            .recommendations(Arrays.asList())
            .assessmentDate(assessmentDate)
            .createdAt(assessmentDate)
            .updatedAt(assessmentDate)
            .build();
    }
}
