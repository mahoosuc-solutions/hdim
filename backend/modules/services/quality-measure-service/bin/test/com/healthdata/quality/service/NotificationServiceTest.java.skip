package com.healthdata.quality.service;

import com.healthdata.quality.dto.ClinicalAlertDTO;
import com.healthdata.quality.persistence.ClinicalAlertEntity;
import com.healthdata.quality.service.notification.EmailNotificationChannel;
import com.healthdata.quality.service.notification.SmsNotificationChannel;
import com.healthdata.quality.service.notification.WebSocketNotificationChannel;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.DisplayName;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import java.time.Instant;

import static org.mockito.ArgumentMatchers.*;
import static org.mockito.Mockito.*;

/**
 * TDD Tests for Multi-Channel Notification Service
 *
 * Tests notification routing, channel selection by severity,
 * and template rendering for different alert types.
 */
@ExtendWith(MockitoExtension.class)
@DisplayName("Notification Service Tests")
class NotificationServiceTest {

    @Mock
    private WebSocketNotificationChannel webSocketChannel;

    @Mock
    private EmailNotificationChannel emailChannel;

    @Mock
    private SmsNotificationChannel smsChannel;

    @InjectMocks
    private NotificationService notificationService;

    private static final String TENANT_ID = "test-tenant";
    private static final String PATIENT_ID = "patient-123";
    private static final String PROVIDER_EMAIL = "provider@hospital.com";
    private static final String PROVIDER_PHONE = "+1234567890";

    @BeforeEach
    void setUp() {
        // Setup common test state
    }

    @Test
    @DisplayName("Should send CRITICAL alert to all channels (WebSocket + Email + SMS)")
    void shouldSendCriticalAlertToAllChannels() {
        // Given: CRITICAL alert (suicide risk)
        ClinicalAlertDTO alert = createAlert(
            "CRITICAL",
            "MENTAL_HEALTH_CRISIS",
            "Suicide Risk Detected",
            "Patient reported suicidal ideation on PHQ-9 assessment"
        );

        when(webSocketChannel.send(any(), any())).thenReturn(true);
        when(emailChannel.send(any(), any())).thenReturn(true);
        when(smsChannel.send(any(), any())).thenReturn(true);

        // When: Sending notification
        notificationService.sendNotification(TENANT_ID, alert);

        // Then: All channels used
        verify(webSocketChannel).send(eq(TENANT_ID), eq(alert));
        verify(emailChannel).send(eq(TENANT_ID), eq(alert));
        verify(smsChannel).send(eq(TENANT_ID), eq(alert));
    }

    @Test
    @DisplayName("Should send HIGH alert to WebSocket + Email only")
    void shouldSendHighAlertToWebSocketAndEmail() {
        // Given: HIGH severity alert
        ClinicalAlertDTO alert = createAlert(
            "HIGH",
            "RISK_ESCALATION",
            "Patient Risk Escalated to Very High",
            "Risk score increased to 85/100"
        );

        when(webSocketChannel.send(any(), any())).thenReturn(true);
        when(emailChannel.send(any(), any())).thenReturn(true);

        // When: Sending notification
        notificationService.sendNotification(TENANT_ID, alert);

        // Then: WebSocket and Email only (no SMS)
        verify(webSocketChannel).send(eq(TENANT_ID), eq(alert));
        verify(emailChannel).send(eq(TENANT_ID), eq(alert));
        verify(smsChannel, never()).send(any(), any());
    }

    @Test
    @DisplayName("Should send MEDIUM alert to WebSocket only")
    void shouldSendMediumAlertToWebSocketOnly() {
        // Given: MEDIUM severity alert
        ClinicalAlertDTO alert = createAlert(
            "MEDIUM",
            "HEALTH_DECLINE",
            "Health Score Declined",
            "Overall health score declined by 17 points"
        );

        when(webSocketChannel.send(any(), any())).thenReturn(true);

        // When: Sending notification
        notificationService.sendNotification(TENANT_ID, alert);

        // Then: WebSocket only
        verify(webSocketChannel).send(eq(TENANT_ID), eq(alert));
        verify(emailChannel, never()).send(any(), any());
        verify(smsChannel, never()).send(any(), any());
    }

    @Test
    @DisplayName("Should render email template for mental health crisis alert")
    void shouldRenderEmailTemplateForMentalHealthCrisis() {
        // Given: Mental health crisis alert
        ClinicalAlertDTO alert = createAlert(
            "CRITICAL",
            "MENTAL_HEALTH_CRISIS",
            "Severe Depression Detected",
            "PHQ-9 score: 22/27 (severe range)"
        );

        when(emailChannel.send(any(), any())).thenAnswer(invocation -> {
            // Verify template rendering
            ClinicalAlertDTO sentAlert = invocation.getArgument(1);
            return true;
        });

        // When: Sending via email
        notificationService.sendNotification(TENANT_ID, alert);

        // Then: Email sent with proper template
        verify(emailChannel).send(eq(TENANT_ID), argThat(a ->
            a.getTitle().contains("Severe Depression") &&
            a.getMessage().contains("PHQ-9")
        ));
    }

    @Test
    @DisplayName("Should render email template for risk escalation alert")
    void shouldRenderEmailTemplateForRiskEscalation() {
        // Given: Risk escalation alert
        ClinicalAlertDTO alert = createAlert(
            "HIGH",
            "RISK_ESCALATION",
            "Patient Risk Level: Very High",
            "Risk score: 85/100. Immediate care coordination required."
        );

        when(emailChannel.send(any(), any())).thenReturn(true);

        // When: Sending notification
        notificationService.sendNotification(TENANT_ID, alert);

        // Then: Email template rendered correctly
        verify(emailChannel).send(eq(TENANT_ID), argThat(a ->
            a.getAlertType().equals("RISK_ESCALATION") &&
            a.getMessage().contains("care coordination")
        ));
    }

    @Test
    @DisplayName("Should format SMS message for CRITICAL alerts (160 char limit)")
    void shouldFormatSmsMessageForCriticalAlerts() {
        // Given: CRITICAL alert
        ClinicalAlertDTO alert = createAlert(
            "CRITICAL",
            "MENTAL_HEALTH_CRISIS",
            "Suicide Risk: Patient John Doe",
            "URGENT: Patient reported suicidal ideation. Immediate intervention required."
        );

        when(smsChannel.send(any(), any())).thenReturn(true);

        // When: Sending SMS
        notificationService.sendNotification(TENANT_ID, alert);

        // Then: SMS formatted within character limit
        verify(smsChannel).send(eq(TENANT_ID), argThat(a ->
            a.getSeverity().equals("CRITICAL")
        ));
    }

    @Test
    @DisplayName("Should handle WebSocket channel failure gracefully")
    void shouldHandleWebSocketChannelFailure() {
        // Given: WebSocket unavailable
        ClinicalAlertDTO alert = createAlert(
            "CRITICAL",
            "MENTAL_HEALTH_CRISIS",
            "Test Alert",
            "Test message"
        );

        when(webSocketChannel.send(any(), any())).thenReturn(false);
        when(emailChannel.send(any(), any())).thenReturn(true);
        when(smsChannel.send(any(), any())).thenReturn(true);

        // When: Sending notification
        notificationService.sendNotification(TENANT_ID, alert);

        // Then: Email and SMS still sent
        verify(webSocketChannel).send(eq(TENANT_ID), eq(alert));
        verify(emailChannel).send(eq(TENANT_ID), eq(alert));
        verify(smsChannel).send(eq(TENANT_ID), eq(alert));
    }

    @Test
    @DisplayName("Should handle email channel failure gracefully")
    void shouldHandleEmailChannelFailure() {
        // Given: Email service unavailable
        ClinicalAlertDTO alert = createAlert(
            "HIGH",
            "RISK_ESCALATION",
            "Test Alert",
            "Test message"
        );

        when(webSocketChannel.send(any(), any())).thenReturn(true);
        when(emailChannel.send(any(), any())).thenThrow(new RuntimeException("SMTP unavailable"));

        // When: Sending notification (should not throw)
        notificationService.sendNotification(TENANT_ID, alert);

        // Then: WebSocket still sent (graceful degradation)
        verify(webSocketChannel).send(eq(TENANT_ID), eq(alert));
        verify(emailChannel).send(eq(TENANT_ID), eq(alert));
    }

    @Test
    @DisplayName("Should batch notifications for multiple alerts")
    void shouldBatchNotificationsForMultipleAlerts() {
        // Given: Multiple alerts for same patient
        ClinicalAlertDTO alert1 = createAlert("CRITICAL", "MENTAL_HEALTH_CRISIS", "Alert 1", "Message 1");
        ClinicalAlertDTO alert2 = createAlert("HIGH", "RISK_ESCALATION", "Alert 2", "Message 2");
        ClinicalAlertDTO alert3 = createAlert("MEDIUM", "HEALTH_DECLINE", "Alert 3", "Message 3");

        when(webSocketChannel.send(any(), any())).thenReturn(true);
        when(emailChannel.send(any(), any())).thenReturn(true);
        when(smsChannel.send(any(), any())).thenReturn(true);

        // When: Sending batch
        notificationService.sendBatchNotification(TENANT_ID, java.util.List.of(alert1, alert2, alert3));

        // Then: All alerts sent via appropriate channels
        verify(webSocketChannel, times(3)).send(eq(TENANT_ID), any(ClinicalAlertDTO.class));
        verify(emailChannel, times(2)).send(eq(TENANT_ID), any(ClinicalAlertDTO.class)); // CRITICAL + HIGH
        verify(smsChannel, times(1)).send(eq(TENANT_ID), any(ClinicalAlertDTO.class)); // CRITICAL only
    }

    @Test
    @DisplayName("Should include patient context in notifications")
    void shouldIncludePatientContextInNotifications() {
        // Given: Alert with patient details
        ClinicalAlertDTO alert = createAlert(
            "CRITICAL",
            "MENTAL_HEALTH_CRISIS",
            "Suicide Risk Detected",
            "Patient: John Doe (MRN: 12345)"
        );
        alert.setPatientId(PATIENT_ID);

        when(emailChannel.send(any(), any())).thenReturn(true);

        // When: Sending notification
        notificationService.sendNotification(TENANT_ID, alert);

        // Then: Patient context included
        verify(emailChannel).send(eq(TENANT_ID), argThat(a ->
            a.getPatientId().equals(PATIENT_ID)
        ));
    }

    @Test
    @DisplayName("Should track notification delivery status")
    void shouldTrackNotificationDeliveryStatus() {
        // Given: Alert to send
        ClinicalAlertDTO alert = createAlert(
            "CRITICAL",
            "MENTAL_HEALTH_CRISIS",
            "Test Alert",
            "Test message"
        );

        when(webSocketChannel.send(any(), any())).thenReturn(true);
        when(emailChannel.send(any(), any())).thenReturn(true);
        when(smsChannel.send(any(), any())).thenReturn(false); // SMS failed

        // When: Sending notification
        var status = notificationService.sendNotificationWithStatus(TENANT_ID, alert);

        // Then: Status reflects delivery results
        // This would track which channels succeeded/failed
        verify(webSocketChannel).send(any(), any());
        verify(emailChannel).send(any(), any());
        verify(smsChannel).send(any(), any());
    }

    // Helper methods
    private ClinicalAlertDTO createAlert(
        String severity,
        String type,
        String title,
        String message
    ) {
        return ClinicalAlertDTO.builder()
            .tenantId(TENANT_ID)
            .patientId(PATIENT_ID)
            .alertType(type)
            .severity(severity)
            .title(title)
            .message(message)
            .triggeredAt(Instant.now())
            .status("ACTIVE")
            .escalated(severity.equals("CRITICAL"))
            .build();
    }
}
