package com.healthdata.quality.service;

import com.healthdata.quality.dto.RiskTrendDTO;
import com.healthdata.quality.persistence.RiskAssessmentEntity;
import com.healthdata.quality.persistence.RiskAssessmentRepository;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import java.time.Instant;
import java.time.temporal.ChronoUnit;
import java.util.*;

import static org.assertj.core.api.Assertions.assertThat;
import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.eq;
import static org.mockito.Mockito.*;

/**
 * TDD Tests for Historical Risk Tracking (Phase 4)
 *
 * Tests historical risk trend analysis:
 * - Risk score trends over time
 * - Risk level changes tracking
 * - Category-specific trends
 * - Deterioration/improvement patterns
 */
@ExtendWith(MockitoExtension.class)
class RiskHistoricalTrackingTest {

    @Mock
    private RiskAssessmentRepository riskAssessmentRepository;

    @InjectMocks
    private RiskHistoricalTrackingService historicalTrackingService;

    private static final String TENANT_ID = "test-tenant";
    private static final String PATIENT_ID = "patient-123";

    @BeforeEach
    void setUp() {
        reset(riskAssessmentRepository);
    }

    @Test
    void testGetRiskTrend_ImprovingOverTime() {
        // Given: Risk scores improving over 6 months
        List<RiskAssessmentEntity> historicalRisks = Arrays.asList(
            createRiskAssessment(Instant.now().minus(180, ChronoUnit.DAYS), "CARDIOVASCULAR", 75, "high"),
            createRiskAssessment(Instant.now().minus(120, ChronoUnit.DAYS), "CARDIOVASCULAR", 60, "high"),
            createRiskAssessment(Instant.now().minus(60, ChronoUnit.DAYS), "CARDIOVASCULAR", 45, "moderate"),
            createRiskAssessment(Instant.now(), "CARDIOVASCULAR", 30, "moderate")
        );

        when(riskAssessmentRepository.findByCategoryForPeriod(
            eq(TENANT_ID), eq(PATIENT_ID), eq("CARDIOVASCULAR"), any(Instant.class), any(Instant.class)))
            .thenReturn(historicalRisks);

        // When: Get risk trend
        RiskTrendDTO trend = historicalTrackingService.getRiskTrend(
            TENANT_ID, PATIENT_ID, "CARDIOVASCULAR", 180);

        // Then: Should show improvement
        assertThat(trend).isNotNull();
        assertThat(trend.getTrendDirection()).isEqualTo("IMPROVING");
        assertThat(trend.getScoreChange()).isEqualTo(-45.0); // 75 → 30
        assertThat(trend.getAverageScore()).isCloseTo(52.5, org.assertj.core.data.Offset.offset(1.0));
        assertThat(trend.getDataPoints()).hasSize(4);
    }

    @Test
    void testGetRiskTrend_DeterioratingOverTime() {
        // Given: Risk scores worsening over 3 months
        List<RiskAssessmentEntity> historicalRisks = Arrays.asList(
            createRiskAssessment(Instant.now().minus(90, ChronoUnit.DAYS), "DIABETES", 35, "moderate"),
            createRiskAssessment(Instant.now().minus(60, ChronoUnit.DAYS), "DIABETES", 50, "high"),
            createRiskAssessment(Instant.now().minus(30, ChronoUnit.DAYS), "DIABETES", 65, "high"),
            createRiskAssessment(Instant.now(), "DIABETES", 78, "critical")
        );

        when(riskAssessmentRepository.findByCategoryForPeriod(
            eq(TENANT_ID), eq(PATIENT_ID), eq("DIABETES"), any(Instant.class), any(Instant.class)))
            .thenReturn(historicalRisks);

        // When: Get risk trend
        RiskTrendDTO trend = historicalTrackingService.getRiskTrend(
            TENANT_ID, PATIENT_ID, "DIABETES", 90);

        // Then: Should show deterioration
        assertThat(trend).isNotNull();
        assertThat(trend.getTrendDirection()).isEqualTo("DETERIORATING");
        assertThat(trend.getScoreChange()).isEqualTo(43.0); // 35 → 78
        assertThat(trend.getLevelChanges()).hasSize(2); // moderate→high, high→critical
    }

    @Test
    void testGetRiskTrend_StableOverTime() {
        // Given: Risk scores stable over time
        List<RiskAssessmentEntity> historicalRisks = Arrays.asList(
            createRiskAssessment(Instant.now().minus(90, ChronoUnit.DAYS), "RESPIRATORY", 22, "low"),
            createRiskAssessment(Instant.now().minus(60, ChronoUnit.DAYS), "RESPIRATORY", 20, "low"),
            createRiskAssessment(Instant.now().minus(30, ChronoUnit.DAYS), "RESPIRATORY", 24, "low"),
            createRiskAssessment(Instant.now(), "RESPIRATORY", 21, "low")
        );

        when(riskAssessmentRepository.findByCategoryForPeriod(
            eq(TENANT_ID), eq(PATIENT_ID), eq("RESPIRATORY"), any(Instant.class), any(Instant.class)))
            .thenReturn(historicalRisks);

        // When: Get risk trend
        RiskTrendDTO trend = historicalTrackingService.getRiskTrend(
            TENANT_ID, PATIENT_ID, "RESPIRATORY", 90);

        // Then: Should show stable trend
        assertThat(trend).isNotNull();
        assertThat(trend.getTrendDirection()).isEqualTo("STABLE");
        assertThat(Math.abs(trend.getScoreChange())).isLessThan(5.0);
    }

    @Test
    void testGetAllCategoryTrends() {
        // Given: Historical data for all categories
        when(riskAssessmentRepository.findByCategoryForPeriod(
            eq(TENANT_ID), eq(PATIENT_ID), eq("CARDIOVASCULAR"), any(Instant.class), any(Instant.class)))
            .thenReturn(Arrays.asList(
                createRiskAssessment(Instant.now().minus(90, ChronoUnit.DAYS), "CARDIOVASCULAR", 50, "high"),
                createRiskAssessment(Instant.now(), "CARDIOVASCULAR", 35, "moderate")
            ));

        when(riskAssessmentRepository.findByCategoryForPeriod(
            eq(TENANT_ID), eq(PATIENT_ID), eq("DIABETES"), any(Instant.class), any(Instant.class)))
            .thenReturn(Arrays.asList(
                createRiskAssessment(Instant.now().minus(90, ChronoUnit.DAYS), "DIABETES", 40, "moderate"),
                createRiskAssessment(Instant.now(), "DIABETES", 60, "high")
            ));

        when(riskAssessmentRepository.findByCategoryForPeriod(
            eq(TENANT_ID), eq(PATIENT_ID), eq("RESPIRATORY"), any(Instant.class), any(Instant.class)))
            .thenReturn(Arrays.asList(
                createRiskAssessment(Instant.now().minus(90, ChronoUnit.DAYS), "RESPIRATORY", 20, "low"),
                createRiskAssessment(Instant.now(), "RESPIRATORY", 22, "low")
            ));

        when(riskAssessmentRepository.findByCategoryForPeriod(
            eq(TENANT_ID), eq(PATIENT_ID), eq("MENTAL_HEALTH"), any(Instant.class), any(Instant.class)))
            .thenReturn(Arrays.asList(
                createRiskAssessment(Instant.now().minus(90, ChronoUnit.DAYS), "MENTAL_HEALTH", 55, "high"),
                createRiskAssessment(Instant.now(), "MENTAL_HEALTH", 35, "moderate")
            ));

        // When: Get all category trends
        Map<String, RiskTrendDTO> allTrends = historicalTrackingService.getAllCategoryTrends(
            TENANT_ID, PATIENT_ID, 90);

        // Then: Should return trends for all 4 categories
        assertThat(allTrends).hasSize(4);
        assertThat(allTrends.keySet()).containsExactlyInAnyOrder(
            "CARDIOVASCULAR", "DIABETES", "RESPIRATORY", "MENTAL_HEALTH");

        // Cardiovascular and mental health improving
        assertThat(allTrends.get("CARDIOVASCULAR").getTrendDirection()).isEqualTo("IMPROVING");
        assertThat(allTrends.get("MENTAL_HEALTH").getTrendDirection()).isEqualTo("IMPROVING");

        // Diabetes deteriorating
        assertThat(allTrends.get("DIABETES").getTrendDirection()).isEqualTo("DETERIORATING");

        // Respiratory stable
        assertThat(allTrends.get("RESPIRATORY").getTrendDirection()).isEqualTo("STABLE");
    }

    @Test
    void testIdentifyRapidDeterioration() {
        // Given: Rapid deterioration in last 30 days (score increased by >20)
        List<RiskAssessmentEntity> historicalRisks = Arrays.asList(
            createRiskAssessment(Instant.now().minus(30, ChronoUnit.DAYS), "MENTAL_HEALTH", 40, "moderate"),
            createRiskAssessment(Instant.now().minus(15, ChronoUnit.DAYS), "MENTAL_HEALTH", 55, "high"),
            createRiskAssessment(Instant.now(), "MENTAL_HEALTH", 75, "critical")
        );

        when(riskAssessmentRepository.findByCategoryForPeriod(
            eq(TENANT_ID), eq(PATIENT_ID), eq("MENTAL_HEALTH"), any(Instant.class), any(Instant.class)))
            .thenReturn(historicalRisks);

        // When: Check for rapid deterioration
        boolean isRapid = historicalTrackingService.hasRapidDeterioration(
            TENANT_ID, PATIENT_ID, "MENTAL_HEALTH", 30);

        // Then: Should detect rapid deterioration
        assertThat(isRapid).isTrue();
    }

    @Test
    void testGetRiskVolatility() {
        // Given: Highly variable risk scores (volatile)
        List<RiskAssessmentEntity> volatileRisks = Arrays.asList(
            createRiskAssessment(Instant.now().minus(90, ChronoUnit.DAYS), "DIABETES", 40, "moderate"),
            createRiskAssessment(Instant.now().minus(75, ChronoUnit.DAYS), "DIABETES", 65, "high"),
            createRiskAssessment(Instant.now().minus(60, ChronoUnit.DAYS), "DIABETES", 35, "moderate"),
            createRiskAssessment(Instant.now().minus(45, ChronoUnit.DAYS), "DIABETES", 70, "high"),
            createRiskAssessment(Instant.now().minus(30, ChronoUnit.DAYS), "DIABETES", 45, "moderate"),
            createRiskAssessment(Instant.now(), "DIABETES", 55, "high")
        );

        when(riskAssessmentRepository.findByCategoryForPeriod(
            eq(TENANT_ID), eq(PATIENT_ID), eq("DIABETES"), any(Instant.class), any(Instant.class)))
            .thenReturn(volatileRisks);

        // When: Calculate volatility
        double volatility = historicalTrackingService.calculateRiskVolatility(
            TENANT_ID, PATIENT_ID, "DIABETES", 90);

        // Then: Should show high volatility (standard deviation of scores)
        assertThat(volatility).isGreaterThan(10.0); // High variation
    }

    @Test
    void testPredictFutureRisk_LinearTrend() {
        // Given: Consistent upward trend
        List<RiskAssessmentEntity> historicalRisks = Arrays.asList(
            createRiskAssessment(Instant.now().minus(120, ChronoUnit.DAYS), "CARDIOVASCULAR", 30, "moderate"),
            createRiskAssessment(Instant.now().minus(90, ChronoUnit.DAYS), "CARDIOVASCULAR", 40, "moderate"),
            createRiskAssessment(Instant.now().minus(60, ChronoUnit.DAYS), "CARDIOVASCULAR", 50, "high"),
            createRiskAssessment(Instant.now().minus(30, ChronoUnit.DAYS), "CARDIOVASCULAR", 60, "high"),
            createRiskAssessment(Instant.now(), "CARDIOVASCULAR", 70, "high")
        );

        when(riskAssessmentRepository.findByCategoryForPeriod(
            eq(TENANT_ID), eq(PATIENT_ID), eq("CARDIOVASCULAR"), any(Instant.class), any(Instant.class)))
            .thenReturn(historicalRisks);

        // When: Predict risk in 30 days
        double predictedRisk = historicalTrackingService.predictFutureRisk(
            TENANT_ID, PATIENT_ID, "CARDIOVASCULAR", 30);

        // Then: Should predict continued increase (around 80)
        assertThat(predictedRisk).isGreaterThan(70.0);
        assertThat(predictedRisk).isLessThan(90.0);
    }

    @Test
    void testCompareRiskAcrossCategories() {
        // Given: Current risk assessments for all categories
        when(riskAssessmentRepository.findLatestByCategoryAndPatient(TENANT_ID, PATIENT_ID, "CARDIOVASCULAR"))
            .thenReturn(Optional.of(createRiskAssessment(Instant.now(), "CARDIOVASCULAR", 65, "high")));

        when(riskAssessmentRepository.findLatestByCategoryAndPatient(TENANT_ID, PATIENT_ID, "DIABETES"))
            .thenReturn(Optional.of(createRiskAssessment(Instant.now(), "DIABETES", 75, "critical")));

        when(riskAssessmentRepository.findLatestByCategoryAndPatient(TENANT_ID, PATIENT_ID, "RESPIRATORY"))
            .thenReturn(Optional.of(createRiskAssessment(Instant.now(), "RESPIRATORY", 25, "moderate")));

        when(riskAssessmentRepository.findLatestByCategoryAndPatient(TENANT_ID, PATIENT_ID, "MENTAL_HEALTH"))
            .thenReturn(Optional.of(createRiskAssessment(Instant.now(), "MENTAL_HEALTH", 55, "high")));

        // When: Get category comparison
        Map<String, Integer> categoryRanking = historicalTrackingService.rankRisksByCategory(
            TENANT_ID, PATIENT_ID);

        // Then: Should rank categories by risk score
        assertThat(categoryRanking).hasSize(4);

        List<Map.Entry<String, Integer>> sortedRisks = new ArrayList<>(categoryRanking.entrySet());
        sortedRisks.sort(Map.Entry.comparingByValue(Comparator.reverseOrder()));

        // Diabetes should be highest risk
        assertThat(sortedRisks.get(0).getKey()).isEqualTo("DIABETES");
        assertThat(sortedRisks.get(0).getValue()).isEqualTo(75);
    }

    @Test
    void testNoHistoricalData() {
        // Given: No historical data
        when(riskAssessmentRepository.findByCategoryForPeriod(
            eq(TENANT_ID), eq(PATIENT_ID), eq("CARDIOVASCULAR"), any(Instant.class), any(Instant.class)))
            .thenReturn(Collections.emptyList());

        // When: Try to get trend
        RiskTrendDTO trend = historicalTrackingService.getRiskTrend(
            TENANT_ID, PATIENT_ID, "CARDIOVASCULAR", 90);

        // Then: Should return null or empty trend
        assertThat(trend).isNull();
    }

    // Helper method
    private RiskAssessmentEntity createRiskAssessment(Instant assessmentDate, String category, int score, String level) {
        return RiskAssessmentEntity.builder()
            .id(UUID.randomUUID())
            .tenantId(TENANT_ID)
            .patientId(PATIENT_ID)
            .riskCategory(category)
            .riskScore(score)
            .riskLevel(RiskAssessmentEntity.RiskLevel.valueOf(level.toUpperCase()))
            .riskFactors(List.of())
            .predictedOutcomes(List.of())
            .recommendations(List.of())
            .assessmentDate(assessmentDate)
            .build();
    }
}
