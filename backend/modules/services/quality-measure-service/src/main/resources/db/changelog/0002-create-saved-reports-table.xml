<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0002-create-saved-reports-table" author="healthdata-team">
        <comment>Create saved reports table for storing generated quality reports</comment>

        <createTable tableName="saved_reports">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="report_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="report_name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>

            <!-- Filter parameters -->
            <column name="patient_id" type="uuid"/>
            <column name="year" type="integer"/>
            <column name="start_date" type="date"/>
            <column name="end_date" type="date"/>

            <!-- Report data stored as JSONB -->
            <column name="report_data" type="jsonb">
                <constraints nullable="false"/>
            </column>

            <!-- Metadata -->
            <column name="created_by" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
            <column name="generated_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>

            <!-- Status tracking -->
            <column name="status" type="varchar(50)" defaultValue="COMPLETED">
                <constraints nullable="false"/>
            </column>
            <column name="error_message" type="text"/>

            <!-- Optimistic locking -->
            <column name="version" type="integer" defaultValue="0"/>
        </createTable>

        <!-- Index for tenant isolation -->
        <createIndex indexName="idx_saved_reports_tenant" tableName="saved_reports">
            <column name="tenant_id"/>
        </createIndex>

        <!-- Index for report type filtering -->
        <createIndex indexName="idx_saved_reports_type" tableName="saved_reports">
            <column name="report_type"/>
        </createIndex>

        <!-- Index for sorting by creation date -->
        <createIndex indexName="idx_saved_reports_created_at" tableName="saved_reports">
            <column name="created_at"/>
        </createIndex>

        <!-- Index for patient reports -->
        <createIndex indexName="idx_saved_reports_patient" tableName="saved_reports">
            <column name="patient_id"/>
        </createIndex>

        <!-- Composite index for tenant + type queries -->
        <createIndex indexName="idx_saved_reports_tenant_type" tableName="saved_reports">
            <column name="tenant_id"/>
            <column name="report_type"/>
        </createIndex>

        <!-- Composite index for tenant + patient queries -->
        <createIndex indexName="idx_saved_reports_tenant_patient" tableName="saved_reports">
            <column name="tenant_id"/>
            <column name="patient_id"/>
        </createIndex>

        <!-- Composite index for tenant + year queries -->
        <createIndex indexName="idx_saved_reports_tenant_year" tableName="saved_reports">
            <column name="tenant_id"/>
            <column name="year"/>
        </createIndex>

        <rollback>
            <dropTable tableName="saved_reports"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
