<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0004-add-soft-delete-columns" author="team-b">
        <comment>Add soft delete support for HIPAA compliance</comment>

        <!-- Add soft delete to custom_measures -->
        <addColumn tableName="custom_measures">
            <column name="published_date" type="TIMESTAMP">
                <constraints nullable="true"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP">
                <constraints nullable="true"/>
            </column>
            <column name="deleted_by" type="VARCHAR(100)">
                <constraints nullable="true"/>
            </column>
        </addColumn>

        <!-- Add indexes for soft delete queries -->
        <createIndex tableName="custom_measures" indexName="idx_custom_measures_deleted_at">
            <column name="deleted_at"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="custom_measures" indexName="idx_custom_measures_deleted_at"/>
            <dropColumn tableName="custom_measures" columnName="published_date"/>
            <dropColumn tableName="custom_measures" columnName="deleted_at"/>
            <dropColumn tableName="custom_measures" columnName="deleted_by"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
