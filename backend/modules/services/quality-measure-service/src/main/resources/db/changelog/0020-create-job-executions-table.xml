<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0013-create-job-executions-table" author="healthdata-team">
        <comment>Create job executions table for scheduled job tracking</comment>

        <createTable tableName="job_executions">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <!-- Tenant isolation -->
            <column name="tenant_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>

            <!-- Job information -->
            <column name="job_name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>

            <column name="status" type="varchar(20)">
                <constraints nullable="false"/>
            </column>

            <!-- Execution timestamps -->
            <column name="started_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>

            <column name="completed_at" type="timestamp with time zone">
                <constraints nullable="true"/>
            </column>

            <!-- Duration in milliseconds -->
            <column name="duration_ms" type="bigint">
                <constraints nullable="true"/>
            </column>

            <!-- Results and errors -->
            <column name="result_message" type="text">
                <constraints nullable="true"/>
            </column>

            <column name="error_message" type="text">
                <constraints nullable="true"/>
            </column>

            <!-- Metrics (JSONB for flexible structure) -->
            <column name="metrics" type="jsonb">
                <constraints nullable="true"/>
            </column>

            <!-- Audit -->
            <column name="created_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Index for job execution history -->
        <createIndex indexName="idx_je_job_history" tableName="job_executions">
            <column name="tenant_id"/>
            <column name="job_name"/>
            <column name="started_at" descending="true"/>
        </createIndex>

        <!-- Index for running jobs detection -->
        <createIndex indexName="idx_je_running" tableName="job_executions">
            <column name="tenant_id"/>
            <column name="job_name"/>
            <column name="status"/>
        </createIndex>

        <!-- Index for performance analysis -->
        <createIndex indexName="idx_je_performance" tableName="job_executions">
            <column name="job_name"/>
            <column name="status"/>
            <column name="duration_ms"/>
        </createIndex>

        <!-- Index for tenant isolation -->
        <createIndex indexName="idx_je_tenant" tableName="job_executions">
            <column name="tenant_id"/>
        </createIndex>

        <!-- Index for cleanup queries -->
        <createIndex indexName="idx_je_cleanup" tableName="job_executions">
            <column name="tenant_id"/>
            <column name="completed_at"/>
        </createIndex>

        <!-- GIN index on metrics for fast querying -->
        <sql>
            CREATE INDEX idx_je_metrics_gin ON job_executions USING GIN (metrics);
        </sql>

        <rollback>
            <dropTable tableName="job_executions"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
