<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0014-create-notification-history-table" author="claude-code">
        <comment>
            Create notification_history table for HIPAA compliance audit trail.
            Tracks all notifications sent through the system (EMAIL, SMS, WebSocket).

            Use Cases:
            - HIPAA audit trail: Track all patient communications
            - Delivery verification: Confirm notifications were sent
            - Analytics: Understand notification patterns and effectiveness
            - Troubleshooting: Debug notification delivery issues
        </comment>

        <createTable tableName="notification_history">
            <!-- Primary Key -->
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <!-- Core Fields -->
            <column name="tenant_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <column name="notification_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <column name="channel" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <column name="template_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <!-- Patient and Recipient -->
            <column name="patient_id" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>

            <column name="recipient_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <!-- Content -->
            <column name="subject" type="VARCHAR(500)">
                <constraints nullable="true"/>
            </column>

            <column name="content" type="TEXT">
                <constraints nullable="true"/>
            </column>

            <!-- Status Tracking -->
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <column name="error_message" type="TEXT">
                <constraints nullable="true"/>
            </column>

            <column name="external_message_id" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>

            <!-- Alert Context -->
            <column name="alert_id" type="VARCHAR(255)">
                <constraints nullable="true"/>
            </column>

            <column name="severity" type="VARCHAR(20)">
                <constraints nullable="true"/>
            </column>

            <!-- Timestamps -->
            <column name="sent_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="delivered_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="true"/>
            </column>

            <column name="read_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="true"/>
            </column>

            <!-- Metadata -->
            <column name="metadata" type="TEXT">
                <constraints nullable="true"/>
            </column>

            <!-- Audit Timestamps -->
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <!-- Indexes for Performance and Querying -->
        <createIndex indexName="idx_notification_patient_id" tableName="notification_history">
            <column name="patient_id"/>
        </createIndex>

        <createIndex indexName="idx_notification_tenant_id" tableName="notification_history">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_notification_sent_at" tableName="notification_history">
            <column name="sent_at"/>
        </createIndex>

        <createIndex indexName="idx_notification_type" tableName="notification_history">
            <column name="notification_type"/>
        </createIndex>

        <createIndex indexName="idx_notification_status" tableName="notification_history">
            <column name="status"/>
        </createIndex>

        <createIndex indexName="idx_notification_channel" tableName="notification_history">
            <column name="channel"/>
        </createIndex>

        <!-- Composite index for common queries -->
        <createIndex indexName="idx_notification_tenant_patient" tableName="notification_history">
            <column name="tenant_id"/>
            <column name="patient_id"/>
        </createIndex>

        <!-- Index for alert tracking -->
        <createIndex indexName="idx_notification_alert_id" tableName="notification_history">
            <column name="alert_id"/>
        </createIndex>

        <!-- Index for delivery monitoring -->
        <createIndex indexName="idx_notification_status_sent_at" tableName="notification_history">
            <column name="status"/>
            <column name="sent_at"/>
        </createIndex>

        <!-- Comments for Documentation -->
        <sql>
            COMMENT ON TABLE notification_history IS 'HIPAA compliance audit trail for all notifications sent through the system';
            COMMENT ON COLUMN notification_history.tenant_id IS 'Tenant ID for multi-tenancy isolation';
            COMMENT ON COLUMN notification_history.notification_type IS 'Type of notification: CRITICAL_ALERT, HEALTH_SCORE_UPDATE, APPOINTMENT_REMINDER, MEDICATION_REMINDER, LAB_RESULT, DAILY_DIGEST';
            COMMENT ON COLUMN notification_history.channel IS 'Communication channel: EMAIL, SMS, WEBSOCKET, PUSH_NOTIFICATION';
            COMMENT ON COLUMN notification_history.template_id IS 'Template used to render the notification';
            COMMENT ON COLUMN notification_history.patient_id IS 'Patient FHIR ID (if notification relates to a specific patient)';
            COMMENT ON COLUMN notification_history.recipient_id IS 'Recipient identifier (email, phone, user ID) - encrypted for PHI protection';
            COMMENT ON COLUMN notification_history.content IS 'Rendered notification content (contains PHI - must be encrypted at rest)';
            COMMENT ON COLUMN notification_history.status IS 'Delivery status: SENT, DELIVERED, FAILED, BOUNCED, PENDING';
            COMMENT ON COLUMN notification_history.sent_at IS 'When the notification was sent';
            COMMENT ON COLUMN notification_history.delivered_at IS 'When the notification was delivered (if delivery confirmation available)';
            COMMENT ON COLUMN notification_history.read_at IS 'When the recipient opened/read the notification (if read receipts available)';
        </sql>

        <rollback>
            <dropTable tableName="notification_history"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
