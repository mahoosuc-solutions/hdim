<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0016-create-alert-routing-configs-table" author="healthdata-team">
        <comment>Create alert routing configuration table</comment>

        <createTable tableName="alert_routing_configs">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="tenant_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="alert_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="severity" type="varchar(20)"/>
            <column name="recipient_role" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="priority" type="integer" defaultValue="10">
                <constraints nullable="false"/>
            </column>
            <column name="business_hours_only" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="after_hours_only" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="escalation_threshold_minutes" type="integer"/>
            <column name="on_call_schedule_ref" type="varchar(100)"/>
            <column name="active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="varchar(500)"/>
            <column name="created_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone"/>
            <column name="created_by" type="varchar(100)"/>
            <column name="updated_by" type="varchar(100)"/>
        </createTable>

        <createIndex indexName="idx_routing_tenant_alert_severity" tableName="alert_routing_configs">
            <column name="tenant_id"/>
            <column name="alert_type"/>
            <column name="severity"/>
        </createIndex>
        <createIndex indexName="idx_routing_tenant_active" tableName="alert_routing_configs">
            <column name="tenant_id"/>
            <column name="active"/>
        </createIndex>
        <createIndex indexName="idx_routing_alert_type" tableName="alert_routing_configs">
            <column name="alert_type"/>
        </createIndex>
    </changeSet>

    <changeSet id="0016-create-care-team-assignments-table" author="healthdata-team">
        <comment>Create care team assignments table</comment>

        <createTable tableName="care_team_assignments">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="tenant_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="provider_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="provider_name" type="varchar(200)"/>
            <column name="role" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="specialty" type="varchar(100)"/>
            <column name="active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="effective_from" type="date"/>
            <column name="effective_to" type="date"/>
            <column name="is_primary" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="contact_priority" type="integer" defaultValue="10">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="varchar(255)"/>
            <column name="phone" type="varchar(50)"/>
            <column name="notes" type="varchar(1000)"/>
            <column name="created_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone"/>
            <column name="created_by" type="varchar(100)"/>
            <column name="updated_by" type="varchar(100)"/>
        </createTable>

        <createIndex indexName="idx_care_team_patient_active" tableName="care_team_assignments">
            <column name="tenant_id"/>
            <column name="patient_id"/>
            <column name="active"/>
        </createIndex>
        <createIndex indexName="idx_care_team_patient_role" tableName="care_team_assignments">
            <column name="tenant_id"/>
            <column name="patient_id"/>
            <column name="role"/>
            <column name="active"/>
        </createIndex>
        <createIndex indexName="idx_care_team_provider" tableName="care_team_assignments">
            <column name="provider_id"/>
            <column name="active"/>
        </createIndex>
        <createIndex indexName="idx_care_team_effective_dates" tableName="care_team_assignments">
            <column name="effective_from"/>
            <column name="effective_to"/>
        </createIndex>
    </changeSet>

    <changeSet id="0016-create-care-team-members-table" author="healthdata-team">
        <comment>Create care team members table</comment>

        <createTable tableName="care_team_members">
            <column name="id" type="varchar(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="tenant_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="is_primary" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="start_date" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
            <column name="end_date" type="timestamp with time zone"/>
            <column name="created_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone"/>
        </createTable>

        <createIndex indexName="idx_care_team_patient" tableName="care_team_members">
            <column name="patient_id"/>
        </createIndex>
        <createIndex indexName="idx_care_team_user" tableName="care_team_members">
            <column name="user_id"/>
        </createIndex>
        <createIndex indexName="idx_care_team_tenant" tableName="care_team_members">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex indexName="idx_care_team_active" tableName="care_team_members">
            <column name="active"/>
        </createIndex>
    </changeSet>

    <changeSet id="0016-create-notification-preferences-table" author="healthdata-team">
        <comment>Create notification preferences table</comment>

        <createTable tableName="notification_preferences">
            <column name="id" type="varchar(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="tenant_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="email_enabled" type="boolean" defaultValueBoolean="true"/>
            <column name="sms_enabled" type="boolean" defaultValueBoolean="false"/>
            <column name="push_enabled" type="boolean" defaultValueBoolean="true"/>
            <column name="in_app_enabled" type="boolean" defaultValueBoolean="true"/>
            <column name="email_address" type="varchar(255)"/>
            <column name="phone_number" type="varchar(50)"/>
            <column name="push_token" type="varchar(255)"/>
            <column name="enabled_types" type="jsonb"/>
            <column name="severity_threshold" type="varchar(20)"/>
            <column name="quiet_hours_enabled" type="boolean" defaultValueBoolean="false"/>
            <column name="quiet_hours_start" type="time"/>
            <column name="quiet_hours_end" type="time"/>
            <column name="quiet_hours_override_critical" type="boolean" defaultValueBoolean="true"/>
            <column name="digest_mode_enabled" type="boolean" defaultValueBoolean="false"/>
            <column name="digest_frequency" type="varchar(20)" defaultValue="DAILY"/>
            <column name="custom_settings" type="jsonb"/>
            <column name="consent_given" type="boolean" defaultValueBoolean="false"/>
            <column name="consent_date" type="timestamp with time zone"/>
        </createTable>

        <addUniqueConstraint
            tableName="notification_preferences"
            columnNames="user_id, tenant_id"
            constraintName="uk_notification_pref_user_tenant"/>

        <createIndex indexName="idx_notification_pref_user" tableName="notification_preferences">
            <column name="user_id"/>
        </createIndex>
        <createIndex indexName="idx_notification_pref_tenant" tableName="notification_preferences">
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="0016-create-notifications-table" author="healthdata-team">
        <comment>Create notifications table</comment>

        <createTable tableName="notifications">
            <column name="id" type="varchar(36)">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="tenant_id" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="varchar(100)"/>
            <column name="user_id" type="varchar(100)"/>
            <column name="channel" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="notification_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="severity" type="varchar(20)"/>
            <column name="template_id" type="varchar(100)"/>
            <column name="subject" type="varchar(255)"/>
            <column name="message" type="text"/>
            <column name="recipient" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="provider" type="varchar(100)"/>
            <column name="provider_message_id" type="varchar(100)"/>
            <column name="metadata" type="jsonb"/>
            <column name="error_message" type="text"/>
            <column name="retry_count" type="integer" defaultValue="0"/>
            <column name="max_retries" type="integer" defaultValue="3"/>
            <column name="created_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
            <column name="sent_at" type="timestamp with time zone"/>
            <column name="delivered_at" type="timestamp with time zone"/>
            <column name="failed_at" type="timestamp with time zone"/>
            <column name="next_retry_at" type="timestamp with time zone"/>
            <column name="expires_at" type="timestamp with time zone"/>
        </createTable>

        <createIndex indexName="idx_notifications_patient" tableName="notifications">
            <column name="patient_id"/>
        </createIndex>
        <createIndex indexName="idx_notifications_status" tableName="notifications">
            <column name="status"/>
        </createIndex>
        <createIndex indexName="idx_notifications_channel" tableName="notifications">
            <column name="channel"/>
        </createIndex>
        <createIndex indexName="idx_notifications_created" tableName="notifications">
            <column name="created_at"/>
        </createIndex>
        <createIndex indexName="idx_notifications_tenant" tableName="notifications">
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
