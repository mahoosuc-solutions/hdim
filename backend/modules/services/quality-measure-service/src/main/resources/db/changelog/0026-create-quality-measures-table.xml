<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0001-create-quality-measures-table" author="healthdata-system">
        <comment>Create quality measures table for HEDIS and other quality measure definitions</comment>

        <createTable tableName="quality_measures">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>

            <!-- Measure Identity -->
            <column name="measure_id" type="varchar(128)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="measure_name" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="measure_set" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="varchar(50)">
                <constraints nullable="false"/>
            </column>

            <!-- Classification -->
            <column name="domain" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="category" type="varchar(100)">
                <constraints nullable="true"/>
            </column>
            <column name="measure_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>

            <!-- Details -->
            <column name="description" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="rationale" type="text">
                <constraints nullable="true"/>
            </column>
            <column name="guidance" type="text">
                <constraints nullable="true"/>
            </column>

            <!-- CQL Integration -->
            <column name="cql_library_id" type="uuid">
                <constraints nullable="true"/>
            </column>
            <column name="calculation_logic" type="text">
                <constraints nullable="true"/>
            </column>

            <!-- Scoring -->
            <column name="scoring_method" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="improvement_notation" type="varchar(50)">
                <constraints nullable="true"/>
            </column>

            <!-- Status -->
            <column name="active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="effective_period_start" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="effective_period_end" type="date">
                <constraints nullable="true"/>
            </column>

            <!-- Audit -->
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_quality_measures_tenant" tableName="quality_measures">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_quality_measures_set" tableName="quality_measures">
            <column name="measure_set"/>
        </createIndex>

        <createIndex indexName="idx_quality_measures_domain" tableName="quality_measures">
            <column name="domain"/>
        </createIndex>

        <createIndex indexName="idx_quality_measures_active" tableName="quality_measures">
            <column name="active"/>
        </createIndex>

        <rollback>
            <dropTable tableName="quality_measures"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
