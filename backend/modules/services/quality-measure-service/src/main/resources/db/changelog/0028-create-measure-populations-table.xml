<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0003-create-measure-populations-table" author="healthdata-system">
        <comment>Create measure populations table for aggregate measure statistics</comment>

        <createTable tableName="measure_populations">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="varchar(64)">
                <constraints nullable="false"/>
            </column>
            <column name="measure_id" type="uuid">
                <constraints nullable="false"
                            foreignKeyName="fk_measure_population_measure"
                            references="quality_measures(id)"/>
            </column>

            <!-- Measurement Period -->
            <column name="measurement_period_start" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="measurement_period_end" type="date">
                <constraints nullable="false"/>
            </column>
            <column name="calculation_date" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>

            <!-- Population Counts -->
            <column name="initial_population" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="denominator" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="numerator" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="denominator_exclusions" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="denominator_exceptions" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <!-- Performance Rate -->
            <column name="performance_rate" type="decimal(5,2)">
                <constraints nullable="false"/>
            </column>

            <!-- Stratification (optional) -->
            <column name="stratification" type="varchar(128)">
                <constraints nullable="true"/>
            </column>

            <!-- Audit -->
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint
            tableName="measure_populations"
            columnNames="tenant_id, measure_id, measurement_period_start, measurement_period_end, stratification"
            constraintName="uk_measure_population"/>

        <createIndex indexName="idx_measure_pop_measure" tableName="measure_populations">
            <column name="measure_id"/>
            <column name="measurement_period_end" descending="true"/>
        </createIndex>

        <createIndex indexName="idx_measure_pop_tenant" tableName="measure_populations">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_measure_pop_period" tableName="measure_populations">
            <column name="measurement_period_start"/>
            <column name="measurement_period_end"/>
        </createIndex>

        <rollback>
            <dropTable tableName="measure_populations"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
