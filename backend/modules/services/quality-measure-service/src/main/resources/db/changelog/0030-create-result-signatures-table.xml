<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="0030-create-result-signatures-table" author="hdim">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="result_signatures"/>
            </not>
        </preConditions>
        <comment>Create result_signatures table for immutable audit trail of signed results</comment>

        <createTable tableName="result_signatures">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="result_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="measure_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="signed_by" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="signed_by_username" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="signed_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="signature_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="VARCHAR(1000)"/>
            <column name="numerator_compliant" type="BOOLEAN"/>
            <column name="compliance_rate" type="DOUBLE"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Index on result_id for quick lookups -->
        <createIndex indexName="idx_result_signatures_result_id" tableName="result_signatures">
            <column name="result_id"/>
        </createIndex>

        <!-- Index for querying by tenant and signer -->
        <createIndex indexName="idx_result_signatures_tenant_signed" tableName="result_signatures">
            <column name="tenant_id"/>
            <column name="signed_by"/>
            <column name="signed_at"/>
        </createIndex>

        <!-- Index for patient-based queries -->
        <createIndex indexName="idx_result_signatures_patient" tableName="result_signatures">
            <column name="tenant_id"/>
            <column name="patient_id"/>
        </createIndex>

        <!-- Unique constraint - each result can only be signed once -->
        <addUniqueConstraint tableName="result_signatures"
                             columnNames="result_id"
                             constraintName="uk_result_signatures_result_id"/>
    </changeSet>

</databaseChangeLog>
