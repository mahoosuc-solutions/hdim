<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <!--
        Phase 2: Patient-Specific Measure Assignments

        Creates patient_measure_assignments table to track which quality measures
        are assigned to which patients, with eligibility rules and audit trail.

        Features:
        - Manual and automatic assignment support
        - Date-based activation/deactivation
        - Clinical justification required
        - Multi-tenant isolation
        - Full audit trail
    -->
    <changeSet id="0034-create-patient-measure-assignments" author="claude-code">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="patient_measure_assignments"/>
            </not>
        </preConditions>

        <comment>Create patient measure assignments table for tracking which measures apply to which patients</comment>

        <createTable tableName="patient_measure_assignments">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false" primaryKeyName="pk_patient_measure_assignments"/>
            </column>

            <!-- Tenant Isolation -->
            <column name="tenant_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>

            <!-- Core References -->
            <column name="patient_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="measure_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="measure_type" type="VARCHAR(20)" defaultValue="STANDARD">
                <constraints nullable="false"/>
            </column>

            <!-- Assignment Details -->
            <column name="assigned_by" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="assigned_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="assignment_reason" type="TEXT"/>

            <!-- Status -->
            <column name="active" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="effective_from" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="effective_until" type="DATE"/>

            <!-- Eligibility -->
            <column name="eligibility_criteria" type="JSONB"/>
            <column name="auto_assigned" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>

            <!-- Deactivation -->
            <column name="deactivated_by" type="UUID"/>
            <column name="deactivated_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="deactivation_reason" type="TEXT"/>

            <!-- Audit -->
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Indexes for performance -->
        <createIndex indexName="idx_pma_patient_active" tableName="patient_measure_assignments">
            <column name="patient_id"/>
            <column name="active"/>
        </createIndex>

        <createIndex indexName="idx_pma_measure_active" tableName="patient_measure_assignments">
            <column name="measure_id"/>
            <column name="active"/>
        </createIndex>

        <createIndex indexName="idx_pma_tenant" tableName="patient_measure_assignments">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_pma_effective_period" tableName="patient_measure_assignments">
            <column name="effective_from"/>
            <column name="effective_until"/>
        </createIndex>

        <createIndex indexName="idx_pma_auto_assigned" tableName="patient_measure_assignments">
            <column name="auto_assigned"/>
            <column name="active"/>
        </createIndex>

        <!-- GIN index for JSONB eligibility criteria -->
        <sql>
            CREATE INDEX idx_pma_eligibility_criteria ON patient_measure_assignments USING GIN (eligibility_criteria);
        </sql>

        <!-- Comments for documentation -->
        <sql>
            COMMENT ON TABLE patient_measure_assignments IS 'Tracks which quality measures are assigned to which patients with eligibility rules and audit trail';
            COMMENT ON COLUMN patient_measure_assignments.measure_type IS 'STANDARD (HEDIS/CMS) or CUSTOM (organization-defined)';
            COMMENT ON COLUMN patient_measure_assignments.eligibility_criteria IS 'JSONB defining dynamic eligibility rules evaluated at runtime';
            COMMENT ON COLUMN patient_measure_assignments.auto_assigned IS 'True if system automatically assigned based on criteria, false if manually assigned';
        </sql>

        <rollback>
            <dropTable tableName="patient_measure_assignments"/>
        </rollback>
    </changeSet>

    <!-- Add CHECK constraints for data integrity -->
    <changeSet id="0034-add-pma-check-constraints" author="claude-code">
        <sql>
            ALTER TABLE patient_measure_assignments
                ADD CONSTRAINT chk_pma_measure_type
                    CHECK (measure_type IN ('STANDARD', 'CUSTOM'));

            ALTER TABLE patient_measure_assignments
                ADD CONSTRAINT chk_pma_effective_dates
                    CHECK (effective_until IS NULL OR effective_until >= effective_from);

            ALTER TABLE patient_measure_assignments
                ADD CONSTRAINT chk_pma_deactivation
                    CHECK (
                        (active = true AND deactivated_at IS NULL AND deactivated_by IS NULL) OR
                        (active = false AND deactivated_at IS NOT NULL AND deactivated_by IS NOT NULL)
                    );
        </sql>

        <rollback>
            <sql>
                ALTER TABLE patient_measure_assignments DROP CONSTRAINT IF EXISTS chk_pma_measure_type;
                ALTER TABLE patient_measure_assignments DROP CONSTRAINT IF EXISTS chk_pma_effective_dates;
                ALTER TABLE patient_measure_assignments DROP CONSTRAINT IF EXISTS chk_pma_deactivation;
            </sql>
        </rollback>
    </changeSet>

</databaseChangeLog>
