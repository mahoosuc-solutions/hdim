package com.healthdata.quality.consumer;

import com.healthdata.quality.service.CategorySpecificRiskService;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import java.util.Map;

import static org.mockito.ArgumentMatchers.any;
import static org.mockito.ArgumentMatchers.eq;
import static org.mockito.Mockito.*;

/**
 * TDD Tests for Health Score Change Event Consumer (Phase 4)
 *
 * Tests Kafka event consumption for health score changes:
 * - health-score.significant-change events
 * - Triggers risk recalculation when health score changes significantly
 * - Multi-tenant isolation
 */
@ExtendWith(MockitoExtension.class)
class HealthScoreChangeConsumerTest {

    @Mock
    private CategorySpecificRiskService categoryRiskService;

    @InjectMocks
    private HealthScoreChangeConsumer healthScoreChangeConsumer;

    private static final String TENANT_ID = "test-tenant";
    private static final String PATIENT_ID = "patient-123";

    @BeforeEach
    void setUp() {
        reset(categoryRiskService);
    }

    @Test
    void testOnHealthScoreSignificantChange_RecalculatesRisk() {
        // Given: Health score dropped significantly (75 → 55, delta -20)
        Map<String, Object> event = Map.of(
            "eventType", "health-score.significant-change",
            "tenantId", TENANT_ID,
            "patientId", PATIENT_ID,
            "previousScore", 75.0,
            "newScore", 55.0,
            "scoreDelta", -20.0,
            "changeReason", "Mental health component declined",
            "timestamp", "2024-12-04T10:00:00Z"
        );

        // When: Event is consumed
        healthScoreChangeConsumer.onHealthScoreSignificantChange(event);

        // Then: Should trigger risk recalculation for all categories
        verify(categoryRiskService).recalculateAllRisks(TENANT_ID, PATIENT_ID);
    }

    @Test
    void testOnHealthScoreSignificantChange_LargeIncrease() {
        // Given: Health score improved significantly (50 → 75, delta +25)
        Map<String, Object> event = Map.of(
            "eventType", "health-score.significant-change",
            "tenantId", TENANT_ID,
            "patientId", PATIENT_ID,
            "previousScore", 50.0,
            "newScore", 75.0,
            "scoreDelta", 25.0,
            "changeReason", "Multiple care gaps closed",
            "timestamp", "2024-12-04T11:00:00Z"
        );

        // When: Event is consumed
        healthScoreChangeConsumer.onHealthScoreSignificantChange(event);

        // Then: Should trigger risk recalculation
        verify(categoryRiskService).recalculateAllRisks(TENANT_ID, PATIENT_ID);
    }

    @Test
    void testOnHealthScoreSignificantChange_CriticalDrop() {
        // Given: Health score dropped to critical level (80 → 45, delta -35)
        Map<String, Object> event = Map.of(
            "eventType", "health-score.significant-change",
            "tenantId", TENANT_ID,
            "patientId", PATIENT_ID,
            "previousScore", 80.0,
            "newScore", 45.0,
            "scoreDelta", -35.0,
            "changeReason", "Multiple deteriorations detected",
            "timestamp", "2024-12-04T12:00:00Z"
        );

        // When: Event is consumed
        healthScoreChangeConsumer.onHealthScoreSignificantChange(event);

        // Then: Should trigger risk recalculation
        verify(categoryRiskService).recalculateAllRisks(TENANT_ID, PATIENT_ID);

        // Should also check for deterioration across all categories
        verify(categoryRiskService).detectDeterioration(TENANT_ID, PATIENT_ID, "CARDIOVASCULAR");
        verify(categoryRiskService).detectDeterioration(TENANT_ID, PATIENT_ID, "DIABETES");
        verify(categoryRiskService).detectDeterioration(TENANT_ID, PATIENT_ID, "RESPIRATORY");
        verify(categoryRiskService).detectDeterioration(TENANT_ID, PATIENT_ID, "MENTAL_HEALTH");
    }

    @Test
    void testOnHealthScoreSignificantChange_MissingFields() {
        // Given: Event with missing required fields
        Map<String, Object> incompleteEvent = Map.of(
            "eventType", "health-score.significant-change",
            "tenantId", TENANT_ID
            // Missing patientId
        );

        // When: Event is consumed
        healthScoreChangeConsumer.onHealthScoreSignificantChange(incompleteEvent);

        // Then: Should not trigger risk recalculation
        verify(categoryRiskService, never()).recalculateAllRisks(any(), any());
    }

    @Test
    void testOnHealthScoreSignificantChange_MultiTenantIsolation() {
        // Given: Events for different tenants
        String tenant1 = "tenant-1";
        String tenant2 = "tenant-2";

        Map<String, Object> event1 = Map.of(
            "eventType", "health-score.significant-change",
            "tenantId", tenant1,
            "patientId", PATIENT_ID,
            "previousScore", 70.0,
            "newScore", 50.0,
            "scoreDelta", -20.0,
            "timestamp", "2024-12-04T10:00:00Z"
        );

        Map<String, Object> event2 = Map.of(
            "eventType", "health-score.significant-change",
            "tenantId", tenant2,
            "patientId", PATIENT_ID,
            "previousScore", 60.0,
            "newScore", 80.0,
            "scoreDelta", 20.0,
            "timestamp", "2024-12-04T10:01:00Z"
        );

        // When: Events are consumed
        healthScoreChangeConsumer.onHealthScoreSignificantChange(event1);
        healthScoreChangeConsumer.onHealthScoreSignificantChange(event2);

        // Then: Should trigger risk recalculation for both tenants separately
        verify(categoryRiskService).recalculateAllRisks(tenant1, PATIENT_ID);
        verify(categoryRiskService).recalculateAllRisks(tenant2, PATIENT_ID);
    }

    @Test
    void testOnHealthScoreSignificantChange_ErrorHandling() {
        // Given: Event that will cause an exception
        Map<String, Object> event = Map.of(
            "eventType", "health-score.significant-change",
            "tenantId", TENANT_ID,
            "patientId", PATIENT_ID,
            "previousScore", 70.0,
            "newScore", 50.0,
            "scoreDelta", -20.0,
            "timestamp", "2024-12-04T10:00:00Z"
        );

        doThrow(new RuntimeException("Database error"))
            .when(categoryRiskService).recalculateAllRisks(TENANT_ID, PATIENT_ID);

        // When: Event is consumed
        healthScoreChangeConsumer.onHealthScoreSignificantChange(event);

        // Then: Should catch exception and log (not re-throw)
        // Verify it attempted the operation
        verify(categoryRiskService).recalculateAllRisks(TENANT_ID, PATIENT_ID);
    }

    @Test
    void testOnHealthScoreSignificantChange_OnlyLargeChanges() {
        // Given: Small health score change (not significant)
        Map<String, Object> event = Map.of(
            "eventType", "health-score.significant-change",
            "tenantId", TENANT_ID,
            "patientId", PATIENT_ID,
            "previousScore", 70.0,
            "newScore", 68.0, // Only -2 points
            "scoreDelta", -2.0,
            "timestamp", "2024-12-04T10:00:00Z"
        );

        // When: Event is consumed
        healthScoreChangeConsumer.onHealthScoreSignificantChange(event);

        // Then: Should still trigger recalculation (event already filtered for significance)
        verify(categoryRiskService).recalculateAllRisks(TENANT_ID, PATIENT_ID);
    }
}
