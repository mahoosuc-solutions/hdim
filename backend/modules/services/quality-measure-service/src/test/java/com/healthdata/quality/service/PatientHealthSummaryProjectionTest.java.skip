package com.healthdata.quality.service;

import com.healthdata.quality.persistence.*;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.ArgumentCaptor;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import java.time.Instant;
import java.util.Optional;

import static org.assertj.core.api.Assertions.*;
import static org.mockito.ArgumentMatchers.*;
import static org.mockito.Mockito.*;

/**
 * TDD Test Suite for CQRS Read Model Projection
 *
 * Tests the event-driven read model that materializes patient health summaries:
 * - Write model (command side) updates
 * - Read model materialization from events
 * - Eventual consistency handling
 * - Read model query performance
 * - Projection updates
 *
 * Read Model Schema:
 * - patient_health_summary: Denormalized view for fast patient queries
 * - population_metrics: Aggregated metrics for dashboard
 */
@ExtendWith(MockitoExtension.class)
class PatientHealthSummaryProjectionTest {

    @Mock
    private PatientHealthSummaryRepository readRepository;

    @Mock
    private CareGapRepository careGapRepository;

    @Mock
    private RiskAssessmentRepository riskRepository;

    @Mock
    private MentalHealthAssessmentRepository mentalHealthRepository;

    private PatientHealthSummaryProjection projection;

    @BeforeEach
    void setUp() {
        projection = new PatientHealthSummaryProjection(
            readRepository,
            careGapRepository,
            riskRepository,
            mentalHealthRepository
        );
    }

    /**
     * TEST 1: Write Model Updates Should Trigger Read Model Update
     *
     * When health score is updated in write model, read model should be updated
     */
    @Test
    void shouldUpdateReadModelWhenHealthScoreUpdated() {
        // Given: Existing patient summary
        String tenantId = "tenant-001";
        String patientId = "patient-123";

        PatientHealthSummaryEntity existingSummary = new PatientHealthSummaryEntity();
        existingSummary.setPatientId(patientId);
        existingSummary.setTenantId(tenantId);
        existingSummary.setLatestHealthScore(75.0);

        when(readRepository.findByTenantIdAndPatientId(tenantId, patientId))
            .thenReturn(Optional.of(existingSummary));

        // When: Health score updated event is processed
        projection.onHealthScoreUpdated(tenantId, patientId, 85.0, "improving");

        // Then: Read model should be updated
        ArgumentCaptor<PatientHealthSummaryEntity> captor =
            ArgumentCaptor.forClass(PatientHealthSummaryEntity.class);
        verify(readRepository).save(captor.capture());

        PatientHealthSummaryEntity updated = captor.getValue();
        assertThat(updated.getLatestHealthScore()).isEqualTo(85.0);
        assertThat(updated.getHealthTrend()).isEqualTo("improving");
        assertThat(updated.getLastUpdatedAt()).isNotNull();
    }

    /**
     * TEST 2: Read Model Materialization from Multiple Events
     *
     * Read model should aggregate data from multiple event sources
     */
    @Test
    void shouldMaterializeReadModelFromMultipleEvents() {
        // Given: New patient with no existing summary
        String tenantId = "tenant-001";
        String patientId = "patient-456";

        when(readRepository.findByTenantIdAndPatientId(tenantId, patientId))
            .thenReturn(Optional.empty());

        // Mock aggregated data
        when(careGapRepository.countOpenCareGaps(tenantId, patientId)).thenReturn(5L);
        when(careGapRepository.countUrgentCareGaps(tenantId, patientId)).thenReturn(2L);

        RiskAssessmentEntity riskAssessment = new RiskAssessmentEntity();
        riskAssessment.setRiskLevel("high");
        riskAssessment.setRiskScore(0.75);
        when(riskRepository.findLatestByTenantIdAndPatientId(tenantId, patientId))
            .thenReturn(Optional.of(riskAssessment));

        // When: Multiple events processed
        projection.onHealthScoreUpdated(tenantId, patientId, 65.0, "declining");
        projection.onCareGapAutoClosed(tenantId, patientId, "gap-1");
        projection.onRiskAssessmentUpdated(tenantId, patientId, "high", 0.75);

        // Then: Read model should be materialized with all data
        ArgumentCaptor<PatientHealthSummaryEntity> captor =
            ArgumentCaptor.forClass(PatientHealthSummaryEntity.class);
        verify(readRepository, atLeastOnce()).save(captor.capture());

        PatientHealthSummaryEntity summary = captor.getValue();
        assertThat(summary.getPatientId()).isEqualTo(patientId);
        assertThat(summary.getTenantId()).isEqualTo(tenantId);
        assertThat(summary.getLatestHealthScore()).isEqualTo(65.0);
        assertThat(summary.getRiskLevel()).isEqualTo("high");
        assertThat(summary.getRiskScore()).isEqualTo(0.75);
    }

    /**
     * TEST 3: Eventual Consistency Handling
     *
     * Read model should handle out-of-order events gracefully
     */
    @Test
    void shouldHandleOutOfOrderEventsGracefully() {
        // Given: Patient summary with timestamp
        String tenantId = "tenant-001";
        String patientId = "patient-789";

        PatientHealthSummaryEntity existingSummary = new PatientHealthSummaryEntity();
        existingSummary.setPatientId(patientId);
        existingSummary.setTenantId(tenantId);
        existingSummary.setLatestHealthScore(80.0);
        existingSummary.setLastUpdatedAt(Instant.now());

        when(readRepository.findByTenantIdAndPatientId(tenantId, patientId))
            .thenReturn(Optional.of(existingSummary));

        // When: Older event arrives (simulating out-of-order)
        Instant olderTimestamp = Instant.now().minusSeconds(3600);
        projection.onHealthScoreUpdatedWithTimestamp(tenantId, patientId, 75.0, "stable", olderTimestamp);

        // Then: Should not overwrite newer data
        verify(readRepository, never()).save(any());
    }

    /**
     * TEST 4: Read Model Query Performance
     *
     * Verify read model queries are optimized
     */
    @Test
    void shouldQueryReadModelEfficiently() {
        // Given: Patient summary in read model
        String tenantId = "tenant-001";
        String patientId = "patient-101";

        PatientHealthSummaryEntity summary = new PatientHealthSummaryEntity();
        summary.setPatientId(patientId);
        summary.setTenantId(tenantId);
        summary.setLatestHealthScore(90.0);
        summary.setOpenCareGapsCount(2);
        summary.setUrgentGapsCount(0);
        summary.setRiskLevel("low");
        summary.setRiskScore(0.15);

        when(readRepository.findByTenantIdAndPatientId(tenantId, patientId))
            .thenReturn(Optional.of(summary));

        // When: Query read model
        Optional<PatientHealthSummaryEntity> result =
            readRepository.findByTenantIdAndPatientId(tenantId, patientId);

        // Then: Should return in single query (no joins needed)
        assertThat(result).isPresent();
        assertThat(result.get().getLatestHealthScore()).isEqualTo(90.0);
        assertThat(result.get().getOpenCareGapsCount()).isEqualTo(2);
        assertThat(result.get().getRiskLevel()).isEqualTo("low");

        // Verify only one database call
        verify(readRepository, times(1)).findByTenantIdAndPatientId(tenantId, patientId);
    }

    /**
     * TEST 5: Projection Update on Care Gap Closure
     *
     * When care gap is closed, read model should update counts
     */
    @Test
    void shouldUpdateReadModelOnCareGapClosure() {
        // Given: Patient with open care gaps
        String tenantId = "tenant-001";
        String patientId = "patient-202";

        PatientHealthSummaryEntity summary = new PatientHealthSummaryEntity();
        summary.setPatientId(patientId);
        summary.setTenantId(tenantId);
        summary.setOpenCareGapsCount(5);
        summary.setUrgentGapsCount(2);

        when(readRepository.findByTenantIdAndPatientId(tenantId, patientId))
            .thenReturn(Optional.of(summary));

        // Mock updated counts
        when(careGapRepository.countOpenCareGaps(tenantId, patientId)).thenReturn(4L);
        when(careGapRepository.countUrgentCareGaps(tenantId, patientId)).thenReturn(1L);

        // When: Care gap closed event
        projection.onCareGapAutoClosed(tenantId, patientId, "gap-urgent-1");

        // Then: Counts should be updated
        ArgumentCaptor<PatientHealthSummaryEntity> captor =
            ArgumentCaptor.forClass(PatientHealthSummaryEntity.class);
        verify(readRepository).save(captor.capture());

        PatientHealthSummaryEntity updated = captor.getValue();
        assertThat(updated.getOpenCareGapsCount()).isEqualTo(4);
        assertThat(updated.getUrgentGapsCount()).isEqualTo(1);
    }

    /**
     * TEST 6: Projection Update on Risk Assessment
     *
     * Risk assessment updates should reflect in read model
     */
    @Test
    void shouldUpdateReadModelOnRiskAssessment() {
        // Given: Patient with low risk
        String tenantId = "tenant-001";
        String patientId = "patient-303";

        PatientHealthSummaryEntity summary = new PatientHealthSummaryEntity();
        summary.setPatientId(patientId);
        summary.setTenantId(tenantId);
        summary.setRiskLevel("low");
        summary.setRiskScore(0.20);

        when(readRepository.findByTenantIdAndPatientId(tenantId, patientId))
            .thenReturn(Optional.of(summary));

        // When: Risk escalates to high
        projection.onRiskAssessmentUpdated(tenantId, patientId, "high", 0.85);

        // Then: Risk data should be updated
        ArgumentCaptor<PatientHealthSummaryEntity> captor =
            ArgumentCaptor.forClass(PatientHealthSummaryEntity.class);
        verify(readRepository).save(captor.capture());

        PatientHealthSummaryEntity updated = captor.getValue();
        assertThat(updated.getRiskLevel()).isEqualTo("high");
        assertThat(updated.getRiskScore()).isEqualTo(0.85);
    }

    /**
     * TEST 7: Projection Update on Clinical Alert
     *
     * Clinical alerts should update alert counts in read model
     */
    @Test
    void shouldUpdateReadModelOnClinicalAlert() {
        // Given: Patient with no active alerts
        String tenantId = "tenant-001";
        String patientId = "patient-404";

        PatientHealthSummaryEntity summary = new PatientHealthSummaryEntity();
        summary.setPatientId(patientId);
        summary.setTenantId(tenantId);
        summary.setActiveAlertsCount(0);
        summary.setCriticalAlertsCount(0);

        when(readRepository.findByTenantIdAndPatientId(tenantId, patientId))
            .thenReturn(Optional.of(summary));

        // When: Critical alert triggered
        projection.onClinicalAlertTriggered(tenantId, patientId, "critical", "HbA1c dangerously high");

        // Then: Alert counts should be updated
        ArgumentCaptor<PatientHealthSummaryEntity> captor =
            ArgumentCaptor.forClass(PatientHealthSummaryEntity.class);
        verify(readRepository).save(captor.capture());

        PatientHealthSummaryEntity updated = captor.getValue();
        assertThat(updated.getActiveAlertsCount()).isEqualTo(1);
        assertThat(updated.getCriticalAlertsCount()).isEqualTo(1);
    }

    /**
     * TEST 8: Rebuild Projection from Write Model
     *
     * Should be able to rebuild entire read model from write model
     */
    @Test
    void shouldRebuildReadModelFromWriteModel() {
        // Given: Write model data exists
        String tenantId = "tenant-001";
        String patientId = "patient-505";

        when(careGapRepository.countOpenCareGaps(tenantId, patientId)).thenReturn(3L);
        when(careGapRepository.countUrgentCareGaps(tenantId, patientId)).thenReturn(1L);

        RiskAssessmentEntity risk = new RiskAssessmentEntity();
        risk.setRiskLevel("medium");
        risk.setRiskScore(0.45);
        when(riskRepository.findLatestByTenantIdAndPatientId(tenantId, patientId))
            .thenReturn(Optional.of(risk));

        when(mentalHealthRepository.countByTenantIdAndPatientId(tenantId, patientId))
            .thenReturn(5L);

        // When: Rebuild projection
        projection.rebuildProjectionForPatient(tenantId, patientId);

        // Then: Read model should be fully reconstructed
        ArgumentCaptor<PatientHealthSummaryEntity> captor =
            ArgumentCaptor.forClass(PatientHealthSummaryEntity.class);
        verify(readRepository).save(captor.capture());

        PatientHealthSummaryEntity rebuilt = captor.getValue();
        assertThat(rebuilt.getPatientId()).isEqualTo(patientId);
        assertThat(rebuilt.getTenantId()).isEqualTo(tenantId);
        assertThat(rebuilt.getOpenCareGapsCount()).isEqualTo(3);
        assertThat(rebuilt.getUrgentGapsCount()).isEqualTo(1);
        assertThat(rebuilt.getRiskLevel()).isEqualTo("medium");
        assertThat(rebuilt.getRiskScore()).isEqualTo(0.45);
    }

    /**
     * TEST 9: Population Metrics Aggregation
     *
     * Should aggregate population-level metrics efficiently
     */
    @Test
    void shouldAggregatePopulationMetrics() {
        // Given: Multiple patient summaries
        String tenantId = "tenant-001";

        when(readRepository.countByTenantId(tenantId)).thenReturn(1000L);
        when(readRepository.averageHealthScoreByTenantId(tenantId)).thenReturn(78.5);
        when(readRepository.countHighRiskPatients(tenantId)).thenReturn(150L);
        when(readRepository.countMediumRiskPatients(tenantId)).thenReturn(300L);
        when(readRepository.totalOpenCareGaps(tenantId)).thenReturn(2500L);

        // When: Query population metrics
        var metrics = projection.getPopulationMetrics(tenantId);

        // Then: Should return aggregated metrics in single query
        assertThat(metrics.getTotalPatients()).isEqualTo(1000);
        assertThat(metrics.getAverageHealthScore()).isEqualTo(78.5);
        assertThat(metrics.getHighRiskCount()).isEqualTo(150);
        assertThat(metrics.getMediumRiskCount()).isEqualTo(300);
        assertThat(metrics.getTotalCareGaps()).isEqualTo(2500);
    }
}
