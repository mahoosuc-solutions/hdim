<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0014-create-sequence-enrollments-table" author="hdim-platform">
        <comment>
            Create sequence_enrollments table for tracking lead/contact enrollment in email sequences
            Entity: com.healthdata.sales.entity.SequenceEnrollment
        </comment>

        <createTable tableName="sequence_enrollments">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>

            <column name="sequence_id" type="UUID">
                <constraints nullable="false"
                             foreignKeyName="fk_sequence_enrollments_sequence"
                             references="email_sequences(id)"/>
            </column>

            <column name="lead_id" type="UUID"/>

            <column name="contact_id" type="UUID"/>

            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="first_name" type="VARCHAR(100)"/>

            <column name="last_name" type="VARCHAR(100)"/>

            <column name="current_step" type="INTEGER">
                <constraints nullable="false"/>
            </column>

            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <column name="next_email_at" type="TIMESTAMP"/>

            <column name="last_email_sent_at" type="TIMESTAMP"/>

            <column name="emails_sent" type="INTEGER">
                <constraints nullable="false"/>
            </column>

            <column name="emails_opened" type="INTEGER">
                <constraints nullable="false"/>
            </column>

            <column name="emails_clicked" type="INTEGER">
                <constraints nullable="false"/>
            </column>

            <column name="emails_bounced" type="INTEGER">
                <constraints nullable="false"/>
            </column>

            <column name="enrolled_by_user_id" type="UUID"/>

            <column name="pause_reason" type="VARCHAR(255)"/>

            <column name="completion_reason" type="VARCHAR(255)"/>

            <column name="unsubscribe_token" type="VARCHAR(100)"/>

            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Indexes for sequence_enrollments table -->
        <createIndex indexName="idx_enrollments_tenant" tableName="sequence_enrollments">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_enrollments_sequence" tableName="sequence_enrollments">
            <column name="sequence_id"/>
        </createIndex>

        <createIndex indexName="idx_enrollments_lead" tableName="sequence_enrollments">
            <column name="lead_id"/>
        </createIndex>

        <createIndex indexName="idx_enrollments_contact" tableName="sequence_enrollments">
            <column name="contact_id"/>
        </createIndex>

        <createIndex indexName="idx_enrollments_status" tableName="sequence_enrollments">
            <column name="status"/>
        </createIndex>

        <createIndex indexName="idx_enrollments_next_email" tableName="sequence_enrollments">
            <column name="next_email_at"/>
        </createIndex>

        <rollback>
            <dropTable tableName="sequence_enrollments"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
