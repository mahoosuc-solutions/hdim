<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0012-create-email-sequences-table" author="hdim-platform">
        <comment>
            Create email_sequences table for automated email campaigns
            Entity: com.healthdata.sales.entity.EmailSequence
        </comment>

        <createTable tableName="email_sequences">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>

            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="description" type="TEXT"/>

            <column name="sequence_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <column name="target_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <column name="is_active" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>

            <column name="from_name" type="VARCHAR(100)"/>

            <column name="from_email" type="VARCHAR(255)"/>

            <column name="reply_to_email" type="VARCHAR(255)"/>

            <column name="unsubscribe_link" type="BOOLEAN"/>

            <column name="track_opens" type="BOOLEAN"/>

            <column name="track_clicks" type="BOOLEAN"/>

            <column name="owner_user_id" type="UUID"/>

            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Indexes for email_sequences table -->
        <createIndex indexName="idx_email_sequences_tenant" tableName="email_sequences">
            <column name="tenant_id"/>
        </createIndex>

        <createIndex indexName="idx_email_sequences_type" tableName="email_sequences">
            <column name="sequence_type"/>
        </createIndex>

        <createIndex indexName="idx_email_sequences_active" tableName="email_sequences">
            <column name="is_active"/>
        </createIndex>

        <rollback>
            <dropTable tableName="email_sequences"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
