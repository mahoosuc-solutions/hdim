<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Initial schema creation -->
    <changeSet id="001-create-leads-table" author="hdim">
        <createTable tableName="leads">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(100)"/>
            <column name="last_name" type="VARCHAR(100)"/>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="phone" type="VARCHAR(50)"/>
            <column name="company" type="VARCHAR(255)"/>
            <column name="title" type="VARCHAR(100)"/>
            <column name="website" type="VARCHAR(255)"/>
            <column name="source" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="organization_type" type="VARCHAR(50)"/>
            <column name="patient_count" type="INTEGER"/>
            <column name="ehr_count" type="INTEGER"/>
            <column name="state" type="VARCHAR(50)"/>
            <column name="score" type="INTEGER"/>
            <column name="notes" type="TEXT"/>
            <column name="zoho_lead_id" type="VARCHAR(100)"/>
            <column name="assigned_to_user_id" type="UUID"/>
            <column name="last_contacted_at" type="TIMESTAMP"/>
            <column name="converted_at" type="TIMESTAMP"/>
            <column name="converted_contact_id" type="UUID"/>
            <column name="converted_opportunity_id" type="UUID"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="leads" indexName="idx_leads_tenant">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="leads" indexName="idx_leads_email">
            <column name="email"/>
        </createIndex>
        <createIndex tableName="leads" indexName="idx_leads_status">
            <column name="status"/>
        </createIndex>
        <createIndex tableName="leads" indexName="idx_leads_source">
            <column name="source"/>
        </createIndex>
        <createIndex tableName="leads" indexName="idx_leads_zoho">
            <column name="zoho_lead_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="002-create-accounts-table" author="hdim">
        <createTable tableName="accounts">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="organization_type" type="VARCHAR(50)"/>
            <column name="website" type="VARCHAR(255)"/>
            <column name="phone" type="VARCHAR(50)"/>
            <column name="address_line1" type="VARCHAR(255)"/>
            <column name="address_line2" type="VARCHAR(255)"/>
            <column name="city" type="VARCHAR(100)"/>
            <column name="state" type="VARCHAR(50)"/>
            <column name="zip_code" type="VARCHAR(20)"/>
            <column name="patient_count" type="INTEGER"/>
            <column name="ehr_count" type="INTEGER"/>
            <column name="ehr_systems" type="VARCHAR(500)"/>
            <column name="stage" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="annual_revenue" type="BIGINT"/>
            <column name="employee_count" type="INTEGER"/>
            <column name="industry" type="VARCHAR(100)"/>
            <column name="description" type="TEXT"/>
            <column name="zoho_account_id" type="VARCHAR(100)"/>
            <column name="owner_user_id" type="UUID"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="accounts" indexName="idx_accounts_tenant">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="accounts" indexName="idx_accounts_name">
            <column name="name"/>
        </createIndex>
        <createIndex tableName="accounts" indexName="idx_accounts_stage">
            <column name="stage"/>
        </createIndex>
        <createIndex tableName="accounts" indexName="idx_accounts_zoho">
            <column name="zoho_account_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="003-create-contacts-table" author="hdim">
        <createTable tableName="contacts">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="account_id" type="UUID"/>
            <column name="first_name" type="VARCHAR(100)"/>
            <column name="last_name" type="VARCHAR(100)"/>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="phone" type="VARCHAR(50)"/>
            <column name="mobile" type="VARCHAR(50)"/>
            <column name="title" type="VARCHAR(100)"/>
            <column name="department" type="VARCHAR(100)"/>
            <column name="contact_type" type="VARCHAR(50)"/>
            <column name="is_primary" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="do_not_call" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="do_not_email" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="linkedin_url" type="VARCHAR(255)"/>
            <column name="notes" type="TEXT"/>
            <column name="zoho_contact_id" type="VARCHAR(100)"/>
            <column name="owner_user_id" type="UUID"/>
            <column name="last_contacted_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="contacts" indexName="idx_contacts_tenant">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="contacts" indexName="idx_contacts_account">
            <column name="account_id"/>
        </createIndex>
        <createIndex tableName="contacts" indexName="idx_contacts_email">
            <column name="email"/>
        </createIndex>
        <createIndex tableName="contacts" indexName="idx_contacts_zoho">
            <column name="zoho_contact_id"/>
        </createIndex>

        <addForeignKeyConstraint
            baseTableName="contacts"
            baseColumnNames="account_id"
            referencedTableName="accounts"
            referencedColumnNames="id"
            constraintName="fk_contacts_account"/>
    </changeSet>

    <changeSet id="004-create-opportunities-table" author="hdim">
        <createTable tableName="opportunities">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="account_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="primary_contact_id" type="UUID"/>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="amount" type="DECIMAL(12,2)"/>
            <column name="stage" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="probability" type="INTEGER"/>
            <column name="expected_close_date" type="DATE"/>
            <column name="actual_close_date" type="DATE"/>
            <column name="lost_reason" type="VARCHAR(50)"/>
            <column name="lost_reason_detail" type="VARCHAR(500)"/>
            <column name="competitor" type="VARCHAR(255)"/>
            <column name="next_step" type="VARCHAR(500)"/>
            <column name="product_tier" type="VARCHAR(50)"/>
            <column name="contract_length_months" type="INTEGER"/>
            <column name="zoho_opportunity_id" type="VARCHAR(100)"/>
            <column name="owner_user_id" type="UUID"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="opportunities" indexName="idx_opportunities_tenant">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="opportunities" indexName="idx_opportunities_account">
            <column name="account_id"/>
        </createIndex>
        <createIndex tableName="opportunities" indexName="idx_opportunities_stage">
            <column name="stage"/>
        </createIndex>
        <createIndex tableName="opportunities" indexName="idx_opportunities_close_date">
            <column name="expected_close_date"/>
        </createIndex>
        <createIndex tableName="opportunities" indexName="idx_opportunities_zoho">
            <column name="zoho_opportunity_id"/>
        </createIndex>

        <addForeignKeyConstraint
            baseTableName="opportunities"
            baseColumnNames="account_id"
            referencedTableName="accounts"
            referencedColumnNames="id"
            constraintName="fk_opportunities_account"/>
        <addForeignKeyConstraint
            baseTableName="opportunities"
            baseColumnNames="primary_contact_id"
            referencedTableName="contacts"
            referencedColumnNames="id"
            constraintName="fk_opportunities_contact"/>
    </changeSet>

    <changeSet id="005-create-activities-table" author="hdim">
        <createTable tableName="activities">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tenant_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="lead_id" type="UUID"/>
            <column name="contact_id" type="UUID"/>
            <column name="account_id" type="UUID"/>
            <column name="opportunity_id" type="UUID"/>
            <column name="activity_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="subject" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="outcome" type="VARCHAR(500)"/>
            <column name="scheduled_at" type="TIMESTAMP"/>
            <column name="completed_at" type="TIMESTAMP"/>
            <column name="duration_minutes" type="INTEGER"/>
            <column name="is_completed" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="assigned_to_user_id" type="UUID"/>
            <column name="zoho_activity_id" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="activities" indexName="idx_activities_tenant">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="activities" indexName="idx_activities_lead">
            <column name="lead_id"/>
        </createIndex>
        <createIndex tableName="activities" indexName="idx_activities_contact">
            <column name="contact_id"/>
        </createIndex>
        <createIndex tableName="activities" indexName="idx_activities_opportunity">
            <column name="opportunity_id"/>
        </createIndex>
        <createIndex tableName="activities" indexName="idx_activities_scheduled">
            <column name="scheduled_at"/>
        </createIndex>
        <createIndex tableName="activities" indexName="idx_activities_type">
            <column name="activity_type"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
