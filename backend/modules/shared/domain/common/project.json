{
  "name": "modules-shared-domain-common",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "backend/modules/shared/domain/common/src",
  "tags": [
    "backend",
    "lib"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/backend/modules/shared/domain/common/build"
      ],
      "options": {
        "command": "./backend/gradlew -p backend :modules:shared:domain:common:build"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./backend/gradlew -p backend :modules:shared:domain:common:test"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./backend/gradlew -p backend :modules:shared:domain:common:clean"
      }
    },
    "coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./backend/gradlew -p backend :modules:shared:domain:common:test :modules:shared:domain:common:jacocoTestReport :modules:shared:domain:common:jacocoTestCoverageVerification"
      }
    }
  }
}
