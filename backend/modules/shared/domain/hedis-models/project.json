{
  "name": "modules-shared-domain-hedis-models",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "backend/modules/shared/domain/hedis-models/src",
  "tags": [
    "backend",
    "lib"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/backend/modules/shared/domain/hedis-models/build"
      ],
      "options": {
        "command": "./backend/gradlew -p backend :modules:shared:domain:hedis-models:build"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./backend/gradlew -p backend :modules:shared:domain:hedis-models:test"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./backend/gradlew -p backend :modules:shared:domain:hedis-models:clean"
      }
    },
    "coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./backend/gradlew -p backend :modules:shared:domain:hedis-models:test :modules:shared:domain:hedis-models:jacocoTestReport :modules:shared:domain:hedis-models:jacocoTestCoverageVerification"
      }
    }
  }
}
