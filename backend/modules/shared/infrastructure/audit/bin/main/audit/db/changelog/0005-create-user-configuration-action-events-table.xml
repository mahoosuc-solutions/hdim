<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0005-create-user-configuration-action-events-table" author="healthdata-system">
        <comment>User Configuration Action Events table for tracking user-initiated configuration actions</comment>

        <createTable tableName="user_configuration_action_events">
            <column name="event_id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="timestamp" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="varchar(100)"/>
            <column name="user_id" type="varchar(100)"/>
            <column name="username" type="varchar(255)"/>
            <column name="user_role" type="varchar(50)"/>
            <column name="user_email" type="varchar(255)"/>
            <column name="action_type" type="varchar(50)"/>
            <column name="action_source" type="varchar(50)"/>
            <column name="session_id" type="varchar(100)"/>
            <column name="ip_address" type="varchar(45)"/>
            <column name="user_agent" type="varchar(500)"/>
            <column name="service_name" type="varchar(100)"/>
            <column name="resource_type" type="varchar(100)"/>
            <column name="resource_id" type="varchar(255)"/>
            <column name="configuration_key" type="varchar(255)"/>
            <column name="requested_value" type="varchar(1000)"/>
            <column name="applied_value" type="varchar(1000)"/>
            <column name="ai_recommendation_id" type="uuid"/>
            <column name="ai_recommendation_action" type="varchar(50)"/>
            <column name="natural_language_query" type="text"/>
            <column name="ai_response_id" type="uuid"/>
            <column name="user_feedback_rating" type="integer"/>
            <column name="user_feedback_comment" type="text"/>
            <column name="action_status" type="varchar(30)"/>
            <column name="error_message" type="text"/>
            <column name="success_message" type="text"/>
            <column name="risk_level" type="varchar(20)"/>
            <column name="affected_tenants" type="integer"/>
            <column name="affected_users" type="integer"/>
            <column name="estimated_impact" type="jsonb"/>
            <column name="requires_approval" type="boolean"/>
            <column name="approval_status" type="varchar(30)"/>
            <column name="approved_by" type="varchar(255)"/>
            <column name="approved_at" type="timestamp with time zone"/>
            <column name="request_id" type="varchar(100)"/>
            <column name="correlation_id" type="varchar(100)"/>
            <column name="change_ticket_id" type="varchar(100)"/>
            <column name="environment" type="varchar(20)"/>
            <column name="created_at" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_user_action_tenant_timestamp" tableName="user_configuration_action_events">
            <column name="tenant_id"/>
            <column name="timestamp"/>
        </createIndex>
        <createIndex indexName="idx_user_action_user" tableName="user_configuration_action_events">
            <column name="user_id"/>
            <column name="timestamp"/>
        </createIndex>
        <createIndex indexName="idx_user_action_type" tableName="user_configuration_action_events">
            <column name="action_type"/>
            <column name="timestamp"/>
        </createIndex>
        <createIndex indexName="idx_user_action_status" tableName="user_configuration_action_events">
            <column name="action_status"/>
            <column name="timestamp"/>
        </createIndex>
        <createIndex indexName="idx_user_action_service" tableName="user_configuration_action_events">
            <column name="service_name"/>
            <column name="timestamp"/>
        </createIndex>
        <createIndex indexName="idx_user_action_ai_recommendation" tableName="user_configuration_action_events">
            <column name="ai_recommendation_id"/>
        </createIndex>
        <createIndex indexName="idx_user_action_correlation" tableName="user_configuration_action_events">
            <column name="correlation_id"/>
        </createIndex>
        <createIndex indexName="idx_user_action_environment" tableName="user_configuration_action_events">
            <column name="environment"/>
            <column name="timestamp"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
