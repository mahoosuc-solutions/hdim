<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0010-enforce-audit-encrypted-not-null" author="healthdata-system">
        <comment>Ensure encrypted flag is non-null to match JPA mapping</comment>

        <update tableName="audit_events">
            <column name="encrypted" valueBoolean="false"/>
            <where>encrypted IS NULL</where>
        </update>

        <addNotNullConstraint tableName="audit_events"
                              columnName="encrypted"
                              columnDataType="boolean"/>
    </changeSet>
</databaseChangeLog>
