<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="0001-create-audit-events-table" author="healthdata-system">
        <comment>Core audit event table + indexes</comment>

        <createTable tableName="audit_events">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="timestamp" type="timestamp with time zone">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="varchar(64)"/>

            <column name="user_id" type="varchar(64)"/>
            <column name="username" type="varchar(128)"/>
            <column name="role" type="varchar(64)"/>
            <column name="ip_address" type="varchar(45)"/>
            <column name="user_agent" type="text"/>

            <column name="action" type="varchar(32)">
                <constraints nullable="false"/>
            </column>
            <column name="resource_type" type="varchar(64)"/>
            <column name="resource_id" type="varchar(64)"/>
            <column name="outcome" type="varchar(32)">
                <constraints nullable="false"/>
            </column>

            <column name="service_name" type="varchar(128)"/>
            <column name="method_name" type="varchar(128)"/>
            <column name="request_path" type="varchar(512)"/>

            <column name="purpose_of_use" type="varchar(64)"/>

            <column name="request_payload" type="jsonb"/>
            <column name="response_payload" type="jsonb"/>
            <column name="error_message" type="text"/>
            <column name="duration_ms" type="bigint"/>
            <column name="fhir_audit_event_id" type="varchar(64)"/>
            <column name="encrypted" type="boolean" defaultValueBoolean="false"/>
        </createTable>

        <createIndex indexName="idx_audit_timestamp" tableName="audit_events">
            <column name="timestamp"/>
        </createIndex>
        <createIndex indexName="idx_audit_user" tableName="audit_events">
            <column name="user_id"/>
            <column name="timestamp"/>
        </createIndex>
        <createIndex indexName="idx_audit_resource" tableName="audit_events">
            <column name="resource_type"/>
            <column name="resource_id"/>
            <column name="timestamp"/>
        </createIndex>
        <createIndex indexName="idx_audit_tenant" tableName="audit_events">
            <column name="tenant_id"/>
            <column name="timestamp"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
