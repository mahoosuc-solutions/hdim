<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0008-create-condition-projections-table" author="team-3-condition-projection">
        <comment>Create condition projections table for diagnosis history and status tracking</comment>

        <createTable tableName="condition_projections">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_condition_projections"/>
            </column>
            <column name="tenant_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="icd_code" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)"/>
            <column name="verification_status" type="VARCHAR(50)"/>
            <column name="onset_date" type="DATE"/>
            <column name="clinical_notes" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"
                    defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"
                    defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_condition_projections_tenant_patient" tableName="condition_projections">
            <column name="tenant_id"/>
            <column name="patient_id"/>
        </createIndex>

        <createIndex indexName="idx_condition_projections_icd_code" tableName="condition_projections">
            <column name="icd_code"/>
        </createIndex>

        <createIndex indexName="idx_condition_projections_status" tableName="condition_projections">
            <column name="status"/>
        </createIndex>

        <createIndex indexName="idx_condition_projections_tenant_patient_status" tableName="condition_projections">
            <column name="tenant_id"/>
            <column name="patient_id"/>
            <column name="status"/>
        </createIndex>

        <createIndex indexName="idx_condition_projections_onset_date" tableName="condition_projections">
            <column name="onset_date"/>
        </createIndex>

        <rollback>
            <dropTable tableName="condition_projections"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
