<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="0007-create-observation-projections-table" author="team-2-observation-projection">
        <comment>Create observation projections table for time-series vital signs data</comment>

        <createTable tableName="observation_projections">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_observation_projections"/>
            </column>
            <column name="tenant_id" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="loinc_code" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="value" type="NUMERIC(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="unit" type="VARCHAR(50)"/>
            <column name="observation_date" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="notes" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE"
                    defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE"
                    defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Indexes for time-series queries -->
        <createIndex indexName="idx_observation_projections_tenant_patient" tableName="observation_projections">
            <column name="tenant_id"/>
            <column name="patient_id"/>
        </createIndex>

        <createIndex indexName="idx_observation_projections_loinc" tableName="observation_projections">
            <column name="loinc_code"/>
        </createIndex>

        <createIndex indexName="idx_observation_projections_date" tableName="observation_projections">
            <column name="observation_date"/>
        </createIndex>

        <createIndex indexName="idx_observation_projections_tenant_patient_loinc" tableName="observation_projections">
            <column name="tenant_id"/>
            <column name="patient_id"/>
            <column name="loinc_code"/>
        </createIndex>

        <createIndex indexName="idx_observation_projections_tenant_patient_date" tableName="observation_projections">
            <column name="tenant_id"/>
            <column name="patient_id"/>
            <column name="observation_date"/>
        </createIndex>

        <rollback>
            <dropTable tableName="observation_projections"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
