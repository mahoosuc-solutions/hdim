{
  "name": "backend",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "backend",
  "tags": ["backend"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./backend/gradlew -p backend buildAllServices"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./backend/gradlew -p backend testAllServices"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./backend/gradlew -p backend cleanAll"
      }
    }
  }
}
