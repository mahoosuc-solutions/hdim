{
  "version": 2,
  "name": "hdim-investor-portal",
  "public": true,
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/demo", "dest": "/landing-page-a.html" },
    { "src": "/calculator", "dest": "/landing-page-b.html" },
    { "src": "/investors", "dest": "/one-pager.html" },
    { "src": "/deck", "dest": "/pitch-deck.html" },
    { "src": "/holiday", "dest": "/holiday-card.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
