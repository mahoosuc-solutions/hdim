{
  "id": null,
  "uid": "authentication-metrics",
  "title": "Authentication Metrics",
  "tags": ["hdim", "authentication", "security"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "editable": true,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up, job)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*"
      },
      {
        "name": "tenant",
        "type": "textbox",
        "query": "acme-health",
        "current": { "text": "acme-health", "value": "acme-health" }
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Auth Success Rate",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 }] }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status!~\"401|403\",job=~\"$service\",uri=~\".*auth.*|.*login.*|.*token.*\"}[5m])) / clamp_min(sum(rate(http_server_requests_seconds_count{job=~\"$service\",uri=~\".*auth.*|.*login.*|.*token.*\"}[5m])), 1e-10)",
          "legendFormat": "success_rate"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Auth Failures/min",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(auth_failure_total{job=~\"$service\"}[5m])) * 60",
          "legendFormat": "failures/min"
        }
      ]
    },
    {
      "type": "stat",
      "title": "JWT Validations/sec",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(rate(jwt_validation_total{job=~\"$service\"}[5m]))",
          "legendFormat": "jwt/sec"
        }
      ]
    },
    {
      "type": "stat",
      "title": "RBAC Denials",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 5 }, { "color": "red", "value": 20 }] }
        }
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(increase(http_server_requests_seconds_count{status=\"403\",job=~\"$service\"}[1h]))",
          "legendFormat": "denials"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Auth Success vs Failure Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 } } },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"2..\",job=~\"$service\",uri=~\".*auth.*|.*login.*|.*token.*\"}[5m]))",
          "legendFormat": "success"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"401|403\",job=~\"$service\"}[5m]))",
          "legendFormat": "failure"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Auth Latency p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1.0 }] } } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=~\"$service\",uri=~\".*auth.*|.*login.*|.*token.*\"}[5m])) by (le, job))",
          "legendFormat": "{{job}} p95"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Failed Auth by Service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "bars", "fillOpacity": 50, "lineWidth": 1 } } },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"401|403\",job=~\"$service\"}[5m])) by (job)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Token Expiry Events",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } } },
      "targets": [
        {
          "expr": "sum(rate(jwt_token_expired_total{job=~\"$service\"}[5m])) by (job)",
          "legendFormat": "{{job}} expired"
        },
        {
          "expr": "sum(rate(jwt_validation_failures_total{job=~\"$service\"}[5m])) by (job)",
          "legendFormat": "{{job}} invalid"
        }
      ]
    }
  ]
}
