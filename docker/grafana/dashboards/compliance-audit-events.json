{
  "id": null,
  "uid": "compliance-audit-events",
  "title": "HIPAA Compliance & Audit Events",
  "tags": ["hdim", "hipaa", "compliance", "audit", "observability"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "editable": true,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(up, job)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*"
      },
      {
        "name": "tenant",
        "type": "textbox",
        "query": "acme-health",
        "current": {"text": "acme-health", "value": "acme-health"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "PHI Access Events (24h)",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{
        "expr": "sum(increase(audit_phi_access_total{job=~\"$service\"}[24h]))",
        "legendFormat": "PHI Access"
      }],
      "options": {"colorMode": "background", "graphMode": "area"},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 10000, "color": "yellow"}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Auth Failures (24h)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{
        "expr": "sum(increase(auth_failure_total{job=~\"$service\"}[24h]))",
        "legendFormat": "Auth Failures"
      }],
      "options": {"colorMode": "background", "graphMode": "area"},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 10, "color": "yellow"},
              {"value": 50, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Tenant Violations (24h)",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{
        "expr": "sum(increase(tenant_violations_total{job=~\"$service\"}[24h]))",
        "legendFormat": "Tenant Violations"
      }],
      "options": {"colorMode": "background", "graphMode": "none"},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 1, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Cache TTL Violations",
      "description": "HIPAA requires PHI cache TTL <= 5 minutes",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{
        "expr": "sum(increase(cache_ttl_violation_total{job=~\"$service\"}[24h]))",
        "legendFormat": "TTL Violations"
      }],
      "options": {"colorMode": "background", "graphMode": "none"},
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "green"},
              {"value": 1, "color": "red"}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "PHI Access Rate by Service",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{
        "expr": "sum(rate(audit_phi_access_total{job=~\"$service\"}[5m])) by (job)",
        "legendFormat": "{{job}}"
      }],
      "fieldConfig": {
        "defaults": {"unit": "ops"}
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Security Events Rate",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "sum(rate(auth_failure_total{job=~\"$service\"}[5m]))",
          "legendFormat": "Auth Failures"
        },
        {
          "expr": "sum(rate(tenant_violations_total{job=~\"$service\"}[5m]))",
          "legendFormat": "Tenant Violations"
        },
        {
          "expr": "sum(rate(hmac_validation_failures_total{job=~\"$service\"}[5m]))",
          "legendFormat": "HMAC Failures"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "ops"}
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Audit Log Completeness",
      "description": "Tracks audit event generation across all services",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_count{job=~\"$service\"}[5m])) by (job)",
        "legendFormat": "{{job}} - Requests"
      }],
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Failed Authentication Attempts",
      "description": "HIPAA §164.312(d) - Person or entity authentication",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [{
        "expr": "sum(rate(http_server_requests_seconds_count{status=\"401\",job=~\"$service\"}[5m])) by (job)",
        "legendFormat": "{{job}} - 401"
      },
      {
        "expr": "sum(rate(http_server_requests_seconds_count{status=\"403\",job=~\"$service\"}[5m])) by (job)",
        "legendFormat": "{{job}} - 403"
      }],
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      }
    }
  ]
}
