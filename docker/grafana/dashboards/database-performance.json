{
  "dashboard": {
    "title": "Database Performance",
    "tags": ["hdim", "database", "postgresql", "performance"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Connection Pool Usage",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "hikaricp_connections_active",
            "legendFormat": "{{pool}} - Active",
            "refId": "A"
          },
          {
            "expr": "hikaricp_connections_idle",
            "legendFormat": "{{pool}} - Idle",
            "refId": "B"
          },
          {
            "expr": "hikaricp_connections_pending",
            "legendFormat": "{{pool}} - Waiting",
            "refId": "C"
          },
          {
            "expr": "hikaricp_connections_max",
            "legendFormat": "{{pool}} - Max",
            "refId": "D"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Connections"},
          {"format": "short"}
        ],
        "xaxis": {"mode": "time"},
        "legend": {"show": true, "alignAsTable": true}
      },
      {
        "id": 2,
        "title": "Connection Pool Utilization (%)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [{
          "expr": "(hikaricp_connections_active / hikaricp_connections_max) * 100",
          "legendFormat": "{{pool}}",
          "refId": "A"
        }],
        "yaxes": [
          {"format": "percent", "label": "Utilization %", "max": 100, "min": 0},
          {"format": "short"}
        ],
        "xaxis": {"mode": "time"},
        "legend": {"show": true},
        "alert": {
          "conditions": [
            {
              "evaluator": {"params": [90], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "name": "Connection Pool > 90%"
        }
      },
      {
        "id": 3,
        "title": "Query Execution Time (p50, p95, p99)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(postgresql_query_duration_seconds_bucket[5m]))",
            "legendFormat": "p50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, rate(postgresql_query_duration_seconds_bucket[5m]))",
            "legendFormat": "p95",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, rate(postgresql_query_duration_seconds_bucket[5m]))",
            "legendFormat": "p99",
            "refId": "C"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Query Time"},
          {"format": "short"}
        ],
        "xaxis": {"mode": "time"},
        "legend": {"show": true}
      },
      {
        "id": 4,
        "title": "Slow Queries (>1 second)",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [{
          "expr": "topk(10, histogram_quantile(0.99, sum(rate(postgresql_query_duration_seconds_bucket[5m])) by (le, query)) > 1)",
          "refId": "A",
          "format": "table",
          "instant": true
        }],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true, "__name__": true, "le": true},
              "renameByName": {
                "query": "Query",
                "Value": "p99 Duration (s)"
              }
            }
          }
        ],
        "options": {
          "showHeader": true,
          "sortBy": [{"displayName": "p99 Duration (s)", "desc": true}]
        }
      },
      {
        "id": 5,
        "title": "Database Size Growth",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [{
          "expr": "pg_database_size_bytes",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }],
        "yaxes": [
          {"format": "bytes", "label": "Database Size"},
          {"format": "short"}
        ],
        "xaxis": {"mode": "time"},
        "legend": {"show": true, "alignAsTable": true}
      },
      {
        "id": 6,
        "title": "Transaction Rate",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "rate(pg_stat_database_xact_commit[5m])",
            "legendFormat": "{{datname}} - Commits",
            "refId": "A"
          },
          {
            "expr": "rate(pg_stat_database_xact_rollback[5m])",
            "legendFormat": "{{datname}} - Rollbacks",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Transactions/sec"},
          {"format": "short"}
        ],
        "xaxis": {"mode": "time"},
        "legend": {"show": true}
      }
    ]
  }
}
