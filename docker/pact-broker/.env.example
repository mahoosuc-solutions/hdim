# Pact Broker Environment Configuration
# Copy this file to .env and customize values for your environment
#
# SECURITY NOTE: Never commit .env files with production credentials
# Use secrets management (e.g., HashiCorp Vault) for production deployments

# PostgreSQL Database Password
# Used for Pact Broker's contract storage database
PACT_BROKER_DB_PASSWORD=pactpassword

# Pact Broker Authentication
# Credentials for accessing the Pact Broker UI and API
PACT_BROKER_USERNAME=hdim
PACT_BROKER_PASSWORD=hdimcontract

# Base URL for Pact Broker (used in generated links)
# Update this for production deployments
PACT_BROKER_BASE_URL=http://localhost:9292
