# WebSocket feed
VITE_WS_BASE_URL=ws://localhost:8081/cql-engine

# Sales API
VITE_SALES_API_URL=

# Approval API
VITE_APPROVAL_API_URL=http://localhost:8097

# Integrations health polling (session-aware)
VITE_ENABLE_INTEGRATIONS_HEALTH_CHECK=false
VITE_INTEGRATIONS_API_URL=
VITE_INTEGRATIONS_HEALTH_POLL_MS=5000
VITE_SESSION_EXPIRED_REDIRECT_URL=/login

# Optional external auth integration for /login page
# If set, login page redirects to this URL instead of local dev sign-in
VITE_AUTH_LOGIN_URL=
# Optional token key for local/dev sign-in fallback
VITE_AUTH_TOKEN_STORAGE_KEY=authToken
# Optional auth callback token parameter name (query or hash)
VITE_AUTH_TOKEN_QUERY_PARAM=access_token
