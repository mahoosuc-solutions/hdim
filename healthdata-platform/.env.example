# ========================================
# HealthData Platform Production Environment
# ========================================
# Copy this to .env and replace placeholder values before deploying.

# Database Configuration
DB_NAME=healthdata
DB_USER=healthdata
DB_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32
DB_PORT=5432

# Redis Configuration
REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32
REDIS_PORT=6379

# Security - JWT Authentication
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# Application Metadata
VERSION=2.0.0
ENVIRONMENT=production
APP_PORT=8080

# Build Metadata
BUILD_DATE=2026-01-01T00:00:00Z
VCS_REF=abc1234

# Nginx Configuration
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Optional: Kafka Configuration (set to false to disable)
KAFKA_ENABLED=false
KAFKA_PORT=9092
ZOOKEEPER_PORT=2181

# Monitoring (Optional)
GRAFANA_ENABLED=false
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_16

# Logging
LOG_LEVEL=INFO
