<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">

    <changeSet id="002-001-create-patients-table" author="healthdata">
        <comment>Create core patients table with demographic information</comment>
        <createTable tableName="patients" schemaName="patient">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_patients"/>
            </column>
            <column name="mrn" type="VARCHAR(50)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_patients_mrn"/>
            </column>
            <column name="first_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="middle_name" type="VARCHAR(100)"/>
            <column name="date_of_birth" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="gender" type="VARCHAR(20)">
                <constraints nullable="false" checkConstraint="gender IN ('MALE', 'FEMALE', 'OTHER', 'UNKNOWN')"/>
            </column>
            <column name="street" type="VARCHAR(255)"/>
            <column name="city" type="VARCHAR(100)"/>
            <column name="state" type="VARCHAR(50)"/>
            <column name="postal_code" type="VARCHAR(20)"/>
            <column name="country" type="VARCHAR(100)"/>
            <column name="phone_number" type="VARCHAR(50)"/>
            <column name="email" type="VARCHAR(255)"/>
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="BOOLEAN" defaultValue="true"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValue="0"/>
        </createTable>
    </changeSet>

    <changeSet id="002-002-create-patient-identifiers-table" author="healthdata">
        <comment>Create patient identifiers table for external system identifiers</comment>
        <createTable tableName="patient_identifiers" schemaName="patient">
            <column name="patient_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="system" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="value" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(100)"/>
        </createTable>
    </changeSet>

    <changeSet id="002-003-add-patient-identifiers-primary-key" author="healthdata">
        <comment>Add composite primary key to patient_identifiers</comment>
        <addPrimaryKey tableName="patient_identifiers" schemaName="patient"
                       columnNames="patient_id,system,value"
                       constraintName="pk_patient_identifiers"/>
    </changeSet>

    <changeSet id="002-004-add-patient-identifiers-foreign-key" author="healthdata">
        <comment>Add foreign key constraint for patient_identifiers</comment>
        <addForeignKeyConstraint
            baseTableSchemaName="patient"
            baseTableName="patient_identifiers"
            baseColumnNames="patient_id"
            referencedTableSchemaName="patient"
            referencedTableName="patients"
            referencedColumnNames="id"
            constraintName="fk_patient_identifiers_patient"
            onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="002-005-create-patients-indexes" author="healthdata">
        <comment>Create indexes on patients table for query optimization</comment>
        <createIndex tableName="patients" schemaName="patient" indexName="idx_patients_mrn">
            <column name="mrn"/>
        </createIndex>
    </changeSet>

    <changeSet id="002-006-create-tenant-index" author="healthdata">
        <comment>Create tenant isolation index</comment>
        <createIndex tableName="patients" schemaName="patient" indexName="idx_patients_tenant">
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="002-007-create-name-index" author="healthdata">
        <comment>Create composite index on patient names</comment>
        <createIndex tableName="patients" schemaName="patient" indexName="idx_patients_name">
            <column name="last_name"/>
            <column name="first_name"/>
        </createIndex>
    </changeSet>

    <changeSet id="002-008-create-active-tenant-index" author="healthdata">
        <comment>Create filtered index for active patients by tenant</comment>
        <sql dbms="postgresql">
            CREATE INDEX idx_patients_active_tenant
            ON patient.patients(tenant_id, active)
            WHERE active = true;
        </sql>
        <rollback>
            DROP INDEX IF EXISTS patient.idx_patients_active_tenant;
        </rollback>
    </changeSet>

    <changeSet id="002-009-create-patient-identifiers-indexes" author="healthdata">
        <comment>Create indexes on patient_identifiers table</comment>
        <createIndex tableName="patient_identifiers" schemaName="patient" indexName="idx_patient_identifiers_system">
            <column name="system"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
