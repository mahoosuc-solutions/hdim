<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">

    <changeSet id="003-001-create-observations-table" author="healthdata">
        <comment>Create FHIR observations table for lab results and measurements</comment>
        <createTable tableName="observations" schemaName="fhir">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_observations"/>
            </column>
            <column name="patient_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="system" type="VARCHAR(255)"/>
            <column name="display" type="VARCHAR(255)"/>
            <column name="value_quantity" type="DECIMAL(10,2)"/>
            <column name="value_unit" type="VARCHAR(50)"/>
            <column name="value_string" type="TEXT"/>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="effective_date" type="TIMESTAMP"/>
            <column name="category" type="VARCHAR(100)"/>
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="fhir_resource" type="JSONB"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="003-002-add-observations-foreign-key" author="healthdata">
        <comment>Add foreign key constraint for observations patient reference</comment>
        <addForeignKeyConstraint
            baseTableSchemaName="fhir"
            baseTableName="observations"
            baseColumnNames="patient_id"
            referencedTableSchemaName="patient"
            referencedTableName="patients"
            referencedColumnNames="id"
            constraintName="fk_observations_patient"
            onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="003-003-create-conditions-table" author="healthdata">
        <comment>Create FHIR conditions table for patient diagnoses</comment>
        <createTable tableName="conditions" schemaName="fhir">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_conditions"/>
            </column>
            <column name="patient_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="code" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="system" type="VARCHAR(255)"/>
            <column name="display" type="VARCHAR(255)"/>
            <column name="clinical_status" type="VARCHAR(50)"/>
            <column name="verification_status" type="VARCHAR(50)"/>
            <column name="onset_date" type="DATE"/>
            <column name="abatement_date" type="DATE"/>
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="fhir_resource" type="JSONB"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="003-004-add-conditions-foreign-key" author="healthdata">
        <comment>Add foreign key constraint for conditions patient reference</comment>
        <addForeignKeyConstraint
            baseTableSchemaName="fhir"
            baseTableName="conditions"
            baseColumnNames="patient_id"
            referencedTableSchemaName="patient"
            referencedTableName="patients"
            referencedColumnNames="id"
            constraintName="fk_conditions_patient"
            onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="003-005-create-medication-requests-table" author="healthdata">
        <comment>Create FHIR medication requests table</comment>
        <createTable tableName="medication_requests" schemaName="fhir">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_medication_requests"/>
            </column>
            <column name="patient_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="medication_code" type="VARCHAR(50)"/>
            <column name="medication_display" type="VARCHAR(255)"/>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="intent" type="VARCHAR(50)"/>
            <column name="authored_on" type="TIMESTAMP"/>
            <column name="dosage_instruction" type="TEXT"/>
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="fhir_resource" type="JSONB"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="003-006-add-medication-requests-foreign-key" author="healthdata">
        <comment>Add foreign key constraint for medication requests patient reference</comment>
        <addForeignKeyConstraint
            baseTableSchemaName="fhir"
            baseTableName="medication_requests"
            baseColumnNames="patient_id"
            referencedTableSchemaName="patient"
            referencedTableName="patients"
            referencedColumnNames="id"
            constraintName="fk_medication_requests_patient"
            onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="003-007-create-observations-indexes" author="healthdata">
        <comment>Create indexes on observations table</comment>
        <createIndex tableName="observations" schemaName="fhir" indexName="idx_obs_patient_code">
            <column name="patient_id"/>
            <column name="code"/>
        </createIndex>
        <createIndex tableName="observations" schemaName="fhir" indexName="idx_obs_effective">
            <column name="effective_date"/>
        </createIndex>
        <createIndex tableName="observations" schemaName="fhir" indexName="idx_obs_tenant">
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="003-008-create-observations-gin-index" author="healthdata">
        <comment>Create GIN index on observations FHIR resource</comment>
        <sql dbms="postgresql">
            CREATE INDEX idx_obs_fhir_gin ON fhir.observations USING gin(fhir_resource);
        </sql>
        <rollback>
            DROP INDEX IF EXISTS fhir.idx_obs_fhir_gin;
        </rollback>
    </changeSet>

    <changeSet id="003-009-create-conditions-indexes" author="healthdata">
        <comment>Create indexes on conditions table</comment>
        <createIndex tableName="conditions" schemaName="fhir" indexName="idx_cond_patient">
            <column name="patient_id"/>
        </createIndex>
        <createIndex tableName="conditions" schemaName="fhir" indexName="idx_cond_code">
            <column name="code"/>
        </createIndex>
        <createIndex tableName="conditions" schemaName="fhir" indexName="idx_cond_tenant">
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="003-010-create-medication-requests-indexes" author="healthdata">
        <comment>Create indexes on medication_requests table</comment>
        <createIndex tableName="medication_requests" schemaName="fhir" indexName="idx_med_patient">
            <column name="patient_id"/>
        </createIndex>
        <createIndex tableName="medication_requests" schemaName="fhir" indexName="idx_med_status">
            <column name="status"/>
        </createIndex>
        <createIndex tableName="medication_requests" schemaName="fhir" indexName="idx_med_tenant">
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
