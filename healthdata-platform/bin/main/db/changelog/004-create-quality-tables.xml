<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd">

    <changeSet id="004-001-create-measures-table" author="healthdata">
        <comment>Create quality measures table for measure definitions</comment>
        <createTable tableName="measures" schemaName="quality">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_measures"/>
            </column>
            <column name="measure_id" type="VARCHAR(50)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_measures_measure_id"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="category" type="VARCHAR(100)"/>
            <column name="version" type="VARCHAR(20)"/>
            <column name="cql_library" type="TEXT"/>
            <column name="active" type="BOOLEAN" defaultValue="true"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="004-002-create-measure-results-table" author="healthdata">
        <comment>Create measure results table for patient measure evaluations</comment>
        <createTable tableName="measure_results" schemaName="quality">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_measure_results"/>
            </column>
            <column name="patient_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="measure_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="score" type="DECIMAL(5,2)"/>
            <column name="numerator" type="INTEGER"/>
            <column name="denominator" type="INTEGER"/>
            <column name="compliant" type="BOOLEAN"/>
            <column name="calculation_date" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="period_start" type="DATE"/>
            <column name="period_end" type="DATE"/>
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="details" type="JSONB"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="004-003-add-measure-results-foreign-keys" author="healthdata">
        <comment>Add foreign key constraints for measure results</comment>
        <addForeignKeyConstraint
            baseTableSchemaName="quality"
            baseTableName="measure_results"
            baseColumnNames="patient_id"
            referencedTableSchemaName="patient"
            referencedTableName="patients"
            referencedColumnNames="id"
            constraintName="fk_measure_results_patient"
            onDelete="CASCADE"/>
        <addForeignKeyConstraint
            baseTableSchemaName="quality"
            baseTableName="measure_results"
            baseColumnNames="measure_id"
            referencedTableSchemaName="quality"
            referencedTableName="measures"
            referencedColumnNames="measure_id"
            constraintName="fk_measure_results_measure"/>
    </changeSet>

    <changeSet id="004-004-create-health-scores-table" author="healthdata">
        <comment>Create health scores table for composite patient health scores</comment>
        <createTable tableName="health_scores" schemaName="quality">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_health_scores"/>
            </column>
            <column name="patient_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="overall_score" type="DECIMAL(5,2)">
                <constraints nullable="false"/>
            </column>
            <column name="clinical_score" type="DECIMAL(5,2)"/>
            <column name="preventive_score" type="DECIMAL(5,2)"/>
            <column name="medication_score" type="DECIMAL(5,2)"/>
            <column name="calculated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="score_components" type="JSONB"/>
        </createTable>
    </changeSet>

    <changeSet id="004-005-add-health-scores-foreign-key" author="healthdata">
        <comment>Add foreign key constraint for health scores</comment>
        <addForeignKeyConstraint
            baseTableSchemaName="quality"
            baseTableName="health_scores"
            baseColumnNames="patient_id"
            referencedTableSchemaName="patient"
            referencedTableName="patients"
            referencedColumnNames="id"
            constraintName="fk_health_scores_patient"
            onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="004-006-create-quality-indexes" author="healthdata">
        <comment>Create indexes on quality tables</comment>
        <createIndex tableName="measure_results" schemaName="quality" indexName="idx_results_patient_measure">
            <column name="patient_id"/>
            <column name="measure_id"/>
        </createIndex>
        <createIndex tableName="measure_results" schemaName="quality" indexName="idx_results_calculation">
            <column name="calculation_date" descending="true"/>
        </createIndex>
        <createIndex tableName="measure_results" schemaName="quality" indexName="idx_results_tenant">
            <column name="tenant_id"/>
        </createIndex>
        <createIndex tableName="health_scores" schemaName="quality" indexName="idx_scores_patient">
            <column name="patient_id"/>
            <column name="calculated_at" descending="true"/>
        </createIndex>
        <createIndex tableName="health_scores" schemaName="quality" indexName="idx_scores_tenant">
            <column name="tenant_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="004-007-create-health-score-history-table" author="healthdata">
        <comment>Create health score history table for tracking score changes over time</comment>
        <createTable tableName="health_score_history" schemaName="quality">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" primaryKeyName="pk_health_score_history"/>
            </column>
            <column name="patient_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="overall_score" type="DECIMAL(5,2)">
                <constraints nullable="false"/>
            </column>
            <column name="clinical_score" type="DECIMAL(5,2)"/>
            <column name="preventive_score" type="DECIMAL(5,2)"/>
            <column name="medication_score" type="DECIMAL(5,2)"/>
            <column name="recorded_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="tenant_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="004-008-add-health-score-history-foreign-key" author="healthdata">
        <comment>Add foreign key constraint for health score history</comment>
        <addForeignKeyConstraint
            baseTableSchemaName="quality"
            baseTableName="health_score_history"
            baseColumnNames="patient_id"
            referencedTableSchemaName="patient"
            referencedTableName="patients"
            referencedColumnNames="id"
            constraintName="fk_health_score_history_patient"
            onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="004-009-create-health-score-history-indexes" author="healthdata">
        <comment>Create indexes on health score history table</comment>
        <createIndex tableName="health_score_history" schemaName="quality" indexName="idx_score_history_patient">
            <column name="patient_id"/>
            <column name="recorded_at" descending="true"/>
        </createIndex>
        <createIndex tableName="health_score_history" schemaName="quality" indexName="idx_score_history_tenant">
            <column name="tenant_id"/>
            <column name="recorded_at" descending="true"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
