# HealthData Platform E2E Test Environment Configuration

# Backend URL
BASE_URL=http://localhost:8080

# Test execution mode
HEADLESS=false
CI=false

# Performance settings
WORKERS=4
TIMEOUT=30000
GLOBAL_TIMEOUT=600000

# Retry configuration
RETRIES=0

# Test filtering
# GREP=@workflow
# GREP_INVERT=@slow

# Reporting
# ALLURE_RESULTS_DIR=./allure-results

# Skip web server (if backend is already running)
# SKIP_WEBSERVER=true

# Screenshot on failure
UPDATE_SNAPSHOTS=false

# Maximum test failures before stopping
# MAX_FAILURES=10

# Test data
TEST_TENANT_ID=test-tenant-001

# Test users (used in global.setup.ts)
ADMIN_USERNAME=admin@healthdata.com
ADMIN_PASSWORD=Admin123!

CLINICIAN_USERNAME=clinician@healthdata.com
CLINICIAN_PASSWORD=Clinician123!

USER_USERNAME=user@healthdata.com
USER_PASSWORD=User123!
