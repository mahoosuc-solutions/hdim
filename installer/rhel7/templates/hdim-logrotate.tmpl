# HDIM Platform Log Rotation
# Generated by hdim-install.sh

${HDIM_LOGS}/*.log {
    daily
    rotate 14
    compress
    delaycompress
    missingok
    notifempty
    create 0640 ${HDIM_USER} ${HDIM_GROUP}
    dateext
    dateformat -%Y%m%d
    sharedscripts
    postrotate
        # Signal Docker to reopen log files if needed
        /usr/bin/docker compose -f ${HDIM_CURRENT}/source/docker-compose.yml \
            kill -s USR1 2>/dev/null || true
    endscript
}
