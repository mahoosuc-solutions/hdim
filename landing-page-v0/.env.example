# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Resend API key — get yours at https://resend.com/api-keys
RESEND_API_KEY=re_xxxx_your_key_here

# Email address that receives lead notifications
LEAD_NOTIFICATION_EMAIL=sales@mahoosuc.solutions

# Google reCAPTCHA v3 — get keys at https://www.google.com/recaptcha/admin
# Type: reCAPTCHA v3 | Domain: www.healthdatainmotion.com
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Lxxx_your_site_key_here   # public — safe in browser
RECAPTCHA_SECRET_KEY=6Lxxx_your_secret_key_here           # private — server only, never expose

# Google Analytics 4 — get Measurement ID at https://analytics.google.com
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
