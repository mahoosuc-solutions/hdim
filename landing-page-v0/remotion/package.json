{
  "name": "hdim-remotion-video",
  "version": "1.0.0",
  "description": "HDIM Product Demo Video - Remotion Project",
  "scripts": {
    "dev": "remotion studio",
    "render:60s": "remotion render src/Root.tsx Short out/hdim-demo-60s.mp4",
    "render:90s": "remotion render src/Root.tsx Main out/hdim-demo-90s.mp4",
    "render:120s": "remotion render src/Root.tsx Long out/hdim-demo-120s.mp4",
    "render:all": "npm run render:60s && npm run render:90s && npm run render:120s",
    "copy:videos": "mkdir -p ../public/videos && cp out/*.mp4 ../public/videos/",
    "build": "npm run render:all && npm run copy:videos"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.409",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "remotion": "^4.0.409",
    "typescript": "^5.9.3"
  },
  "author": "HDIM Team",
  "license": "MIT"
}
