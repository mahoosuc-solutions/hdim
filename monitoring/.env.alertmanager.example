# ============================================================
# Alertmanager Notification Channel Configuration
# ============================================================
# Copy to .env.alertmanager and fill in real values.
# DO NOT commit .env.alertmanager to git (it's in .gitignore).
#
# Usage:
#   Docker Compose:
#     export $(cat .env.alertmanager | xargs) && docker compose up alertmanager
#
#   Kubernetes (create Secret):
#     kubectl create secret generic alertmanager-credentials \
#       --from-env-file=.env.alertmanager \
#       -n hdim-production
#
# See: monitoring/alertmanager-production.yml for how these are used.
# ============================================================

# ---- Slack ----
# Create a Slack App at https://api.slack.com/apps
# Enable Incoming Webhooks, add to workspace, copy URL.
# Required channels: #alerts, #critical-alerts, #slo-breaches,
#   #security-alerts, #database-alerts, #hdim-compliance
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TXXXXXXXX/BXXXXXXXX/XXXXXXXXXXXXXXXXXXXXXXXX

# ---- PagerDuty ----
# Create 3 PagerDuty services (General, Security, Compliance).
# Navigate to: Services > Service Directory > Service > Integrations
# Add "Prometheus" integration, copy the integration key.

# General engineering on-call (critical + SLO breaches)
PAGERDUTY_INTEGRATION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Security team on-call (security alerts only)
PAGERDUTY_SECURITY_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Compliance team (HIPAA compliance alerts)
PAGERDUTY_COMPLIANCE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Email (SMTP) ----
# Use an app password for Gmail, or configure your SMTP relay.
# Gmail: Account Settings > Security > App Passwords
EMAIL_USERNAME=alerts@your-domain.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ---- Email Recipients ----
# These are referenced in alertmanager-production.yml
ONCALL_EMAIL=oncall@your-domain.com
LEADERSHIP_EMAIL=leadership@your-domain.com
COMPLIANCE_EMAIL=compliance@your-domain.com
DATABASE_TEAM_EMAIL=database-team@your-domain.com
DEVOPS_EMAIL=devops@your-domain.com
