    "@angular/language-service": "21.0.8",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "@eslint/js": "^9.8.0",
    "@module-federation/enhanced": "0.21.2",
    "@nx/devkit": "22.4.5",
    "@nx/eslint": "22.4.5",
    "@nx/eslint-plugin": "22.4.5",
    "@nx/jest": "22.4.5",
