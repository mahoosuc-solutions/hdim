    "@materia-ui/ngx-monaco-editor": "^6.0.0",
    "@ngrx/effects": "21.0.1",
    "@ngrx/store": "21.0.1",
    "@nx/angular": "22.4.5",
    "@types/d3-scale-chromatic": "^3.1.0",
    "@types/three": "^0.181.0",
    "chart.js": "^4.5.1",
    "d3-color": "^3.1.0",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "express": "^4.21.2",
    "gsap": "^3.13.0",
    "monaco-editor": "^0.52.2",
    "ng2-charts": "^8.0.0",
