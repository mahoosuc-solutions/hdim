{
  "name": "@healthdata-in-motion/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "nx": "NX_ISOLATE_PLUGINS=false NX_SOCKET_DIR=.nx/socket NX_DAEMON_SOCKET_DIR=.nx/socket NX_DAEMON=false nx",
    "lint": "npm run nx -- run-many -t lint --projects=feature-shell,data-access,ui-common,util-auth,realtime,testing,state,mfeDeployment,mfe-care-gaps,mfe-quality,mfe-reports,mfePatients",
    "lint:slow": "npm run nx -- run shared-notifications:lint",
    "lint:all": "npm run nx -- run-many -t lint --all",
    "test": "npm run nx -- run-many -t test --projects=feature-shell,data-access,ui-common,util-auth,realtime,state,mfeDeployment,mfe-care-gaps,mfe-quality,mfe-reports,mfePatients",
    "test:measure-builder:focused": "npx jest --config apps/clinical-portal/jest.config.ts --runInBand --runTestsByPath apps/clinical-portal/src/app/pages/measure-builder/create-measure-page.component.spec.ts apps/clinical-portal/src/app/pages/measure-builder/measure-builder.sorting.spec.ts apps/clinical-portal/src/app/pages/measure-builder/dialogs/measure-metadata-dialog.component.spec.ts apps/clinical-portal/src/app/pages/measure-builder/dialogs/test-preview-dialog.component.spec.ts apps/clinical-portal/src/app/pages/measure-builder/utils/api-error-parser.spec.ts",
    "test:measure-builder:readiness": "bash scripts/validation/ensure-system-operational.sh",
    "test:measure-builder:group-a": "npx tsc -p apps/clinical-portal/tsconfig.app.json --noEmit && npm run test:measure-builder:focused",
    "test:measure-builder:group-b": "bash scripts/validation/run-measure-builder-group-b.sh",
    "test:measure-builder:group-b:local": "PORT=${PORT:-4210} PW_CHROMIUM_NO_SANDBOX=${PW_CHROMIUM_NO_SANDBOX:-1} GROUP_B_SERVER_MODE=${GROUP_B_SERVER_MODE:-auto} BASE_URL=${BASE_URL:-http://localhost:${PORT:-4210}} bash scripts/validation/run-measure-builder-group-b.sh",
    "test:measure-builder:centralized": "bash scripts/validation/measure-builder-centralized-test-gate.sh",
    "test:measure-builder:centralized:local": "PORT=${PORT:-4210} PW_CHROMIUM_NO_SANDBOX=${PW_CHROMIUM_NO_SANDBOX:-1} BASE_URL=${BASE_URL:-http://localhost:${PORT:-4210}} bash scripts/validation/measure-builder-centralized-test-gate.sh",
    "test:measure-builder:queue:local": "PORT=${PORT:-4210} PW_CHROMIUM_NO_SANDBOX=${PW_CHROMIUM_NO_SANDBOX:-1} QUEUE_MAX_ATTEMPTS=${QUEUE_MAX_ATTEMPTS:-3} QUEUE_SLEEP_SECONDS=${QUEUE_SLEEP_SECONDS:-45} BASE_URL=${BASE_URL:-http://localhost:${PORT:-4210}} bash scripts/validation/measure-builder-local-runner-queue.sh",
    "release:measure-builder:gate": "npx tsc -p apps/clinical-portal/tsconfig.app.json --noEmit && npm run test:measure-builder:focused && npm run e2e:measure-builder:retry",
    "test:all": "npm run nx -- run-many -t test --all --exclude=cms-connector-service",
    "build:clinical-portal": "NX_ISOLATE_PLUGINS=false NX_SOCKET_DIR=.nx/socket NX_DAEMON_SOCKET_DIR=.nx/socket NX_DAEMON=false npx nx build clinical-portal --configuration=production",
    "e2e:clinical-portal": "nx e2e clinical-portal-e2e",
    "e2e:measure-builder:retry": "node node_modules/@playwright/test/cli.js test --config apps/clinical-portal-e2e/playwright.config.ts --project=chromium --workers=1 apps/clinical-portal-e2e/src/measure-builder-metadata-retry.e2e.spec.ts",
    "e2e:measure-builder:retry:local": "PORT=4210 PW_CHROMIUM_NO_SANDBOX=1 node node_modules/@playwright/test/cli.js test --config apps/clinical-portal-e2e/playwright.config.ts --project=chromium --workers=1 apps/clinical-portal-e2e/src/measure-builder-metadata-retry.e2e.spec.ts",
    "e2e:clinical-portal:cli": "node node_modules/@playwright/test/cli.js test --config apps/clinical-portal-e2e/playwright.config.ts",
    "e2e:clinical-portal:demo": "DEMO_SAFE=1 node node_modules/@playwright/test/cli.js test --config apps/clinical-portal-e2e/playwright.config.ts",
    "e2e:clinical-portal:smoke": "DEMO_SAFE=1 node node_modules/@playwright/test/cli.js test --config apps/clinical-portal-e2e/playwright.config.ts --project=chromium apps/clinical-portal-e2e/src/smoke.e2e.spec.ts",
    "e2e:deployment-console": "BASE_URL=http://localhost:4300 OPS_BASE_URL=http://localhost:4710 nx e2e shell-app-e2e",
    "e2e:open": "cypress open",
    "e2e:run": "cypress run",
    "e2e:run:chrome": "cypress run --browser chrome",
    "e2e:run:firefox": "cypress run --browser firefox",
    "e2e:run:dashboard": "cypress run --spec 'cypress/e2e/nurse-dashboard-workflows.cy.ts'",
    "e2e:run:ci": "cypress run --record --headed=false --browser chrome",
    "ci:local": "./scripts/ci/local-ci.sh pr",
    "ci:local:quick": "./scripts/ci/local-ci.sh quick",
    "ci:local:demo": "./scripts/ci/local-ci.sh demo",
    "hygiene:audit": "bash scripts/repo-hygiene-audit.sh",
    "hygiene:clean": "bash scripts/repo-hygiene-clean.sh --apply",
    "test:contracts": "nx run clinical-portal:test-contracts",
    "pact:publish": "nx run clinical-portal:pact-publish",
    "mcp:nx": "node scripts/mcp/nx-mcp.mjs",
    "mcp:hdim": "node scripts/mcp/hdim-platform-mcp.mjs",
    "mcp:docker": "node scripts/mcp/hdim-docker-mcp.mjs",
    "mcp:release-gate": "node scripts/mcp/context-aware-release-gate.mjs",
    "mcp:evidence-pack": "node scripts/mcp/build-release-evidence-pack.mjs",
    "mcp:evidence-package": "node scripts/mcp/package-deployment-evidence.mjs",
    "mcp:controlled-restart": "node scripts/mcp/controlled-restart-smoke.mjs",
    "mcp:operator:go-no-go": "node scripts/mcp/operator-go-no-go.mjs",
    "mcp:operator:go-no-go:local": "node scripts/mcp/operator-go-no-go.mjs --mode permissive",
    "mcp:operator:go-no-go:target": "node scripts/mcp/operator-go-no-go.mjs --mode strict --profile production",
    "mcp:spec:check": "node scripts/mcp/sync-reference-spec-examples.mjs --check",
    "mcp:spec:sync": "node scripts/mcp/sync-reference-spec-examples.mjs --write",
    "mcp:pretest": "bash scripts/mcp/pre-test-checklist.sh",
    "test:mcp": "node --test scripts/mcp/nx-mcp-config.test.mjs scripts/mcp/hdim-platform-mcp.test.mjs scripts/mcp/hdim-docker-mcp.test.mjs scripts/mcp/context-aware-release-gate.test.mjs scripts/mcp/build-release-evidence-pack.test.mjs scripts/mcp/package-deployment-evidence.test.mjs scripts/mcp/controlled-restart-smoke.test.mjs scripts/mcp/mcp-reference-spec.test.mjs scripts/mcp/sync-reference-spec-examples.test.mjs scripts/mcp/operator-go-no-go.test.mjs && node scripts/mcp/run-smoke.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular-devkit/build-angular": "21.0.5",
    "@angular/cdk": "21.0.6",
