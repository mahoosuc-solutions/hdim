									"pm.test(\"Response time is less than 500ms\", function () {",
									"    pm.expect(pm.response.responseTime).to.be.below(500);",
									"});",
									"",
									"pm.test(\"Evaluation status is SUCCESS\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.status).to.eql(\"SUCCESS\");",
									"});",
									"",
									"pm.test(\"Has evaluation result\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.evaluationResult).to.exist;",
									"});",
									"",
									"pm.test(\"Has duration in milliseconds\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.durationMs).to.be.a('number');",
									"    pm.expect(jsonData.durationMs).to.be.above(0);",
									"});",
									"",
									"pm.test(\"Patient is in denominator\", function () {",
									"    var jsonData = pm.response.json();",
									"    var result = JSON.parse(jsonData.evaluationResult);",
