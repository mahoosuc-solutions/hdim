				{
					"name": "Get All Libraries",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has content array\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('content');",
									"    pm.expect(jsonData.content).to.be.an('array');",
									"});",
									"",
									"pm.test(\"Has at least 4 libraries\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.content.length).to.be.at.least(4);",
									"});",
									"",
									"pm.test(\"Libraries have required fields\", function () {",
									"    var jsonData = pm.response.json();",
									"    jsonData.content.forEach(function(library) {",
									"        pm.expect(library).to.have.property('id');",
									"        pm.expect(library).to.have.property('name');",
									"        pm.expect(library).to.have.property('version');",
									"        pm.expect(library).to.have.property('status');",
									"    });",
									"});"
								],
