eclipse.angus\/angus-mail\/2.0.3\/56f811522d693700013768db83b741a65da6c61c\/angus-mail-2.0.3.jar\/META-INF\/maven\/org.eclipse.angus\/smtp\/pom.xml","index": 21 }},"logicalLocations": [{"fullyQualifiedName": "pkg:maven\/org.eclipse.angus\/smtp@2.0.3"}]}]}, {"ruleId": "CVE-2025-7962","level": "warning","message": {"text": "CVE-2025-7962 - In Jakarta Mail 2.0.2 it is possible to preform a SMTP Injection by utilizing the\u00A0\\r and \\n UTF-8 characters to separate different messages."},"partialFingerprints": {"vulnerabilityHash": "57872bb0fef436b9843b8ed7b100d9d4"},"locations": [{"physicalLocation": {"artifactLocation": {"uri": "file://\/home\/webemo-aaron\/.gradle\/caches\/modules-2\/files-2.1\/org.eclipse.angus\/angus-mail\/2.0.3\/56f811522d693700013768db83b741a65da6c61c\/angus-mail-2.0.3.jar","index": 22 }},"logicalLocations": [{"fullyQualifiedName": "pkg:maven\/org.eclipse.angus\/angus-mail@2.0.3"}]}]}, {"ruleId": "CVE-2023-36415","level": "warning","message": {"text": "CVE-2023-36415 - Azure Identity SDK Remote Code Execution Vulnerability"},"partialFingerprints": {"vulnerabilityHash": "885e182c7b4c1a19c4fa7296a8cb7d5f"},"locations": [{"physicalLocation": {"artifactLocation": {"uri": "file://\/home\/webemo-aaron\/.gradle\/caches\/modules-2\/files-2.1\/com.azure\/azure-identity\/1.15.3\/935dcef0aa6388cc9f3c3fa587237166601d16cf\/azure-identity-1.15.3.jar","index": 58 }},"logicalLocations": [{"fullyQualifiedName": "pkg:maven\/com.azure\/azure-identity@1.15.3"}]}]}, {"ruleId": "CVE-2024-35255","level": "warning","message": {"text": "CVE-2024-35255 - Azure Identity Libraries and Microsoft Authentication Library Elevation of Privilege Vulnerability"},"partialFingerprints": {"vulnerabilityHash": "fb670ae0c1d2e843143b61fe929aca56"},"locations": [{"physicalLocation": {"artifactLocation": {"uri": "file://\/home\/webemo-aaron\/.gradle\/caches\/modules-2\/files-2.1\/com.azure\/azure-identity\/1.15.3\/935dcef0aa6388cc9f3c3fa587237166601d16cf\/azure-identity-1.15.3.jar","index": 58 }},"logicalLocations": [{"fullyQualifiedName": "pkg:maven\/com.azure\/azure-identity@1.15.3"}]}]}, {"ruleId": "CVE-2023-6298","level": "warning","message": {"text": "CVE-2023-6298 - A vulnerability classified as problematic was found in Apryse iText 8.0.2. This vulnerability affects the function main of the file PdfDocument.java. The manipulation leads to improper validation of array index. The attack can be initiated remotely. The exploit has been disclosed to the public and may be used. The real existence of this vulnerability is still doubted at the moment. The identifier of this vulnerability is VDB-246124. NOTE: The vendor was contacted early about this disclosure but did not respond in any way. A statement published afterwards explains that the exception is not a vulnerability and the identified CWEs might not apply to the software."},"partialFingerprints": {"vulnerabilityHash": "5c349c1386f9a89fb06ba5f675e93ba2"},"locations": [{"physicalLocation": {"artifactLocation": {"uri": "file://\/home\/webemo-aaron\/.gradle\/caches\/modules-2\/files-2.1\/com.itextpdf\/barcodes\/8.0.2\/a9edd4a5b7f2cd0417492faa16dd98f6ce19988f\/barcodes-8.0.2.jar","index": 61 }},"logicalLocations": [{"fullyQualifiedName": "pkg:maven\/com.itextpdf\/barcodes@8.0.2"}]}]}, {"ruleId": "CVE-2023-6298","level": "warning","message": {"text": "CVE-2023-6298 - A vulnerability classified as problematic was found in Apryse iText 8.0.2. This vulnerability affects the function main of the file PdfDocument.java. The manipulation leads to improper validation of array index. The attack can be initiated remotely. The exploit has been disclosed to the public and may be used. The real existence of this vulnerability is still doubted at the moment. The identifier of this vulnerability is VDB-246124. NOTE: The vendor was contacted early about this disclosure but did not respond in any way. A statement published afterwards explains that the exception is not a vulnerability and the identified CWEs might not apply to the software."},"partialFingerprints": {"vulnerabilityHash": "5c349c1386f9a89fb06ba5f675e93ba2"},"locations": [{"physicalLocation": {"artifactLocation": {"uri": "file://\/home\/webemo-aaron\/.gradle\/caches\/modules-2\/files-2.1\/com.itextpdf\/bouncy-castle-connector\/8.0.2\/15563e97b944c4976458570fdb5ae529204c1a72\/bouncy-castle-connector-8.0.2.jar","index": 65 }},"logicalLocations": [{"fullyQualifiedName": "pkg:maven\/com.itextpdf\/bouncy-castle-connector@8.0.2"}]}]}, {"ruleId": "CVE-2023-6298","level": "warning","message": {"text": "CVE-2023-6298 - A vulnerability classified as problematic was found in Apryse iText 8.0.2. This vulnerability affects the function main of the file PdfDocument.java. The manipulation leads to improper validation of array index. The attack can be initiated remotely. The exploit has been disclosed to the public and may be used. The real existence of this vulnerability is still doubted at the moment. The identifier of this vulnerability is VDB-246124. NOTE: The vendor was contacted early about this disclosure but did not respond in any way. A statement published afterwards explains that the exception is not a vulnerability and the identified CWEs might not apply to the software."},"partialFingerprints": {"vulnerabilityHash": "5c349c1386f9a89fb06ba5f675e93ba2"},"locations": [{"physicalLocation": {"artifactLocation": {"uri": "file://\/home\/webemo-aaron\/.gradle\/caches\/modules-2\/files-2.1\/com.itextpdf\/commons\/8.0.2\/8387ef8346202c756d155f85255ef5cba2dfca5f\/commons-8.0.2.jar","index": 92 }},"logicalLocations": [{"fullyQualifiedName": "pkg:maven\/com.itextpdf\/commons@8.0.2"}]}]}, {"ruleId": "CVE-2025-48734","level": "warning","message": {"text": "CVE-2025-48734 - Improper Access Control vulnerability in Apache Commons.\n\n\n\nA special BeanIntrospector class was added in version 1.9.2. This can be used to stop attackers from using the declared class property of Java enum objects to get access to the classloader. However this protection was not enabled by default. PropertyUtilsBean (and consequently BeanUtilsBean) now disallows declared class level property access by default.\n\n\n\n\n\nReleases 1.11.0 and 2.0.0-M2 address a potential security issue when accessing enum properties in an uncontrolled way. If an application using Commons BeanUtils passes property paths from an external source directly to the getProperty() method of PropertyUtilsBean, an attacker can access the enum\u2019s class loader via the \u201CdeclaredClass\u201D property available on all Java \u201Cenum\u201D objects. Accessing the enum\u2019s \u201CdeclaredClass\u201D allows remote attackers to access the ClassLoader and execute arbitrary code. The same issue exists with PropertyUtilsBean.getNestedProperty().\nStarting in versions 1.11.0 and 2.0.0-M2 a special BeanIntrospector suppresses the \u201CdeclaredClass\u201D property. Note that this new BeanIntrospector is enabled by default, but you can disable it to regain the old behavior; see section 2.5 of the user's guide and the unit tests.\n\nThis issue affects Apache Commons BeanUtils 1.x before 1.11.0, and 2.x before 2.0.0-M2.Users of the artifact commons-beanutils:commons-beanutils\n\n 1.x are recommended to upgrade to version 1.11.0, which fixes the issue.\n\n\nUsers of the artifact org.apache.commons:commons-beanutils2\n\n 2.x are recommended to upgrade to version 2.0.0-M2, which fixes the issue."},"partialFingerprints": {"vulnerabilityHash": "eb5f8cf1401189092840e52c25d48e77"},"locations": [{"physicalLocation": {"artifactLocation": {"uri": "file://\/home\/webemo-aaron\/.gradle\/caches\/modules-2\/files-2.1\/commons-beanutils\/commons-beanutils\/1.9.4\/d52b9abcd97f38c81342bb7e7ae1eee9b73cba51\/commons-beanutils-1.9.4.jar","index": 93 }},"logicalLocations": [{"fullyQualifiedName": "pkg:maven\/commons-beanutils\/commons-beanutils@1.9.4"}]}]}, {"ruleId": "CVE-2024-25710","level": "warning","message": {"text": "CVE-2024-25710 - Loop with Unreachable Exit Condition ('Infinite Loop') vulnerability in Apache Commons Compress.This issue affects Apache Commons Compress: from 1.3 through 1.25.0.\n\nUsers are recommended to upgrade to version 1.26.0 which fixes the issue."},"partialFingerprints": {"vulnerabilityHash": "07dde4162f14c7855ec912bbb9f2a632"},"locations": [{"physicalLocation": {"artifactLocation": {"uri": "file://\/home\/webemo-aaron\/.gradle\/caches\/modules-2\/files-2.1\/org.apache.commons\/commons-compress\/1.24.0\/b4b1b5a3d9573b2970fddab236102c0a4d27d35e\/commons-compress-1.24.0.jar","index": 100 }},"logicalLocations": [{"fullyQualifiedName": "pkg:maven\/org.apache.commons\/commons-compress@1.24.0"}]}]}, {"ruleId": "CVE-2024-26308","level": "warning","message": {"text": "CVE-2024-26308 - Allocation of Resources Without Limits or Throttling vulnerability in Apache Commons Compress.This issue affects Apache Commons Compress: from 1.21 before 1.26.\n\nUsers are recommended to upgrade to version 1.26, which fixes the issue."},"partialFingerprints": {"vulnerabilityHash": "0614cfc02596b9067d8c428e4d8aeb09"},"locations": [{"physicalLocation": {"artifactLocation": {"uri": "file://\/home\/webemo-aaron\/.gradle\/caches\/modules-2\/files-2.1\/org.apache.commons\/commons-compress\/1.24.0\/b4b1b5a3d9573b2970fddab236102c0a4d27d35e\/commons-compress-1.24.0.jar","index": 100 }},"logicalLocations": [{"fullyQualifiedName": "pkg:maven\/org.apache.commons\/commons-compress@1.24.0"}]}]}, {"ruleId": "CVE-2024-25710","level": "warning","message": {"text": "CVE-2024-25710 - Loop with Unreachable Exit Condition ('Infinite Loop') vulnerability in Apache Commons Compress.This issue affects Apache Commons Compress: from 1.3 through 1.25.0.\n\nUsers are recommended to upgrade to version 1.26.0 which fixes the issue."},"partialFingerprints": {"vulnerabilityHash": "07dde4162f14c7855ec912bbb9f2a632"},"locations": [{"physicalLocation": {"artifactLocation": {"uri": "file://\/home\/webemo-aaron\/.gradle\/caches\/modules-2\/files-2.1\/org.apache.commons\/commons-compress\/1.25.0\/9d35aec423da6c8a7f93d7e9e1c6b1d9fe14bb5e\/commons-compress-1.25.0.jar","index": 101 }},"logicalLocations": [{"fullyQualifiedName": "pkg:maven\/org.apache.commons\/commons-compress@1.25.0"}]}]}, {"ruleId": "CVE-2024-26308","level": "warning","message": {"text": "CVE-2024-26308 - Allocation of Resources Without Limits or Throttling vulnerability in Apache Commons Compress.This issue affects Apache Commons Compress: from 1.21 before 1.26.\n\nUsers are recommended to upgrade to version 1.26, which fixes the issue."},"partialFingerprints": {"vulnerabilityHash": "0614cfc02596b9067d8c428e4d8aeb09"},"locations": [{"physicalLocation": {"artifactLocation": {"uri": "file://\/home\/webemo-aaron\/.gradle\/caches\/modules-2\/files-2.1\/org.apache.commons\/commons-compress\/1.25.0\/9d35aec423da6c8a7f93d7e9e1c6b1d9fe14bb5e\/commons-compress-1.25.0.jar","index": 101 }},"logicalLocations": [{"fullyQualifiedName": "pkg:maven\/org.apache.commons\/commons-compress@1.25.0"}]}]}, {"ruleId": "CVE-2024-47554","level": "warning","message": {"text": "CVE-2024-47554 - Uncontrolled Resource Consumption vulnerability in Apache Commons IO.\n\nThe org.apache.commons.io.input.XmlStreamReader class may excessively consume CPU resources when processing maliciously crafted input.\n\n\nThis issue affects Apache Commons IO: from 2.0 before 2.14.0.\n\nUsers are recommended to upgrade to version 2.14.0 or later, which fixes the issue."},"partialFingerprints": {"vulnerabilityHash": "4faf75707d9007129db1379700f23d9d"},"locations": [{"physicalLocation": {"artifactLocation": {"uri": "file://\/home\/webemo-aaron\/.gradle\/caches\/modules-2\/files-2.1\/commons-io\/commons-io\/2.7\/3f2bd4ba11c4162733c13cc90ca7c7ea09967102\/commons-io-2.7.jar","index": 110 }},"logicalLocations": [{"fullyQualifiedName": "pkg:maven\/commons-io\/commons-io@2.7"}]}]}, {"ruleId": "CVE-2025-48924","level": "warning","message": {"text": "CVE-2025-48924 - Uncontrolled Recursion vulnerability in Apache Commons Lang.\n\nThis issue affects Apache Commons Lang: Starting with\u00A0commons-lang:commons-lang\u00A02.0 to 2.6, and, from org.apache.commons:commons-lang3 3.0 before\u00A03.18.0.\n\nThe methods ClassUtils.getClass(...) can throw\u00A0StackOverflowError on very long inputs. Because an Error is usually not handled by applications and libraries, a \nStackOverflowError could\u00A0cause an application to stop.\n\nUsers are recommended to upgrade to version 3.18.0, which fixes the issue."},"partialFingerprints": {"vulnerabilityHash": "065ac7df188e8c80a7c2979bc5e08183"},"locations": [{"physicalLocation": {"artifactLocation": {"uri": "file://\/home\/webemo-aaron\/.gradle\/caches\/modules-2\/files-2.1\/org.apache.commons\/commons-lang3\/3.12.0\/c6842c86792ff03b9f1d1fe2aab8dc23aa6c6f0e\/commons-lang3-3.12.0.jar","index": 111 }},"logicalLocations": [{"fullyQualifiedName": "pkg:maven\/org.apache.commons\/commons-lang3@3.12.0"}]}]}, {"ruleId": "CVE-2025-48924","level": "warning","message": {"text": "CVE-2025-48924 - Uncontrolled Recursion vulnerability in Apache Commons Lang.\n\nThis issue affects Apache Commons Lang: Starting with\u00A0commons-lang:commons-lang\u00A02.0 to 2.6, and, from org.apache.commons:commons-lang3 3.0 before\u00A03.18.0.\n\nThe methods ClassUtils.getClass(...) can throw\u00A0StackOverflowError on very long inputs. Because an Error is usually not handled by applications and libraries, a \nStackOverflowError could\u00A0cause an application to stop.\n\nUsers are recommended to upgrade to version 3.18.0, which fixes the issue."},"partialFingerprints": {"vulnerabilityHash": "065ac7df188e8c80a7c2979bc5e08183"},"locations": [{"physicalLocation": {"artifactLocation": {"uri": "file://\/home\/webemo-aaron\/.gradle\/caches\/modules-2\/files-2.1\/org.apache.commons\/commons-lang3\/3.14.0\/1ed471194b02f2c6cb734a0cd6f6f107c673afae\/commons-lang3-3.14.0.jar","index": 112 }},"logicalLocations": [{"fullyQualifiedName": "pkg:maven\/org.apache.commons\/commons-lang3@3.14.