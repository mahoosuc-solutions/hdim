# Agent Testing Harness Configuration
# Copy to .env and fill in your values

# =============================================================================
# Langfuse Configuration (Self-Hosted)
# =============================================================================
LANGFUSE_HOST=http://localhost:3100
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx

# =============================================================================
# Anthropic Claude Configuration
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Default model for testing
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# =============================================================================
# DeepEval Configuration
# =============================================================================
# Optional: Connect to DeepEval Cloud for test reports
# CONFIDENT_API_KEY=your-confident-api-key

# =============================================================================
# HDIM Agent Services (for integration testing)
# =============================================================================
AGENT_BUILDER_URL=http://localhost:8096
AGENT_RUNTIME_URL=http://localhost:8088
GATEWAY_URL=http://localhost:8080

# JWT for authenticated requests
TEST_JWT_TOKEN=

# =============================================================================
# Test Configuration
# =============================================================================
# Number of concurrent test workers
TEST_WORKERS=4

# Timeout for agent operations (seconds)
AGENT_TIMEOUT=60

# Enable verbose logging
VERBOSE=false
