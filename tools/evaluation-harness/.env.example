# HDIM Evaluation Harness Configuration
# Copy this file to .env and fill in your values

# Server Configuration
EVAL_HOST=0.0.0.0
EVAL_PORT=8500
EVAL_WORKERS=4
EVAL_LOG_LEVEL=INFO

# OpenAI Configuration (required for full DeepEval support)
# Without this, metrics will use fallback heuristic scoring
EVAL_OPENAI_API_KEY=sk-...
EVAL_OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI (optional alternative to OpenAI)
# EVAL_USE_AZURE=true
# EVAL_AZURE_OPENAI_API_KEY=
# EVAL_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# EVAL_AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Evaluation Settings
EVAL_DEFAULT_THRESHOLD=0.70
EVAL_TIMEOUT_SECONDS=30
EVAL_MAX_RETRIES=3

# Healthcare-Specific Settings
EVAL_HIPAA_STRICT_MODE=true
EVAL_CLINICAL_SAFETY_ZERO_TOLERANCE=true

# Enabled Metrics (comma-separated)
EVAL_ENABLED_METRICS=RELEVANCY,FAITHFULNESS,HALLUCINATION,HIPAA_COMPLIANCE,CLINICAL_ACCURACY,CLINICAL_SAFETY,CARE_GAP_RELEVANCE,HEDIS_COMPLIANCE
