<div class="row">
  <div class="col-md-5">
    <h2 class="mb-3">Compose Email</h2>

    <form id="composeForm">
      <div class="mb-3">
        <label class="form-label">Recipient</label>
        <select id="contactSelect" class="form-select" onchange="updatePlaceholders()">
          <option value="">Select a contact...</option>
          <% contacts.forEach(c => { %>
            <option value="<%= c.id %>"
              data-name="<%= c.name %>"
              data-organization="<%= c.organization %>"
              data-fund="<%= c.organization %>"
              data-type="<%= c.type %>"
              data-role="<%= c.role || '' %>"
              data-portfolio="<%= c.portfolio_fit || '' %>"
              data-angle="<%= c.notes || '' %>"
              <%= selectedContact && selectedContact.id === c.id ? 'selected' : '' %>>
              <%= c.name %> &mdash; <%= c.organization || c.type %> (<%= c.type %>)
            </option>
          <% }) %>
        </select>
      </div>

      <div class="mb-3">
        <label class="form-label">Template</label>
        <select id="categorySelect" class="form-select mb-2" onchange="filterTemplates()">
          <option value="">All categories</option>
          <% [...new Set(templates.map(t => t.category))].forEach(cat => { %>
            <option value="<%= cat %>"><%= cat %></option>
          <% }) %>
        </select>
        <select id="templateSelect" class="form-select" onchange="loadTemplate()">
          <option value="">Select a template...</option>
          <% templates.forEach(t => { %>
            <option value="<%= t.id %>"
              data-category="<%= t.category %>"
              data-subject="<%= (t.subject || '').replace(/"/g, '&quot;') %>"
              data-body="<%= encodeURIComponent(t.body) %>"
              data-placeholders="<%= t.placeholders || '[]' %>">
              [<%= t.category %>] <%= t.name %>
            </option>
          <% }) %>
        </select>
      </div>

      <div id="placeholderFields" class="mb-3"></div>

      <button type="button" class="btn btn-primary w-100" onclick="generatePreview()">
        <i class="bi bi-eye me-1"></i>Generate Preview
      </button>
    </form>
  </div>

  <div class="col-md-7">
    <div id="previewPanel" style="display: none;">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">Email Preview</h4>
        <div class="d-flex gap-2">
          <button class="btn btn-sm btn-outline-success" onclick="copyTarget('subjectPreview')">
            <i class="bi bi-clipboard me-1"></i>Copy Subject
          </button>
          <button class="btn btn-sm btn-outline-success" onclick="copyTarget('bodyPreview')">
            <i class="bi bi-clipboard me-1"></i>Copy Body
          </button>
          <button class="btn btn-sm btn-outline-primary" onclick="copyBoth()">
            <i class="bi bi-files me-1"></i>Copy Both
          </button>
        </div>
      </div>

      <div class="card mb-2">
        <div class="card-body py-2">
          <small class="text-muted">Subject:</small>
          <div id="subjectPreview" class="fw-bold"></div>
        </div>
      </div>

      <div class="email-preview" id="bodyPreview"></div>

      <form action="/compose/log" method="POST" class="mt-3" id="logForm">
        <input type="hidden" name="contact_id" id="logContactId">
        <input type="hidden" name="details" id="logDetails">
        <button type="submit" class="btn btn-sm btn-outline-secondary">
          <i class="bi bi-journal-check me-1"></i>Log as Email Sent
        </button>
      </form>
    </div>

    <div id="previewPlaceholder" class="text-center text-muted mt-5">
      <i class="bi bi-envelope" style="font-size: 3rem;"></i>
      <p class="mt-2">Select a contact and template to preview your email</p>
    </div>
  </div>
</div>

<script>
function filterTemplates() {
  const cat = document.getElementById('categorySelect').value;
  document.querySelectorAll('#templateSelect option').forEach(opt => {
    if (!opt.value) return;
    opt.style.display = (!cat || opt.dataset.category === cat) ? '' : 'none';
  });
  document.getElementById('templateSelect').value = '';
}

function loadTemplate() {
  const opt = document.getElementById('templateSelect').selectedOptions[0];
  if (!opt || !opt.value) return;
  const placeholders = JSON.parse(opt.dataset.placeholders || '[]');
  const container = document.getElementById('placeholderFields');
  container.textContent = '';

  const contactOpt = document.getElementById('contactSelect').selectedOptions[0];
  const autoFilled = {};
  if (contactOpt && contactOpt.value) {
    autoFilled['Name'] = contactOpt.dataset.name || '';
    autoFilled['name'] = contactOpt.dataset.name || '';
    autoFilled['Fund'] = contactOpt.dataset.fund || '';
    autoFilled['fund'] = contactOpt.dataset.fund || '';
    autoFilled['Partner Name'] = contactOpt.dataset.name || '';
    autoFilled['organization'] = contactOpt.dataset.organization || '';
    autoFilled['Hospital Name'] = contactOpt.dataset.organization || '';
    autoFilled['Hospital'] = contactOpt.dataset.organization || '';
    autoFilled['similar company'] = contactOpt.dataset.portfolio || '';
    autoFilled['relevant portfolio company or experience'] = contactOpt.dataset.portfolio || '';
    autoFilled['Your name'] = 'Aaron';
    autoFilled['Your Name'] = 'Aaron';
  }

  placeholders.forEach(ph => {
    const val = autoFilled[ph] || '';
    const div = document.createElement('div');
    div.className = 'mb-2';

    const label = document.createElement('label');
    label.className = 'form-label small';
    label.textContent = ph + (val ? ' (auto-filled)' : '');

    const input = document.createElement('input');
    input.type = 'text';
    input.className = 'form-control form-control-sm placeholder-field';
    input.dataset.placeholder = ph;
    input.value = val;

    div.appendChild(label);
    div.appendChild(input);
    container.appendChild(div);
  });
}

function updatePlaceholders() {
  loadTemplate();
}

function generatePreview() {
  const templateOpt = document.getElementById('templateSelect').selectedOptions[0];
  if (!templateOpt || !templateOpt.value) { alert('Select a template'); return; }

  let subject = templateOpt.dataset.subject || '';
  let body = decodeURIComponent(templateOpt.dataset.body || '');

  document.querySelectorAll('.placeholder-field').forEach(input => {
    const ph = input.dataset.placeholder;
    const val = input.value || '[' + ph + ']';
    const patterns = ['{{' + ph + '}}', '[' + ph + ']'];
    patterns.forEach(p => {
      subject = subject.split(p).join(val);
      body = body.split(p).join(val);
    });
  });

  document.getElementById('subjectPreview').textContent = subject;
  document.getElementById('bodyPreview').textContent = body;
  document.getElementById('previewPanel').style.display = '';
  document.getElementById('previewPlaceholder').style.display = 'none';

  const contactId = document.getElementById('contactSelect').value;
  document.getElementById('logContactId').value = contactId;
  document.getElementById('logDetails').value = 'Template: ' + templateOpt.textContent.trim() + ' | Subject: ' + subject;
}

function copyTarget(elementId) {
  const el = document.getElementById(elementId);
  navigator.clipboard.writeText(el.textContent).then(() => {
    const btn = event.target.closest('button');
    const orig = btn.textContent;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = orig; }, 2000);
  });
}

function copyBoth() {
  const subject = document.getElementById('subjectPreview').textContent;
  const body = document.getElementById('bodyPreview').textContent;
  navigator.clipboard.writeText('Subject: ' + subject + '\n\n' + body).then(() => {
    const btn = event.target.closest('button');
    const orig = btn.textContent;
    btn.textContent = 'Copied!';
    setTimeout(() => { btn.textContent = orig; }, 2000);
  });
}

<% if (selectedContact) { %>
document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('contactSelect').value = '<%= selectedContact.id %>';
});
<% } %>
</script>
