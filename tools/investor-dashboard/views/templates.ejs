<h2 class="mb-4">Email Templates</h2>

<div class="row">
  <% const categories = [...new Set(templates.map(t => t.category))]; %>
  <% categories.forEach(cat => { %>
    <div class="col-12 mb-4">
      <h4 class="border-bottom pb-2"><%= cat %></h4>
      <% templates.filter(t => t.category === cat).forEach(t => { %>
        <div class="card mb-3">
          <div class="card-header d-flex justify-content-between align-items-center">
            <strong><%= t.name %></strong>
            <button class="btn btn-sm btn-outline-success copy-btn" data-copy-target="tmpl-body-<%= t.id %>">
              <i class="bi bi-clipboard me-1"></i>Copy
            </button>
          </div>
          <div class="card-body">
            <% if (t.subject) { %>
              <p class="mb-2"><strong>Subject:</strong> <%= t.subject %></p>
            <% } %>
            <% const phs = JSON.parse(t.placeholders || '[]'); %>
            <% if (phs.length > 0) { %>
              <p class="mb-2 small text-muted">
                <strong>Placeholders:</strong> <%= phs.map(p => '[' + p + ']').join(', ') %>
              </p>
            <% } %>
            <pre class="email-preview mb-0" id="tmpl-body-<%= t.id %>" style="font-size: 0.9rem;"><%= t.body %></pre>
          </div>
        </div>
      <% }) %>
    </div>
  <% }) %>
</div>
