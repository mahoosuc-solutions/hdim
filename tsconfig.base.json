{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@clinical-portal/feature-dashboard": [
        "libs/clinical-portal/feature-dashboard/src/index.ts"
      ],
      "@health-platform/shared/data-access": [
        "libs/shared/data-access/src/index.ts"
      ],
      "@health-platform/shared/ui-common": [
        "libs/shared/ui-common/src/index.ts"
      ],
      "@health-platform/shared/util-auth": [
        "libs/shared/util-auth/src/index.ts"
      ],
      "@health-platform/shared/feature-shell": [
        "libs/shared/feature-shell/src/index.ts"
      ],
      "mfePatients/Routes": [
        "apps/mfe-patients/src/app/remote-entry/entry.routes.ts"
      ],
      "@health-platform/shared/state": [
        "libs/shared/state/src/index.ts"
      ],
      "@health-platform/shared/testing": [
        "libs/shared/testing/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
